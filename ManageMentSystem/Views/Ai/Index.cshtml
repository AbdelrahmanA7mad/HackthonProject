@{
    ViewData["Title"] = "مساعد قطة الذكي";
    Layout = "_Layout";
}

<div class="h-[calc(100vh-2rem)] -m-4 w-full bg-bgSubtle p-4 md:p-6" dir="rtl">
    
    <!-- Main Container -->
    <div class="w-full h-full flex flex-col md:flex-row gap-4 md:gap-6">

        <!-- History Sidebar -->
        <div class="w-full md:w-72 flex-shrink-0 flex flex-col gap-4 h-[300px] md:h-full">
            <div class="flex-1 bg-bgBase rounded-xl shadow-sm border border-borderSubtle flex flex-col overflow-hidden">
                <div class="px-4 py-3 border-b border-borderSubtle bg-bgSubtle flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-gray-500"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
                        <h3 class="font-bold text-sm text-primary">المحادثات السابقة</h3>
                    </div>
                    <button onclick="startNewChat()" class="text-primary hover:bg-borderSubtle p-1 rounded-md transition-colors" title="محادثة جديدة">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"/></svg>
                    </button>
                </div>
                <div id="history-list" class="flex-1 overflow-y-auto p-2 space-y-1">
                    <!-- محادثات سابقة هتتحمل هنا عبر JS -->
                    <div class="text-center py-4 text-gray-400 text-xs hidden" id="empty-history">
                        لا توجد محادثات سابقة
                    </div>
                </div>
            </div>
        </div>

        <!-- Chat Area -->
        <div class="flex-1 bg-bgBase rounded-xl shadow-sm border border-borderSubtle flex flex-col overflow-hidden h-[500px] md:h-full">
            
            <!-- Chat Header -->
            <div class="bg-primary px-6 py-4 flex items-center justify-between text-bgBase">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-bgBase/10 flex items-center justify-center border border-bgBase/20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-bgBase"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
                    </div>
                    <div>
                        <h2 class="font-bold text-lg leading-tight">اسأل مساعد نماء</h2>
                        <p class="text-xs text-bgBase/70">مساعدك للإدارة والتحليل</p>
                    </div>
                </div>
                <a href="/Ai/Telemetry" class="zen-btn zen-btn-neutral">
                    لوحة المتابعة
                </a>
            </div>

            <!-- Messages Container -->
            <div id="messages" class="flex-1 overflow-y-auto p-4 md:p-6 space-y-6 bg-bgSubtle">
                <!-- Welcome Message -->
                <div id="welcome-msg" class="h-full flex flex-col items-center justify-center text-center opacity-70">
                    <div class="w-20 h-20 bg-bgSubtle text-primary rounded-full flex items-center justify-center mb-4 shadow-sm border border-borderSubtle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">مرحباً بك في الذكاء الاصطناعي</h3>
                    <p class="text-sm text-gray-500 max-w-sm">
                        أنا هنا لمساعدتك في الحصول على إجابات دقيقة من بيانات متجرك، اسألني ما تريد!
                    </p>
                </div>
            </div>

            <!-- Input Area -->
            <div class="p-3 bg-white border-t border-gray-200 flex flex-col gap-2">
                <!-- Quick Suggestions (Horizontal Scroll) -->
                <div class="flex items-center gap-1.5 overflow-x-auto py-1 px-1 max-w-4xl mx-auto w-full no-scrollbar">
                    <button onclick="sendSuggestion('كام إجمالي المبيعات النهارده؟')" class="zen-btn zen-btn-neutral !py-1.5 !px-3 !text-xs flex-shrink-0 gap-1.5 group relative z-10 hover:z-20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-textMuted group-hover:text-primary w-3 h-3"><rect width="20" height="12" x="2" y="6" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg> مبيعات اليوم
                    </button>
                    <button onclick="sendSuggestion('أكتر 5 منتجات مبيعاً الشهر ده؟')" class="zen-btn zen-btn-neutral !py-1.5 !px-3 !text-xs flex-shrink-0 gap-1.5 group relative z-10 hover:z-20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-textMuted group-hover:text-primary w-3 h-3"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg> أفضل المنتجات
                    </button>
                    <button onclick="sendSuggestion('كام الربح الصافي؟')" class="zen-btn zen-btn-neutral !py-1.5 !px-3 !text-xs flex-shrink-0 gap-1.5 group relative z-10 hover:z-20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-textMuted group-hover:text-primary w-3 h-3"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg> الربح الصافي
                    </button>
                    <button onclick="sendSuggestion('أيه المنتجات اللي خلصت تقريباً؟')" class="zen-btn zen-btn-neutral !py-1.5 !px-3 !text-xs flex-shrink-0 gap-1.5 group relative z-10 hover:z-20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-textMuted group-hover:text-primary w-3 h-3"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg> مخزون منخفض
                    </button>
                    <button onclick="sendSuggestion('إيه رصيد الخزينة والديون المتبقية؟')" class="zen-btn zen-btn-neutral !py-1.5 !px-3 !text-xs flex-shrink-0 gap-1.5 group relative z-10 hover:z-20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-textMuted group-hover:text-primary w-3 h-3"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg> الخزينة والديون
                    </button>
                </div>
                
                <div class="relative flex items-center gap-3 max-w-4xl mx-auto w-full">
                    
                    <div class="flex-1 relative">
                        <textarea 
                            id="user-input" 
                            rows="1" 
                            class="w-full bg-bgSubtle border border-borderSubtle rounded-xl px-4 py-3 min-h-[50px] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all resize-none max-h-32 text-gray-700 shadow-sm leading-6"
                            placeholder="اكتب سؤالك هنا... (مثلاً: أرباحي الشهر ده كام؟)"
                            onkeydown="handleKey(event)"
                            oninput="autoResize(this)"
                        ></textarea>
                    </div>
                    
                    <button 
                        id="send-btn" 
                        onclick="sendMessage()" 
                        class="w-[50px] h-[50px] rounded-xl bg-bgSubtle hover:bg-borderSubtle text-primary flex items-center justify-center transition-all shadow-md active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed disabled:active:scale-100 flex-shrink-0"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-send w-6 h-6 transform -translate-x-0.5">
                            <path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"></path>
                            <path d="m21.854 2.147-10.94 10.939"></path>
                        </svg>
                    </button>
                </div>

            </div>

        </div>


    </div>
</div>

<style>
    /* Prevent layout shift (navbar jump) by forcing the scrollbar */
    html, body { overflow-y: scroll !important; }

    /* Formatting for Markdown output inside bubbles */
    .ai-bubble-bot strong { color: var(--zen-theme-primary); font-weight: 700; }
    .ai-bubble-bot ul { list-style-type: disc; margin-right: 1.5rem; margin-top: 0.5rem; margin-bottom: 0.5rem; }
    .ai-bubble-bot li { margin-bottom: 0.25rem; }
    
    /* Scrollbar styling */
    #messages::-webkit-scrollbar { width: 6px; }
    #messages::-webkit-scrollbar-track { background: transparent; }
    #messages::-webkit-scrollbar-thumb { background: var(--zen-theme-border-subtle); border-radius: 10px; }
    #messages::-webkit-scrollbar-thumb:hover { background: var(--zen-theme-text-muted); }
    
    /* Hide scrollbar for horizontal suggestions */
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
</style>

<script>
    const messagesEl = document.getElementById('messages');
    const inputEl    = document.getElementById('user-input');
    const sendBtn    = document.getElementById('send-btn');
    const welcomeEl  = document.getElementById('welcome-msg');
    let isStreaming = false;
    let currentConversationId = null;

    async function fetchConversations() {
        try {
            const res = await fetch('/Ai/GetConversations');
            if (res.ok) {
                const list = await res.json();
                renderHistoryList(list);
            }
        } catch (err) {
            console.error('Failed to fetch conversations', err);
        }
    }

    function renderHistoryList(list) {
        const listEl = document.getElementById('history-list');
        const emptyEl = document.getElementById('empty-history');
        
        listEl.innerHTML = '';
        listEl.appendChild(emptyEl);
        
        if (list.length === 0) {
            emptyEl.classList.remove('hidden');
        } else {
            emptyEl.classList.add('hidden');
            list.forEach(conv => {
                const isSelected = conv.id === currentConversationId;
                
                const wrapper = document.createElement('div');
                wrapper.className = 'flex items-center w-full group relative conv-item';
                wrapper.dataset.id = conv.id;
                
                const btn = document.createElement('button');
                btn.className = isSelected 
                    ? 'flex-1 text-right pl-10 pr-3 py-2.5 rounded-lg text-sm truncate transition-colors flex items-center gap-2 bg-borderSubtle text-primary font-bold'
                    : 'flex-1 text-right pl-10 pr-3 py-2.5 rounded-lg text-sm truncate transition-colors flex items-center gap-2 text-gray-600 hover:bg-gray-100';
                btn.onclick = () => loadConversation(conv.id);
                btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 flex-shrink-0"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> <span class="truncate">${conv.title}</span>`;
                
                const delBtn = document.createElement('button');
                delBtn.className = 'w-6 h-6 rounded-md flex items-center justify-center text-red-600 hover:bg-red-50 transition-colors absolute left-1 opacity-100 group-hover:opacity-100';
                delBtn.title = 'حذف المحادثة';
                delBtn.onclick = (e) => { e.stopPropagation(); deleteConversation(conv.id); };
                delBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-accentRed"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>`;

                wrapper.appendChild(btn);
                wrapper.appendChild(delBtn);
                listEl.appendChild(wrapper);
            });
        }
    }

    function updateSidebarSelection() {
        const items = document.querySelectorAll('.conv-item');
        items.forEach(wrapper => {
            const id = parseInt(wrapper.dataset.id);
            const isSelected = id === currentConversationId;
            const btn = wrapper.children[0];
            const delBtn = wrapper.children[1];
            
            if (isSelected) {
                btn.className = 'flex-1 text-right pl-10 pr-3 py-2.5 rounded-lg text-sm truncate transition-colors flex items-center gap-2 bg-borderSubtle text-primary font-bold';
                delBtn.className = 'w-6 h-6 rounded-md flex items-center justify-center text-red-600 hover:bg-red-50 transition-colors absolute left-1 opacity-100 group-hover:opacity-100';
            } else {
                btn.className = 'flex-1 text-right pl-10 pr-3 py-2.5 rounded-lg text-sm truncate transition-colors flex items-center gap-2 text-gray-600 hover:bg-gray-100';
                delBtn.className = 'w-6 h-6 rounded-md flex items-center justify-center text-red-600 hover:bg-red-50 transition-colors absolute left-1 opacity-100 group-hover:opacity-100';
            }
        });
    }

    async function loadConversation(id) {
        if (isStreaming) return;
        try {
            const res = await fetch(`/Ai/GetConversation/${id}`);
            if (res.ok) {
                const messages = await res.json();
                currentConversationId = id;
                
                messagesEl.innerHTML = '';
                if (messages.length === 0) {
                    messagesEl.appendChild(welcomeEl);
                } else {
                    messages.forEach(msg => {
                        const { wrapper } = createMessageBubble(msg.role, formatText(msg.text));
                        messagesEl.appendChild(wrapper);
                    });
                }
                scrollToBottom();
                updateSidebarSelection();
            }
        } catch (err) {
            console.error('Failed to load conversation', err);
        }
    }

    function startNewChat() {
        if (isStreaming) return;
        currentConversationId = null;
        messagesEl.innerHTML = '';
        messagesEl.appendChild(welcomeEl);
        updateSidebarSelection();
        inputEl.focus();
    }

    async function deleteConversation(id) {
        if (isStreaming) return;
        
        const result = await Swal.fire({
            title: 'هل أنت متأكد؟',
            text: "سيتم حذف المحادثة نهائياً ولن تتمكن من استعادتها!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: accentRed,
            cancelButtonColor: textMuted,
            confirmButtonText: 'نعم، احذفها',
            cancelButtonText: 'إلغاء'
        });

        if (!result.isConfirmed) return;
        
        try {
            const res = await fetch(`/Ai/DeleteConversation/${id}`, { method: 'DELETE' });
            if (res.ok) {
                if (currentConversationId === id) {
                    startNewChat();
                } else {
                    fetchConversations();
                }
                
                Swal.fire({
                    title: 'تم الحذف!',
                    text: 'تم حذف المحادثة بنجاح.',
                    icon: 'success',
                    timer: 1500,
                    showConfirmButton: false
                });
            }
        } catch (err) {
            console.error('Failed to delete conversation', err);
            Swal.fire('خطأ', 'حدث خطأ أثناء حذف المحادثة.', 'error');
        }
    }

    function handleKey(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    }

    function autoResize(el) {
        el.style.height = 'auto';
        el.style.height = Math.min(el.scrollHeight, 120) + 'px';
    }

    function sendSuggestion(text) {
        inputEl.value = text;
        sendMessage();
    }

    function formatText(text) {
        return text
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\\n/g, '\n')
            .replace(/\n/g, '<br>');
    }

    function createMessageBubble(role, htmlContent, id = null) {
        const msgWrapper = document.createElement('div');
        msgWrapper.className = `flex gap-3 items-end animate-[fadeIn_0.3s_ease-out] w-full ${role === 'user' ? 'flex-row-reverse' : ''}`;
        if (id) msgWrapper.id = id;

        // Avatar
        const avatar = document.createElement('div');
        avatar.className = `w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 text-sm shadow-sm ${
            role === 'user' 
            ? 'bg-bgSubtle text-primary border border-borderSubtle' 
            : 'bg-primary text-bgBase'
        }`;
        avatar.innerHTML = role === 'user' ? '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' : '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>';

        // Bubble Content
        const bubble = document.createElement('div');
        
        if (role === 'user') {
            bubble.className = 'max-w-[85%] bg-primary text-bgBase px-4 py-3 rounded-2xl rounded-bl-sm shadow-sm text-sm leading-relaxed';
            bubble.innerHTML = htmlContent;
        } else {
            bubble.className = 'ai-bubble-bot max-w-[85%] bg-bgBase border border-borderSubtle text-gray-800 px-5 py-4 rounded-2xl rounded-br-sm shadow-sm text-sm leading-relaxed';
            bubble.innerHTML = htmlContent;
        }

        msgWrapper.appendChild(avatar);
        msgWrapper.appendChild(bubble);
        return { wrapper: msgWrapper, bubble };
    }

    function addThinking() {
        if (welcomeEl && welcomeEl.parentNode === messagesEl) {
            messagesEl.removeChild(welcomeEl);
        }

        const thinkingHtml = `
            <div class="flex items-center gap-1.5 h-4">
                <div class="w-1.5 h-1.5 bg-gray-100 rounded-full animate-bounce" style="animation-delay: 0s"></div>
                <div class="w-1.5 h-1.5 bg-gray-100 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                <div class="w-1.5 h-1.5 bg-gray-100 rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
            </div>
        `;
        
        const { wrapper, bubble } = createMessageBubble('bot', thinkingHtml, 'thinking-msg');
        messagesEl.appendChild(wrapper);
        scrollToBottom();
        return bubble;
    }

    function removeThinking() {
        const el = document.getElementById('thinking-msg');
        if (el) el.remove();
    }

    function scrollToBottom() {
        messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    async function sendMessage() {
        const text = inputEl.value.trim();
        if (!text || isStreaming) return;

        isStreaming = true;
        sendBtn.disabled = true;
        inputEl.disabled = true;

        if (welcomeEl && welcomeEl.parentNode === messagesEl) {
            messagesEl.removeChild(welcomeEl);
        }

        // Add user message
        const { wrapper: userMsg } = createMessageBubble('user', formatText(text));
        messagesEl.appendChild(userMsg);
        
        inputEl.value = '';
        inputEl.style.height = 'auto';

        // Add thinking bubble which we will update
        const bubble = addThinking();

        try {
            const response = await fetch('/Ai/Stream', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text, conversationId: currentConversationId })
            });

            if (!response.ok) throw new Error('فشل الاتصال بالخادم.');

            const reader  = response.body.getReader();
            const decoder = new TextDecoder();
            let fullText  = '';
            let firstChunk = true;

            while (true) {
                const { done, value } = await reader.read();
                if (done) break;

                const rawChunk = decoder.decode(value);
                const lines = rawChunk.split('\n');

                for (const line of lines) {
                    if (!line.startsWith('data: ')) continue;
                    const data = line.slice(6);

                    if (data === '[DONE]') {
                        fetchConversations(); // Refresh list to show new chat or updated titles
                        break;
                    }
                    
                    if (data.startsWith('[CONVERSATION_ID] ')) {
                        currentConversationId = parseInt(data.replace('[CONVERSATION_ID] ', '').trim());
                        fetchConversations(); // Refresh list to show new chat
                        continue;
                    }

                    if (data.startsWith('[ERROR]')) {
                        bubble.innerHTML = `<div class="flex items-center gap-2 text-red-600"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> <span>${data.slice(7)}</span></div>`;
                        break;
                    }

                    if (data === '[STATUS] analyzing') {
                        bubble.innerHTML = `<div class="flex items-center gap-2 text-primary font-medium animate-pulse"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg> <span>جاري تحليل الطلب...</span></div>`;
                        continue;
                    }

                    if (data === '[STATUS] generating') {
                        firstChunk = false;
                        continue;
                    }

                    if (data === '[STATUS] finalizing') {
                        continue;
                    }

                    firstChunk = false;
                    const chunk = data.replace(/\\n/g, '\n');
                    fullText += chunk;
                    bubble.innerHTML = formatText(fullText);
                    scrollToBottom();
                }
            }

        } catch (err) {
            bubble.innerHTML = `<div class="flex items-center gap-2 text-red-600"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg> <span>حدث خطأ: ${err.message}</span></div>`;
        } finally {
            isStreaming = false;
            sendBtn.disabled = false;
            inputEl.disabled = false;
            inputEl.focus();
        }
    }



    document.addEventListener('DOMContentLoaded', () => {
        inputEl.focus();
        fetchConversations();
    });
</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>





