@model ManageMentSystem.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول | نماء</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/cairo-font.css" />
    <link rel="stylesheet" href="~/css/zenith-ui.css" />
    <style>
        body { font-family: 'Cairo', sans-serif; background-color: var(--zen-paper); color: var(--zen-ink); }
        .auth-page {
            --start-x: 0px;
            opacity: 0;
            transform: translateX(var(--start-x));
            transition: transform .6s cubic-bezier(.22,1,.36,1), opacity .4s ease;
            will-change: transform, opacity;
        }
        .auth-page.is-visible { opacity: 1; transform: translateX(0); }
        .auth-page.is-leaving-left { opacity: 0; transform: translateX(-40px); }
        .auth-page.is-leaving-right { opacity: 0; transform: translateX(40px); }

        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body class="bg-[#fdfdfd] text-slate-900 antialiased overflow-x-hidden">

    <main id="authPage" class="auth-page h-screen flex items-stretch overflow-hidden">
        <!-- Form Section -->
        <div class="w-full lg:w-[55%] flex flex-col justify-center px-8 md:px-16 lg:px-24 py-12 bg-[var(--zen-paper)] relative z-10 overflow-y-auto">
            <div class="max-w-md w-full mx-auto">
                <div class="mb-10">
                    <div class="flex items-center justify-between mb-8">
                        <a href="/" class="flex items-center gap-3 group">
                            <img src="~/images/blogo.webp" alt="نماء" class="w-10 h-10 object-contain transition-transform group-hover:scale-110">
                            <span class="text-3xl font-black tracking-tighter text-[var(--zen-ink)] uppercase group-hover:text-[var(--zen-primary)] transition-all">نماء</span>
                        </a>
                        <a href="/" class="flex items-center gap-2 text-sm font-bold text-[var(--zen-ink-soft)] hover:text-[var(--zen-primary)] transition-all group">
                            العودة للرئيسية
                            <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        </a>
                    </div>
                    <div class="text-right">
                        <h1 class="text-4xl font-extrabold text-[var(--zen-ink)] mb-3 tracking-tight">تسجيل الدخول</h1>
                        <p class="text-[var(--zen-ink-soft)] font-medium opacity-70">أهلاً بك مجدداً، أدخل بياناتك للمتابعة.</p>
                    </div>
                </div>

                <form asp-controller="Auth" asp-action="Login" method="post" class="space-y-6">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                    {
                        <div class="p-4 rounded-xl bg-red-50 border border-red-100 text-red-600 text-sm font-bold flex items-center gap-3">
                            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <div>
                                @foreach (var error in ViewData.ModelState[string.Empty].Errors)
                                {
                                    <p>@error.ErrorMessage</p>
                                }
                            </div>
                        </div>
                    }

                    <div class="space-y-2">
                        <label asp-for="Email" class="text-sm font-bold text-[var(--zen-ink-soft)] mr-1">البريد الإلكتروني</label>
                        <div class="relative">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            </span>
                            <input asp-for="Email" class="w-full bg-[var(--zen-muted)] border border-[var(--zen-border)] rounded-2xl py-3.5 pr-12 pl-4 text-[var(--zen-ink)] outline-none focus:ring-2 focus:ring-[var(--zen-primary-light)] focus:border-[var(--zen-primary)] transition-all font-medium" placeholder="name@company.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-[var(--zen-danger)] text-xs font-bold mr-1 block"></span>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="Password" class="text-sm font-bold text-[var(--zen-ink-soft)] mr-1">كلمة المرور</label>
                        <div class="relative">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            </span>
                            <input asp-for="Password" type="password" id="passwordInput" class="w-full bg-[var(--zen-muted)] border border-[var(--zen-border)] rounded-2xl py-3.5 pr-12 pl-12 text-[var(--zen-ink)] outline-none focus:ring-2 focus:ring-[var(--zen-primary-light)] focus:border-[var(--zen-primary)] transition-all font-medium placeholder:tracking-widest" placeholder="••••••••" />
                            <button type="button" class="absolute left-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40 hover:opacity-100 hover:text-[var(--zen-ink)] transition-all toggle-password" data-target="passwordInput">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path class="eye-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    <path class="eye-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    <path class="eye-closed hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"></path>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-red-500 text-xs font-bold mr-1 block"></span>
                    </div>

                    <div class="flex items-center justify-between py-2">
                        <label class="flex items-center gap-2 cursor-pointer group">
                            <div class="relative flex items-center justify-center">
                                <input asp-for="RememberMe" class="peer appearance-none w-5 h-5 border-2 border-[var(--zen-border)] rounded-md checked:bg-[var(--zen-primary)] checked:border-[var(--zen-primary)] transition-all">
                                <svg class="absolute w-3 h-3 text-white opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            <span class="text-sm font-bold text-[var(--zen-ink-soft)] opacity-80 group-hover:opacity-100 group-hover:text-[var(--zen-ink)] transition-all">تذكرني</span>
                        </label>
                        <a href="#" class="text-sm font-bold text-[var(--zen-ink-soft)] opacity-60 hover:opacity-100 hover:text-[var(--zen-ink)] transition-all">نسيت كلمة المرور؟</a>
                    </div>

                    <button type="submit" id="btn-submit-signin" class="w-full bg-[var(--zen-primary)] text-white py-4 rounded-2xl font-black text-lg hover:bg-[var(--zen-primary-hover)] hover:scale-[1.01] active:scale-[0.98] transition-all shadow-xl shadow-[var(--zen-primary)]/10">
                        تسجيل الدخول
                    </button>


                    <p class="text-center text-[var(--zen-ink-soft)] font-bold text-sm pt-4">
                        ليس لديك حساب؟
                        <a asp-controller="Auth" asp-action="Register" data-direction="left" class="text-[var(--zen-ink)] underline underline-offset-4 hover:text-[var(--zen-primary-hover)] transition-colors auth-switch-link">أنشئ حساباً الآن</a>
                    </p>
                </form>

            </div>
        </div>

        <!-- Branding Section -->
        <div class="hidden lg:flex lg:w-[45%] relative overflow-hidden bg-[var(--zen-primary)] items-end justify-center p-12">
            <!-- Background Image -->
            <img src="~/images/auth-bg.webp" alt="Visual" class="absolute inset-0 w-full h-full object-cover opacity-60 scale-105">
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--zen-ink)] via-[var(--zen-ink)]/40 to-transparent"></div>

            <div class="relative z-10 max-w-xl text-right">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/10 text-white text-xs font-bold mb-8">
                    <span class="flex h-2 w-2 rounded-full bg-[var(--zen-success)] animate-pulse"></span>
                    انضم لأكثر من 5,000 شركة ناجحة
                </div>
                
                <h2 class="text-6xl font-black text-white mb-6 leading-tight tracking-tighter">
                    أدر أعمالك <br/> 
                    <span class="text-[var(--zen-border)]">بذكاء وفعالية.</span>
                </h2>
                
                <p class="text-xl text-[var(--zen-muted)] font-medium leading-relaxed mb-12">
                    نظام نماء يوفر لك كل ما تحتاجه لإدارة المبيعات، المخازن، والتقارير المالية في منصة واحدة سهلة الاستخدام.
                </p>

            </div>

            <!-- Decorative Elements -->
            <div class="absolute top-20 right-20 w-64 h-64 bg-slate-500/20 rounded-full blur-[120px]"></div>
            <div class="absolute bottom-20 left-20 w-96 h-96 bg-black rounded-full blur-[120px]"></div>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function bindAuthInteractions() {
            const authPage = document.getElementById('authPage');
            if (!authPage) return;

            const toggleButtons = authPage.querySelectorAll('.toggle-password');
            toggleButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    const targetId = this.dataset.target;
                    const input = document.getElementById(targetId);
                    if (!input) return;
                    
                    const isPassword = input.type === 'password';
                    input.type = isPassword ? 'text' : 'password';
                    
                    const eyeOpen = this.querySelectorAll('.eye-open');
                    const eyeClosed = this.querySelector('.eye-closed');
                    
                    if (isPassword) {
                        eyeOpen.forEach(p => p.classList.add('hidden'));
                        eyeClosed.classList.remove('hidden');
                    } else {
                        eyeOpen.forEach(p => p.classList.remove('hidden'));
                        eyeClosed.classList.add('hidden');
                    }
                });
            });

            const form = authPage.querySelector('form');
            if (form) {
                $(form).off('submit.authSubmit').on('submit.authSubmit', function () {
                    if ($(this).valid()) {
                        const btn = $('#btn-submit-signin');
                        btn.prop('disabled', true);
                        btn.html('<span class="flex items-center justify-center gap-2"><svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> جاري تسجيل الدخول...</span>');
                    }
                });
                if ($.validator && $.validator.unobtrusive) {
                    $.validator.unobtrusive.parse($(form));
                }
            }

            requestAnimationFrame(() => authPage.classList.add('is-visible'));

            authPage.querySelectorAll('.auth-switch-link').forEach((link) => {
                link.addEventListener('click', async function (e) {
                    const target = this.getAttribute('href');
                    if (!target || target.startsWith('#')) return;
                    const direction = this.dataset.direction === 'right' ? 'right' : 'left';
                    e.preventDefault();

                    authPage.classList.remove('is-visible');
                    authPage.classList.add(direction === 'left' ? 'is-leaving-left' : 'is-leaving-right');

                    try {
                        const response = await fetch(target, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                        const html = await response.text();
                        const parser = new DOMParser();
                        const nextDoc = parser.parseFromString(html, 'text/html');
                        const nextPage = nextDoc.getElementById('authPage');

                        if (!nextPage) {
                            window.location.href = target;
                            return;
                        }

                        nextPage.style.setProperty('--start-x', direction === 'left' ? '40px' : '-40px');
                        authPage.replaceWith(nextPage);
                        document.title = nextDoc.title;
                        history.pushState({}, '', target);
                        bindAuthInteractions();
                    } catch {
                        window.location.href = target;
                    }
                });
            });
        }

        window.addEventListener('popstate', () => window.location.reload());
        bindAuthInteractions();
    </script>
</body>
</html>
