@model ManageMentSystem.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "_Layout";
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden font-sans" dir="rtl" style="font-family: 'Cairo', sans-serif;">

    <!-- Subtle grid background -->
    <div class="absolute inset-0 pointer-events-none select-none opacity-[0.03]" aria-hidden="true" style="background-image: linear-gradient(rgba(0,0,0,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,.1) 1px, transparent 1px); background-size: 64px 64px;"></div>

    <!-- Login Card -->
    <div class="relative z-10 w-full max-w-md">
        <div class="bg-white rounded-2xl border border-gray-200 shadow-xl shadow-gray-200/50 p-8 sm:p-10 space-y-8 animate__animated animate__fadeIn">

            <!-- Logo & Heading -->
            <div class="text-center space-y-4">
                <div class="mx-auto w-14 h-14 rounded-xl bg-gray-50 border border-gray-200 flex items-center justify-center">
                    <img src="~/images/zenith_new_logo.webp" alt="Zenith ERP" class="w-8 h-8 object-contain opacity-90" />
                </div>
                <div>
                    <h2 class="text-2xl font-extrabold text-primary tracking-tight">
                        مرحباً بعودتك
                    </h2>
                    <p class="mt-2 text-sm text-gray-500">
                        أدخل بياناتك للوصول إلى لوحة التحكم
                    </p>
                </div>
            </div>

            <form class="space-y-5" action="@Url.Action("Login", "Auth")" method="post">
                @Html.AntiForgeryToken()

                <!-- Error Messages -->
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                {
                    <div class="bg-accentRed/10 border border-accentRed/20 p-4 rounded-xl">
                        <div class="flex items-start gap-3">
                            <i data-lucide="alert-circle" class="text-accentRed w-5 h-5 mt-0.5 flex-shrink-0"></i>
                            <div>
                                <h3 class="text-sm font-bold text-accentRed">خطأ في الدخول</h3>
                                <div class="mt-1 text-sm text-accentRed">
                                    @foreach (var error in ViewData.ModelState[string.Empty].Errors)
                                    {
                                        <p>@error.ErrorMessage</p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Email -->
                <div class="space-y-2">
                    <label asp-for="Email" class="block text-sm font-bold text-gray-700">البريد الإلكتروني / اسم المستخدم</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 right-0 pr-3.5 flex items-center pointer-events-none">
                            <i data-lucide="mail" class="text-gray-400 w-4.5 h-4.5"></i>
                        </div>
                        <input asp-for="Email"
                               class="w-full bg-bgBase border border-borderSubtle rounded-xl pl-4 pr-11 py-3 text-sm text-primary placeholder-textMuted outline-none transition-all duration-200 focus:border-primary focus:ring-2 focus:ring-primary/20"
                               placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-accentRed text-xs font-bold block"></span>
                </div>

                <!-- Password -->
                <div class="space-y-2">
                    <label asp-for="Password" class="block text-sm font-bold text-gray-700">كلمة المرور</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 right-0 pr-3.5 flex items-center pointer-events-none">
                            <i data-lucide="lock" class="text-gray-400 w-4.5 h-4.5"></i>
                        </div>
                        <input asp-for="Password" type="password" id="passwordInput"
                               class="w-full bg-bgBase border border-borderSubtle rounded-xl pl-11 pr-11 py-3 text-sm text-primary placeholder-textMuted outline-none transition-all duration-200 focus:border-primary focus:ring-2 focus:ring-primary/20"
                               placeholder="••••••••" />
                        <button type="button" id="togglePassword" class="absolute inset-y-0 left-0 pl-3.5 flex items-center cursor-pointer text-gray-400 hover:text-primary transition-colors outline-none z-20">
                            <i data-lucide="eye" class="w-4.5 h-4.5"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-accentRed text-xs font-bold block"></span>
                </div>

                <!-- Remember Me -->
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <input asp-for="RememberMe" class="h-4 w-4 rounded border-borderSubtle text-primary focus:ring-primary cursor-pointer" />
                        <label asp-for="RememberMe" class="text-sm text-gray-600 font-bold cursor-pointer select-none">
                            تذكرني
                        </label>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" id="btn-submit"
                        class="w-full flex items-center justify-center gap-2 py-3.5 px-6 rounded-xl text-white font-bold text-sm bg-primary border border-transparent hover:bg-primaryHover transition-all duration-200 shadow-lg shadow-black/10 hover:-translate-y-0.5 active:translate-y-0">
                    تسجيل الدخول
                </button>

                <!-- Register Link -->
                <p class="text-center text-sm text-gray-500">
                    ليس لديك حساب؟
                    <a asp-action="Register" asp-controller="Auth" class="font-bold text-primary hover:text-primaryHover underline underline-offset-4 decoration-borderSubtle hover:decoration-textMuted transition-colors">
                        إنشاء حساب جديد
                    </a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('togglePassword').addEventListener('click', function (e) {
            const passwordInput = document.getElementById('passwordInput');
            const icon = this.querySelector('i');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                this.innerHTML = '<i data-lucide="eye-off" class="w-4.5 h-4.5"></i>';
            } else {
                passwordInput.type = 'password';
                this.innerHTML = '<i data-lucide="eye" class="w-4.5 h-4.5"></i>';
            }
            lucide.createIcons();
        });

        $('form').on('submit', function() {
            if ($(this).valid()) {
                const btn = $('#btn-submit');
                const originalText = btn.text();
                btn.prop('disabled', true);
                btn.html('<i data-lucide="loader-2" class="animate-spin ml-2 inline-block w-4 h-4"></i> جاري الدخول...');
                lucide.createIcons();
                
                setTimeout(() => {
                    btn.prop('disabled', false);
                    btn.text(originalText);
                }, 10000);
            }
        });
    </script>
}
