@model ManageMentSystem.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "_Layout";
}

<div class="min-h-screen flex items-center justify-center bg-gray-50/50 py-12 px-4 sm:px-6 lg:px-8" dir="rtl">
    <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-2xl shadow-xl border border-slate-100 animate__animated animate__fadeIn">
        <div>
            <div class="mx-auto h-20 w-20 bg-indigo-50 rounded-full flex items-center justify-center mb-4">
                <i class="fas fa-user-circle text-4xl text-indigo-800"></i>
            </div>
            <h2 class="mt-2 text-center text-3xl font-extrabold text-slate-900">
                تسجيل الدخول
            </h2>
            <p class="mt-2 text-center text-sm text-slate-600">
                مرحباً بك مجدداً! الرجاء إدخال بيانات الدخول
            </p>
        </div>
        
        <form class="mt-8 space-y-6" action="@Url.Action("Login", "Auth")" method="post">
            @Html.AntiForgeryToken()
            
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
            {
                <div class="bg-red-50 border-r-4 border-red-500 p-4 rounded-lg">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i class="fas fa-exclamation-circle text-red-500"></i>
                        </div>
                        <div class="mr-3">
                            <h3 class="text-sm font-bold text-red-800">خطأ في الدخول</h3>
                            <div class="mt-2 text-sm text-red-700">
                                @foreach (var error in ViewData.ModelState[string.Empty].Errors)
                                {
                                    <p>@error.ErrorMessage</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="rounded-md shadow-sm space-y-4">
                <div>
                    <label asp-for="Email" class="block text-sm font-bold text-slate-700 mb-1">البريد الإلكتروني / اسم المستخدم</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fas fa-envelope text-slate-400 text-lg"></i>
                        </div>
                        <input asp-for="Email" class="appearance-none rounded-xl relative block w-full px-4 py-3 pr-10 border border-slate-300 placeholder-slate-400 text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-800 focus:border-indigo-800 focus:z-10 sm:text-sm font-medium transition-all" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 font-bold"></span>
                </div>
                <div>
                    <label asp-for="Password" class="block text-sm font-bold text-slate-700 mb-1">كلمة المرور</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fas fa-lock text-slate-400 text-lg"></i>
                        </div>
                        <input asp-for="Password" type="password" id="passwordInput" class="appearance-none rounded-xl relative block w-full px-4 py-3 pr-10 pl-10 border border-slate-300 placeholder-slate-400 text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-800 focus:border-indigo-800 focus:z-10 sm:text-sm font-medium transition-all" placeholder="••••••••" />
                        <button type="button" id="togglePassword" class="absolute inset-y-0 left-0 pl-3 flex items-center cursor-pointer text-slate-400 hover:text-indigo-800 transition-colors focus:outline-none z-20">
                             <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 font-bold"></span>
                </div>
            </div>

            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <input asp-for="RememberMe" class="h-4 w-4 text-indigo-800 focus:ring-indigo-800 border-gray-300 rounded cursor-pointer" />
                    <label asp-for="RememberMe" class="mr-2 block text-sm text-slate-700 font-bold cursor-pointer">
                        تذكرني
                    </label>
                </div>

                @* <div class="text-sm">
                    <a href="#" class="font-bold text-indigo-600 hover:text-indigo-800">
                        نسيت كلمة المرور؟
                    </a>
                </div> *@
            </div>

            <div>
                <button type="submit" id="btn-submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-indigo-800 hover:bg-indigo-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-800 transition-all shadow-sm shadow-indigo-500/30">
                    تسجيل الدخول
                </button>
            </div>
            
            <div class="text-center mt-6">
                <p class="text-sm text-slate-600">
                    ليس لديك حساب؟ 
                    <a asp-action="Register" asp-controller="Auth" class="font-bold text-indigo-600 hover:text-indigo-800 transition-colors">
                        إنشاء حساب جديد
                    </a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('togglePassword').addEventListener('click', function (e) {
            const passwordInput = document.getElementById('passwordInput');
            const icon = this.querySelector('i');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        });

        $('form').on('submit', function() {
            if ($(this).valid()) {
                const btn = $('#btn-submit');
                const originalText = btn.text();
                btn.prop('disabled', true);
                btn.html('<i class="fas fa-spinner fa-spin ml-2"></i> جاري الدخول...');
                
                // Safety timeout in case of network error or server not engaging
                setTimeout(() => {
                    btn.prop('disabled', false);
                    btn.text(originalText);
                }, 10000);
            }
        });
    </script>
}