@model ManageMentSystem.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "_Layout";
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8" dir="rtl">
    <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-2xl shadow-xl border border-gray-200 animate__animated animate__fadeIn">
        <div>
            <div class="mx-auto h-20 w-20 bg-gray-50 rounded-full flex items-center justify-center mb-4 border border-gray-200">
                <i data-lucide="user" class="text-4xl text-[#0f1419] w-10 h-10"></i>
            </div>
            <h2 class="mt-2 text-center text-3xl font-extrabold text-[#0f1419]">
                تسجيل الدخول
            </h2>
            <p class="mt-2 text-center text-sm text-gray-500">
                مرحباً بك مجدداً! الرجاء إدخال بيانات الدخول
            </p>
        </div>
        
        <form class="mt-8 space-y-6" action="@Url.Action("Login", "Auth")" method="post">
            @Html.AntiForgeryToken()
            
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
            {
                <div class="bg-red-50 border-r-4 border-accentRed p-4 rounded-lg">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i data-lucide="alert-circle" class="text-accentRed w-5 h-5"></i>
                        </div>
                        <div class="mr-3">
                            <h3 class="text-sm font-bold text-red-800">خطأ في الدخول</h3>
                            <div class="mt-2 text-sm text-red-700">
                                @foreach (var error in ViewData.ModelState[string.Empty].Errors)
                                {
                                    <p>@error.ErrorMessage</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="rounded-md shadow-sm space-y-4">
                <div>
                    <label asp-for="Email" class="block text-sm font-bold text-gray-700 mb-1">البريد الإلكتروني / اسم المستخدم</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i data-lucide="mail" class="text-gray-500 text-lg w-5 h-5"></i>
                        </div>
                        <input asp-for="Email" class="w-full border border-gray-200 rounded-xl pl-4 pr-10 py-2.5 focus:border-[#0f1419] outline-none text-sm transition-colors bg-white" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-accentRed text-xs mt-1 font-bold"></span>
                </div>
                <div>
                    <label asp-for="Password" class="block text-sm font-bold text-gray-700 mb-1">كلمة المرور</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i data-lucide="lock" class="text-gray-500 text-lg w-5 h-5"></i>
                        </div>
                        <input asp-for="Password" type="password" id="passwordInput" class="w-full border border-gray-200 rounded-xl pl-10 pr-10 py-2.5 focus:border-[#0f1419] outline-none text-sm transition-colors bg-white" placeholder="••••••••" />
                        <button type="button" id="togglePassword" class="absolute inset-y-0 left-0 pl-3 flex items-center cursor-pointer text-gray-500 hover:text-[#0f1419] transition-colors outline-none z-20">
                              <i data-lucide="eye" class="w-4 h-4"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-accentRed text-xs mt-1 font-bold"></span>
                </div>
            </div>

            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <input asp-for="RememberMe" class="h-4 w-4 text-[#0f1419] focus:ring-[#0f1419] border-gray-200 rounded cursor-pointer" />
                    <label asp-for="RememberMe" class="mr-2 block text-sm text-gray-700 font-bold cursor-pointer">
                        تذكرني
                    </label>
                </div>

                @* <div class="text-sm">
                    <a href="#" class="font-bold text-[#0f1419] hover:text-[#0f1419]">
                        نسيت كلمة المرور؟
                    </a>
                </div> *@
            </div>

            <div>
                <button type="submit" id="btn-submit" class="w-full flex justify-center py-2.5 px-4 rounded-xl text-white bg-[#0f1419] hover:bg-primaryHover font-bold outline-none transition-colors">
                    تسجيل الدخول
                </button>
            </div>
            
            <div class="text-center mt-6">
                <p class="text-sm text-gray-500">
                    ليس لديك حساب؟ 
                    <a asp-action="Register" asp-controller="Auth" class="font-bold text-[#0f1419] hover:text-primaryHover hover:underline transition-colors">
                        إنشاء حساب جديد
                    </a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('togglePassword').addEventListener('click', function (e) {
            const passwordInput = document.getElementById('passwordInput');
            const icon = this.querySelector('i');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                this.innerHTML = '<i data-lucide="eye-off" class="w-4 h-4"></i>';
            } else {
                passwordInput.type = 'password';
                this.innerHTML = '<i data-lucide="eye" class="w-4 h-4"></i>';
            }
            lucide.createIcons();
        });

        $('form').on('submit', function() {
            if ($(this).valid()) {
                const btn = $('#btn-submit');
                const originalText = btn.text();
                btn.prop('disabled', true);
                btn.html('<i data-lucide="loader-2" class="animate-spin ml-2 inline-block w-4 h-4"></i> جاري الدخول...');
                lucide.createIcons();
                
                // Safety timeout in case of network error or server not engaging
                setTimeout(() => {
                    btn.prop('disabled', false);
                    btn.text(originalText);
                }, 10000);
            }
        });
    </script>
}
