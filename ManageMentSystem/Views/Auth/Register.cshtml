@model ManageMentSystem.ViewModels.RegisterViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>إنشاء حساب | Zenith ERP</title>
    <script src="~/lib/tailwindcss/tailwind.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="~/js/tailwind-theme.js"></script>
    <link rel="stylesheet" href="~/css/cairo-font.css" />
    <link href="~/css/landing.css" rel="stylesheet" />
    <style>
        .auth-page {
            --start-x: 0px;
            opacity: 0;
            transform: translateX(var(--start-x));
            transition: transform .45s cubic-bezier(.22,1,.36,1), opacity .35s ease;
            will-change: transform, opacity;
        }

        .auth-page.is-visible {
            opacity: 1;
            transform: translateX(0);
        }

        .auth-page.is-leaving-left {
            opacity: 0;
            transform: translateX(-64px);
        }

        .auth-page.is-leaving-right {
            opacity: 0;
            transform: translateX(64px);
        }
    </style>
</head>
<body class="bg-[#fafafa] text-black antialiased" style="font-family: 'Cairo', sans-serif;">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <main id="authPage" class="auth-page relative min-h-screen px-5 py-10 md:px-10 flex items-center justify-center">
        <div class="w-full max-w-6xl bg-white/95 backdrop-blur-xl border border-black/5 rounded-3xl shadow-[0_30px_80px_rgba(0,0,0,0.08)] overflow-hidden">
            <div class="grid lg:grid-cols-2">
                <aside class="hidden lg:flex bg-black text-white p-10 flex-col justify-between">
                    <div class="flex items-center gap-3">
                        <img src="~/logo.png" alt="Zenith Logo" class="w-10 h-10 object-contain">
                        <p class="font-bold text-xl">ZENITH</p>
                    </div>
                    <div>
                        <h2 class="text-4xl font-bold leading-tight mb-4">ابدأ الآن</h2>
                        <p class="text-white/70 leading-7">انشئ حسابك وابدأ تشغيل مشروعك من لوحة موحدة فيها المبيعات والمخزون والتقارير.</p>
                    </div>
                </aside>

                <section class="p-8 md:p-10">
                    <div class="text-center mb-8">
                        <img src="~/logo.png" alt="Zenith Logo" class="w-14 h-14 object-contain mx-auto mb-4">
                        <h1 class="text-3xl font-bold tracking-tight">إنشاء حساب جديد</h1>
                        <p class="text-black/60 mt-2">املأ البيانات التالية لفتح حسابك</p>
                    </div>

                    <form class="space-y-5" asp-controller="Auth" asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
                {
                    <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p>@error.ErrorMessage</p>
                        }
                    </div>
                }

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="FullName" class="mb-2 block text-sm font-bold text-black/80"></label>
                        <input asp-for="FullName" class="w-full rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm outline-none focus:border-black/30" placeholder="الاسم الكامل" />
                        <span asp-validation-for="FullName" class="text-red-600 text-xs font-bold mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Username" class="mb-2 block text-sm font-bold text-black/80"></label>
                        <input asp-for="Username" class="w-full rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm outline-none focus:border-black/30" placeholder="اسم المستخدم" />
                        <span asp-validation-for="Username" class="text-red-600 text-xs font-bold mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Email" class="mb-2 block text-sm font-bold text-black/80"></label>
                        <input asp-for="Email" type="email" class="w-full rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm outline-none focus:border-black/30" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-red-600 text-xs font-bold mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="PhoneNumber" class="mb-2 block text-sm font-bold text-black/80"></label>
                        <input asp-for="PhoneNumber" id="phoneNumber" class="w-full rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm outline-none focus:border-black/30" placeholder="01xxxxxxxxx" />
                        <span asp-validation-for="PhoneNumber" class="text-red-600 text-xs font-bold mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="StoreName" class="mb-2 block text-sm font-bold text-black/80"></label>
                        <input asp-for="StoreName" class="w-full rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm outline-none focus:border-black/30" placeholder="اسم المتجر / الشركة" />
                        <span asp-validation-for="StoreName" class="text-red-600 text-xs font-bold mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="CurrencyCode" class="mb-2 block text-sm font-bold text-black/80"></label>
                        <select asp-for="CurrencyCode" class="w-full rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm outline-none focus:border-black/30">
                            <option value="">اختر العملة</option>
                            <option value="EGP">جنيه مصري (EGP)</option>
                            <option value="SAR">ريال سعودي (SAR)</option>
                            <option value="AED">درهم إماراتي (AED)</option>
                            <option value="USD">دولار أمريكي (USD)</option>
                            <option value="EUR">يورو (EUR)</option>
                        </select>
                        <span asp-validation-for="CurrencyCode" class="text-red-600 text-xs font-bold mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Password" class="mb-2 block text-sm font-bold text-black/80"></label>
                        <input asp-for="Password" type="password" id="password" class="w-full rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm outline-none focus:border-black/30" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-red-600 text-xs font-bold mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="ConfirmPassword" class="mb-2 block text-sm font-bold text-black/80"></label>
                        <input asp-for="ConfirmPassword" type="password" id="confirmPassword" class="w-full rounded-2xl border border-black/10 bg-white px-4 py-3 text-sm outline-none focus:border-black/30" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="text-red-600 text-xs font-bold mt-1 block"></span>
                    </div>
                </div>

                <button type="submit" id="btn-submit-reg" class="w-full bg-black text-white px-8 py-3 rounded-full font-bold hover:scale-[1.02] transition-all">
                    إنشاء الحساب
                </button>

                        <p class="text-center text-sm text-black/60">
                            لديك حساب بالفعل؟
                            <a asp-controller="Auth" asp-action="Login" data-direction="right" class="font-bold text-black auth-switch-link">تسجيل الدخول</a>
                        </p>
                    </form>
                </section>
            </div>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function bindAuthInteractions() {
            const authPage = document.getElementById('authPage');
            if (!authPage) return;

            const phoneNumber = document.getElementById('phoneNumber');
            if (phoneNumber) {
                phoneNumber.addEventListener('input', function () {
                    this.value = this.value.replace(/[^0-9]/g, '');
                });
            }

            const form = authPage.querySelector('form');
            if (form) {
                $(form).off('submit.authSubmit').on('submit.authSubmit', function () {
                    if ($(this).valid()) {
                        const btn = $('#btn-submit-reg');
                        btn.prop('disabled', true);
                        btn.text('جاري إنشاء الحساب...');
                    }
                });
                if ($.validator && $.validator.unobtrusive) {
                    $.validator.unobtrusive.parse($(form));
                }
            }

            requestAnimationFrame(() => authPage.classList.add('is-visible'));

            authPage.querySelectorAll('.auth-switch-link').forEach((link) => {
                link.addEventListener('click', async function (e) {
                    const target = this.getAttribute('href');
                    if (!target || target.startsWith('#')) return;
                    const direction = this.dataset.direction === 'right' ? 'right' : 'left';
                    e.preventDefault();

                    authPage.classList.remove('is-visible');
                    authPage.classList.add(direction === 'left' ? 'is-leaving-left' : 'is-leaving-right');

                    try {
                        const response = await fetch(target, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                        const html = await response.text();
                        const parser = new DOMParser();
                        const nextDoc = parser.parseFromString(html, 'text/html');
                        const nextPage = nextDoc.getElementById('authPage');

                        if (!nextPage) {
                            window.location.href = target;
                            return;
                        }

                        nextPage.style.setProperty('--start-x', direction === 'left' ? '64px' : '-64px');
                        authPage.replaceWith(nextPage);
                        document.title = nextDoc.title;
                        history.pushState({}, '', target);
                        bindAuthInteractions();
                    } catch {
                        window.location.href = target;
                    }
                });
            });
        }

        window.addEventListener('popstate', () => window.location.reload());
        bindAuthInteractions();
    </script>
</body>
</html>
