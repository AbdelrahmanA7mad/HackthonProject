@model ManageMentSystem.ViewModels.RegisterViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>إنشاء حساب | Zenith ERP</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/cairo-font.css" />
    <link rel="stylesheet" href="~/css/zenith-ui.css" />
    <style>
        body { font-family: 'Cairo', sans-serif; background-color: var(--zen-paper); color: var(--zen-ink); }
        .auth-page {
            --start-x: 0px;
            opacity: 0;
            transform: translateX(var(--start-x));
            transition: transform .6s cubic-bezier(.22,1,.36,1), opacity .4s ease;
            will-change: transform, opacity;
        }
        .auth-page.is-visible { opacity: 1; transform: translateX(0); }
        .auth-page.is-leaving-left { opacity: 0; transform: translateX(-40px); }
        .auth-page.is-leaving-right { opacity: 0; transform: translateX(40px); }

        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body class="bg-[#fdfdfd] text-slate-900 antialiased overflow-x-hidden">

    <main id="authPage" class="auth-page min-h-screen flex items-stretch">
        <!-- branding Section (Shown on right in RTL) -->
        <div class="hidden lg:flex lg:w-[45%] relative overflow-hidden bg-[var(--zen-primary)] items-center justify-center p-12">
            <!-- Background Image -->
            <img src="~/images/auth-bg.png" alt="Visual" class="absolute inset-0 w-full h-full object-cover opacity-60 scale-105">
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--zen-ink)] via-[var(--zen-ink)]/40 to-transparent"></div>

            <div class="relative z-10 max-w-md text-right">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/10 text-white text-xs font-bold mb-8">
                    <span class="flex h-2 w-2 rounded-full bg-[var(--zen-success)] animate-pulse"></span>
                    ابدأ رحلتك اليوم
                </div>
                
                <h2 class="text-5xl font-black text-white mb-6 leading-tight tracking-tighter">
                    انضم لمستقبل <br/> 
                    <span class="text-[var(--zen-border)]">إدارة الأعمال.</span>
                </h2>
                
                <p class="text-lg text-[var(--zen-muted)] font-medium leading-relaxed mb-8">
                    خطوات بسيطة تفصلك عن امتلاك أقوى أدوات الإدارة في السوق المصري والعربي.
                </p>

                <!-- Info Card -->
                <div class="glass-card p-6 rounded-2xl">
                    <div class="space-y-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-emerald-400">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            <span class="text-white font-bold">تجربة مجانية لمدة 14 يوم</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-emerald-400">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            <span class="text-white font-bold">دعم فني متواصل 24/7</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Form Section -->
        <div class="w-full lg:w-[55%] flex flex-col justify-center px-8 md:px-16 lg:px-20 py-12 bg-[var(--zen-paper)] relative z-10">
            <div class="max-w-2xl w-full mx-auto">
                <!-- Header -->
                <div class="mb-8 text-right">
                    <div class="flex items-center gap-3 mb-6">
                        <img src="~/logo.png" alt="Zenith" class="w-8 h-8 object-contain">
                        <span class="text-lg font-black tracking-tighter text-[var(--zen-ink)] uppercase">Zenith</span>
                    </div>
                    <h1 class="text-3xl font-extrabold text-[var(--zen-ink)] mb-2 tracking-tight">إنشاء حساب جديد</h1>
                    <p class="text-[var(--zen-ink-soft)] font-medium text-sm opacity-70">ابدأ بإدخال بياناتك الأساسية لتجهيز متجرك.</p>
                </div>

                <form asp-controller="Auth" asp-action="Register" method="post" class="space-y-4">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
                    {
                        <div class="p-4 rounded-xl bg-red-50 border border-red-100 text-red-600 text-sm font-bold flex items-center gap-3">
                            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <div class="flex flex-col">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <span>@error.ErrorMessage</span>
                                }
                            </div>
                        </div>
                    }

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-1.5">
                            <label asp-for="FullName" class="text-xs font-bold text-[var(--zen-ink-soft)] mr-1">الاسم الكامل</label>
                            <div class="relative">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                                </span>
                                <input asp-for="FullName" class="w-full bg-[var(--zen-muted)] border border-[var(--zen-border)] rounded-xl py-2.5 pr-10 pl-4 text-[var(--zen-ink)] outline-none focus:ring-2 focus:ring-[var(--zen-primary-light)] focus:border-[var(--zen-primary)] transition-all font-medium text-sm" placeholder="الاسم كما سيظهر في الفواتير" />
                            </div>
                            <span asp-validation-for="FullName" class="text-[var(--zen-danger)] text-[10px] font-bold mr-1 block"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="Username" class="text-xs font-bold text-[var(--zen-ink-soft)] mr-1">اسم المستخدم</label>
                            <div class="relative">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                </span>
                                <input asp-for="Username" class="w-full bg-[var(--zen-muted)] border border-[var(--zen-border)] rounded-xl py-2.5 pr-10 pl-4 text-[var(--zen-ink)] outline-none focus:ring-2 focus:ring-[var(--zen-primary-light)] focus:border-[var(--zen-primary)] transition-all font-medium text-sm" placeholder="اسم فريد للدخول" />
                            </div>
                            <span asp-validation-for="Username" class="text-[var(--zen-danger)] text-[10px] font-bold mr-1 block"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="Email" class="text-xs font-bold text-[var(--zen-ink-soft)] mr-1">البريد الإلكتروني</label>
                            <div class="relative">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                </span>
                                <input asp-for="Email" type="email" class="w-full bg-[var(--zen-muted)] border border-[var(--zen-border)] rounded-xl py-2.5 pr-10 pl-4 text-[var(--zen-ink)] outline-none focus:ring-2 focus:ring-[var(--zen-primary-light)] focus:border-[var(--zen-primary)] transition-all font-medium text-sm" placeholder="name@company.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-[var(--zen-danger)] text-[10px] font-bold mr-1 block"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="PhoneNumber" class="text-xs font-bold text-[var(--zen-ink-soft)] mr-1">رقم الهاتف</label>
                            <div class="relative">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                </span>
                                <input asp-for="PhoneNumber" id="phoneNumber" class="w-full bg-[var(--zen-muted)] border border-[var(--zen-border)] rounded-xl py-2.5 pr-10 pl-4 text-[var(--zen-ink)] outline-none focus:ring-2 focus:ring-[var(--zen-primary-light)] focus:border-[var(--zen-primary)] transition-all font-medium text-sm" placeholder="01xxxxxxxxx" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-[var(--zen-danger)] text-[10px] font-bold mr-1 block"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="StoreName" class="text-xs font-bold text-[var(--zen-ink-soft)] mr-1">اسم المتجر / الشركة</label>
                            <div class="relative">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                                </span>
                                <input asp-for="StoreName" class="w-full bg-[var(--zen-muted)] border border-[var(--zen-border)] rounded-xl py-2.5 pr-10 pl-4 text-[var(--zen-ink)] outline-none focus:ring-2 focus:ring-[var(--zen-primary-light)] focus:border-[var(--zen-primary)] transition-all font-medium text-sm" placeholder="مثال: مؤسسة التقنية الحديثة" />
                            </div>
                            <span asp-validation-for="StoreName" class="text-[var(--zen-danger)] text-[10px] font-bold mr-1 block"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="CurrencyCode" class="text-xs font-bold text-[var(--zen-ink-soft)] mr-1">عملة النظام</label>
                            <div class="relative">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                </span>
                                <select asp-for="CurrencyCode" class="w-full bg-[var(--zen-muted)] border border-[var(--zen-border)] rounded-xl py-2.5 pr-10 pl-4 text-[var(--zen-ink)] outline-none focus:ring-2 focus:ring-[var(--zen-primary-light)] focus:border-[var(--zen-primary)] transition-all font-medium text-sm appearance-none bg-[url('https://www.svgrepo.com/show/490456/chevron-down.svg')] bg-[length:14px_14px] bg-[right_1rem_center] bg-no-repeat">
                                    <option value="">اختر العملة</option>
                                    <option value="EGP">جنيه مصري (EGP)</option>
                                    <option value="SAR">ريال سعودي (SAR)</option>
                                    <option value="AED">درهم إماراتي (AED)</option>
                                    <option value="USD">دولار أمريكي (USD)</option>
                                    <option value="EUR">يورو (EUR)</option>
                                </select>
                            </div>
                            <span asp-validation-for="CurrencyCode" class="text-[var(--zen-danger)] text-[10px] font-bold mr-1 block"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="Password" class="text-xs font-bold text-[var(--zen-ink-soft)] mr-1">كلمة المرور</label>
                            <div class="relative">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                </span>
                                <input asp-for="Password" type="password" id="passwordInput" class="w-full bg-[var(--zen-muted)] border border-[var(--zen-border)] rounded-xl py-2.5 pr-10 pl-10 text-[var(--zen-ink)] outline-none focus:ring-2 focus:ring-[var(--zen-primary-light)] focus:border-[var(--zen-primary)] transition-all font-medium text-sm" placeholder="••••••••" />
                                <button type="button" class="absolute left-3 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40 hover:opacity-100 hover:text-[var(--zen-ink)] transition-all toggle-password" data-target="passwordInput">
                                    <svg class="w-4 h-4 eye-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path class="eye-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                        <path class="eye-closed hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"></path>
                                    </svg>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-[var(--zen-danger)] text-[10px] font-bold mr-1 block"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="ConfirmPassword" class="text-xs font-bold text-[var(--zen-ink-soft)] mr-1">تأكيد كلمة المرور</label>
                            <div class="relative">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                </span>
                                <input asp-for="ConfirmPassword" type="password" id="confirmPasswordInput" class="w-full bg-[var(--zen-muted)] border border-[var(--zen-border)] rounded-xl py-2.5 pr-10 pl-10 text-[var(--zen-ink)] outline-none focus:ring-2 focus:ring-[var(--zen-primary-light)] focus:border-[var(--zen-primary)] transition-all font-medium text-sm" placeholder="••••••••" />
                                <button type="button" class="absolute left-3 top-1/2 -translate-y-1/2 text-[var(--zen-ink-soft)] opacity-40 hover:opacity-100 hover:text-[var(--zen-ink)] transition-all toggle-password" data-target="confirmPasswordInput">
                                    <svg class="w-4 h-4 eye-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path class="eye-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                        <path class="eye-closed hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"></path>
                                    </svg>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-[var(--zen-danger)] text-[10px] font-bold mr-1 block"></span>
                        </div>
                    </div>

                    <div class="pt-4">
                        <button type="submit" id="btn-submit-reg" class="w-full bg-[var(--zen-primary)] text-white py-4 rounded-xl font-black text-lg hover:bg-[var(--zen-primary-hover)] hover:scale-[1.01] active:scale-[0.98] transition-all shadow-xl shadow-[var(--zen-primary)]/10">
                            بدء استخدام زينيث مجاناً
                        </button>
                    </div>

                    <p class="text-center text-[var(--zen-ink-soft)] font-bold text-sm pt-4">
                        لديك حساب بالفعل؟
                        <a asp-controller="Auth" asp-action="Login" data-direction="right" class="text-[var(--zen-ink)] underline underline-offset-4 hover:text-[var(--zen-primary-hover)] transition-colors auth-switch-link">تسجيل الدخول</a>
                    </p>
                </form>

                <div class="mt-12 text-center">
                    <p class="text-[10px] text-slate-400 font-medium">بالنقر على "بدء الاستخدام"، فإنك توافق على شروط الخدمة وسياسة الخصوصية الخاصة بنا.</p>
                </div>
            </div>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function bindAuthInteractions() {
            const authPage = document.getElementById('authPage');
            if (!authPage) return;

            const phoneNumber = document.getElementById('phoneNumber');
            if (phoneNumber) {
                phoneNumber.addEventListener('input', function () {
                    this.value = this.value.replace(/[^0-9]/g, '');
                });
            }

            const toggleButtons = authPage.querySelectorAll('.toggle-password');
            toggleButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    const targetId = this.dataset.target;
                    const input = document.getElementById(targetId);
                    if (!input) return;
                    
                    const isPassword = input.type === 'password';
                    input.type = isPassword ? 'text' : 'password';
                    
                    const eyeOpen = this.querySelector('.eye-open');
                    const eyeClosed = this.querySelector('.eye-closed');
                    
                    if (isPassword) {
                        eyeOpen.classList.add('hidden');
                        eyeClosed.classList.remove('hidden');
                    } else {
                        eyeOpen.classList.remove('hidden');
                        eyeClosed.classList.add('hidden');
                    }
                });
            });

            const form = authPage.querySelector('form');
            if (form) {
                $(form).off('submit.authSubmit').on('submit.authSubmit', function () {
                    if ($(this).valid()) {
                        const btn = $('#btn-submit-reg');
                        btn.prop('disabled', true);
                        btn.html('<span class="flex items-center justify-center gap-2"><svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> جاري إنشاء الحساب...</span>');
                    }
                });
                if ($.validator && $.validator.unobtrusive) {
                    $.validator.unobtrusive.parse($(form));
                }
            }
            requestAnimationFrame(() => authPage.classList.add('is-visible'));

            authPage.querySelectorAll('.auth-switch-link').forEach((link) => {
                link.addEventListener('click', async function (e) {
                    const target = this.getAttribute('href');
                    if (!target || target.startsWith('#')) return;
                    const direction = this.dataset.direction === 'right' ? 'right' : 'left';
                    e.preventDefault();

                    authPage.classList.remove('is-visible');
                    authPage.classList.add(direction === 'left' ? 'is-leaving-left' : 'is-leaving-right');

                    try {
                        const response = await fetch(target, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                        const html = await response.text();
                        const parser = new DOMParser();
                        const nextDoc = parser.parseFromString(html, 'text/html');
                        const nextPage = nextDoc.getElementById('authPage');

                        if (!nextPage) {
                            window.location.href = target;
                            return;
                        }

                        nextPage.style.setProperty('--start-x', direction === 'left' ? '40px' : '-40px');
                        authPage.replaceWith(nextPage);
                        document.title = nextDoc.title;
                        history.pushState({}, '', target);
                        bindAuthInteractions();
                    } catch {
                        window.location.href = target;
                    }
                });
            });
        }

        window.addEventListener('popstate', () => window.location.reload());
        bindAuthInteractions();
    </script>
</body>
</html>
