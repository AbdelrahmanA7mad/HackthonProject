@model ManageMentSystem.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "تسجيل حساب جديد";
    Layout = "_Layout";
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8" dir="rtl">
    <div class="max-w-2xl w-full space-y-8 bg-white p-8 rounded-2xl shadow-xl border border-gray-200 animate__animated animate__fadeIn">
        <div>
            <div class="mx-auto h-20 w-20 bg-gray-50 rounded-full flex items-center justify-center mb-4 border border-gray-200">
                <i data-lucide="user-plus" class="text-4xl text-[#0f1419] w-10 h-10"></i>
            </div>
            <h2 class="mt-2 text-center text-3xl font-extrabold text-[#0f1419]">
                إنشاء حساب جديد
            </h2>
            <p class="mt-2 text-center text-sm text-gray-500">
                ابدأ رحلتك معنا بإعداد حسابك الشخصي
            </p>
        </div>

        <form class="mt-8 space-y-6" action="@Url.Action("Register", "Auth")" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
            {
                <div class="bg-red-50 border-r-4 border-accentRed p-4 rounded-lg">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i data-lucide="alert-circle" class="text-accentRed w-5 h-5"></i>
                        </div>
                        <div class="mr-3">
                            <h3 class="text-sm font-bold text-red-800">تنبيه</h3>
                            <div class="mt-2 text-sm text-red-700">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <p>@error.ErrorMessage</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Full Name -->
                <div>
                    <label asp-for="FullName" class="block text-sm font-bold text-gray-700 mb-1">الاسم الكامل</label>
                    <input asp-for="FullName" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 focus:border-[#0f1419] outline-none text-sm transition-colors" placeholder="الاسم الكامل" />
                    <span asp-validation-for="FullName" class="text-accentRed text-xs mt-1 font-bold"></span>
                </div>

                <!-- Username -->
                <div>
                    <label asp-for="Username" class="block text-sm font-bold text-gray-700 mb-1">اسم المستخدم</label>
                    <input asp-for="Username" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 focus:border-[#0f1419] outline-none text-sm transition-colors" placeholder="اسم المستخدم" />
                    <span asp-validation-for="Username" class="text-accentRed text-xs mt-1 font-bold"></span>
                </div>

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="block text-sm font-bold text-gray-700 mb-1">البريد الإلكتروني</label>
                    <input asp-for="Email" type="email" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 focus:border-[#0f1419] outline-none text-sm transition-colors" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-accentRed text-xs mt-1 font-bold"></span>
                </div>

                <!-- Phone Number -->
                <div>
                    <label asp-for="PhoneNumber" class="block text-sm font-bold text-gray-700 mb-1">رقم الهاتف</label>
                    <input asp-for="PhoneNumber" type="tel" id="phoneNumber" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 focus:border-[#0f1419] outline-none text-sm transition-colors" placeholder="01xxxxxxxxx" />
                    <span asp-validation-for="PhoneNumber" class="text-accentRed text-xs mt-1 font-bold"></span>
                </div>

                <!-- Store Name -->
                <div>
                    <label asp-for="StoreName" class="block text-sm font-bold text-gray-700 mb-1">اسم المتجر/الشركة <span class="text-gray-500 font-normal text-xs">(اختياري)</span></label>
                    <input asp-for="StoreName" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 focus:border-[#0f1419] outline-none text-sm transition-colors" placeholder="اسم المتجر" />
                    <span asp-validation-for="StoreName" class="text-accentRed text-xs mt-1 font-bold"></span>
                </div>

                <!-- Currency Code -->
                <div>
                    <label asp-for="CurrencyCode" class="block text-sm font-bold text-gray-700 mb-1">العملة الافتراضية</label>
                    <div class="relative">
                        <select asp-for="CurrencyCode" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 focus:border-[#0f1419] outline-none text-sm transition-colors bg-white appearance-none cursor-pointer">
                            <option value="">اختر العملة</option>
                            <optgroup label="العملات العربية">
                                <option value="EGP">جنيه مصري (EGP)</option>
                                <option value="SAR">ريال سعودي (SAR)</option>
                                <option value="AED">درهم إماراتي (AED)</option>
                                <option value="KWD">دينار كويتي (KWD)</option>
                                <option value="QAR">ريال قطري (QAR)</option>
                                <option value="BHD">دينار بحريني (BHD)</option>
                                <option value="OMR">ريال عماني (OMR)</option>
                                <option value="JOD">دينار أردني (JOD)</option>
                            </optgroup>
                            <optgroup label="العملات الأجنبية">
                                <option value="USD">دولار أمريكي (USD)</option>
                                <option value="EUR">يورو (EUR)</option>
                                <option value="GBP">جنيه إسترليني (GBP)</option>
                                <option value="CAD">دولار كندي (CAD)</option>
                                <option value="AUD">دولار أسترالي (AUD)</option>
                            </optgroup>
                        </select>
                         <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-500">
                            <i data-lucide="chevron-down" class="w-3 h-3"></i>
                        </div>
                    </div>
                    <span asp-validation-for="CurrencyCode" class="text-accentRed text-xs mt-1 font-bold"></span>
                </div>

                <!-- Password -->
                <div>
                    <label asp-for="Password" class="block text-sm font-bold text-gray-700 mb-1">كلمة المرور</label>
                    <input asp-for="Password" type="password" id="password" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 focus:border-[#0f1419] outline-none text-sm transition-colors" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-accentRed text-xs mt-1 font-bold"></span>
                    <div id="strengthMessage" class="h-1 mt-1 rounded-full bg-border-gray-200 overflow-hidden transition-all duration-300 opacity-0">
                         <div id="strengthBar" class="h-full bg-accentRed w-0 transition-all duration-300"></div>
                    </div>
                    <p id="strengthText" class="text-[10px] mt-0.5 text-right hidden"></p>
                </div>

                <!-- Confirm Password -->
                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-bold text-gray-700 mb-1">تأكيد كلمة المرور</label>
                    <div class="relative">
                        <input asp-for="ConfirmPassword" type="password" id="confirmPassword" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 focus:border-[#0f1419] outline-none text-sm transition-colors" placeholder="••••••••" />
                        <div id="matchIndicator" class="absolute inset-y-0 left-0 pl-3 flex items-center hidden transition-all">
                             <i data-lucide="check-circle" class="text-accentGreen text-lg w-5 h-5"></i>
                        </div>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-accentRed text-xs mt-1 font-bold"></span>
                    <p id="matchText" class="text-[10px] text-accentRed mt-1 font-bold hidden">كلمات المرور غير متطابقة</p>
                </div>
            </div>

            <div class="pt-4">
                <button type="submit" id="btn-submit" class="w-full flex justify-center py-2.5 px-4 rounded-xl text-white bg-[#0f1419] hover:bg-primaryHover font-bold outline-none transition-colors">
                    إنشاء الحساب
                </button>
            </div>

            <div class="text-center">
                <p class="text-sm text-gray-500">
                    لديك حساب بالفعل؟
                    <a asp-action="Login" asp-controller="Auth" class="font-bold text-[#0f1419] hover:text-primaryHover hover:underline transition-colors">
                        تسجيل الدخول
                    </a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            const password = $('#password');
            const confirmPassword = $('#confirmPassword');
            const strengthBar = $('#strengthBar');
            const strengthMessage = $('#strengthMessage');
            const strengthText = $('#strengthText');
            const matchIndicator = $('#matchIndicator');
            const matchText = $('#matchText');
            const phoneNumber = $('#phoneNumber');

            // Password Strength
            password.on('input', function() {
                const val = $(this).val();
                if(val.length > 0) {
                     strengthMessage.removeClass('opacity-0');
                     strengthText.removeClass('hidden');
                } else {
                     strengthMessage.addClass('opacity-0');
                     strengthText.addClass('hidden');
                     return;
                }

                let strength = 0;
                if (val.length >= 6) strength++;
                if (val.match(/[A-z]/)) strength++;
                if (val.match(/[0-9]/)) strength++;
                if (val.match(/[^a-zA-Z0-9]/)) strength++;

                let width = '0%';
                let color = 'bg-accentRed';
                let text = 'ضعيفة';

                switch(strength) {
                    case 1: width = '25%'; color = 'bg-accentRed'; text = 'ضعيفة جداً'; break;
                    case 2: width = '50%'; color = 'bg-accentAmber'; text = 'متوسطة'; break;
                    case 3: width = '75%'; color = 'bg-blue-500'; text = 'جيدة'; break;
                    case 4: width = '100%'; color = 'bg-accentGreen'; text = 'قوية'; break;
                }

                strengthBar.width(width).removeClass('bg-accentRed bg-accentAmber bg-blue-500 bg-accentGreen').addClass(color);
                strengthText.text(text).removeClass('text-accentRed text-accentAmber text-[#0f1419] text-accentGreen');
                if(strength === 1) strengthText.addClass('text-accentRed');
                else if(strength === 2) strengthText.addClass('text-accentAmber');
                else if(strength === 3) strengthText.addClass('text-[#0f1419]');
                else if(strength === 4) strengthText.addClass('text-accentGreen');
                
                checkMatch();
            });

            // Confirm Password Match
            confirmPassword.on('input', checkMatch);

            function checkMatch() {
                const p = password.val();
                const cp = confirmPassword.val();

                if (cp.length > 0) {
                    if (p === cp) {
                         matchIndicator.removeClass('hidden');
                         lucide.createIcons();
                         matchText.addClass('hidden');
                         confirmPassword.removeClass('border-accentRed focus:border-accentRed focus:ring-accentRed').addClass('border-accentGreen focus:border-accentGreen focus:ring-accentGreen');
                    } else {
                         matchIndicator.addClass('hidden');
                         matchText.removeClass('hidden');
                         confirmPassword.removeClass('border-accentGreen focus:border-accentGreen focus:ring-accentGreen').addClass('border-accentRed focus:border-accentRed focus:ring-accentRed');
                    }
                } else {
                    matchIndicator.addClass('hidden');
                    matchText.addClass('hidden');
                    confirmPassword.removeClass('border-accentGreen focus:border-accentGreen focus:ring-accentGreen border-accentRed focus:border-accentRed focus:ring-accentRed');
                }
            }

            // Simple Phone Logic (Allow only numbers)
            phoneNumber.on('input', function() {
                this.value = this.value.replace(/[^0-9]/g, '');
            });

            // Form Submit Loading
            $('form').on('submit', function() {
                if ($(this).valid()) {
                    const btn = $('#btn-submit');
                    const originalText = btn.text();
                    btn.prop('disabled', true);
                    btn.html('<i data-lucide="loader-2" class="animate-spin ml-2 inline-block w-4 h-4"></i> جاري التسجيل...');
                    lucide.createIcons();
                    
                    setTimeout(() => {
                        btn.prop('disabled', false);
                        btn.text(originalText);
                    }, 10000);
                }
            });
        });
    </script>
}
