@model ManageMentSystem.ViewModels.CreateCategoryViewModel
@{
    ViewData["Title"] = "إضافة فئة جديدة";
}

<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
        <i class="fas fa-plus text-indigo-800"></i> إضافة فئة جديدة
    </h1>
    <a asp-action="Index" class="px-6 py-2.5 bg-white border border-slate-200 text-slate-600 rounded-xl font-bold hover:bg-indigo-100 hover:-translate-y-0.5 transition-all shadow-sm flex items-center gap-2">
        العودة للقائمة <i class="fas fa-arrow-left"></i>
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="md:col-span-2">
        <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
                <h5 class="text-lg font-bold text-gray-700">بيانات الفئة</h5>
            </div>
            <div class="p-6">
                <form asp-action="Create" method="post" class="space-y-4">
                    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

                    <div>
                        <label asp-for="Name" class="block text-sm font-bold text-gray-700 mb-1"></label>
                        <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition duration-200" placeholder="أدخل اسم الفئة" />
                        <span asp-validation-for="Name" class="text-red-500 font-bold text-sm mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-1"></label>
                        <textarea asp-for="Description" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition duration-200" placeholder="أدخل وصف الفئة (اختياري)"></textarea>
                        <span asp-validation-for="Description" class="text-red-500 font-bold text-sm mt-1 block"></span>
                    </div>

                    <div class="flex gap-3 pt-2">
                        <button type="submit" class="bg-indigo-800 hover:bg-indigo-900 text-white px-6 py-2 rounded-lg transition duration-200 flex items-center gap-2 shadow-md hover:-translate-y-0.5 transition-all">
                            <i class="fas fa-save"></i> حفظ الفئة
                        </button>
                        <a asp-action="Index" class="border border-gray-300 text-gray-700 hover:text-red-700  hover:bg-red-50 px-6 py-2 rounded-lg transition duration-200 flex items-center gap-2 hover:-translate-y-0.5 transition-all">
                            <i class="fas fa-times"></i> إلغاء
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="md:col-span-1">
        <div class="bg-white rounded-xl shadow-sm border border-indigo-100 overflow-hidden">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
                <h6 class="font-bold text-md text-gray-800">نصائح هامة</h6>
            </div>
            <div class="p-5">
                <ul class="space-y-3">
                    <li class="flex items-start gap-3 text-sm text-gray-600 font-bold">
                        <i class="fas fa-info-circle text-indigo-800 mt-1"></i>
                        <span>اختر اسماً واضحاً ومميزاً للفئة ليسهل البحث عنه لاحقاً.</span>
                    </li>
                    <li class="flex items-start gap-3 text-sm text-gray-600 font-bold">
                        <i class="fas fa-info-circle text-indigo-800 mt-1"></i>
                        <span>أضف وصفاً مفصلاً لسهولة التصنيف وفهم محتوى الفئة.</span>
                    </li>
                    <li class="flex items-start gap-3 text-sm text-gray-600 font-bold">
                        <i class="fas fa-info-circle text-indigo-800 mt-1"></i>
                        <span>يمكنك دائماً تعديل بيانات الفئة أو حذفها إذا لم يتم استخدامها.</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}