@model ManageMentSystem.Models.Category
@{
    ViewData["Title"] = "حذف الفئة";
}

<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
        <i class="fas fa-trash text-red-700"></i> @ViewData["Title"]
    </h1>
    <a asp-action="Index" class="px-6 py-2.5 bg-white border border-slate-200 text-slate-600 rounded-xl font-bold hover:bg-indigo-100 hover:-translate-y-0.5 transition-all shadow-sm flex items-center gap-2">
        العودة للقائمة <i class="fas fa-arrow-left"></i>
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="md:col-span-2">
        <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
            <div class="bg-red-50 px-6 py-4 border-b border-red-100 flex items-center gap-2">
                <i class="fas fa-exclamation-triangle text-red-700 text-xl"></i>
                <h5 class="text-lg font-bold text-red-800">تأكيد الحذف</h5>
            </div>

            <div class="p-6 space-y-6">
                <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 flex gap-4 items-start">
                    <div class="p-2 bg-amber-100 rounded-lg text-amber-600">
                        <i class="fas fa-info-circle text-xl"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-800 text-lg">تحذير!</h4>
                        <p class="text-gray-600 font-bold text-sm mt-1">هذا الإجراء لا يمكن التراجع عنه.</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-gray-50 p-4 rounded-xl border border-gray-100">
                    <div>
                        <label class="block text-sm font-bold text-gray-500 mb-1">اسم الفئة</label>
                        <p class="text-xl font-bold text-gray-800">@Model.Name</p>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-500 mb-1">عدد المنتجات</label>
                        <span class="inline-block px-3 py-1 bg-indigo-100 text-indigo-800 rounded-lg text-sm font-bold border border-indigo-200">
                            @Model.Products.Count منتج
                        </span>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-500 mb-1">الوصف</label>
                        <p class="text-gray-700 font-bold">
                            @(string.IsNullOrEmpty(Model.Description) ? "لا يوجد وصف" : Model.Description)
                        </p>
                    </div>

                    <div >
                        <label class="block text-sm font-bold text-gray-500 mb-1">تاريخ الإنشاء</label>
                        <p class="text-gray-700 font-semibold text-sm">@Model.CreatedAt.ToString("dd/MM/yyyy") <span class="text-gray-700 font-bold text-sm"> في الساعة:</span>  @Model.CreatedAt.ToString("hh:mm tt") </p>
                    </div>
                </div>

                @if (Model.Products.Any())
                {
                    <div class="bg-red-50 border border-red-200 rounded-xl p-4">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="p-2 bg-red-100 rounded-full text-red-700">
                                <i class="fas fa-ban"></i>
                            </div>
                            <div>
                                <h6 class="font-bold text-red-800 text-lg">لا يمكن حذف الفئة!</h6>
                                <p class="text-red-700 text-sm font-bold">يجب نقل أو حذف المنتجات (@Model.Products.Count) المرتبطة بهذه الفئة أولاً.</p>
                            </div>
                        </div>

                        <div class="overflow-hidden rounded-lg border border-red-200 bg-white">
                            <table class="w-full text-right">
                                <thead class="bg-gray-50 text-gray-700 font-bold text-sm">
                                    <tr>
                                        <th class="px-4 py-3">اسم المنتج</th>
                                        <th class="px-4 py-3">الكمية</th>
                                        <th class="px-4 py-3">سعر البيع</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    @foreach (var product in Model.Products.Take(5))
                                    {
                                        <tr class="hover:bg-gray-50 transition-colors">
                                            <td class="px-4 py-3 text-sm font-bold text-gray-800">@product.Name</td>
                                            <td class="px-4 py-3 text-sm font-bold text-gray-600">@product.Quantity</td>
                                            <td class="px-4 py-3 text-sm font-bold text-emerald-700">@product.SalePrice.ToString("C")</td>
                                        </tr>
                                    }
                                    @if (Model.Products.Count > 5)
                                    {
                                        <tr>
                                            <td colspan="3" class="px-4 py-3 text-center text-gray-500 font-bold text-xs bg-gray-50">
                                                ... و @(Model.Products.Count - 5) منتج آخر
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="pt-2">
                        <a asp-action="Index" class="w-full block text-center bg-gray-100 hover:bg-gray-200 text-gray-700 px-6 py-3 rounded-xl font-bold transition duration-200 hover:-translate-y-0.5 transition-all">
                            العودة للقائمة
                        </a>
                    </div>
                }
                else
                {
                    <form asp-action="Delete" method="post" class="flex gap-3 pt-2 border-t border-gray-100">
                        <input type="hidden" asp-for="Id" />

                        <button type="submit" class="bg-red-700 hover:bg-red-800 text-white px-6 py-3 rounded-xl font-bold transition duration-200 flex items-center gap-2 shadow-md hover:shadow-red-500 hover:-translate-y-0.5">
                            <i class="fas fa-trash"></i> تأكيد الحذف
                        </button>

                        <a asp-action="Index" class="border border-gray-300 text-gray-700 hover:text-indigo-800 hover:bg-indigo-50 px-6 py-3 rounded-xl font-bold transition duration-200 flex items-center gap-2 hover:-translate-y-0.5">
                            <i class="fas fa-times"></i> إلغاء
                        </a>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="md:col-span-1">
        <div class="bg-white rounded-xl shadow-sm border border-indigo-100 overflow-hidden">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
                <h6 class="font-bold text-md text-gray-800">بدائل الحذف</h6>
            </div>
            <div class="p-5">
                <ul class="space-y-4 mb-6">
                    <li class="flex items-start gap-3 text-sm text-gray-700 font-bold">
                        <i class="fas fa-edit text-amber-500 mt-1"></i>
                        <span>يمكنك تعديل اسم أو وصف الفئة بدلاً من حذفها.</span>
                    </li>
                    <li class="flex items-start gap-3 text-sm text-gray-700 font-bold">
                        <i class="fas fa-toggle-off text-gray-600 mt-1"></i>
                        <span>يمكنك إلغاء تفعيل الفئة لإخفائها مؤقتاً.</span>
                    </li>
                    <li class="flex items-start gap-3 text-sm text-gray-700 font-bold">
                        <i class="fas fa-exchange-alt text-indigo-800 mt-1"></i>
                        <span>يجب نقل المنتجات لفئة أخرى قبل الحذف.</span>
                    </li>
                </ul>

                <div class="space-y-3">
                    <a href="/Categories/Edit/@Model.Id" class="w-full flex justify-center items-center gap-2 px-4 py-2 bg-indigo-100 hover:bg-indigo-200 text-indigo-800 hover:text-indigo-800 rounded-xl font-bold hover:-translate-y-0.5 transition-all">
                        <i class="fas fa-edit"></i> تعديل الفئة
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>