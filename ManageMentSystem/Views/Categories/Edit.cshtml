@model ManageMentSystem.ViewModels.EditCategoryViewModel
@{
    ViewData["Title"] = "تعديل الفئة";
}

<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
        <i class="fas fa-edit text-indigo-800"></i> @ViewData["Title"]
    </h1>
    <a asp-action="Index" class="px-6 py-2.5 bg-white border border-slate-200 text-slate-600 rounded-xl font-bold hover:bg-indigo-100 hover:-translate-y-0.5 transition-all shadow-sm flex items-center gap-2">
        العودة للقائمة <i class="fas fa-arrow-left"></i>
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="md:col-span-2">
        <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
                <h5 class="text-lg font-bold text-gray-700">بيانات الفئة</h5>
            </div>
            <div class="p-6">
                <form asp-action="Edit" method="post" class="space-y-5">
                    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
                    <input type="hidden" asp-for="Id" />

                    <div>
                        <label asp-for="Name" class="block text-sm font-bold text-gray-700 mb-1"></label>
                        <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition duration-200" placeholder="أدخل اسم الفئة" />
                        <span asp-validation-for="Name" class="text-red-500 text-sm mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-1"></label>
                        <textarea asp-for="Description" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition duration-200" placeholder="أدخل وصف الفئة (اختياري)"></textarea>
                        <span asp-validation-for="Description" class="text-red-500 text-sm mt-1 block"></span>
                    </div>

                    <div class="flex items-center p-3 border border-gray-200 rounded-lg bg-gray-50 hover:bg-gray-100 transition cursor-pointer">
                        <div class="flex items-center h-5">
                            <input asp-for="IsActive" type="checkbox" class="w-5 h-5 text-indigo-800 border-gray-300 rounded focus:ring-indigo-900" />
                        </div>
                        <div class="mr-3 text-sm">
                            <label asp-for="IsActive" class="font-medium text-gray-700 select-none cursor-pointer"></label>
                            <p class="text-gray-500 text-xs">تحديد هذا الخيار يجعل الفئة مرئية للعملاء</p>
                        </div>
                    </div>

                    <div class="flex gap-3 pt-2 border-t border-gray-100 mt-4">
                        <button type="submit" class="bg-indigo-800 hover:bg-indigo-900 text-white px-6 py-2 rounded-lg transition duration-200 flex items-center gap-2 shadow-md hover:-translate-y-0.5 transition-all">
                            <i class="fas fa-save"></i> حفظ التغييرات
                        </button>
                        <a asp-action="Index" class="border border-gray-300 text-gray-700 hover:text-red-700  hover:bg-red-50 px-6 py-2 rounded-lg transition duration-200 flex items-center gap-2 hover:-translate-y-0.5 transition-all">
                            <i class="fas fa-times"></i> إلغاء
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="md:col-span-1">
        <div class="bg-white rounded-xl shadow-sm border border-indigo-100 overflow-hidden">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
                <h6 class="font-bold text-gray-800">معلومات هامة</h6>
            </div>
            <div class="p-5">
                <ul class="space-y-4">
                    <li class="flex items-start gap-3 text-sm text-gray-600 font-bold">
                        <i class="fas fa-info-circle text-indigo-800 mt-1 flex-shrink-0"></i>
                        <span>تغيير الحالة إلى <span class="font-bold text-red-500">غير نشط</span> سيخفي الفئة وجميع منتجاتها من واجهة المتجر.</span>
                    </li>
                    <li class="flex items-start gap-3 text-sm text-gray-600 font-bold">
                        <i class="fas fa-exclamation-triangle text-amber-500 mt-1 flex-shrink-0"></i>
                        <span>لا يمكنك حذف الفئة إذا كانت تحتوي على منتجات، ولكن يمكنك إلغاء تفعيلها بدلاً من ذلك.</span>
                    </li>
                    <li class="flex items-start gap-3 text-sm text-gray-600 font-bold">
                        <i class="fas fa-check-circle text-emerald-700 mt-1 flex-shrink-0"></i>
                        <span>يمكنك إعادة تفعيل الفئة في أي وقت لتعود للظهور فوراً.</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}