@model ManageMentSystem.ViewModels.EditCategoryViewModel
@{
    ViewData["Title"] = "تعديل الفئة";
}

<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
        <i data-lucide="edit" class="text-primary w-6 h-6"></i> @ViewData["Title"]
    </h1>
    <a asp-action="Index" class="zen-btn zen-btn-neutral">
        العودة للقائمة <i data-lucide="arrow-left" class="w-4 h-4"></i>
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="md:col-span-2">
        <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-200">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
                <h5 class="text-lg font-bold text-gray-700">بيانات الفئة</h5>
            </div>
            <div class="p-6">
                <form asp-action="Edit" method="post" class="space-y-5">
                    <div asp-validation-summary="ModelOnly" class="text-accentRed text-sm"></div>
                    <input type="hidden" asp-for="Id" />

                    <div>
                        <label asp-for="Name" class="block text-sm font-bold text-gray-700 mb-1"></label>
                        <input asp-for="Name" class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-1 focus:ring-primary/20 focus:border-primary outline-none transition duration-200" placeholder="أدخل اسم الفئة" />
                        <span asp-validation-for="Name" class="text-accentRed text-sm mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-1"></label>
                        <textarea asp-for="Description" rows="3" class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-1 focus:ring-primary/20 focus:border-primary outline-none transition duration-200" placeholder="أدخل وصف الفئة (اختياري)"></textarea>
                        <span asp-validation-for="Description" class="text-accentRed text-sm mt-1 block"></span>
                    </div>

                    <div class="flex items-center p-3 border border-gray-200 rounded-lg bg-gray-50 hover:bg-gray-50 transition cursor-pointer">
                        <div class="flex items-center h-5">
                            <input asp-for="IsActive" type="checkbox" class="w-5 h-5 text-primary border-gray-200 rounded focus:ring-primary/20" />
                        </div>
                        <div class="mr-3 text-sm">
                            <label asp-for="IsActive" class="font-medium text-gray-700 select-none cursor-pointer"></label>
                            <p class="text-gray-500 text-xs">تحديد هذا الخيار يجعل الفئة مرئية للعملاء</p>
                        </div>
                    </div>

                    <div class="flex gap-3 pt-2 border-t border-gray-200 mt-4">
                        <button type="submit" class="zen-btn zen-btn-primary">
                            <i data-lucide="save" class="w-4 h-4"></i> حفظ التغييرات
                        </button>
                        <a asp-action="Index" class="zen-btn zen-btn-neutral">
                            <i data-lucide="x" class="w-4 h-4"></i> إلغاء
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="md:col-span-1">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
                <h6 class="font-bold text-gray-800">معلومات هامة</h6>
            </div>
            <div class="p-5">
                <ul class="space-y-4">
                    <li class="flex items-start gap-3 text-sm text-gray-600 font-bold">
                        <i data-lucide="info" class="text-primary mt-1 flex-shrink-0 w-4 h-4"></i>
                        <span>تغيير الحالة إلى <span class="font-bold text-accentRed">غير نشط</span> سيخفي الفئة وجميع منتجاتها من واجهة المتجر.</span>
                    </li>
                    <li class="flex items-start gap-3 text-sm text-gray-600 font-bold">
                        <i data-lucide="alert-triangle" class="text-amber-500 mt-1 flex-shrink-0 w-4 h-4"></i>
                        <span>لا يمكنك حذف الفئة إذا كانت تحتوي على منتجات، ولكن يمكنك إلغاء تفعيلها بدلاً من ذلك.</span>
                    </li>
                    <li class="flex items-start gap-3 text-sm text-gray-600 font-bold">
                        <i data-lucide="check-circle" class="text-accentGreen mt-1 flex-shrink-0 w-4 h-4"></i>
                        <span>يمكنك إعادة تفعيل الفئة في أي وقت لتعود للظهور فوراً.</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
