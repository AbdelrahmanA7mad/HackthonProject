@using ManageMentSystem.Helpers
@using ManageMentSystem.Models
@inject ManageMentSystem.Services.UserServices.IUserService UserService
@model IEnumerable<ManageMentSystem.Models.Category>
@{
    ViewData["Title"] = "إدارة الفئات";
}

<div class="min-h-screen bg-[#f8f9fc] p-6 md:p-8 space-y-8" dir="rtl">

    <div class="space-y-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="flex items-center p-4 mb-4 text-accentGreen rounded-2xl bg-emerald-50 border border-emerald-100 shadow-sm" role="alert">
                <i data-lucide="check-circle" class="ml-3 text-xl"></i>
                <div class="ml-auto font-medium">
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="mr-2 text-accentGreen hover:bg-emerald-200 rounded-lg p-1.5 inline-flex h-8 w-8 items-center justify-center transition-colors" data-bs-dismiss="alert" aria-label="Close">
                    <i data-lucide="x"></i>
                </button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="flex items-center p-4 mb-4 text-red-800 rounded-2xl bg-red-50 border border-red-100 shadow-sm" role="alert">
                <i data-lucide="alert-circle" class="ml-3 text-xl"></i>
                <div class="ml-auto font-medium">
                    @TempData["ErrorMessage"]
                </div>
                <button type="button" class="mr-2 text-red-600 hover:bg-red-200 rounded-lg p-1.5 inline-flex h-8 w-8 items-center justify-center transition-colors" data-bs-dismiss="alert" aria-label="Close">
                    <i data-lucide="x"></i>
                </button>
            </div>
        }
    </div>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 m-0">
        <div>
            <h1 class="text-2xl font-bold text-[#0f1419] flex items-center gap-3">
                <span class="p-2 bg-gray-50 rounded-xl text-[#0f1419]">
                    <i data-lucide="tags"></i>
                </span>
                @ViewData["Title"]
            </h1>
            <p class="text-gray-500 mt-1 mr-12 text-sm font-medium">عرض وإدارة تصنيفات المنتجات</p>
        </div>

   
            <button onclick="openCreateModal()" class="flex items-center justify-center px-4 py-2.5 text-sm font-bold text-white bg-[#0f1419] hover:bg-primaryHover rounded-xl shadow-sm shadow-gray-200 transition-all duration-200 gap-2 whitespace-nowrap hover:-translate-y-0.5">
                <i data-lucide="plus"></i>
                <span>إضافة فئة جديدة</span>
            </button>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-5 border-b border-gray-200 bg-gray-50/50">
            <h5 class="font-bold text-gray-600 flex items-center gap-2">
                <i data-lucide="list" class="text-[#0f1419]"></i>
                قائمة الفئات
            </h5>
        </div>

        <div class="w-full max-w-full overflow-x-auto">
            @if (Model.Any())
            {
                <table class="w-full text-right" id="categoriesTable">
                    <thead class="bg-gray-50 text-gray-500 text-sm uppercase font-bold">
                        <tr>
                            <th class="px-6 py-4 rounded-tr-lg">اسم الفئة</th>
                            <th class="px-6 py-4">الوصف</th>
                            <th class="px-6 py-4">عدد المنتجات</th>
                            <th class="px-6 py-4">الحالة</th>
                            <th class="px-6 py-4">تاريخ الإنشاء</th>
                            <th class="px-6 py-4 rounded-tl-lg text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 text-sm">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50/80 transition-colors duration-150">
                                <td class="px-6 py-4 font-bold text-gray-600">@item.Name</td>
                                <td class="px-6 py-4 text-gray-500 max-w-xs truncate">
                                    @(string.IsNullOrEmpty(item.Description) ? "-" : item.Description)
                                </td>
                                <td class="px-6 py-4">
                                    <span class="bg-gray-50 text-[#0f1419] px-2.5 py-1 rounded-full text-xs font-bold border border-gray-200">
                                        @item.Products.Count منتج
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.IsActive)
                                    {
                                        <div class="flex items-center gap-1.5 text-accentGreen bg-emerald-50 px-2.5 py-1 rounded-full w-fit border border-emerald-100 text-sm font-bold">
                                            <span class="w-1.5 h-1.5 rounded-full bg-accentGreen"></span>
                                            نشط
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="flex items-center gap-1.5 text-accentRed bg-red-100 px-2.5 py-1 rounded-full w-fit border border-red-200 text-sm font-bold">
                                            <span class="w-1.5 h-1.5 rounded-full bg-red-700"></span>
                                            غير نشط
                                        </div>
                                    }
                                </td>
                                <td class="px-6 py-4 text-gray-500 text-sm font-semibold">@item.CreatedAt.ToShortDateString()</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-1">
                                        <a asp-controller="Products" asp-action="ByCategory" asp-route-categoryId="@item.Id"
                                           class="p-2 text-accentGreen hover:text-accentGreen hover:bg-emerald-50 rounded-lg transition-colors" title="عرض المنتجات">
                                            <i data-lucide="eye" class="w-4 h-4"></i>
                                        </a>

                                   
                                            <button onclick="openEditModal(@item.Id)" class="p-2 text-[#0f1419] hover:bg-gray-50 rounded-lg transition-colors" title="تعديل">
                                                <i data-lucide="edit" class="w-4 h-4"></i>
                                            </button>
                                            <button onclick="deleteCategory(@item.Id)" class="p-2 text-accentRed hover:text-accentRed hover:bg-red-50 rounded-lg transition-colors" title="حذف">
                                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                                            </button>
                                        
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="p-4 border-t border-gray-200 bg-gray-50/50 flex flex-col md:flex-row justify-between items-center gap-4">
                   <p class="text-sm text-gray-500">
                        عرض <span class="font-bold text-[#0f1419]">@((ViewBag.CurrentPage - 1) * ViewBag.PageSize + 1)</span> إلى <span class="font-bold text-[#0f1419]">@Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems)</span> من أصل <span class="font-bold text-[#0f1419]">@ViewBag.TotalItems</span> فئة
                    </p>

                    @if (ViewBag.TotalPages > 1)
                    {
                        <nav aria-label="Pagination">
                            <ul class="flex items-center gap-1">
                                <li>
                                    @if (ViewBag.HasPreviousPage)
                                    {
                                        <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })"
                                           class="flex items-center justify-center w-8 h-8 rounded-lg border border-gray-200 bg-white text-gray-500 hover:bg-gray-50 hover:text-[#0f1419] hover:border-gray-200 transition-all">
                                            <i data-lucide="chevron-right" class="w-4 h-4"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="flex items-center justify-center w-8 h-8 rounded-lg border border-gray-200 bg-gray-50 text-gray-300 cursor-not-allowed">
                                            <i data-lucide="chevron-right" class="w-4 h-4"></i>
                                        </span>
                                    }
                                </li>

                                @{
                                    int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                                    int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                                }

                                @if (startPage > 1)
                                {
                                    <li>
                                        <a href="@Url.Action("Index", new { page = 1, pageSize = ViewBag.PageSize })" class="flex items-center justify-center w-8 h-8 rounded-lg border border-gray-200 bg-white text-gray-500 hover:bg-gray-50 hover:text-[#0f1419] text-sm font-medium">1</a>
                                    </li>
                                    @if (startPage > 2)
                                    {
                                        <li class="px-1 text-gray-500">...</li>
                                    }
                                }

                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    <li>
                                        <a href="@Url.Action("Index", new { page = i, pageSize = ViewBag.PageSize })"
                                           class="flex items-center justify-center w-8 h-8 rounded-lg border text-sm font-bold transition-all @(i == ViewBag.CurrentPage ? "bg-[#0f1419] border-gray-200 text-white shadow-sm shadow-gray-200" : "border-gray-200 bg-white text-gray-500 hover:bg-gray-50 hover:text-[#0f1419]")">
                                            @i
                                        </a>
                                    </li>
                                }

                                @if (endPage < ViewBag.TotalPages)
                                {
                                    @if (endPage < ViewBag.TotalPages - 1)
                                    {
                                        <li class="px-1 text-gray-500">...</li>
                                    }
                                    <li>
                                        <a href="@Url.Action("Index", new { page = ViewBag.TotalPages, pageSize = ViewBag.PageSize })" class="flex items-center justify-center w-8 h-8 rounded-lg border border-gray-200 bg-white text-gray-500 hover:bg-gray-50 hover:text-[#0f1419] text-sm font-medium">@ViewBag.TotalPages</a>
                                    </li>
                                }

                                <li>
                                    @if (ViewBag.HasNextPage)
                                    {
                                        <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })"
                                           class="flex items-center justify-center w-8 h-8 rounded-lg border border-gray-200 bg-white text-gray-500 hover:bg-gray-50 hover:text-[#0f1419] hover:border-gray-200 transition-all">
                                            <i data-lucide="chevron-left" class="w-4 h-4"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="flex items-center justify-center w-8 h-8 rounded-lg border border-gray-200 bg-gray-50 text-gray-300 cursor-not-allowed">
                                            <i data-lucide="chevron-left" class="w-4 h-4"></i>
                                        </span>
                                    }
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-16 text-gray-500">
                    <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                        <i data-lucide="tags" class="text-4xl text-gray-300 w-12 h-12"></i>
                    </div>
                    <h5 class="text-lg font-bold text-gray-500">لا توجد فئات</h5>
                    <p class="text-sm">ابدأ بإضافة فئة جديدة للمنتجات</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal for Create/Edit Category -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-2xl border-0 shadow-lg overflow-hidden">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex justify-between items-center">
                <h5 class="text-lg font-bold text-gray-800" id="categoryModalLabel">إضافة فئة جديدة</h5>
                <button type="button" class="text-gray-500 hover:text-accentRed transition-colors" data-bs-dismiss="modal" aria-label="Close">
                    <i data-lucide="x" class="text-xl"></i>
                </button>
            </div>
            <form id="categoryForm" method="post" class="p-6 space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" id="categoryId" name="Id" value="0">
                
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">اسم الفئة <span class="text-accentRed">*</span></label>
                    <input type="text" id="categoryName" name="Name" required class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-1 focus:ring-[#0f1419] focus:border-[#0f1419] outline-none transition-all" placeholder="ادخل اسم الفئة">
                </div>
                
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">الوصف</label>
                    <textarea id="categoryDescription" name="Description" class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-1 focus:ring-[#0f1419] focus:border-[#0f1419] outline-none transition-all" rows="3" placeholder="وصف اختياري للفئة"></textarea>
                </div>
                
                <div class="flex items-center gap-2">
                    <input type="checkbox" id="categoryIsActive" name="IsActive" value="true" class="w-5 h-5 text-[#0f1419] rounded focus:ring-[#0f1419] border-gray-200" checked>
                    <label for="categoryIsActive" class="text-sm font-bold text-gray-700 select-none">نشط</label>
                    <input type="hidden" name="IsActive" value="false" />
                </div>

                <div class="flex gap-3 pt-4 border-t border-gray-200 mt-4">
                    <button type="button" class="flex-1 py-2.5 border border-gray-200 text-gray-700 hover:text-accentRed rounded-xl font-bold hover:bg-red-50 hover:-translate-y-0.5 transition-all" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" id="saveBtn" class="flex-1 py-2.5 bg-[#0f1419] text-white rounded-xl font-bold hover:bg-primaryHover shadow-md hover:-translate-y-0.5 transition-all">حفظ الفئة</button>
                </div>
            </form>
        </div>
    </div>
</div>

<form id="deleteCategoryForm" method="post" style="display: none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        // Open Modal for Create
        function openCreateModal() {
            $('#categoryModalLabel').text('إضافة فئة جديدة');
            $('#categoryForm')[0].reset();
            $('#categoryId').val(0);
            $('#categoryIsActive').prop('checked', true); // Default to active
            $('#categoryModal').modal('show');
        }

        // Open Modal for Edit
        function openEditModal(id) {
            // Loading is fast enough that we don't need a full screen blocker for this
            
            $.get('/Categories/Edit/' + id, function(data) {
                // closeSwal();
                $('#categoryModalLabel').text('تعديل الفئة');
                $('#categoryId').val(data.id);
                $('#categoryName').val(data.name);
                $('#categoryDescription').val(data.description);
                $('#categoryIsActive').prop('checked', data.isActive);
                $('#categoryModal').modal('show');
            }).fail(function() {
                showError('خطأ', 'حدث خطأ أثناء تحميل بيانات الفئة');
            });
        }

        // Handle Form Submission
        $('#categoryForm').on('submit', function(e) {
            e.preventDefault();
            
            // Basic Validation
            if (!$('#categoryName').val().trim()) {
                showWarning('بيانات ناقصة', 'يرجى إدخال اسم الفئة');
                return;
            }

            var id = $('#categoryId').val();
            var url = id == 0 ? '@Url.Action("Create", "Categories")' : '@Url.Action("Edit", "Categories")/' + id;
            var isEdit = id != 0;

            // Loading State
            var btn = $('#saveBtn');
            var originalText = btn.text();
            btn.prop('disabled', true).html('<i data-lucide="loader-2" class="animate-spin ml-2 inline-block"></i> جارٍ الحفظ...');
            lucide.createIcons();

            $.ajax({
                url: url,
                type: 'POST',
                data: $(this).serialize(),
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                success: function(result) {
                    if (result.success) {
                        $('#categoryModal').modal('hide');
                        showSuccess(
                            isEdit ? 'تم التعديل' : 'تم الحفظ', 
                            result.message
                        ).then(() => location.reload());
                    } else {
                        showError('خطأ', result.message);
                        btn.prop('disabled', false).text(originalText);
                    }
                },
                error: function() {
                    showError('خطأ', 'حدث خطأ أثناء الاتصال بالخادم');
                    btn.prop('disabled', false).text(originalText);
                }
            });
        });

        // Delete Category
        function deleteCategory(id) {
            showDangerConfirm(
                'تأكيد الحذف',
                'هل أنت متأكد من حذف هذه الفئة؟ لا يمكن التراجع عن هذا الإجراء.',
                'نعم، احذف',
                'إلغاء'
            ).then((result) => {
                if (result.isConfirmed) {
                    showLoading('جاري الحذف...', 'يرجى الانتظار');

                    $('#deleteCategoryForm').attr('action', '@Url.Action("Delete", "Categories")/' + id);

                    $.ajax({
                        url: $('#deleteCategoryForm').attr('action'),
                        type: 'POST',
                        data: $('#deleteCategoryForm').serialize(),
                        success: function(result) {
                            if (result.success) {
                                showSuccess('تم الحذف', result.message).then(() => location.reload());
                            } else {
                                showError('خطأ', result.message);
                            }
                        },
                        error: function() {
                             showError('خطأ', 'حدث خطأ أثناء الحذف');
                        }
                    });
                }
            });
        }
    </script>
}
