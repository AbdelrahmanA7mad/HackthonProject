هذا تحديث شامل لصفحة Print / Statement (كشف الحساب).
بما أن هذه الصفحة مخصصة للطباعة (Layout = null)، فقد قمت بما يلي:
 * تضمين Tailwind CSS عبر CDN مباشرة لضمان ظهور التنسيقات.
 * تصميم هجين (Hybrid): يبدو عصرياً وجذاباً عند عرضه على الشاشة (بألوان الـ Indigo)، ويتحول تلقائياً إلى تصميم نظيف واحترافي (أبيض وأسود عالي التباين) عند الطباعة.
 * إضافة زر طباعة يظهر فقط على الشاشة ويختفي في الورقة.
<!-- end list -->
@model ManageMentSystem.ViewModels.CustomerFullAccountViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>كشف حساب - @Model.CustomerName</title>

    <link href="~/css/cairo-font.css" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Cairo', 'sans-serif'],
                    },
                    colors: {
                        indigo: {
                            50: '#eef2ff',
                            100: '#e0e7ff',
                            600: '#0f1419',
                            800: '#3730a3',
                            900: '#312e81',
                        }
                    }
                }
            }
        }
    </script>

    <style>
        /* تخصيصات الطباعة */
        @@media print {
            body

        {
            background-color: white !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        .no-print {
            display: none !important;
        }

        .invoice-container {
            box-shadow: none !important;
            border: none !important;
            margin: 0 !important;
            padding: 0 !important;
            max-width: 100% !important;
        }
        /* إجبار الخلفيات الملونة على الظهور بشكل خفيف لتوفير الحبر ولكن الحفاظ على التباين */
        .bg-gray-50 {
            background-color: #f3f4f6 !important;
        }

        .bg-[#0f1419] {
            background-color: #333 !important;
            color: white !important;
        }

        .bg-gray-50 {
            background-color: #f9fafb !important;
        }

        /* تحسين الحدود */
        .border-gray-200, .border-gray-200 {
            border-color: #e5e7eb !important;
        }

        /* إجبار الجدول على عدم الانقسام */
        tr {
            page-break-inside: avoid;
        }

        }

        /* تنسيقات عامة */
        body {
            font-family: 'Cairo', sans-serif;
        }
    </style>
</head>
<body class="bg-gray-100 text-gray-800 min-h-screen p-4 md:p-8">

    <div class="no-print fixed bottom-8 left-8 z-50 flex gap-2">
        <button onclick="window.print()" class="bg-[#0f1419] hover:bg-[#0f1419] text-white px-6 py-3 rounded-full shadow-lg font-bold flex items-center gap-2 transition-transform hover:-translate-y-1">
            <i data-lucide="print" class="w-5 h-5"></i> طباعة الكشف
        </button>
        <button onclick="window.history.back()" class="bg-white hover:bg-gray-50 text-gray-700 px-6 py-3 rounded-full shadow-lg font-bold flex items-center gap-2 transition-transform hover:-translate-y-1 border border-gray-200">
            <i data-lucide="arrow-right" class="w-5 h-5"></i> رجوع
        </button>
    </div>

    <div class="invoice-container max-w-[210mm] mx-auto bg-white rounded-2xl shadow-xl overflow-hidden">

        <div class="bg-gray-50 p-8 border-b border-gray-200">
            <div class="flex justify-between items-start">
                <div>
                    <h1 class="text-3xl font-bold text-[#0f1419] mb-1">
                        @(string.IsNullOrWhiteSpace(Model.CompanyName) ? "كشف حساب عميل" : Model.CompanyName)
                    </h1>
                    @if (!string.IsNullOrEmpty(Model.CompanySubtitle))
                    {
                        <p class="text-[#0f1419] font-medium opacity-80">@Model.CompanySubtitle</p>
                    }
                </div>
                <div class="text-left">
                    <div class="bg-white px-4 py-2 rounded-lg border border-gray-200 shadow-sm inline-block text-center">
                        <p class="text-xs text-gray-500 font-bold uppercase tracking-wider">تاريخ الإصدار</p>
                        <p class="text-lg font-bold text-[#0f1419] dir-ltr">@DateTime.Now.ToString("yyyy-MM-dd")</p>
                    </div>
                </div>
            </div>

            <div class="mt-8 flex flex-col md:flex-row justify-between bg-white p-4 rounded-xl border border-gray-200 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center text-[#0f1419] text-xl">
                        <i data-lucide="user" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 font-bold">السيد / السادة</p>
                        <h2 class="text-xl font-bold text-gray-800">@Model.CustomerName</h2>
                    </div>
                </div>
                <div class="mt-4 md:mt-0 flex items-center gap-6">
                    <div>
                        <p class="text-xs text-gray-500 font-bold">رقم الهاتف</p>
                        <p class="text-lg font-bold text-gray-800 dir-ltr">@(Model.CustomerPhone ?? "-")</p>
                    </div>
                    <div class="w-px h-8 bg-gray-200"></div>
                    <div>
                        <p class="text-xs text-gray-500 font-bold">عدد العمليات</p>
                        <p class="text-lg font-bold text-gray-800">@Model.TotalItems</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="p-8 pb-0">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="p-4 bg-gray-50 rounded-xl border border-gray-200">
                    <p class="text-xs font-bold text-gray-500 mb-1">إجمالي المبيعات</p>
                    <p class="text-xl font-bold text-[#0f1419]">@Model.TotalSalesAmount.ToString("C")</p>
                </div>
                <div class="p-4 bg-gray-50 rounded-xl border border-gray-200">
                    <p class="text-xs font-bold text-gray-500 mb-1">إجمالي المرتجعات</p>
                    <p class="text-xl font-bold text-amber-600">@Model.TotalReturnsAmount.ToString("C")</p>
                </div>
                <div class="p-4 bg-gray-50 rounded-xl border border-gray-200">
                    <p class="text-xs font-bold text-gray-500 mb-1">صافي المدفوع</p>
                    <p class="text-xl font-bold text-accentGreen">@Model.NetSalesAmount.ToString("C")</p>
                </div>
                <div class="p-4 bg-black rounded-xl text-white shadow-md">
                    <p class="text-xs font-bold text-gray-500 mb-1">الرصيد المتبقي</p>
                    <p class="text-2xl font-bold">@Model.Balance.ToString("C")</p>
                </div>
            </div>
        </div>

        <div class="p-8">
            <div class="border border-gray-200 rounded-lg overflow-hidden">
                <table class="w-full text-right text-sm">
                    <thead class="bg-gray-100 text-gray-700 font-bold border-b border-gray-200">
                        <tr>
                            <th class="px-4 py-3 text-center">التاريخ</th>
                            <th class="px-4 py-3 text-center">النوع</th>
                            <th class="px-4 py-3">البيان / طريقة الدفع</th>
                            <th class="px-4 py-3 text-left">المبلغ</th>
                            <th class="px-4 py-3 text-left bg-gray-50">تراكمي فواتير</th>
                            <th class="px-4 py-3 text-left bg-gray-50">تراكمي مدفوع</th>
                            <th class="px-4 py-3 text-left font-extrabold text-gray-900">الرصيد</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var e in Model.Entries)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-4 py-3 text-center font-mono text-gray-600">@e.Date.ToString("yyyy-MM-dd")</td>
                                <td class="px-4 py-3 text-center">
                                    <span class="inline-block px-2 py-0.5 rounded text-xs font-bold border
                                            @(e.Type == "دفعة" ? "bg-gray-50 text-accentGreen border-gray-200" :
                                                                                    e.Type == "مرتجع" ? "bg-red-50 text-accentRed border-red-100" :
                                                                                              "bg-gray-50 text-[#0f1419] border-gray-200")">
                                    @e.Type
                                </span>
                            </td>
                            <td class="px-4 py-3 text-gray-700">
                                @(e.PaymentMethodName ?? e.SalePaymentTypeName ?? "-")
                            </td>
                            <td class="px-4 py-3 text-left font-bold text-gray-800">
                                @e.Amount.ToString("C")
                            </td>
                            <td class="px-4 py-3 text-left text-gray-500 bg-gray-50 font-mono">
                                @e.RunningSales.ToString("C")
                            </td>
                            <td class="px-4 py-3 text-left text-gray-500 bg-gray-50 font-mono">
                                @e.RunningPaid.ToString("C")
                            </td>
                            <td class="px-4 py-3 text-left font-bold font-mono @(e.RunningBalance > 0 ? "text-accentRed" : "text-accentGreen")">
                                @e.RunningBalance.ToString("C")
                            </td>
                        </tr>
                                                }
                    </tbody>
                    <tfoot class="bg-gray-50 border-t-2 border-gray-200 font-bold">
                        <tr>
                            <td colspan="6" class="px-4 py-3 text-left text-gray-600">الرصيد النهائي المستحق:</td>
                            <td class="px-4 py-3 text-left text-lg text-[#0f1419]">@Model.Balance.ToString("C")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="bg-gray-50 p-8 border-t border-gray-200 text-center text-sm text-gray-500">
            @if (!string.IsNullOrEmpty(Model.FooterMessage))
            {
                <p class="font-bold text-gray-700 mb-2">@Model.FooterMessage</p>
            }

            <div class="flex flex-wrap justify-center gap-4 md:gap-8 mt-4">
                @if (!string.IsNullOrEmpty(Model.Address))
                {
                    <div class="flex items-center gap-2">
                        <i data-lucide="map-pin" class="text-[#0f1419] w-4 h-4"></i>
                        <span>@Model.Address</span>
                    </div>
                }
                @if (Model.PhoneNumbers != null && Model.PhoneNumbers.Any())
                {
                    <div class="flex items-center gap-2">
                        <i data-lucide="phone" class="text-[#0f1419] w-4 h-4"></i>
                        <span>@string.Join(" - ", Model.PhoneNumbers)</span>
                    </div>
                }
            </div>

            <div class="mt-6 pt-4 border-t border-gray-200 flex justify-between items-center text-xs text-gray-500">
                <span>تم استخراج هذا المستند آلياً من النظام</span>
                <span>الصفحة @Model.CurrentPage من @Model.TotalPages</span>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
        // الطباعة التلقائية عند التحميل (اختياري)
        window.onload = function () {
            // Uncomment the line below if you want auto-print
            // setTimeout(function(){ window.print(); }, 500);
        };
    </script>
</body>
</html>
