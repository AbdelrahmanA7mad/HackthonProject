@model IEnumerable<ManageMentSystem.Models.Customer>
@using ManageMentSystem.Helpers
@using ManageMentSystem.Models
@inject ManageMentSystem.Services.UserServices.IUserService UserService
@{
    ViewData["Title"] = "العملاء";
}

<div class="min-h-screen bg-gray-50/50 p-6">

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
                <i class="fas fa-users text-indigo-800 "></i> إدارة العملاء
            </h1>
            <p class="text-sm text-gray-500 font-bold mt-1 pt-2">عرض وإدارة قائمة العملاء</p>
        </div>

        <div class="flex flex-wrap gap-3">
            
                <a href="@Url.Action("SendBulkWhatsapp", "Customers")" class="bg-emerald-700 hover:bg-emerald-800 text-white px-4 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:-translate-y-0.5 flex items-center gap-2">
                    <i class="fab fa-whatsapp text-lg"></i> رسائل جماعية
                </a>

            <a href="@Url.Action("TopCustomers", "Customers")" class="bg-amber-600 hover:bg-amber-700 text-white px-4 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:-translate-y-0.5 flex items-center gap-2">
                <i class="fas fa-trophy"></i> أفضل العملاء
            </a>

           
                <button type="button" data-bs-toggle="modal" data-bs-target="#addCustomerModal" class="bg-indigo-800 hover:bg-indigo-900 text-white px-4 py-2.5 rounded-xl font-bold transition-all shadow-md hover:shadow-indigo-200 hover:-translate-y-0.5 flex items-center gap-2">
                    <i class="fas fa-plus"></i> إضافة عميل
                </button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="md:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 p-2 self-start">
            <form method="get" action="@Url.Action("Index", "Customers")" class="flex gap-2 p-2">
                <div class="relative flex-grow">
                    <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                           class="w-full pl-4 pr-10 py-2.5 border border-gray-200 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all font-bold text-gray-700 placeholder-gray-400"
                           placeholder="ابحث بالاسم، الهاتف، أو العنوان...">
                    <i class="fas fa-search absolute left-3 top-3.5 text-gray-400"></i>
                </div>
                <button type="submit" class="bg-indigo-50 text-indigo-800 hover:bg-indigo-100 px-6 rounded-lg font-bold transition-colors border border-indigo-100">
                    بحث
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                {
                    <a href="@Url.Action("Index", "Customers")" class="bg-gray-100 text-gray-600 hover:bg-gray-200 px-4 rounded-lg font-bold transition-colors flex items-center justify-center border border-gray-200">
                        <i class="fas fa-times"></i>
                    </a>
                }
            </form>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-1 px-2 flex items-center justify-between relative overflow-hidden">
            <div class="relative z-10">
                <p class="text-sm font-bold text-gray-700 my-1 mx-2">إجمالي العملاء</p>
                <h2 class="text-xl font-bold my-1 mx-2 text-indigo-800 ">@ViewBag.TotalCount</h2>
            </div>
            <div class="p-3 bg-indigo-50 rounded-xl text-indigo-800 my-1 ml-2 relative z-10">
                <i class="fas fa-users text-lg"></i>
            </div>
            <div class="absolute -left-4 -bottom-4 w-24 h-24 bg-indigo-50 rounded-full opacity-50 z-0"></div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-100 flex justify-between items-center">
            <h6 class="font-bold text-gray-800">قائمة العملاء المسجلين</h6>
            <a href="#" onclick="exportToExcel(event)" class="bg-emerald-700 hover:bg-emerald-800 text-white px-4 py-2 rounded-xl font-bold transition-all shadow-sm hover:-translate-y-0.5 flex items-center gap-2 text-sm">
                <i class="fas fa-file-excel"></i> تصدير Excel
            </a>
        </div>

        @if (Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-right" id="customersTable">
                    <thead>
                        <tr class="bg-gray-200/50 text-gray-900 border-b border-gray-400">
                            <th class="px-6 py-4 font-bold text-sm">الاسم الكامل</th>
                            <th class="px-6 py-4 font-bold text-sm">رقم الهاتف</th>
                            <th class="px-6 py-4 font-bold text-sm">العنوان</th>
                            <th class="px-6 py-4 font-bold text-sm">عدد المبيعات</th>
                            <th class="px-6 py-4 font-bold text-sm text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition-colors group">
                                <td class="px-6 py-4 font-bold text-gray-800">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-800 flex items-center justify-center font-bold text-xs">
                                            @item.FullName.Substring(0, 1)
                                        </div>
                                        @item.FullName
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <a href="tel:@item.PhoneNumber" class="text-gray-600 hover:text-indigo-800 font-bold  justify-center transition-colors dir-ltr text-right">
                                        @item.PhoneNumber
                                    </a>
                                </td>
                                <td class="px-6 py-4 text-gray-600 font-medium">
                                    @(!string.IsNullOrWhiteSpace(item.Address) ? item.Address : "-")
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-block px-3 py-1 bg-indigo-50 text-indigo-800 rounded-lg text-sm font-bold border border-indigo-100">
                                        @(item.Sales?.Count ?? 0)
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex justify-center items-center gap-2 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
                                        <a href="@Url.Action("Statement", "Customers", new { id = item.Id })" class="w-8 h-8 flex items-center justify-center rounded-lg text-emerald-800 hover:text-emerald-800  hover:bg-emerald-50 transition-colors" title="كشف حساب">
                                            <i class="fas fa-eye text-sm"></i>
                                        </a>

                                    
                                            <button onclick="editCustomer(@item.Id)" class="w-8 h-8 flex items-center justify-center rounded-lg  text-indigo-800 hover:bg-indigo-50 transition-colors" title="تعديل">
                                                <i class="fas fa-pen text-sm"></i>
                                            </button>

                                     
                                            <button onclick="deleteCustomer(@item.Id)" class="w-8 h-8 flex items-center justify-center rounded-lg text-red-600 hover:bg-red-50 transition-colors" title="حذف">
                                                <i class="fas fa-trash text-sm"></i>
                                            </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div class="bg-gray-50 px-6 py-4 border-t border-gray-100 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <div class="text-sm font-bold text-gray-500">
                        عرض @(((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1) إلى @Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalCount) من @ViewBag.TotalCount عميل
                    </div>
                    <div class="flex gap-1">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a href="@Url.Action("Index", "Customers", new { page = ViewBag.CurrentPage - 1, searchTerm = ViewBag.SearchTerm })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-600 hover:bg-indigo-50 hover:text-indigo-800 hover:border-indigo-200 transition-all">
                                <i class="fas fa-chevron-right text-xs"></i>
                            </a>
                        }

                        @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                        {
                            <a href="@Url.Action("Index", "Customers", new { page = i, searchTerm = ViewBag.SearchTerm })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg border text-sm font-bold transition-all @(i == ViewBag.CurrentPage ? "bg-indigo-800 text-white border-indigo-800 shadow-md" : "bg-white border-gray-300 text-gray-600 hover:bg-indigo-50 hover:text-indigo-800")">
                                @i
                            </a>
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a href="@Url.Action("Index", "Customers", new { page = ViewBag.CurrentPage + 1, searchTerm = ViewBag.SearchTerm })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-600 hover:bg-indigo-50 hover:text-indigo-800 hover:border-indigo-200 transition-all">
                                <i class="fas fa-chevron-left text-xs"></i>
                            </a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12">
                <div class="bg-gray-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-users text-3xl text-gray-300"></i>
                </div>
                <h5 class="text-lg font-bold text-gray-800">لا يوجد عملاء</h5>
                <p class="text-gray-500 mt-1">ابدأ بإضافة عميل جديد للقائمة</p>
            </div>
        }
    </div>
</div>

<!-- Add Customer Modal -->
<div class="modal fade" id="addCustomerModal" tabindex="-1" aria-labelledby="addCustomerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-2xl border-0 shadow-lg overflow-hidden">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                <h5 class="text-lg font-bold text-gray-800" id="addCustomerModalLabel">إضافة عميل جديد</h5>
                <button type="button" class="text-gray-400 hover:text-red-500 transition-colors" data-bs-dismiss="modal" aria-label="Close">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <form id="addCustomerForm" asp-action="Create" method="post" class="p-6 space-y-4">
                @Html.AntiForgeryToken()
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">الاسم الكامل <span class="text-red-500">*</span></label>
                    <input type="text" name="FullName" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all" placeholder="ادخل اسم العميل">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">رقم الهاتف <span class="text-red-500">*</span></label>
                    <input type="tel" name="PhoneNumber" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all" placeholder="01xxxxxxxxx">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">العنوان <span class="text-red-500">*</span></label>
                    <input type="text" name="Address" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all" placeholder="ادخل العنوان بالتفصيل">
                </div>

                <div class="flex gap-3 pt-4 border-t border-gray-100 mt-4">
                    <button type="button" class="flex-1 py-2.5 border border-gray-300 text-gray-700 hover:text-red-700 rounded-xl font-bold hover:bg-red-50 hover:-translate-y-0.5 transition-all" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" id="saveBtn" class="flex-1 py-2.5 bg-indigo-800 text-white rounded-xl font-bold hover:bg-indigo-900 shadow-md hover:-translate-y-0.5 transition-all">حفظ العميل</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Customer Modal -->
<div class="modal fade" id="editCustomerModal" tabindex="-1" aria-labelledby="editCustomerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-2xl border-0 shadow-lg overflow-hidden">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                <h5 class="text-lg font-bold text-gray-800" id="editCustomerModalLabel">تعديل بيانات العميل</h5>
                <button type="button" class="text-gray-400 hover:text-red-500 transition-colors" data-bs-dismiss="modal" aria-label="Close">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <form id="editCustomerForm" method="post" class="p-6 space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editCustomerId" name="Id">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">الاسم الكامل <span class="text-red-500">*</span></label>
                    <input type="text" id="editCustomerFullName" name="FullName" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">رقم الهاتف <span class="text-red-500">*</span></label>
                    <input type="tel" id="editCustomerPhoneNumber" name="PhoneNumber" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">العنوان <span class="text-red-500">*</span></label>
                    <input type="text" id="editCustomerAddress" name="Address" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all">
                </div>

                <div class="flex gap-3 pt-4 border-t border-gray-100 mt-4">
                    <button type="button" class="flex-1 py-2.5 border border-gray-300 text-gray-700 rounded-xl font-bold hover:bg-gray-50 hover:-translate-y-0.5 transition-all" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" id="editSaveBtn" class="flex-1 py-2.5 bg-indigo-800 text-white rounded-xl font-bold hover:bg-indigo-900 shadow-md hover:-translate-y-0.5 transition-all">حفظ التغييرات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<form id="deleteCustomerForm" method="post" style="display: none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script src="~/js/sweetalert-customers.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Add Customer - Loading effect
            const addForm = document.querySelector("#addCustomerForm");
            const saveBtn = document.getElementById("saveBtn");

            if(addForm){
                addForm.addEventListener("submit", function () {
                    if(addForm.checkValidity()){
                        saveBtn.disabled = true;
                        saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin ml-2"></i> جارٍ الحفظ...';
                        saveBtn.classList.add('opacity-75', 'cursor-not-allowed');
                    }
                });
            }
        });

        // Initialize phone validation
        if (typeof initializePhoneValidation === 'function') {
            initializePhoneValidation('#addCustomerForm input[name="PhoneNumber"]', '#addCustomerModal', '#modalCustomerSelect', '#newCustomerFields', false);
        }

        // Add Customer Form Submission via AJAX
        $('#addCustomerForm').on('submit', function(e) {
            e.preventDefault();

            if (typeof checkPhoneAlertBeforeSubmit === 'function' && !checkPhoneAlertBeforeSubmit('#addCustomerModal')) {
                return false;
            }

            $.ajax({
                url: '@Url.Action("Create", "Customers")',
                type: 'POST',
                data: $(this).serialize(),
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                success: function(result) {
                    if (result.success) {
                        $('#addCustomerModal').modal('hide');
                        $('#addCustomerForm')[0].reset();

                        showSuccess('تم بنجاح', 'تم إضافة العميل بنجاح').then(() => location.reload());
                    } else {
                        showError('خطأ', result.message);
                        $('#saveBtn').prop('disabled', false).html('حفظ العميل').removeClass('opacity-75 cursor-not-allowed');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Add Customer Error:', {xhr, status, error});
                    showError('خطأ', 'حدث خطأ أثناء إضافة العميل');
                    $('#saveBtn').prop('disabled', false).html('حفظ العميل').removeClass('opacity-75 cursor-not-allowed');
                }
            });
        });

        // Edit Customer - Load data
        function editCustomer(id) {
            console.log('Loading customer data for ID:', id);

            $.ajax({
                url: '@Url.Action("Edit", "Customers")/' + id,
                type: 'GET',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                success: function(data) {
                    console.log('Customer data loaded:', data);
                    $('#editCustomerId').val(data.id);
                    $('#editCustomerFullName').val(data.fullName);
                    $('#editCustomerPhoneNumber').val(data.phoneNumber);
                    $('#editCustomerAddress').val(data.address || data.Address);
                    $('#editCustomerModal').modal('show');
                },
                error: function(xhr, status, error) {
                    console.error('Load Customer Error:', {xhr, status, error});
                    showError('خطأ', 'حدث خطأ أثناء تحميل بيانات العميل');
                }
            });
        }

        // Edit Customer Form Submission
        $('#editCustomerForm').on('submit', function(e) {
            e.preventDefault();
            var id = $('#editCustomerId').val();
            var editSaveBtn = $('#editSaveBtn');

            console.log('Submitting edit for customer ID:', id);
            console.log('Form data:', $(this).serialize());

            // Disable button and show loading
            editSaveBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin ml-2"></i> جارٍ الحفظ...').addClass('opacity-75 cursor-not-allowed');

            $.ajax({
                url: '@Url.Action("Edit", "Customers")/' + id,
                type: 'POST',
                data: $(this).serialize(),
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                success: function(result) {
                    console.log('Edit response:', result);
                    if (result.success) {
                        $('#editCustomerModal').modal('hide');
                        showSuccess('تم التعديل', 'تم تحديث بيانات العميل بنجاح', 1500).then(() => location.reload());
                    } else {
                        showError('خطأ', result.message || 'حدث خطأ أثناء التحديث');
                        editSaveBtn.prop('disabled', false).html('حفظ التغييرات').removeClass('opacity-75 cursor-not-allowed');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Edit Customer Error:', {
                        xhr: xhr,
                        status: status,
                        error: error,
                        responseText: xhr.responseText
                    });
                    showError('خطأ', 'حدث خطأ أثناء التحديث');
                    editSaveBtn.prop('disabled', false).html('حفظ التغييرات').removeClass('opacity-75 cursor-not-allowed');
                }
            });
        });

        // Delete Customer
        function deleteCustomer(id) {
            showDangerConfirm(
                'تأكيد الحذف',
                'هل أنت متأكد من حذف هذا العميل؟ لا يمكن التراجع عن هذا الإجراء.',
                'نعم، احذف',
                'إلغاء'
            ).then((result) => {
                if (result.isConfirmed) {
                    showLoading('جاري الحذف...', 'يرجى الانتظار');

                    $('#deleteCustomerForm').attr('action', '@Url.Action("Delete", "Customers")/' + id);

                    $.ajax({
                        url: $('#deleteCustomerForm').attr('action'),
                        type: 'POST',
                        data: $('#deleteCustomerForm').serialize(),
                        success: function(result) {
                            if (result.success) {
                                showSuccess('تم الحذف', 'تم حذف العميل بنجاح').then(() => location.reload());
                            } else {
                                showError('خطأ', result.message);
                            }
                        },
                        error: function() {
                            showError('خطأ', 'حدث خطأ أثناء الحذف');
                        }
                    });
                }
            });
        }

        // Export to Excel
        function exportToExcel(e) {
            e.preventDefault();

            Swal.fire({
                title: 'جاري التصدير...',
                text: 'يرجى الانتظار بينما يتم إعداد ملف Excel',
                icon: 'info',
                allowOutsideClick: false,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            fetch('@Url.Action("ExportToExcel", "Customers")', {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => {
                if (response.ok) {
                    return response.blob();
                } else {
                    throw new Error('حدث خطأ أثناء التصدير');
                }
            })
            .then(blob => {
                var url = window.URL.createObjectURL(blob);
                var a = document.createElement('a');
                a.href = url;
                var date = new Date();
                var timestamp = date.getFullYear() +
                              ('0' + (date.getMonth() + 1)).slice(-2) +
                              ('0' + date.getDate()).slice(-2) + '_' +
                              ('0' + date.getHours()).slice(-2) +
                              ('0' + date.getMinutes()).slice(-2) +
                              ('0' + date.getSeconds()).slice(-2);
                a.download = `Customers_${timestamp}.xlsx`;
                document.body.appendChild(a);
                a.click();
                a.remove();

                Swal.fire({
                    title: 'تم التصدير!',
                    text: 'تم تحميل ملف Excel بنجاح',
                    icon: 'success',
                    timer: 2000,
                    showConfirmButton: false
                });
            })
            .catch(error => {
                console.error('Export Error:', error);
                Swal.fire({
                    title: 'خطأ',
                    text: 'حدث خطأ أثناء محاولة تصدير الملف',
                    icon: 'error'
                });
            });
        }
    </script>
}