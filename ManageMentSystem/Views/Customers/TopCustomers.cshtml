@model IEnumerable<ManageMentSystem.Models.Customer>
@using ManageMentSystem.Helpers
@{
    ViewData["Title"] = "أفضل العملاء";
}

<div class="min-h-screen bg-gray-50/50 p-6">

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-3">
                <div class="p-2 bg-amber-100 rounded-xl text-accentAmber shadow-sm">
                    <i data-lucide="trophy" class="w-6 h-6"></i>
                </div>
                أفضل العملاء
            </h1>
            <p class="text-sm text-gray-500 font-bold mt-4 mr-1">ترتيب العملاء حسب النشاط والمبيعات</p>
        </div>

        <div class="flex flex-wrap items-center gap-3">
            <a href="@Url.Action("Index", "Customers")" class="bg-[#0f1419] hover:bg-primaryHover text-white px-4 py-2.5 rounded-xl font-bold transition-all shadow-md hover:shadow-gray-200 hover:-translate-y-0.5 flex items-center gap-2">
                <i data-lucide="plus" class="w-4 h-4"></i> إضافة عميل
            </a>
            <a href="@Url.Action("Index", "Customers")" class="bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-[#0f1419] px-4 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:-translate-y-0.5 flex items-center gap-2">
                العودة للعملاء<i data-lucide="arrow-left" class="w-4 h-4"></i>
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 flex items-center justify-between hover:shadow-md transition-shadow">
            <div>
                <p class="text-md font-bold text-gray-700 mb-1">إجمالي العملاء</p>
                <h2 class="text-3xl font-bold text-[#0f1419]">@ViewBag.TotalCustomers</h2>
            </div>
            <div class="w-12 h-12 rounded-xl bg-gray-50 text-[#0f1419] flex items-center justify-center text-xl">
                <i data-lucide="users" class="w-6 h-6"></i>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 flex items-center justify-between hover:shadow-md transition-shadow">
            <div>
                <p class="text-md font-bold text-gray-700 mb-1">عملاء لديهم مبيعات</p>
                <h2 class="text-3xl font-bold text-accentGreen">@Model.Count(c => c.Sales?.Any() == true)</h2>
            </div>
            <div class="w-12 h-12 rounded-xl bg-gray-50 text-accentGreen flex items-center justify-center text-xl">
                <i data-lucide="shopping-cart" class="w-6 h-6"></i>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 flex items-center justify-between hover:shadow-md transition-shadow">
            <div>
                <p class="text-md font-bold text-gray-700 mb-1">إجمالي عمليات البيع</p>
                <h2 class="text-3xl font-bold text-accentAmber">@Model.Sum(c => c.Sales?.Count ?? 0)</h2>
            </div>
            <div class="w-12 h-12 rounded-xl bg-gray-50 text-accentAmber flex items-center justify-center text-xl">
                <i data-lucide="trending-up" class="w-6 h-6"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
        <div class=" bg-[#0f1419]  px-6 py-4 flex items-center gap-2">
            <i data-lucide="medal" class="text-amber-400 w-6 h-6"></i>
            <h6 class="font-bold text-white">لوحة الشرف (الترتيب العام)</h6>
            <div class="flex items-center bg-white border border-gray-200 rounded-xl px-3 py-2 shadow-sm">
                <label class="text-sm font-bold text-gray-600 ml-2">عرض:</label>
                <select class="text-sm font-bold text-gray-700 bg-transparent border-none focus:ring-0 cursor-pointer outline-none" onchange="changePageSize(this.value)">
                    <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
                    <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
                    <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                    <option value="100" selected="@(ViewBag.PageSize == 100)">100</option>
                </select>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-right">
                    <thead>
                        <tr class="bg-gray-50 text-gray-600 border-b border-gray-200 text-center">
                            <th class="px-6 py-4 font-bold text-sm w-24">الترتيب</th>
                            <th class="px-6 py-4 font-bold text-sm">بيانات العميل</th>
                            <th class="px-6 py-4 font-bold text-sm">العنوان</th>
                            <th class="px-6 py-4 font-bold text-sm">عدد المبيعات</th>
                            <th class="px-6 py-4 font-bold text-sm text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 text-center">
                        @{
                            int rank = 1;
                        }
                        @foreach (var customer in Model)
                        {
                            var rankBg = rank == 1 ? " from-yellow-400 to-amber-600 shadow-amber-200" :
                            rank == 2 ? " from-slate-300 to-slate-500 shadow-slate-200" :
                            rank == 3 ? " from-amber-700 to-orange-800 shadow-orange-200" :
                            "bg-gray-50 text-[#0f1419] border border-gray-200";

                            var rankIcon = rank == 1 ? "crown" :
                                           rank == 2 ? "medal" :
                                           rank == 3 ? "award" : "star";

                            var rankText = rank <= 3 ? "text-white" : "text-[#0f1419]";

                            <tr class="hover:bg-gray-50/30 transition-all duration-200 group">
                                <td class="px-6 py-4">
                                    <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold shadow-sm @rankBg @rankText">
                                        @if (rank <= 3)
                                        {
                                            <i data-lucide="@rankIcon" class="w-4 h-4"></i>
                                        }
                                        else
                                        {

                                            @rank
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <h6 class="font-bold text-gray-800 text-base mb-1">@customer.FullName</h6>
                                    <a href="tel:@customer.PhoneNumber" class="text-sm text-gray-500 font-bold hover:text-[#0f1419] transition-colors gap-1 w-fit ">
                                        @customer.PhoneNumber <i data-lucide="phone" class="w-3 h-3 inline-block"></i>
                                    </a>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-gray-600 font-medium text-sm">
                                        @(!string.IsNullOrWhiteSpace(customer.Address) ? customer.Address : "-")
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="font-bold text-accentGreen text-sm">
                                        @(customer.Sales?.Count ?? 0)
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <a href="@Url.Action("Statement", "Customers", new { id = customer.Id })"
                                       class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-accentGreen hover:bg-gray-50 hover:text-accentGreen transition-colors"
                                       title="عرض التفاصيل">
                                        <i data-lucide="eye" class="w-4 h-4"></i>
                                    </a>
                                </td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div class="bg-gray-50 px-6 py-4 border-t border-gray-200 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <div class="text-sm font-bold text-gray-500">
                        عرض @(((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1) إلى @Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TopCustomersCount) من @ViewBag.TopCustomersCount عميل
                    </div>

                    <div class="flex gap-1">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a href="@Url.Action("TopCustomers", "Customers", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 hover:text-[#0f1419] hover:border-gray-200 transition-all">
                                <i data-lucide="chevron-right" class="w-4 h-4"></i>
                            </a>
                        }

                        @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                        {
                            <a href="@Url.Action("TopCustomers", "Customers", new { page = i, pageSize = ViewBag.PageSize })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg border text-sm font-bold transition-all @(i == ViewBag.CurrentPage ? "bg-[#0f1419] text-white border-gray-200 shadow-md" : "bg-white border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-[#0f1419]")">
                                @i
                            </a>
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a href="@Url.Action("TopCustomers", "Customers", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 hover:text-[#0f1419] hover:border-gray-200 transition-all">
                                <i data-lucide="chevron-left" class="w-4 h-4"></i>
                            </a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12">
                <div class="bg-gray-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="trophy" class="w-10 h-10 text-gray-300"></i>
                </div>
                <h5 class="text-lg font-bold text-gray-800">لا يوجد بيانات كافية</h5>
                <p class="text-gray-500 mt-1">ابدأ بإضافة مبيعات للعملاء لتظهر القائمة</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function changePageSize(pageSize) {
            window.location.href = '@Url.Action("TopCustomers", "Customers")?page=1&pageSize=' + pageSize;
        }

        // حفظ تفضيل المستخدم
        document.addEventListener('DOMContentLoaded', function() {
            const savedPageSize = localStorage.getItem('topCustomersPageSize');
            const select = document.querySelector('select[onchange="changePageSize(this.value)"]');

            if (savedPageSize && select && !getParameterByName('pageSize')) {
                 // only if distinct form url param to avoid loop
                 // select.value = savedPageSize;
            }
        });

        document.querySelector('select[onchange="changePageSize(this.value)"]').addEventListener('change', function() {
            localStorage.setItem('topCustomersPageSize', this.value);
        });

        function getParameterByName(name) {
            var url = window.location.href;
            name = name.replace(/[\[\]]/g, '\\$&');
            var regex = new RegExp('[?&]' + name + '(=([^&#]*)|&|#|$)'),
                results = regex.exec(url);
            if (!results) return null;
            if (!results[2]) return '';
            return decodeURIComponent(results[2].replace(/\+/g, ' '));
        }
    </script>
}
