@model ManageMentSystem.ViewModels.GeneralDebtIndexViewModel
@using ManageMentSystem.Helpers
@using ManageMentSystem.Models
@inject ManageMentSystem.Services.UserServices.IUserService UserService
@{
    ViewData["Title"] = "إدارة الديون";
}

<div class="min-h-screen bg-bgSubtle p-6">
    @Html.AntiForgeryToken()

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-3">
                <div class="p-2 bg-gray-100 rounded-xl text-primary shadow-sm">
                    <i data-lucide="scale" class="text-xl"></i>
                </div>
                إدارة الديون
            </h1>
            <p class="text-sm text-gray-500 font-bold mt-2 mr-1">متابعة المستحقات والالتزامات المالية</p>
        </div>

     
            <button type="button" class="zen-btn zen-btn-primary zen-btn-sm" onclick="openCreateDebtModal()">
                <i data-lucide="plus"></i> إضافة دين جديد
            </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-emerald-100 p-5 hover:shadow-md transition-all relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-2 h-full bg-accentGreen"></div>
            <div class="flex justify-between items-start mb-4">
                <div>
                    <p class="text-md font-bold text-gray-600 mb-1">ديون مستحقة لي</p>
                    <h3 class="text-3xl font-bold text-accentGreen">@Model.TotalReceivables.ToString("C")</h3>
                </div>
                <div class="p-3 bg-emerald-50 rounded-xl text-accentGreen group-hover:scale-110 transition-transform">
                    <i data-lucide="arrow-down" class="text-xl"></i>
                </div>
            </div>
            <div class="text-sm font-bold text-accentGreen flex items-center gap-1">
                <i data-lucide="check-circle" class="w-4 h-4 inline-block"></i> أموال واردة
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-red-100 p-5 hover:shadow-md transition-all relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-2 h-full bg-red-700"></div>
            <div class="flex justify-between items-start mb-4">
                <div>
                    <p class="text-md font-bold text-gray-600 mb-1">ديون مستحقة عليّ</p>
                    <h3 class="text-3xl font-bold text-accentRed">@Model.TotalPayables.ToString("C")</h3>
                </div>
                <div class="p-3 bg-red-50 rounded-xl text-accentRed group-hover:scale-110 transition-transform">
                    <i data-lucide="arrow-up" class="text-xl"></i>
                </div>
            </div>
            <div class="text-sm font-bold text-accentRed flex items-center gap-1">
                <i data-lucide="alert-circle" class="w-4 h-4 inline-block"></i> التزامات للدفع
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-all relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-2 h-full bg-primary"></div>
            <div class="flex justify-between items-start mb-4">
                <div>
                    <p class="text-md font-bold text-gray-600 mb-1">المركز المالي الصافي</p>
                    <h3 class="text-3xl font-bold text-primary">@Model.NetPosition.ToString("C")</h3>
                </div>
                <div class="p-3 bg-gray-50 rounded-xl text-primary group-hover:scale-110 transition-transform">
                    <i data-lucide="scale" class="text-xl"></i>
                </div>
            </div>
            <div class="text-sm font-bold text-primary flex items-center gap-1">
                <i data-lucide="trending-up" class="w-4 h-4 inline-block"></i> الفرق بين الدائن والمدين
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-6">
        <div class="relative">
            <i data-lucide="search" class="absolute right-4 top-3.5 text-gray-500 w-5 h-5"></i>
            <input type="text" id="searchInput"
                   class="w-full pr-10 pl-4 py-3 border border-gray-200 rounded-lg focus:ring-1 focus:ring-primary/20 focus:border-primary outline-none transition-all font-bold text-gray-700 placeholder-gray-400"
                   placeholder="ابحث بعنوان الدين، اسم الطرف، أو المبلغ...">
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex justify-between items-center">
            <h6 class="font-bold text-gray-800 flex items-center gap-2">
                <i data-lucide="list" class="text-primary"></i> سجل الديون
            </h6>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-right" id="debtsTable">
                <thead>
                    <tr class="bg-bgSubtle text-gray-900 border-b border-gray-200 text-sm-center uppercase">
                        <th class="px-3 py-4 font-bold">الطرف</th>
                        <th class="px-3 py-4 font-bold">العنوان</th>
                        <th class="px-3 py-4 font-bold">النوع</th>
                        <th class="px-3 py-4 font-bold">الإجمالي</th>
                        <th class="px-3 py-4 font-bold">المدفوع</th>
                        <th class="px-3 py-4 font-bold">المتبقي</th>
                        <th class="px-3 py-4 font-bold">التاريخ</th>
                        <th class="px-3 py-4 font-bold">الاستحقاق</th>
                        <th class="px-3 py-4 font-bold">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-sm-center font-bold">
                    @foreach (var d in Model.Debts)
                    {
                        var remaining = d.Amount - d.PaidAmount;
                        var isComplete = remaining <= 0;
                        var rowClass = isComplete ? "bg-bgSubtle text-gray-500" : "hover:bg-gray-50 text-gray-700";

                        <tr class="transition-colors @rowClass group">
                            <td class="px-3 py-4 font-bold">@(string.IsNullOrWhiteSpace(d.PartyName) ? "-" : d.PartyName)</td>
                            <td class="px-3 py-4">@d.Title</td>
                            <td class="px-3 py-4">
                                @if (d.DebtType == GeneralDebtType.OwedToMe)
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200">
                                        <i data-lucide="arrow-down" class="w-3 h-3"></i> ليا
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-red-100 text-accentRed border border-red-200">
                                        <i data-lucide="arrow-up" class="w-3 h-3"></i> عليا
                                    </span>
                                }
                            </td>
                            <td class="px-3 py-4 font-bold">@d.Amount.ToString("C")</td>
                                          
                            <td class="px-3 py-4 font-bold text-accentGreen">
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200"> @d.PaidAmount.ToString("C")</span>
                                
                                </td>
                            <td class="px-3 py-4 font-bold @(isComplete ? "text-gray-500 " : "text-accentRed")">
                                @if (isComplete)
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-emerald-100 text-emerald-800 border border-emerald-2000">
                                        <i data-lucide="check-circle" class="w-3 h-3"></i> مكتمل
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-red-100 text-accentRed border border-red-200">@d.Remaining.ToString("C")</span>  
                                }
                            </td>
                            <td class="px-3 py-4 text-sm font-bold">@d.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="px-3 py-4 text-sm text-accentRed font-bold">@(d.DueDate?.ToString("dd/MM/yyyy") ?? "-")</td>

                            <td class="px-3 py-4">
                                <div class="flex items-center justify-center gap-2">
                                    @if (!isComplete)
                                    {
                                        <form asp-action="AddPayment" method="post" class="flex gap-1 items-center bg-gray-50 p-1 rounded-lg border border-gray-200 shadow-sm" onsubmit="return confirmAddPayment(this);">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@d.Id" />

                                            <input type="number" step="0.01" min="0" name="amount" placeholder="مبلغ" required
                                                   class="w-20 px-2 py-1 text-xs border border-gray-200 rounded focus:ring-1 focus:ring-primary/20 outline-none" />

                                            <select name="paymentMethodId" class="w-24 px-1 py-1 text-xs border border-gray-200 rounded focus:ring-1 focus:ring-primary/20 outline-none bg-white">
                                                <option value="">الدفع</option>
                                                @foreach (var pm in (IEnumerable<ManageMentSystem.Models.PaymentMethodOption>)(ViewBag.PaymentMethods ?? new List<ManageMentSystem.Models.PaymentMethodOption>()))
                                                {
                                                    <option value="@pm.Id">@pm.Name</option>
                                                }
                                            </select>

                                            <button type="submit" class="zen-action-btn zen-action-btn-info" title="إضافة دفعة">
                                                <i data-lucide="check" class="text-[10px] w-3 h-3"></i>
                                            </button>
                                        </form>
                                    }

                                    <div class="flex gap-2">
                                            <button type="button"
                                                    class="zen-action-btn zen-action-btn-neutral"
                                                    title="تعديل"
                                                    data-id="@d.Id"
                                                    data-title="@d.Title"
                                                    data-party-name="@(d.PartyName ?? "")"
                                                    data-debt-type="@((int)d.DebtType)"
                                                    data-amount="@d.Amount"
                                                    data-paid-amount="@d.PaidAmount"
                                                    data-due-date="@(d.DueDate?.ToString("yyyy-MM-dd") ?? "")"
                                                    data-description="@(d.Description ?? "")"
                                                    onclick="openEditDebtModal(this)">
                                                <i data-lucide="edit" class="w-4 h-4"></i>
                                            </button>

                                       
                                            <button onclick="confirmDeleteDebt(@d.Id, '@d.Title', '@(d.PartyName ?? "")', '@d.Amount.ToString("F2")', '@d.DebtType')"
                                                    class="zen-action-btn zen-action-btn-danger" title="حذف">
                                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                                            </button>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="bg-gray-50 px-6 py-4 border-t border-gray-200 flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="text-sm font-bold text-gray-500">
                    صفحة @Model.CurrentPage من @Model.TotalPages
                </div>

                <div class="flex gap-1">
                    <a href="@Url.Action("Index", new { page = Model.CurrentPage - 1, pageSize = Model.PageSize })"
                       class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 hover:text-primary transition-all @(Model.CurrentPage == 1 ? "opacity-50 pointer-events-none" : "")">
                        <i data-lucide="chevron-right" class="w-4 h-4"></i>
                    </a>

                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <a href="@Url.Action("Index", new { page = p, pageSize = Model.PageSize })"
                           class="w-9 h-9 flex items-center justify-center rounded-lg border text-sm font-bold transition-all @(p == Model.CurrentPage ? "bg-primary text-white border-gray-200 shadow-sm" : "bg-white border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-primary")">
                            @p
                        </a>
                    }

                    <a href="@Url.Action("Index", new { page = Model.CurrentPage + 1, pageSize = Model.PageSize })"
                       class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 hover:text-primary transition-all @(Model.CurrentPage == Model.TotalPages ? "opacity-50 pointer-events-none" : "")">
                        <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<!-- Create Debt Modal -->
<div id="createDebtModal" class="fixed inset-0 z-[1050] hidden" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" onclick="closeCreateDebtModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-4xl max-h-[90vh] overflow-y-auto rounded-2xl bg-white shadow-2xl border border-gray-200">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex items-center justify-between sticky top-0">
                <h5 class="text-lg font-bold text-gray-800">إضافة دين جديد</h5>
                <button type="button" class="text-gray-500 hover:text-accentRed" onclick="closeCreateDebtModal()">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <form asp-action="Create" method="post" class="p-6">
                @Html.AntiForgeryToken()
                @{
                    ViewData["IsEdit"] = false;
                }
                <partial name="_GeneralDebtForm" model="new ManageMentSystem.ViewModels.CreateGeneralDebtViewModel()" />
                <div class="bg-gray-50 px-6 py-4 mt-6 border border-gray-200 rounded-xl flex items-center gap-3">
                    <button type="submit" class="zen-btn zen-btn-primary">
                        <i data-lucide="save" class="w-4 h-4"></i> حفظ البيانات
                    </button>
                    <button type="button" class="zen-btn zen-btn-neutral" onclick="closeCreateDebtModal()">إلغاء</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Debt Modal -->
<div id="editDebtModal" class="fixed inset-0 z-[1050] hidden" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" onclick="closeEditDebtModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-4xl max-h-[90vh] overflow-y-auto rounded-2xl bg-white shadow-2xl border border-gray-200">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex items-center justify-between sticky top-0">
                <h5 class="text-lg font-bold text-gray-800">تعديل بيانات الدين</h5>
                <button type="button" class="text-gray-500 hover:text-accentRed" onclick="closeEditDebtModal()">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <form asp-action="Edit" method="post" class="p-6" id="editDebtForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editDebtId" />
                @{
                    ViewData["IsEdit"] = true;
                }
                <partial name="_GeneralDebtForm" model="new ManageMentSystem.ViewModels.CreateGeneralDebtViewModel()" />
                <div class="bg-gray-50 px-6 py-4 mt-6 border border-gray-200 rounded-xl flex items-center gap-3">
                    <button type="submit" class="zen-btn zen-btn-primary">
                        <i data-lucide="save" class="w-4 h-4"></i> حفظ التغييرات
                    </button>
                    <button type="button" class="zen-btn zen-btn-neutral" onclick="closeEditDebtModal()">إلغاء</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/js/sweetalert-debts.js"></script>
    <script>
        $(document).ready(function () {
            // البحث الفوري في الجدول
            $("#searchInput").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#debtsTable tbody tr").filter(function () {
                    // البحث في أول عمودين (العنوان والطرف)
                    $(this).toggle($(this).children('td').slice(0, 2).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });

const accentRed = window.accentRed || theme.accentRed || window.getComputedStyle(document.documentElement).getPropertyValue('--zen-theme-accent-red').trim();
        const textMuted = window.textMuted || '#6b7280';

        // دالة تأكيد الحذف
        function confirmDeleteDebt(debtId, title, partyName, amount, debtType) {
            // استخدام SweetAlert المخصص للديون (المفترض وجوده في sweetalert-debts.js)
            // إذا لم يكن موجوداً، نستخدم النسخة القياسية
            if (typeof showDebtDeleteConfirmation === 'function') {
                showDebtDeleteConfirmation(debtId, title, partyName, amount, debtType).then((result) => {
                    if (result.isConfirmed) processDelete(debtId);
                });
            } else {
                Swal.fire({
                    title: 'تأكيد الحذف',
                    text: `هل أنت متأكد من حذف هذا الدين؟`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: accentRed,
                    cancelButtonColor: textMuted,
                    confirmButtonText: 'نعم، حذف',
                    cancelButtonText: 'إلغاء'
                }).then((result) => {
                    if (result.isConfirmed) processDelete(debtId);
                });
            }
        }

        function processDelete(debtId) {
            // Show loading
            Swal.fire({
                title: 'جاري الحذف...',
                didOpen: () => Swal.showLoading()
            });

            $.ajax({
                url: '@Url.Action("Delete")',
                type: 'POST',
                data: {
                    id: debtId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    Swal.fire({
                        icon: 'success',
                        title: 'تم الحذف',
                        text: 'تم حذف الدين بنجاح',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                },
                error: function() {
                    Swal.fire('خطأ', 'حدث خطأ أثناء الحذف', 'error');
                }
            });
        }

        // دالة تأكيد إضافة الدفعة
        function confirmAddPayment(form) {
            const amount = form.querySelector('input[name="amount"]').value;
            const paymentMethodId = form.querySelector('select[name="paymentMethodId"]').value;

            if (!amount || parseFloat(amount) <= 0) {
                Swal.fire('تنبيه', 'يرجى إدخال مبلغ صحيح أكبر من صفر', 'warning');
                return false;
            }

            if (!paymentMethodId) {
                Swal.fire('تنبيه', 'يرجى اختيار طريقة الدفع', 'warning');
                return false;
            }

            // إظهار رسالة تحميل صغيرة بدل التأكيد الكامل لتسريع العمل، أو يمكنك استخدام confirm عادي
            // هنا سنعتمد الإرسال المباشر مع مؤشر تحميل لتسريع عملية السداد المتكرر
            // ولكن إذا أردت تأكيد، يمكنك إضافته هنا.

            // إضافة مؤشر تحميل للزر
            const btn = form.querySelector('button[type="submit"]');
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i data-lucide="loader-2" class="animate-spin inline-block"></i>';
            lucide.createIcons();

            $.ajax({
                url: '@Url.Action("AddPayment")',
                type: 'POST',
                data: $(form).serialize(),
                success: function(response) {
                    Swal.fire({
                        icon: 'success',
                        title: 'تم السداد',
                        text: `تم إضافة دفعة بقيمة ${amount}`,
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                },
                error: function() {
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                    Swal.fire('خطأ', 'حدث خطأ أثناء إضافة الدفعة', 'error');
                }
            });

            return false; // منع الإرسال التقليدي
        }

        function openCreateDebtModal() {
            document.getElementById('createDebtModal').classList.remove('hidden');
        }

        function closeCreateDebtModal() {
            document.getElementById('createDebtModal').classList.add('hidden');
        }

        function openEditDebtModal(button) {
            const modal = document.getElementById('editDebtModal');
            const form = document.getElementById('editDebtForm');
            const id = button.getAttribute('data-id');

            document.getElementById('editDebtId').value = id;

            form.querySelector('input[name="Title"]').value = button.getAttribute('data-title') || '';
            form.querySelector('input[name="PartyName"]').value = button.getAttribute('data-party-name') || '';
            form.querySelector('select[name="DebtType"]').value = button.getAttribute('data-debt-type') || '0';
            form.querySelector('input[name="Amount"]').value = button.getAttribute('data-amount') || '0';
            const paidInput = form.querySelector('input[name="PaidAmount"]');
            if (paidInput) {
                paidInput.value = button.getAttribute('data-paid-amount') || '0';
            }
            form.querySelector('input[name="DueDate"]').value = button.getAttribute('data-due-date') || '';
            form.querySelector('textarea[name="Description"]').value = button.getAttribute('data-description') || '';

            modal.classList.remove('hidden');
            lucide.createIcons();
        }

        function closeEditDebtModal() {
            document.getElementById('editDebtModal').classList.add('hidden');
        }
    </script>
}


