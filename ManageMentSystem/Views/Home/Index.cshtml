@model ManageMentSystem.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
}

<style>
    * { font-family: 'Cairo', sans-serif !important; }
    @@keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: .5; transform: scale(1.3); }
    }
    .pulse-dot { animation: pulse-dot 2s infinite; }
    @@keyframes treasure-pulse {
        0%, 100% { transform: scale(1); }
        50%       { transform: scale(1.05); }
    }
    .hero-cash { animation: treasure-pulse 4s ease-in-out infinite; }
    .hero-cash:hover { animation: none; }
</style>

<div class="min-h-screen bg-gray-100 p-6 md:p-8 font-sans" dir="rtl">

    
    <div class="flex items-center justify-between mb-8">
        <div>
            <div class="text-2xl font-extrabold text-gray-900 tracking-tight">لوحة التحكم</div>

        </div>

    </div>

    
    
    <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">
        <span>نشاط الشهر الحالي</span>
        <div class="flex-1 h-px bg-gray-200"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-6">

        
        <div class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm hover:-translate-y-0.5 transition-transform duration-200">
            <div class="flex items-center justify-between mb-1.5">
                <div class="text-xs font-semibold text-gray-400">عدد الفواتير</div>
                <div class="w-11 h-11 rounded-xl flex items-center justify-center bg-zen-primary-light text-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                </div>
            </div>
            <div class="text-2xl font-black text-gray-900 mb-3">@Model.MonthlySalesCount</div>
            <div class="flex items-center gap-2 text-xs font-bold">
                <span class="px-2 py-0.5 rounded-full @(Model.IsSalesCountTrendUp ? "bg-emerald-50 text-accentGreen" : "bg-red-50 text-accentRed")">
                    @(Model.IsSalesCountTrendUp ? "▲" : "▼") @Model.SalesCountTrend%
                </span>
                <span class="text-gray-400">مقارنة بالشهر الماضي</span>
            </div>
        </div>

        
        <div class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm hover:-translate-y-0.5 transition-transform duration-200">
            <div class="flex items-center justify-between mb-1.5">
                <div class="text-xs font-semibold text-gray-400">إيرادات الشهر</div>
                <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background: rgb(var(--zen-theme-accent-rgb) / 0.12); color: var(--zen-theme-accent);">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                    </svg>
                </div>
            </div>
            <div class="text-2xl font-black text-gray-900 mb-3">@Model.MonthlyRevenue.ToString("C")</div>
            <div class="flex items-center gap-2 text-xs font-bold">
                <span class="px-2 py-0.5 rounded-full @(Model.IsRevenueTrendUp ? "bg-emerald-50 text-accentGreen" : "bg-red-50 text-accentRed")">
                    @(Model.IsRevenueTrendUp ? "▲" : "▼") @Model.RevenueTrend%
                </span>
                <span class="text-gray-400">مقارنة بالشهر الماضي</span>
            </div>
        </div>

        
        <div class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm hover:-translate-y-0.5 transition-transform duration-200">
            <div class="flex items-center justify-between mb-1.5">
                <div class="text-xs font-semibold text-gray-400">مصاريف الشهر</div>
                <div class="w-11 h-11 rounded-xl flex items-center justify-center bg-red-50 text-accentRed">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
                    </svg>
                </div>
            </div>
            <div class="text-2xl font-black text-accentRed mb-3">@Model.MonthlyExpenses.ToString("C")</div>
            <div class="flex items-center gap-2 text-xs font-bold">
                <span class="px-2 py-0.5 rounded-full @(Model.IsExpensesTrendUp ? "bg-red-50 text-accentRed" : "bg-emerald-50 text-accentGreen")">
                    @(Model.IsExpensesTrendUp ? "▲" : "▼") @Model.ExpensesTrend%
                </span>
                <span class="text-gray-400">رواتب وتشغيل</span>
            </div>
        </div>

        
        <div class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm hover:-translate-y-0.5 transition-transform duration-200">
            <div class="flex items-center justify-between mb-1.5">
                <div class="text-xs font-semibold text-gray-400">صافي الربح</div>
                <div class="w-11 h-11 rounded-xl flex items-center justify-center bg-amber-50 text-amber-500">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                </div>
            </div>
            <div class="text-2xl font-black text-gray-900 mb-3">@((Model.MonthlyRevenue - Model.MonthlyExpenses).ToString("C"))</div>
            <div class="text-xs text-gray-400 font-medium">إيرادات بعد خصم المصاريف</div>
        </div>

    </div>

    
    <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">
        <span>إحصائيات عامة للنظام</span>
        <div class="flex-1 h-px bg-gray-200"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">

        
        <div class="md:col-span-1 rounded-2xl p-6 relative overflow-hidden flex flex-col justify-between min-h-[180px] hero-cash" style="background: var(--zen-theme-primary); color: var(--zen-theme-bg-base);">
            <div class="absolute w-44 h-44 rounded-full top-[-55px] left-[-40px] pointer-events-none" style="background:radial-gradient(circle,rgba(255,255,255,.12) 0%,transparent 70%)"></div>
            <div class="absolute w-28 h-28 rounded-full bottom-[-30px] right-[30px] pointer-events-none" style="background: radial-gradient(circle, rgb(var(--zen-theme-accent-rgb) / 0.35) 0%, transparent 70%);"></div>
            <div class="relative z-10">
                <div class="text-xs font-semibold text-gray-400 mb-1">الرصيد الكلي الحالي</div>
                <div class="text-3xl font-black tracking-tight" dir="ltr">@Model.CashBalance.ToString("C")</div>
                <div class="inline-flex items-center gap-2 mt-4 bg-white/10 backdrop-blur rounded-full px-3 py-1 text-xs font-semibold w-fit">
                    <div class="w-2 h-2 rounded-full bg-accentGreen pulse-dot"></div>
                    <span>مباشر</span>
                </div>
            </div>
            <svg viewBox="0 0 220 50" class="absolute bottom-0 left-0 right-0 w-full opacity-20" preserveAspectRatio="none">
                <polyline points="0,40 30,32 60,36 90,20 120,28 150,12 180,18 220,8" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                <polyline points="0,40 30,32 60,36 90,20 120,28 150,12 180,18 220,8 220,50 0,50" fill="white" stroke="none" opacity=".35" />
            </svg>
        </div>

        
        <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start">
                <div>
                    <div class="text-xs font-semibold text-gray-400 mb-2">إجمالي العملاء</div>
                    <div class="text-3xl font-black text-gray-900">@Model.TotalCustomers <span class="text-base font-medium text-gray-400">عميل</span></div>
                </div>
                @{
                    double pct = Model.TotalCustomers > 0 ? Math.Min(100, (double)Model.ActiveCustomersCount / Model.TotalCustomers * 100) : 0;
                    double circ = 2 * Math.PI * 20;
                    double dash = pct / 100 * circ;
                }
                <div class="relative w-20 h-20 flex-shrink-0">
                    <svg viewBox="0 0 56 56" class="w-20 h-20" style="transform:rotate(-90deg)">
                        <circle cx="28" cy="28" r="20" fill="none" stroke-width="6" style="stroke: var(--zen-theme-bg-subtle);" />
                        <circle cx="28" cy="28" r="20" fill="none" stroke-width="6" style="stroke: var(--zen-theme-accent);"
                                stroke-dasharray="@dash.ToString("F1") @circ.ToString("F1")"
                                stroke-linecap="round" />
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center text-sm font-black text-gray-900">@pct.ToString("F0")%</div>
                </div>
            </div>
            <div class="pt-0 border-t border-gray-100 flex justify-between items-center text-xs">
                <span class="font-semibold text-gray-400">نشط هذا الشهر</span>
                <span class="font-black text-gray-900">@Model.ActiveCustomersCount عميل</span>
            </div>
        </div>

        
        <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start">
                <div>
                    <div class="text-xs font-semibold text-gray-400 mb-2">المخزون</div>
                    <div class="text-3xl font-black text-gray-900">@Model.TotalProducts <span class="text-base font-medium text-gray-400">قطعة</span></div>
                </div>
                <div class="w-14 h-14 rounded-xl flex items-center justify-center bg-amber-50 text-amber-500">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-8 h-8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                </div>
            </div>
            <div class="pt-0 border-t border-gray-100 flex justify-between items-center text-xs">
                <span class="font-semibold text-gray-400">القيمة التقديرية</span>
                <span class="font-black text-gray-900">@Model.StockTotalValue.ToString("C")</span>
            </div>
        </div>

    </div>

    
    <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">
        <span>تحليل مالي</span>
        <div class="flex-1 h-px bg-gray-200"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">

        
        <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
            <div class="flex justify-between items-center mb-4">
                <div>
                    <div class="text-sm font-bold text-gray-900">الإيرادات مقابل المصاريف</div>
                    <div class="text-xs text-gray-400 mt-0.5">الشهر الحالي — مقارنة بصرية</div>
                </div>
            </div>
            <div class="h-44 relative">
                <canvas id="revExpChart"></canvas>
            </div>
        </div>

        
        <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
            <div class="flex justify-between items-center mb-4">
                <div>
                    <div class="text-sm font-bold text-gray-900">توزيع النشاط المالي</div>
                    <div class="text-xs text-gray-400 mt-0.5">نسبة المصاريف من الإيرادات</div>
                </div>
            </div>
            <div class="h-44 flex items-center justify-center gap-8">
                <canvas id="donutChart" style="max-height:160px;max-width:160px"></canvas>
                <div id="donutLegend" class="text-sm font-sans"></div>
            </div>
        </div>

    </div>

    
    <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">
        <span>أحدث العمليات</span>
        <div class="flex-1 h-px bg-gray-200"></div>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mb-6">
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-100">
            <div class="text-sm font-bold text-gray-900">آخر الفواتير المُصدرة</div>
            <a asp-controller="Sales" asp-action="Index" class="flex items-center gap-1 text-xs font-bold transition-opacity hover:opacity-70" style="color: var(--zen-theme-accent);">
                عرض الكل
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="w-3 h-3" style="transform:rotate(180deg)">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
            </a>
        </div>

        @if (Model.RecentSales.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-right border-collapse">
                    <thead>
                        <tr class="bg-gray-50">
                            <th class="px-6 py-3 text-xs font-bold uppercase tracking-wide text-gray-400 border-b border-gray-100">رقم الفاتورة</th>
                            <th class="px-6 py-3 text-xs font-bold uppercase tracking-wide text-gray-400 border-b border-gray-100">العميل</th>
                            <th class="px-6 py-3 text-xs font-bold uppercase tracking-wide text-gray-400 border-b border-gray-100">التاريخ</th>
                            <th class="px-6 py-3 text-xs font-bold uppercase tracking-wide text-gray-400 border-b border-gray-100">المبلغ</th>
                            <th class="px-6 py-3 text-xs font-bold uppercase tracking-wide text-gray-400 border-b border-gray-100">الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sale in Model.RecentSales)
                        {
                            <tr class="border-b border-gray-50 hover:bg-gray-50/60 transition-colors">
                                <td class="px-6 py-3">
                                    <span class="font-black text-gray-700"><span class="text-gray-400 font-medium">#</span>@sale.Id</span>
                                </td>
                                <td class="px-6 py-3">
                                    <div class="flex items-center gap-2.5">
                                        <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-black flex-shrink-0"
                                             style="background: linear-gradient(135deg, var(--zen-theme-accent) 0%, var(--zen-success-hover) 100%);">
                                            @(sale.Customer?.FullName?.Substring(0, 1) ?? "ع")
                                        </div>
                                        <span class="font-bold text-gray-900 text-sm">@sale.Customer?.FullName</span>
                                    </div>
                                </td>
                                <td class="px-6 py-3 text-gray-400 text-sm font-medium" dir="ltr">@sale.SaleDate.ToString("yyyy-MM-dd")</td>
                                <td class="px-6 py-3 font-black text-gray-900 text-sm">@sale.TotalAmount.ToString("C")</td>
                                <td class="px-6 py-3">
                                    <span class="inline-flex items-center gap-1.5 bg-emerald-50 text-accentGreen text-xs font-bold px-3 py-1 rounded-full">✓ مكتمل</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-12">
                <div class="w-14 h-14 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-gray-400">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0H4" />
                    </svg>
                </div>
                <div class="text-sm font-semibold text-gray-400">لا توجد مبيعات حديثة بعد</div>
            </div>
        }
    </div>

</div>

@* Setup Wizard Partial *@
<partial name="_SetupWizard" />

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        (function () {
            Chart.defaults.font.family = "'Cairo', sans-serif";
            const theme = window.THEME || {};
const primary = window.primary || theme.primary || window.getComputedStyle(document.documentElement).getPropertyValue('--zen-theme-primary').trim();
            const accent = window.accent || theme.accent || '#315f8f';
const accentGreen = window.accentGreen || theme.accentGreen || window.getComputedStyle(document.documentElement).getPropertyValue('--zen-theme-accent-green').trim();
const accentRed = window.accentRed || theme.accentRed || window.getComputedStyle(document.documentElement).getPropertyValue('--zen-theme-accent-red').trim();
            const bgSubtle = window.bgSubtle || theme.bgSubtle || '#f8f9fa';
            const textMuted = window.textMuted || theme.textMuted || '#6b7280';

            const rev  = @Model.MonthlyRevenue;
            const exp  = @Model.MonthlyExpenses;
            const prof = Math.max(0, rev - exp);

            // ── Bar: Revenue vs Expenses ──
            const barCtx = document.getElementById('revExpChart')?.getContext('2d');
            if (barCtx) {
                new Chart(barCtx, {
                    type: 'bar',
                    data: {
                        labels: ['الإيرادات', 'المصاريف', 'صافي الربح'],
                        datasets: [{
                            data: [rev, exp, prof],
                            backgroundColor: [accentGreen, accentRed, accent],
                            borderRadius: 10,
                            borderSkipped: false,
                            maxBarThickness: 55
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { grid: { display: false }, ticks: { font: { size: 12, weight: '600', family: "'Cairo'" } } },
                            y: { grid: { color: bgSubtle }, ticks: { font: { size: 11, family: "'Cairo'" }, callback: v => v.toLocaleString('ar-EG') } }
                        }
                    }
                });
            }

            // ── Donut: Expenses share ──
            const donutCtx = document.getElementById('donutChart')?.getContext('2d');
            if (donutCtx) {
                new Chart(donutCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['إيرادات صافية', 'مصاريف'],
                        datasets: [{
                            data: [prof, exp],
                            backgroundColor: [accent, accentRed],
                            borderWidth: 0,
                            hoverOffset: 6
                        }]
                    },
                    options: {
                        responsive: false,
                        cutout: '68%',
                        plugins: {
                            legend: { display: false },
                            tooltip: { callbacks: { label: ctx => ' ' + ctx.label + ': ' + ctx.parsed.toLocaleString('ar-EG') } }
                        }
                    }
                });

                const legend = document.getElementById('donutLegend');
                if (legend) {
                    const items = [
                        { color: accent, label: 'إيرادات صافية', val: prof },
                        { color: accentRed, label: 'مصاريف',     val: exp  },
                    ];
                    legend.innerHTML = items.map(i => `
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
                            <div style="width:12px;height:12px;border-radius:3px;background:${i.color};flex-shrink:0"></div>
                            <div>
                                <div style="font-weight:700;color:${primary};font-size:.82rem">${i.label}</div>
                                <div style="color:${textMuted};font-size:.75rem">${i.val.toLocaleString('ar-EG')}</div>
                            </div>
                        </div>`).join('');
                }
            }
        })();
    </script>
}
