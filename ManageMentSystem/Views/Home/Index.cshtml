@model ManageMentSystem.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="min-h-screen bg-[#fafafa] p-6 md:p-8 space-y-8" dir="rtl">

    <section>
        <div class="flex items-center gap-2 mb-4">
            <h3 class="text-xl font-bold text-[#0f1419]">تفاصيل نشاط الشهر</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 hover:-translate-y-1 transition-transform duration-300">
                <div class="flex items-start justify-between">
                    <div class="flex flex-col gap-2">
                        <p class="text-gray-500 text-lg font-bold">عدد فواتير الشهر</p>

                        <h3 class="text-2xl font-bold text-[#0f1419]">@Model.MonthlySalesCount</h3>

                        <p class="text-sm font-bold text-gray-500 mt-1">فاتورة تم إصدارها هذا الشهر</p>
                    </div>
                    <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-gray-50">
                        <i data-lucide="receipt" class="text-[#0f1419] text-xl"></i>
                    </div>
                </div>

                <div class="mt-4 flex items-center text-sm">
                    <span class="font-medium @(Model.IsSalesCountTrendUp ? "text-green-600" : "text-red-500") flex items-center gap-1">
                        @(Model.IsSalesCountTrendUp ? "+" : "-")@Model.SalesCountTrend%
                    </span>
                    <span class="text-gray-500 mr-2 text-xs font-bold">مقارنة بالشهر الماضي</span>
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 hover:-translate-y-1 transition-transform duration-300">
                <div class="flex items-start justify-between">
                    <div class="flex flex-col gap-2">
                        <p class="text-gray-500 text-lg font-bold">إيرادات الشهر</p>
                        <h3 class="text-2xl font-bold text-[#0f1419]">@Model.MonthlyRevenue.ToString("C")</h3>
                        <p class="text-sm font-bold text-gray-500 mt-1">إجمالي الدخل المالي للشهر</p>
                    </div>
                    <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-gray-50">
                        <i data-lucide="dollar-sign" class="text-[#0f1419] text-xl"></i>
                    </div>
                </div>
                <div class="mt-4 flex items-center text-sm">
                    <span class="font-medium @(Model.IsRevenueTrendUp ? "text-green-600" : "text-red-500") flex items-center gap-1">
                        @(Model.IsRevenueTrendUp ? "+" : "-")@Model.RevenueTrend%
                    </span>
                    <span class="text-gray-500 mr-2 text-xs font-bold">مقارنة بالشهر الماضي</span>
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 hover:-translate-y-1 transition-transform duration-300">
                <div class="flex items-start justify-between">
                    <div class="flex flex-col gap-2">
                        <p class="text-gray-500 text-lg font-bold">مصاريف الشهر</p>
                        <h3 class="text-2xl font-bold text-[#e11d48]">@Model.MonthlyExpenses.ToString("C")</h3>
                        <p class="text-sm font-bold text-gray-500 mt-1">رواتب وتشغيل (شهر حالي)</p>
                    </div>
                    <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-gray-50">
                        <i data-lucide="trending-down" class="text-[#e11d48] text-xl"></i>
                    </div>
                </div>

                <div class="mt-4 flex items-center text-sm">
                    <span class="font-medium @(Model.IsExpensesTrendUp ? "text-red-500" : "text-green-600") flex items-center gap-1">
                        @(Model.IsExpensesTrendUp ? "+" : "-")@Model.ExpensesTrend%
                    </span>
                    <span class="text-gray-500 mr-2 text-xs font-bold">مقارنة بالشهر الماضي</span>
                </div>
            </div>

        </div>
    </section>

    <section class="bg-white rounded-3xl p-6 md:p-8 shadow-sm border border-gray-200">
        <div class="flex items-center gap-2 mb-6">
            <h3 class="text-xl font-bold text-[#0f1419]">إحصائيات عامة للنظام</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="relative overflow-hidden bg-[#0f1419] rounded-2xl p-6 text-white shadow-xl">
                <div class="absolute left-0 top-0 w-32 h-32 bg-white opacity-5 rounded-full blur-2xl transform -translate-x-10 -translate-y-10"></div>
                <div class="absolute top-0 right-0 p-4 opacity-10">
                    <i data-lucide="wallet" class="text-9xl transform rotate-12 -mr-8 -mt-8"></i>
                </div>
                <div class="relative z-10">
                    <p class="text-gray-300 font-bold mb-1">الرصيد الكلي الحالي</p>
                    <h2 class="text-4xl font-bold mb-4 text-white" dir="ltr"> <span class="text-2xl"></span> @Model.CashBalance.ToString("C") </h2>
                    <div class="flex items-center gap-2 bg-white/10 w-fit px-3 py-1 rounded-full backdrop-blur-sm">
                        <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
                        <span class="text-xs font-medium text-white">تم التحديث للتو</span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl p-6 border border-gray-200 flex flex-col justify-between hover:shadow-sm transition-shadow">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-gray-500 font-bold mb-1">إجمالي العملاء</p>
                        <h2 class="text-3xl font-bold text-[#0f1419]">@Model.TotalCustomers <span class="text-lg text-gray-500 font-normal">عميل</span></h2>
                    </div>
                    <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-gray-50">
                        <i data-lucide="users" class="text-[#0f1419] text-xl"></i>
                    </div>
                </div>
                <div class="mt-4 pt-4 border-t border-gray-200 flex justify-between items-center text-sm">
                    <span class="text-gray-500 font-bold text-sm">نشط هذا الشهر</span>
                    <span class="font-bold text-[#0f1419]">@Model.ActiveCustomersCount عميل</span>
                </div>
            </div>

            <div class="bg-white rounded-2xl p-6 border border-gray-200 flex flex-col justify-between hover:shadow-sm transition-shadow">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-gray-500 font-bold mb-1">حالة المخزون</p>
                        <h2 class="text-3xl font-bold text-[#0f1419]">@Model.TotalProducts <span class="text-lg text-gray-500 font-normal">قطعة</span></h2>
                    </div>
                    <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-gray-50">
                        <i data-lucide="package" class="text-[#0f1419] text-xl"></i>
                    </div>
                </div>
                <div class="mt-4 pt-4 border-t border-gray-200 flex justify-between items-center text-sm">
                    <span class="text-gray-500 font-bold text-sm">القيمة التقديرية</span>
                    <span class="font-bold text-[#0f1419]">@Model.StockTotalValue.ToString("C")</span>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm">
        <div class="p-6 flex justify-between items-center mb-2 border-b border-gray-50">
            <h3 class="font-bold text-[#0f1419]">أحدث العمليات</h3>
            <a asp-controller="Sales" asp-action="Index" class="text-sm font-bold text-gray-500 hover:text-[#0f1419] transition-colors">عرض الكل</a>
        </div>

        @if (Model.RecentSales.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-right">
                    <thead class="bg-gray-50 text-gray-500 text-sm">
                        <tr>
                            <th class="px-6 py-4 font-medium">رقم الطلب</th>
                            <th class="px-6 py-4 font-medium">العميل</th>
                            <th class="px-6 py-4 font-medium">التاريخ</th>
                            <th class="px-6 py-4 font-medium">المبلغ</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var sale in Model.RecentSales)
                        {
                            <tr class="hover:bg-gray-50 transition-colors text-sm">
                                <td class="px-6 py-4 font-bold text-[#0f1419]">#@sale.Id</td>
                                <td class="px-6 py-4 text-[#0f1419] font-bold">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-[#0f1419]">
                                            @(sale.Customer?.FullName?.Substring(0, 1) ?? "ع")
                                        </div>
                                        @sale.Customer?.FullName
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-gray-500 text-xs" dir="ltr">@sale.SaleDate.ToString("yyyy-MM-dd")</td>
                                <td class="px-6 py-4 font-bold text-[#0f1419]">@sale.TotalAmount.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-12">
                <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="inbox" class="text-gray-500 text-2xl w-10 h-10"></i>
                </div>
                <p class="text-gray-500 font-medium">لا توجد مبيعات حديثة</p>
            </div>
        }
    </section>

</div>

@* Setup Wizard Partial *@
<partial name="_SetupWizard" />


