@{
    Layout = null;
}
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ZENITH ERP | نظام متكامل لادارة البيزنس</title>
    <script src="~/lib/tailwindcss/tailwind.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/cairo-font.css" />
    <script src="~/js/tailwind-theme.js"></script>
    <link href="~/css/landing.css" rel="stylesheet" />
</head>
<body class="bg-[#fafafa] text-black antialiased">
    <div id="loader" class="fixed inset-0 z-[9999] flex items-center justify-center bg-white transition-opacity duration-700">
        <div class="loader-stage">
            <div class="loader-icon-wrap">
                <div class="loader-core"></div>
                <img src="~/logo.webp" alt="Cropped Circle Image" class="loader-icon">
            </div>
            <div class="loader-wordmark-wrap">
                <div class="loader-wordmark">ZENITH</div>
            </div>
        </div>
    </div>

    <nav class="fixed top-4 md:top-8 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-24px)] md:w-[calc(100%-80px)] max-w-[1200px]">
        <div class="bg-white/85 backdrop-blur-xl border border-black/5 px-4 md:px-8 py-3 rounded-full shadow-[0_20px_50px_rgba(0,0,0,0.05)] flex items-center justify-between">
            <a href="#home" class="flex items-center gap-2.5 group">
                <img src="~/logo.webp" alt="Zenith Logo" class="w-9 h-9 object-contain transition-transform group-hover:scale-110">
                <span class="font-bold text-lg tracking-tight">ZENITH</span>
            </a>
            <button id="menuBtn" aria-label="فتح القائمة" class="md:hidden px-3 py-2 rounded-full border border-black/10 inline-flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M4 7h16M4 12h16M4 17h16"></path>
                </svg>
            </button>
            <div id="menu" class="hidden md:flex items-center gap-6 lg:gap-10">
                <a href="#home" class="nav-link">الرئيسية</a>
                <a href="#services" class="nav-link">المزايا</a>
                <a href="#benefits" class="nav-link">الخدمات</a>
                <a href="#pricing" class="nav-link">الاسعار</a>
                <a href="#success-stories" class="nav-link">قصص النجاح</a>
            </div>
            <a asp-controller="Auth" asp-action="Register" class="hidden md:flex bg-black text-white px-7 py-2.5 rounded-full font-bold text-[13px] items-center gap-2 hover:scale-105 transition-all">
                ابدأ الآن <span>↖</span>
            </a>
        </div>
        <div id="mobileMenu" class="hidden mt-3 bg-white rounded-2xl p-4 border border-black/5 shadow-lg md:hidden">
            <div class="flex flex-col gap-3">
                <a href="#home" class="nav-link">الرئيسية</a>
                <a href="#services" class="nav-link">المزايا</a>
                <a href="#benefits" class="nav-link">الخدمات</a>
                <a href="#pricing" class="nav-link">الاسعار</a>
                <a href="#success-stories" class="nav-link">قصص النجاح</a>
                <a asp-controller="Auth" asp-action="Login" class="nav-link">تسجيل الدخول</a>
                <a asp-controller="Auth" asp-action="Register" class="nav-link">إنشاء حساب</a>
            </div>
        </div>
    </nav>

    <main>
        <section id="home" class="relative pt-36 pb-20 md:pb-32 px-5 md:px-10 max-w-[1440px] mx-auto min-h-screen overflow-hidden">
            <!-- Decorative Background Elements -->
            <div class="absolute top-60 left-20 w-[600px] h-[600px] bg-[#e4e4e7]/20 blur-[150px] rounded-full -z-10"></div>

            <!-- Floating Icons - Left -->
            <div class="absolute left-[14%] top-[36%] bg-[#315f8f] p-2 rounded-full shadow-xl hidden lg:block z-20 floating">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#e4e4e7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </div>
            <div class="absolute left-[10%] top-[39%] bg-white border border-gray-100 p-2 rounded-full shadow-lg hidden lg:block z-20 floating-delayed">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 3 7.07 16.97 2.51-7.39 7.39-2.51L3 3z"></path><path d="m13 13 6 6"></path></svg>
            </div>
            <div class="absolute left-[14%] top-[42%] bg-[#e4e4e7] p-2 rounded-full shadow-md hidden lg:block z-20 floating">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
            </div>
 
            <!-- Floating Icons - Right -->
            <div class="absolute right-[14%] top-[40%] bg-white border border-gray-100 p-2.5 rounded-full shadow-xl hidden lg:block z-20 floating">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#315f8f]"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path></svg>
            </div>
            <div class="absolute right-[10%] top-[37%] bg-[#e4e4e7] p-2 rounded-full shadow-lg hidden lg:block z-20 floating-reverse">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"></line><line x1="18" y1="20" x2="18" y2="4"></line><line x1="6" y1="20" x2="6" y2="16"></line></svg>
            </div>

            <div class="flex flex-col items-center text-center mb-12 relative z-10 reveal">
                <h1 class="text-4xl md:text-[65px] font-bold leading-[1.1] tracking-tight max-w-[900px]">
                    نظام واحد لادارة كل العمليات المالية <span class="text-[#315f8f]">لمشروعك</span> .
                </h1>
                <p class="text-black/60 text-base md:text-lg font-medium max-w-[700px] leading-relaxed mt-6">
                    يجمع Zenith ERP بين التشغيل التجاري والانضباط المالي مع AI مدمج يحلل بياناتك تلقائيا، يبني تقارير ذكية، ويقترح قرارات اسرع <span class="text-[#315f8f]">لزيادة الربحية وتقليل المخاطر</span>.
                </p>
                <div class="flex flex-wrap justify-center gap-4 mt-8">
                    <a asp-controller="Auth" asp-action="Register" class="bg-[#0f1419] text-[#f6f7f8] px-9 py-3 rounded-full font-bold text-base hover:scale-105 transition-all shadow-xl shadow-black/10">ابدأ الآن</a>
                    <a href="#services" class="bg-[#f6f7f8] text-[#0f1419] border-2 border-[#0f1419]/5 px-9 py-3 rounded-full font-bold text-base hover:bg-[#e4e4e7] transition-all">اعرف أكتر</a>
                </div>
                <div class="mt-10 flex flex-col items-center gap-2 opacity-90 reveal">
                    <div class="flex gap-1.5 items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#facc15" stroke="#facc15"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#facc15" stroke="#facc15"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#facc15" stroke="#facc15"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#facc15" stroke="#facc15"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#facc15" stroke="#facc15"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <span class="mr-2 font-extrabold text-lg text-[#0f1419]">5.0</span>
                    </div>
                    <p class="font-bold text-[11px] uppercase tracking-[0.2em] text-[#0f1419]/40">من أكثر من 2500 عميل سعيد</p>
                </div>
            </div>

            <!-- Dynamic Grid Layout -->
            <div class="max-w-[1200px] mx-auto hero-cards-grid items-end -mt-32 relative z-10">
                <!-- Card 1: Edge -->
                <div class="md:col-span-5 h-[350px] bg-[#0f1419] rounded-2xl overflow-hidden relative shadow-xl reveal">
                    <img src="~/img/governance_dark.webp" alt="حوكمة ذكية" class="absolute inset-0 w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-6">
                        <p class="text-white font-bold text-lg">حوكمة مالية</p>
                        <p class="text-white/90 text-[13px] leading-relaxed font-bold">
                            تحكم كامل في تفاصيل <span class="text-[#315f8f]">مشروعك</span> <br/>
                            متابعة دقيقة للسيولة <br/>
                            تقارير ذكية لقراراتك
                        </p>
                    </div>
                </div>

                <!-- Card 2: Narrow -->
                <div class="md:col-span-4 h-[280px] bg-[#315f8f] rounded-xl p-6 flex flex-col justify-center items-center text-center text-white shadow-xl shadow-[#315f8f]/20 reveal">
                    <h3 class="text-4xl font-bold mb-2 tracking-tighter text-white">99.9%</h3>
                    <p class="text-white/60 text-[12px] font-bold uppercase tracking-widest leading-tight">استقرار النظام <br/> والمزامنة</p>
                </div>

                <!-- Card 3: Middle (Total Projects) - Sync with Reference Image -->
                <div class="md:col-span-6 h-[210px] bg-white border border-black/10 rounded-xl p-6 shadow-[0_20px_60px_rgba(0,0,0,0.03)] flex flex-col justify-between reveal">
                    <div class="flex items-center justify-between">
                        <div class="bg-[#315f8f]/10 p-2.5 rounded-xl">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#315f8f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                        </div>
                        <div class="text-black/20">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"></circle><circle cx="12" cy="5" r="1"></circle><circle cx="12" cy="19" r="1"></circle></svg>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <p class="text-black/40 font-bold text-[10px] uppercase tracking-widest">إجمالي العمليات</p>
                            <div class="flex items-center gap-1.5">
                                <div class="bg-[#315f8f] w-5 h-5 rounded-full flex items-center justify-center shadow-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
                                </div>
                                <span class="text-[13px] font-bold text-[#315f8f]">8%</span>
                            </div>
                        </div>
                        <h3 class="text-4xl font-bold text-black mb-3 tracking-tighter">1951<span class="text-black">+</span></h3>
                        <p class="text-black/50 text-[12px] font-bold tracking-tight">زيادة بمقدار <span class="text-[#315f8f]">126</span> هذا الشهر</p>
                    </div>
                </div>

                <!-- Card 4: Narrow -->
                <div class="md:col-span-4 h-[280px] bg-[#e4e4e7] rounded-xl p-6 flex flex-col justify-center items-center text-center shadow-xl reveal">
                    <h3 class="text-4xl font-bold text-black mb-2 tracking-tighter">1800+</h3>
                    <p class="text-black/40 text-[13px] font-bold uppercase tracking-widest leading-tight">عملية بيع <br/> يومية ناجحة</p>
                </div>

                <!-- Card 5: Edge - React Inspired Background -->
                <div class="md:col-span-5 h-[350px] bg-[#0f1419] rounded-2xl p-8 flex flex-col justify-end text-white relative overflow-hidden shadow-2xl reveal">
                    <!-- Dot Matrix Grid (from React) -->
                    <div class="absolute inset-0 opacity-[0.05] pointer-events-none" 
                         style="background-image: radial-gradient(#f6f7f8 1px, transparent 1px); background-size: 20px 20px;"></div>

                    <!-- Top Wave (from React) -->
                    <div class="absolute top-0 right-0 w-full opacity-10 rotate-180">
                        <svg viewBox="0 0 200 100" class="w-full h-32">
                            <path d="M0,80 C50,0 150,100 200,20" fill="none" stroke="#f6f7f8" stroke-width="4" stroke-linecap="round" />
                        </svg>
                    </div>

                    <div class="relative z-10">
                        <div class="mb-8 mt-6 text-white/90">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>
                        </div>
                        <p class="text-xl md:text-2xl font-medium leading-[1.2] tracking-tight">
                            حقق أقصى <br/> 
                            كفاءة لعملياتك <br/> 
                            وضاعف إنتاجيتك
                        </p>
                    </div>

                    <!-- Bottom Wave (from React) -->
                    <div class="absolute bottom-0 left-0 w-full opacity-20">
                        <svg viewBox="0 0 200 100" class="w-full h-24">
                            <path d="M0,80 C50,100 150,0 200,80" fill="none" stroke="#f6f7f8" stroke-width="8" stroke-linecap="round" />
                        </svg>
                    </div>
                </div>
            </div>
        </section>

        <section id="services" class="bg-black py-20 md:py-32 px-5 md:px-10">
            <div class="max-w-[1200px] mx-auto">
                <div class="text-center mb-16 reveal">
                    <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight">أهم مزايا Zenith ERP AI</h2>
                    <p class="text-white/40 text-lg max-w-[720px] mx-auto font-medium">نظام مالي متكامل بذكاء اصطناعي مدمج في التقارير والتحليل والتنبؤ لدعم التشغيل والتحصيل والنمو.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- Service 1 -->
                    <article class="service-card reveal group bg-white/5 border border-white/10 p-8 rounded-2xl hover:bg-white/[0.08] transition-all cursor-pointer relative overflow-hidden">
                        <div class="absolute top-8 left-8 text-white/20 group-hover:text-white transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="17" x2="7" y2="7"></line><polyline points="7 17 7 7 17 7"></polyline></svg>
                        </div>
                        <div class="mb-8">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2 tracking-tight">الادارة المالية الشاملة</h3>
                        <p class="text-white/40 leading-relaxed font-medium">لوحة تنفيذية موحدة لمؤشرات الاداء، الربحية، والمصروفات في الوقت الفعلي.</p>
                    </article>

                    <!-- Service 2 -->
                    <article class="service-card reveal group bg-white/5 border border-white/10 p-8 rounded-2xl hover:bg-white/[0.08] transition-all cursor-pointer relative overflow-hidden">
                        <div class="absolute top-8 left-8 text-white/20 group-hover:text-white transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="17" x2="7" y2="7"></line><polyline points="7 17 7 7 17 7"></polyline></svg>
                        </div>
                        <div class="mb-8">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2 tracking-tight">المبيعات والاقساط</h3>
                        <p class="text-white/40 leading-relaxed font-medium">دعم سيناريوهات الدفع النقدي والاجل والجزئي مع جدولة اقساط دقيقة وتنبيهات تحصيل.</p>
                    </article>

                    <!-- Service 3 -->
                    <article class="service-card reveal group bg-white/5 border border-white/10 p-8 rounded-2xl hover:bg-white/[0.08] transition-all cursor-pointer relative overflow-hidden">
                        <div class="absolute top-8 left-8 text-white/20 group-hover:text-white transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="17" x2="7" y2="7"></line><polyline points="7 17 7 7 17 7"></polyline></svg>
                        </div>
                        <div class="mb-8">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2 tracking-tight">حوكمة المخزون</h3>
                        <p class="text-white/40 leading-relaxed font-medium">تتبع محاسبي وتشغيلي لحركة الاصناف مع مستويات حد ادنى وتنبيهات نقص مؤتمتة.</p>
                    </article>

                    <!-- Service 4 -->
                    <article class="service-card reveal group bg-white/5 border border-white/10 p-8 rounded-2xl hover:bg-white/[0.08] transition-all cursor-pointer relative overflow-hidden">
                        <div class="absolute top-8 left-8 text-white/20 group-hover:text-white transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="17" x2="7" y2="7"></line><polyline points="7 17 7 7 17 7"></polyline></svg>
