        <script>
            let currentStoryIdx = 0;
            const storyItems = document.querySelectorAll('.story-item');

            function updateSlider() {
                storyItems.forEach((item, index) => {
                    if (index === currentStoryIdx) {
                        item.classList.replace('opacity-0', 'opacity-100');
                        item.classList.replace('pointer-events-none', 'pointer-events-auto');
                    } else {
                        item.classList.replace('opacity-100', 'opacity-0');
                        item.classList.replace('pointer-events-auto', 'pointer-events-none');
                    }
                });
            }

            function nextStory() {
                currentStoryIdx = (currentStoryIdx + 1) % storyItems.length;
                updateSlider();
            }

            function prevStory() {
                currentStoryIdx = (currentStoryIdx - 1 + storyItems.length) % storyItems.length;
                updateSlider();
