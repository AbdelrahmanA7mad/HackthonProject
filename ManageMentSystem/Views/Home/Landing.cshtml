@{
    Layout = null;
}
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zenith ERP | تجربة تشغيل مستقبلية</title>
    <meta name="description" content="تصميم حديث جدًا لإدارة المتجر والمبيعات والمخزون والعملاء من لوحة واحدة واضحة." />

    <script src="~/lib/tailwindcss/tailwind.js"></script>
    <script src="~/js/tailwind-theme.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="~/css/cairo-font.css" rel="stylesheet">

    <style>
        :root{
            --ink:#0a1024;
            --ink-soft:#2d3753;
            --line:#d8e1f3;
            --glass:rgba(255,255,255,.64);
        }
        *{box-sizing:border-box}
        html{scroll-behavior:smooth}
        body{
            margin:0;
            font-family:"Cairo",sans-serif;
            color:var(--ink);
            background:
                radial-gradient(1200px 700px at 15% -15%, #dbeafe 0%, transparent 65%),
                radial-gradient(980px 620px at 95% 5%, #e2e8f0 0%, transparent 60%),
                linear-gradient(170deg,#f8fafc 0%,#f1f5f9 52%,#f8fafc 100%);
            overflow-x:hidden;
        }

        .nav-shell{
            background:var(--glass);
            backdrop-filter:blur(12px);
            border:1px solid rgba(148,163,184,.28);
        }

        .hero{
            min-height:calc(100vh - 5rem);
            position:relative;
            display:flex;
            align-items:center;
            overflow:hidden;
            isolation:isolate;
        }
        .hero-grid{
            position:absolute;inset:0;z-index:-3;pointer-events:none;
            background-image:
                linear-gradient(rgba(15,23,42,.07) 1px, transparent 1px),
                linear-gradient(90deg, rgba(15,23,42,.07) 1px, transparent 1px);
            background-size:42px 42px;
            mask-image:radial-gradient(ellipse 70% 60% at 50% 42%, #000 48%, transparent 100%);
            animation:gridDrift 22s linear infinite, gridTint 10s ease-in-out infinite alternate;
        }
        .hero-noise{
            position:absolute;inset:0;z-index:-2;pointer-events:none;opacity:.17;
            background-image:radial-gradient(rgba(15,23,42,.3) .5px, transparent .5px);
            background-size:3px 3px;
        }
        .blob{
            position:absolute;z-index:-1;pointer-events:none;border-radius:999px;filter:blur(70px);
            animation:floaty 14s ease-in-out infinite;
        }
        .b1{width:560px;height:560px;top:-170px;right:-160px;background:radial-gradient(circle,#cbd5e1 0%,#94a3b8 58%,transparent 74%)}
        .b2{width:520px;height:520px;bottom:-220px;left:-130px;background:radial-gradient(circle,#e2e8f0 0%,#cbd5e1 56%,transparent 75%);animation-delay:2.5s}
        .b3{width:360px;height:360px;top:42%;left:48%;background:radial-gradient(circle,#cbd5e1 0%,transparent 70%);animation-delay:1.2s}

        .headline{letter-spacing:-.03em;text-wrap:balance}
        .gradient-word{
            background:linear-gradient(135deg,#0f172a 0%,#1e293b 55%,#334155 100%);
            -webkit-background-clip:text;background-clip:text;color:transparent;
        }

        .btn-main{
            background:linear-gradient(135deg,#0f172a 0%,#1e293b 56%,#334155 100%);
            color:#fff;
            box-shadow:0 18px 36px rgba(15,23,42,.24);
            transition:.28s ease;
        }
        .btn-main:hover{transform:translateY(-2px) scale(1.01);box-shadow:0 22px 42px rgba(15,23,42,.32)}

        .orbit-shell{
            position:relative;
            border-radius:28px;
            background:rgba(255,255,255,.62);
            border:1px solid rgba(148,163,184,.35);
            backdrop-filter:blur(10px);
            box-shadow:0 20px 44px rgba(15,23,42,.11);
        }
        .ring{
            position:absolute;inset:-34px;pointer-events:none;z-index:-1;
            background:conic-gradient(from 120deg, rgba(148,163,184,.18), rgba(100,116,139,.12), rgba(203,213,225,.18), rgba(148,163,184,.18));
            filter:blur(26px);
            border-radius:999px;
        }

        .chip{
            border:1px solid var(--line);
            background:rgba(255,255,255,.78);
            transition:.22s ease;
        }
        .chip:hover{transform:translateY(-2px);border-color:#b8c7e8}

        .feature-card{
            position:relative;overflow:hidden;
            border:1px solid #d8e1f3;background:rgba(255,255,255,.86);
            border-radius:26px;transition:.28s ease;
        }
        .feature-card::before{
            content:"";position:absolute;inset:-30% -20% auto auto;width:170px;height:170px;border-radius:999px;
            background:radial-gradient(circle,rgba(148,163,184,.24) 0%,transparent 70%);
            pointer-events:none;
        }
        .feature-card:hover{transform:translateY(-6px);border-color:#bcd0f2;box-shadow:0 18px 34px rgba(15,23,42,.1)}

        .section-title{letter-spacing:-.02em;text-wrap:balance}
        .fade-up{opacity:0;transform:translateY(14px);transition:.55s ease}
        .fade-up.show{opacity:1;transform:translateY(0)}

        @@keyframes floaty{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(14px,-18px,0)}}
        @@keyframes gridDrift{
            0%{background-position:0 0,0 0}
            100%{background-position:42px 42px,42px 42px}
        }
        @@keyframes gridTint{
            0%{
                opacity:.75;
                filter:hue-rotate(0deg) saturate(100%);
            }
            50%{
                opacity:.95;
                filter:hue-rotate(-8deg) saturate(115%);
            }
            100%{
                opacity:.8;
                filter:hue-rotate(6deg) saturate(95%);
            }
        }
    </style>
</head>
<body>
    <nav class="sticky top-0 z-50 border-b border-slate-200/70 nav-shell">
        <div class="max-w-6xl mx-auto px-5 md:px-8 h-20 flex items-center justify-between">
            <a href="/" class="flex items-center">
                <img src="~/images/zenith_new_logo.webp" alt="Zenith ERP" class="w-28 h-12 object-contain" />
            </a>
            <div class="hidden md:flex items-center gap-8 text-[15px] font-bold text-slate-700">
                <a href="#features" class="hover:text-slate-950 transition">المزايا</a>
                <a href="#flow" class="hover:text-slate-950 transition">تجربة التشغيل</a>
                <a href="#cta" class="hover:text-slate-950 transition">ابدأ الآن</a>
            </div>
            <div class="flex items-center gap-3">
                <a asp-controller="Auth" asp-action="Login" class="hidden sm:inline-flex px-5 py-2.5 rounded-xl border border-slate-300 text-slate-700 font-bold hover:bg-white/80 transition">
                    تسجيل الدخول
                </a>
                <a asp-controller="Auth" asp-action="Register" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl btn-main font-bold">
                    إنشاء حساب
                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                </a>
            </div>
        </div>
    </nav>

    <main>
        <section class="hero">
            <div class="hero-grid"></div>
            <div class="hero-noise"></div>
            <div class="blob b1"></div>
            <div class="blob b2"></div>
            <div class="blob b3"></div>

            <div class="max-w-6xl mx-auto px-5 md:px-8 w-full py-12">
                <div class="text-center fade-up">
                    <p class="inline-flex px-4 py-1.5 rounded-full text-sm font-bold bg-white/70 border border-slate-200 text-slate-700">
                        تصميم مختلف. تجربة أسرع. نتائج أوضح.
                    </p>
                    <h1 class="headline mt-5 text-3xl md:text-5xl font-black leading-tight">
                        شغّل مشروعك
                        <span class="gradient-word">بذكاء بصري</span>
                        من أول نظرة
                    </h1>
                    <p class="mt-4 text-base md:text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
                        Zenith ERP يربط المبيعات والمخزون والعملاء والتقارير في تجربة حديثة
                        تعطيك وضوح كامل واتخاذ قرار أسرع كل يوم.
                    </p>
                    <div class="mt-8 flex flex-wrap justify-center gap-3">
                        <a asp-controller="Auth" asp-action="Register" class="btn-main inline-flex items-center gap-2 px-6 py-3 rounded-xl text-base font-bold">
                            جرّب مجانًا الآن
                            <i data-lucide="sparkles" class="w-4 h-4"></i>
                        </a>
                        <a href="#features" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-slate-300 bg-white/70 text-slate-800 text-base font-bold hover:bg-white transition">
                            استكشف التجربة
                            <i data-lucide="chevron-down" class="w-4 h-4"></i>
                        </a>
                    </div>
                </div>

                <div class="mt-8 max-w-3xl mx-auto orbit-shell p-3 md:p-4 fade-up">
                    <div class="ring"></div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                        <div class="chip rounded-xl px-4 py-3">
                            <p class="text-xs text-slate-500">مبيعات اليوم</p>
                            <p class="text-2xl font-black text-slate-900">+38 طلب</p>
                        </div>
                        <div class="chip rounded-xl px-4 py-3">
                            <p class="text-xs text-slate-500">تنبيهات المخزون</p>
                            <p class="text-2xl font-black text-slate-900">07 عناصر</p>
                        </div>
                        <div class="chip rounded-xl px-4 py-3">
                            <p class="text-xs text-slate-500">عملاء نشطين</p>
                            <p class="text-2xl font-black text-slate-900">342 عميل</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="features" class="py-20">
            <div class="max-w-6xl mx-auto px-5 md:px-8">
                <div class="text-center mb-12 fade-up">
                    <h2 class="section-title text-3xl md:text-5xl font-black">مزايا بروح تصميم غير تقليدية</h2>
                    <p class="mt-4 text-slate-600 text-lg">واجهة مبنية لتخدم سرعة التشغيل مش مجرد شكل.</p>
                </div>
                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                    <article class="feature-card p-7 fade-up">
                        <i data-lucide="shopping-cart" class="w-7 h-7"></i>
                        <h3 class="mt-4 text-xl font-extrabold">إدارة المبيعات</h3>
                        <p class="mt-2 text-slate-600">فواتير سريعة، خصومات مرنة، وتجربة بيع عملية.</p>
                    </article>
                    <article class="feature-card p-7 fade-up">
                        <i data-lucide="boxes" class="w-7 h-7"></i>
                        <h3 class="mt-4 text-xl font-extrabold">مخزون لحظي</h3>
                        <p class="mt-2 text-slate-600">تنبيهات قبل النفاد وتتبع واضح للحركة اليومية.</p>
                    </article>
                    <article class="feature-card p-7 fade-up">
                        <i data-lucide="users-round" class="w-7 h-7"></i>
                        <h3 class="mt-4 text-xl font-extrabold">رحلة عميل أفضل</h3>
                        <p class="mt-2 text-slate-600">بيانات موحدة لكل عميل تساعدك تبيع أكثر.</p>
                    </article>
                    <article class="feature-card p-7 fade-up">
                        <i data-lucide="message-circle-more" class="w-7 h-7"></i>
                        <h3 class="mt-4 text-xl font-extrabold">تكامل واتساب</h3>
                        <p class="mt-2 text-slate-600">إرسال فواتير ورسائل مباشرة من داخل النظام.</p>
                    </article>
                    <article class="feature-card p-7 fade-up">
                        <i data-lucide="bar-chart-3" class="w-7 h-7"></i>
                        <h3 class="mt-4 text-xl font-extrabold">تقارير تفاعلية</h3>
                        <p class="mt-2 text-slate-600">لقطات أداء واضحة تسهّل القرار اليومي.</p>
                    </article>
                    <article class="feature-card p-7 fade-up">
                        <i data-lucide="brain-circuit" class="w-7 h-7"></i>
                        <h3 class="mt-4 text-xl font-extrabold">مساعد ذكي</h3>
                        <p class="mt-2 text-slate-600">فهم أسرع للأرقام المهمة في لحظتها.</p>
                    </article>
                </div>
            </div>
        </section>

        <section id="flow" class="py-10 pb-20">
            <div class="max-w-6xl mx-auto px-5 md:px-8">
                <div class="grid lg:grid-cols-2 gap-8">
                    <div class="p-8 md:p-10 rounded-[28px] text-white relative overflow-hidden fade-up"
                         style="background:linear-gradient(145deg,#0f172a 0%,#1e293b 58%,#334155 100%)">
                        <div class="absolute -top-16 -left-14 w-52 h-52 rounded-full bg-white/10 blur-2xl"></div>
                        <p class="text-slate-200 font-bold">تجربة التشغيل</p>
                        <h2 class="section-title mt-3 text-3xl md:text-4xl font-black leading-tight">من الصفر للتشغيل خلال دقائق</h2>
                        <p class="mt-4 text-slate-100/90 leading-relaxed">مسار واضح وبسيط يخلّي الفريق يبدأ بسرعة وبدون تعقيد.</p>
                    </div>
                    <div class="space-y-4">
                        <div class="feature-card p-6 fade-up">
                            <p class="text-sm text-slate-500 font-bold">01</p>
                            <h3 class="text-xl font-extrabold">أنشئ حسابك</h3>
                            <p class="text-slate-600 mt-1">خطوة سريعة لبدء إعداد متجرك.</p>
                        </div>
                        <div class="feature-card p-6 fade-up">
                            <p class="text-sm text-slate-500 font-bold">02</p>
                            <h3 class="text-xl font-extrabold">أضف البيانات الأساسية</h3>
                            <p class="text-slate-600 mt-1">المنتجات، العملاء، وسياسات التشغيل.</p>
                        </div>
                        <div class="feature-card p-6 fade-up">
                            <p class="text-sm text-slate-500 font-bold">03</p>
                            <h3 class="text-xl font-extrabold">ابدأ البيع وتابع الأداء</h3>
                            <p class="text-slate-600 mt-1">من لوحة واحدة بمؤشرات واضحة.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="cta" class="pb-20">
            <div class="max-w-4xl mx-auto px-5 md:px-8">
                <div class="orbit-shell rounded-[34px] p-8 md:p-12 text-center fade-up">
                    <h2 class="section-title text-3xl md:text-5xl font-black">جاهز تشوف تصميم يوصل شغلك لمستوى تاني؟</h2>
                    <p class="mt-4 text-slate-600 text-lg">ابدأ مجانًا وخلّي إدارتك أسرع، أوضح، وأجمل.</p>
                    <div class="mt-8 flex flex-wrap justify-center gap-3">
                        <a asp-controller="Auth" asp-action="Register" class="btn-main inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold">
                            ابدأ الآن
                            <i data-lucide="arrow-left" class="w-4 h-4"></i>
                        </a>
                        <a asp-controller="Auth" asp-action="Login" class="inline-flex items-center px-8 py-4 rounded-xl border border-slate-300 text-slate-700 font-bold hover:bg-white transition">
                            تسجيل الدخول
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="border-t border-slate-200/80 bg-white/65 backdrop-blur">
        <div class="max-w-6xl mx-auto px-5 md:px-8 py-8 flex flex-col md:flex-row items-center justify-between gap-3">
            <p class="text-slate-700 font-bold" id="footer-year"></p>
            <p class="text-slate-500 text-sm">Zenith ERP - تصميم حديث لتشغيل أذكى</p>
        </div>
    </footer>

    <script>
        document.getElementById("footer-year").textContent = `© ${new Date().getFullYear()} Zenith ERP. جميع الحقوق محفوظة.`;
        lucide.createIcons();

        const observer = new IntersectionObserver((entries)=>{
            entries.forEach((e)=>{ if(e.isIntersecting){ e.target.classList.add("show"); observer.unobserve(e.target);} });
        }, { threshold:.2 });
        document.querySelectorAll(".fade-up").forEach((el)=>observer.observe(el));
    </script>
</body>
</html>
