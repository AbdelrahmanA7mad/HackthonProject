@{
    Layout = null;
}
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ZENITH ERP | نظام متكامل لادارة البيزنس</title>
    <script src="~/lib/tailwindcss/tailwind.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/cairo-font.css" />
    <script src="~/js/tailwind-theme.js"></script>
    <link href="~/css/landing.css" rel="stylesheet" />
</head>
<body class="bg-[#fafafa] text-black antialiased">
    <div id="loader" class="fixed inset-0 z-[9999] flex items-center justify-center bg-white transition-opacity duration-700">
        <div class="loader-stage">
            <div class="loader-icon-wrap">
                <div class="loader-core"></div>
                <img src="~/logo.png" alt="Cropped Circle Image" class="loader-icon">
            </div>
            <div class="loader-wordmark-wrap">
                <div class="loader-wordmark">ZENITH</div>
            </div>
        </div>
    </div>

    <nav class="fixed top-4 md:top-8 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-24px)] md:w-[calc(100%-80px)] max-w-[1200px]">
        <div class="bg-white/85 backdrop-blur-xl border border-black/5 px-4 md:px-8 py-3 rounded-full shadow-[0_20px_50px_rgba(0,0,0,0.05)] flex items-center justify-between">
            <a href="#home" class="flex items-center gap-2.5 group">
                <img src="~/logo.png" alt="Zenith Logo" class="w-9 h-9 object-contain transition-transform group-hover:scale-110">
                <span class="font-bold text-lg tracking-tight">ZENITH</span>
            </a>
            <button id="menuBtn" aria-label="فتح القائمة" class="md:hidden px-3 py-2 rounded-full border border-black/10 inline-flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M4 7h16M4 12h16M4 17h16"></path>
                </svg>
            </button>
            <div id="menu" class="hidden md:flex items-center gap-6 lg:gap-10">
                <a href="#home" class="nav-link">الرئيسية</a>
                <a href="#services" class="nav-link">الخدمات</a>
                <a href="#benefits" class="nav-link">المزايا</a>
                <a href="#pricing" class="nav-link">الاسعار</a>
                <a href="#integrations" class="nav-link">التكاملات</a>
            </div>
            <a asp-controller="Auth" asp-action="Register" class="hidden md:flex bg-black text-white px-7 py-2.5 rounded-full font-bold text-[13px] items-center gap-2 hover:scale-105 transition-all">
                ابدأ الآن <span>↗</span>
            </a>
        </div>
        <div id="mobileMenu" class="hidden mt-3 bg-white rounded-2xl p-4 border border-black/5 shadow-lg md:hidden">
            <div class="flex flex-col gap-3">
                <a href="#home" class="nav-link">الرئيسية</a>
                <a href="#services" class="nav-link">الخدمات</a>
                <a href="#benefits" class="nav-link">المزايا</a>
                <a href="#pricing" class="nav-link">الاسعار</a>
                <a href="#integrations" class="nav-link">التكاملات</a>
                <a asp-controller="Auth" asp-action="Login" class="nav-link">تسجيل الدخول</a>
                <a asp-controller="Auth" asp-action="Register" class="nav-link">إنشاء حساب</a>
            </div>
        </div>
    </nav>

    <main>
        <section id="home" class="relative pt-36 pb-20 md:pb-32 px-5 md:px-10 max-w-[1440px] mx-auto min-h-screen overflow-hidden">
            <div class="absolute top-60 left-20 w-[600px] h-[600px] bg-[#e4e4e7]/20 blur-[150px] rounded-full -z-10"></div>
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="orb orb-3"></div>
            <div class="flex flex-col items-center text-center mb-12 relative z-10 reveal">
                <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-black/10 bg-white/60 text-sm font-bold mb-5 micro-pill">Zenith ERP AI - منصة مالية ذكية لادارة العمليات والمدفوعات</span>
                <h1 class="text-4xl md:text-[65px] font-bold leading-[1.1] tracking-tight max-w-[900px]">
                    نظام واحد لادارة كل العمليات المالية لمشروعك .
                </h1>
                <p class="text-black/60 text-base md:text-lg font-medium max-w-[700px] leading-relaxed mt-6">
                    يجمع Zenith ERP بين التشغيل التجاري والانضباط المالي مع AI مدمج يحلل بياناتك تلقائيا، يبني تقارير ذكية، ويقترح قرارات اسرع لزيادة الربحية وتقليل المخاطر.
                </p>
                <div class="flex flex-wrap justify-center gap-4 mt-8">
                    <a asp-controller="Auth" asp-action="Register" class="bg-black text-white px-9 py-3 rounded-full font-bold text-base hover:scale-105 transition-all">إنشاء حساب</a>
                    <a asp-controller="Auth" asp-action="Login" class="bg-white text-black border-2 border-black/5 px-9 py-3 rounded-full font-bold text-base">تسجيل الدخول</a>
                </div>
            </div>
            <div class="max-w-[1000px] mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 relative z-10">
                <article class="metric-card reveal">
                    <p class="metric-number" data-target="99.9">0</p>
                    <p class="metric-label">استقرار النظام %</p>
                </article>
                <article class="metric-card reveal">
                    <p class="metric-number" data-target="1800">0</p>
                    <p class="metric-label">معاملة بيع يوميا</p>
                </article>
                <article class="metric-card reveal">
                    <p class="metric-number" data-target="120">0</p>
                    <p class="metric-label">تقرير ذكي تلقائي</p>
                </article>
                <article class="metric-card reveal">
                    <p class="metric-number" data-target="24">0</p>
                    <p class="metric-label">تنبيهات ومتابعة لحظية</p>
                </article>
            </div>
            <div class="data-strip reveal">
                <div class="ticker-card">
                    <p class="ticker-label">تحليل AI لحظي</p>
                    <p class="ticker-value">+<span class="live-value" data-live-min="12" data-live-max="38">12</span>%</p>
                    <p class="ticker-note">توقعات نمو الارباح اليوم</p>
                </div>
                <div class="bars-card" aria-label="مؤشر اداء مالي متحرك">
                    <div class="bars-grid">
                        <span class="bar bar-1"></span>
                        <span class="bar bar-2"></span>
                        <span class="bar bar-3"></span>
                        <span class="bar bar-4"></span>
                        <span class="bar bar-5"></span>
                        <span class="bar bar-6"></span>
                    </div>
                </div>
                <div class="ticker-card money-glow">
                    <p class="ticker-label">تدفق نقدي</p>
                    <p class="ticker-value">$<span class="live-value" data-live-min="420" data-live-max="980">420</span>K</p>
                    <p class="ticker-note">صافي المبيعات الشهري</p>
                </div>
            </div>
        </section>

        <section id="services" class="bg-black py-20 md:py-32 px-5 md:px-10">
            <div class="max-w-[1200px] mx-auto">
                <div class="text-center mb-16 reveal">
                    <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight">اهم مميزات Zenith ERP AI</h2>
                    <p class="text-white/40 text-lg max-w-[720px] mx-auto font-medium">نظام مالي متكامل بذكاء اصطناعي مدمج في التقارير والتحليل والتنبؤ لدعم التشغيل والتحصيل والنمو.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <article class="service-card reveal"><h3>الادارة المالية الشاملة</h3><p>لوحة تنفيذية موحدة لمؤشرات الاداء، الربحية، والمصروفات في الوقت الفعلي.</p></article>
                    <article class="service-card reveal"><h3>المبيعات والاقساط</h3><p>دعم سيناريوهات الدفع النقدي والاجل والجزئي مع جدولة اقساط دقيقة وتنبيهات تحصيل.</p></article>
                    <article class="service-card reveal"><h3>حوكمة المخزون</h3><p>تتبع محاسبي وتشغيلي لحركة الاصناف مع مستويات حد ادنى وتنبيهات نقص مؤتمتة.</p></article>
                    <article class="service-card reveal"><h3>ادارة العملاء والذمم</h3><p>ملفات عملاء موحدة، كشوف حساب تفصيلية، ومتابعة مديونيات واستحقاقات بشكل احترافي.</p></article>
                    <article class="service-card reveal"><h3>قنوات الدفع والتواصل</h3><p>ارسال الفواتير والتنبيهات عبر واتساب وقنوات رقمية مع تتبع حالة التسليم والتحصيل.</p></article>
                    <article class="service-card reveal"><h3>محرك AI للتقارير</h3><p>توليد تقارير مالية تلقائية مع ملخصات تنفيذية وتوصيات مباشرة قابلة للتنفيذ.</p></article>
                </div>
            </div>
        </section>

        <section id="benefits" class="bg-white py-20 md:py-32 px-5 md:px-10">
            <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-20 items-stretch">
                <div class="relative p-6 md:p-12 h-full reveal">
                    <div class="absolute inset-4 border border-black/10 rounded-[24px]"></div>
                    <img src="~/img/engineer.png" alt="لوحة تحكم مالية" class="relative z-10 w-full h-full min-h-[420px] object-cover rounded-2xl shadow-2xl">
                </div>
                <div class="reveal">
                    <h2 class="text-4xl md:text-5xl font-bold mb-6 leading-[1.1] tracking-tight">القيمة الاساسية من Zenith ERP</h2>
                    <p class="text-black/60 text-lg mb-10 font-medium max-w-[560px]">مصمم لفرق التشغيل والماليات التي تحتاج دقة اعلى وسرعة تنفيذ، مع AI يشرح الارقام ويكشف فرص التحسين تلقائيا.</p>
                    <div class="space-y-8">
                        <div><h3 class="text-xl font-bold mb-2">تحكم تشغيلي ومالي في واجهة واحدة</h3><p class="text-black/60">تشغيل يومي منظم بدون تضارب بين فرق المبيعات والمحاسبة.</p></div>
                        <div><h3 class="text-xl font-bold mb-2">قرارات مبنية على مؤشرات مالية</h3><p class="text-black/60">تحليل لحظي للايرادات والمصروفات والهوامش الربحية يدعم النمو بثقة.</p></div>
                        <div><h3 class="text-xl font-bold mb-2">مساعد AI داخل كل قسم</h3><p class="text-black/60">يدعم التقارير، التحصيل، ادارة المصروفات، والمتابعة التشغيلية برسائل وتوصيات ذكية.</p></div>
                    </div>
                </div>
            </div>
        </section>

        <section id="pricing" class="bg-[#0a0a0a] py-24 md:py-40 px-5 md:px-10">
            <div class="max-w-[1200px] mx-auto">
                <div class="text-center mb-16 reveal">
                    <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">خطط اسعار مرنة حسب حجم نشاطك</h2>
                    <p class="text-white/40 text-lg font-medium">ابدأ بالخطة المناسبة اليوم، وفعّل مزايا AI المتقدمة مع التوسع.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="price-card reveal">
                        <h3>Starter</h3>
                        <p>للشركات الصغيرة التي تبدأ التحول الرقمي المالي.</p>
                        <p class="price">$29 <span>/ شهريا</span></p>
                        <p>مبيعات، مخزون، حسابات اساسية وتقارير يومية.</p>
                    </div>
                    <div class="price-card reveal">
                        <h3>Growth AI</h3>
                        <p>الاكثر استخداما للنشاطات التي تحتاج نمو وتحليل ادق.</p>
                        <p class="price">$79 <span>/ شهريا</span></p>
                        <p>كل مزايا Starter + مساعد AI للتقارير والتوقعات والتنبيهات.</p>
                    </div>
                    <div class="price-card reveal">
                        <h3>Enterprise FinTech</h3>
                        <p>للفروع المتعددة وفرق الماليات ذات الاحتياج المتقدم.</p>
                        <p class="price">$149 <span>/ شهريا</span></p>
                        <p>كل مزايا Growth AI + صلاحيات متقدمة وتكاملات وتقارير تنفيذية.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="integrations" class="bg-white py-20 md:py-32 px-5 md:px-10">
            <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div class="reveal">
                    <h2 class="text-4xl md:text-5xl font-bold mb-8 leading-[1.1] tracking-tight">نتائج مدعومة بتحليل مالي ذكي</h2>
                    <p class="text-black/60 text-lg mb-10 font-medium">مع AI المدمج في Zenith ERP ستحصل على توقعات اوضح، تحصيل اسرع، وتحسين مستمر في هوامش الربح وتجربة العميل.</p>
                    <a asp-controller="Auth" asp-action="Register" class="inline-flex bg-[#e4e4e7] text-black px-10 py-4 rounded-full font-bold text-lg hover:scale-105 transition-transform">ابدأ الآن</a>
                </div>
                <div class="h-[380px] md:h-[500px] bg-[#f4f4f5] rounded-2xl flex items-center justify-center reveal pulse-border">
                    <div class="text-center">
                        <p class="font-bold mt-4 text-black/60">منصة تشغيل مالي متكاملة</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="bg-black py-24 md:py-32 px-5 md:px-10 text-center">
            <h2 class="text-4xl md:text-6xl font-bold text-white mb-8 reveal">Zenith ERP AI هو الحل الشامل لاي مشروع</h2>
            <p class="text-white/40 text-lg md:text-xl font-medium max-w-[760px] mx-auto mb-10 reveal">اذا كنت تبحث عن منصة FinTech بذكاء اصطناعي مدمج في كل التفاصيل، Zenith ERP يمنحك تحكما كاملا من اول عملية بيع حتى التقارير الختامية.</p>
            <a asp-controller="Auth" asp-action="Register" class="inline-flex bg-[#e4e4e7] text-black px-12 py-4 rounded-full font-bold text-lg hover:scale-105 transition-transform reveal">ابدأ الآن</a>
        </section>
    </main>

    <footer class="bg-[#0a0a0a] pt-16 pb-10 px-5 md:px-10 border-t border-white/5">
        <div class="max-w-[1200px] mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-10">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <img src="~/logo.png" alt="Zenith Logo" class="w-10 h-10 object-contain">
                        <p class="text-white font-extrabold tracking-wide">ZENITH ERP</p>
                    </div>
                    <p class="text-white/45 text-sm leading-7">حل متكامل لادارة المبيعات، الاقساط، المخزون، العملاء والحسابات في منصة واحدة سريعة وسهلة.</p>
                </div>
                <div>
                    <h3 class="text-white font-bold mb-4">روابط سريعة</h3>
                    <div class="flex flex-col gap-3">
                        <a href="#home" class="text-white/40 hover:text-white transition-colors text-sm">الرئيسية</a>
                        <a href="#services" class="text-white/40 hover:text-white transition-colors text-sm">المميزات</a>
                        <a href="#benefits" class="text-white/40 hover:text-white transition-colors text-sm">القيمة الاساسية</a>
                        <a href="#integrations" class="text-white/40 hover:text-white transition-colors text-sm">النتائج</a>
                    </div>
                </div>
                <div>
                    <h3 class="text-white font-bold mb-4">وسائل التواصل</h3>
                    <div class="flex flex-col gap-3">
                        <a href="tel:+201000000000" class="text-white/40 hover:text-white transition-colors text-sm">+20 100 000 0000</a>
                        <a href="mailto:info@zenitherp.com" class="text-white/40 hover:text-white transition-colors text-sm">info@zenitherp.com</a>
                        <a href="#" class="text-white/40 hover:text-white transition-colors text-sm">واتساب الدعم</a>
                        <a href="#" class="text-white/40 hover:text-white transition-colors text-sm">حجز ديمو مجاني</a>
                    </div>
                </div>
                <div>
                    <h3 class="text-white font-bold mb-4">النشرة البريدية</h3>
                    <p class="text-white/40 text-sm mb-4">ابدأ الآن مع منصة مالية ذكية تساعدك على النمو.</p>
                    <a asp-controller="Auth" asp-action="Register" class="inline-flex bg-white text-black text-sm font-bold px-5 py-2.5 rounded-xl hover:opacity-90 transition-opacity">إنشاء حساب</a>
                </div>
            </div>
            <div class="pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
                <p class="text-white/25 text-sm font-medium">© 2026 ZENITH ERP. جميع الحقوق محفوظة.</p>
                <div class="flex items-center gap-6">
                    <a href="#" class="text-white/25 hover:text-white transition-colors text-sm font-medium">سياسة الخصوصية</a>
                    <a href="#" class="text-white/25 hover:text-white transition-colors text-sm font-medium">شروط الاستخدام</a>
                </div>
            </div>
        </div>
    </footer>

    @* <script src="./script.js"></script> *@
    <script src="~/js/landing.js"></script>
</body>
</html>

