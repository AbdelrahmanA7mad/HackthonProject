    <!-- How It Works - Treasure Map Style -->
    <section id="how-it-works" class="py-20  from-gray-100 via-gray-50 to-gray-100 relative overflow-hidden">
        <!-- Background Pattern -->
        <div class="absolute inset-0 opacity-5" style="background-image: repeating-linear-gradient(45deg, #3730a3 0px, #3730a3 1px, transparent 1px, transparent 20px);"></div>
        
        <div class="max-w-6xl mx-auto px-6 relative z-10">
            <div class="text-center mb-16">
                <span class="inline-block px-6 py-2 rounded-full bg-gray-50 text-zen-success font-bold">
                    🗺️ خارطة طريق
                </span>
                <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 flex items-center justify-center gap-3">
                    خطوات بسيطة تقدم كبير
                </h2>
                <p class="text-xl text-gray-700 font-medium">
                    رحلتك لتطوير مشروعك في 4 خطوات بسيطة
                </p>
            </div>

            <!-- Treasure Map Path -->
            <div class="treasure-map relative">
                <!-- SVG Path -->
                <svg class="treasure-path" viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="pathGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                            <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1" />
                            <stop offset="100%" style="stop-color:#3730a3;stop-opacity:1" />
                        </linearGradient>
                    </defs>
                    <path d="M 100 200 Q 250 100, 350 200 T 700 200" 
                          stroke="url(#pathGradient)" 
                          stroke-width="4" 
                          stroke-dasharray="8,8"
                          fill="none"
                          class="animate-path"/>
                </svg>

                <!-- Step 1 -->
                <div class="treasure-step" style="left: 8%; top: 50%;">
                    <div class="step-marker bg-[#0f1419]">
                        <i data-lucide="user-plus" class="text-3xl text-white w-10 h-10"></i>
                        <span class="step-number">1</span>
                    </div>
                    <div class="step-content">
                        <h3 class="text-xl font-bold text-gray-900 mb-2">إنشاء حساب</h3>
                        <p class="text-gray-600 text-sm font-bold">سجل في ثوانٍ وابدأ رحلتك</p>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="treasure-step" style="left: 32%; top: 25%;">
                    <div class="step-marker bg-[#0f1419]">
                        <i data-lucide="package" class="text-3xl text-white w-10 h-10"></i>
                        <span class="step-number">2</span>
                    </div>
                    <div class="step-content">
                        <h3 class="text-xl font-bold text-gray-900 mb-2">إضافة منتجاتك</h3>
                        <p class="text-gray-600 text-sm font-bold">سجل مخزونك بسهولة</p>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="treasure-step" style="left: 56%; top: 50%;">
                    <div class="step-marker bg-[#0f1419]">
                        <i data-lucide="shopping-cart" class="text-3xl text-white w-10 h-10"></i>
                        <span class="step-number">3</span>
                    </div>
                    <div class="step-content">
                        <h3 class="text-xl font-bold text-gray-900 mb-2">إدارة المبيعات</h3>
                        <p class="text-gray-600 text-sm font-bold">سجل معاملاتك بسرعة</p>
                    </div>
                </div>

                <!-- Step 4 - Treasure! -->
                <div class="treasure-step treasure-final" style="left: 85%; top: 50%;">
                    <div class="step-marker bg-[#0f1419] treasure-glow">
                        <i data-lucide="trophy" class="text-4xl text-white w-12 h-12"></i>
                        <span class="step-number">4</span>
                        <div class="treasure-shine"></div>
                    </div>
                    <div class="step-content">
                        <h3 class="text-lg font-bold text-primary mb-2 flex items-center gap-2">
                            <i data-lucide="trending-up" class="text-gray-600 w-5 h-5"></i>  تقارير شاملة
                        </h3>
                        <p class="text-gray-700 text-sm font-bold">راقب نمو عملك بالتقارير</p>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .treasure-map {
                position: relative;
                min-height: 500px;
                margin-top: 3rem;
            }

            .treasure-path {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: 1;
            }

            .animate-path {
                animation: dash 3s linear infinite;
            }

            @@keyframes dash {
                to { stroke-dashoffset: -16; }
            }

            .treasure-step {
                position: absolute;
                transform: translate(-50%, -50%);
                z-index: 10;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 1rem;
            }

            .step-marker {
                width: 100px;
                height: 100px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 10px 30px rgba(0,0,0,0.2);
                border: 4px solid white;
                position: relative;
                transition: all 0.3s ease;
                cursor: pointer;
            }

            .step-marker:hover {
                transform: scale(1.15) rotate(5deg);
                box-shadow: 0 15px 40px rgba(0,0,0,0.3);
            }

            .step-number {
                position: absolute;
                top: -10px;
                right: -10px;
                width: 35px;
                height: 35px;
                background: white;
                color: #1f2937;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: bold;
                font-size: 1.1rem;
                box-shadow: 0 4px 10px rgba(0,0,0,0.2);
                border: 3px solid #1e3a8a;
            }

            .step-content {
                background: white;
                padding: 1rem 1.5rem;
                border-radius: 1rem;
                box-shadow: 0 8px 20px rgba(0,0,0,0.1);
                text-align: center;
                border: 2px solid #1e3a8a;
                max-width: 200px;
            }

            .treasure-final .step-marker {
                animation: treasure-pulse 2s ease-in-out infinite;
            }

            .treasure-glow {
                box-shadow: 0 0 30px rgba(55, 48, 163, 0.6), 0 
                
                
                px 40px rgba(0,0,0,0.3);
            }

            .treasure-shine {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                border-radius: 50%;
                background: linear-gradient(45deg, transparent, rgba(255,255,255,0.3), transparent);
                animation: shine 2s linear infinite;
            }

            @@keyframes treasure-pulse {
                0%, 100% { transform: scale(1); }
                50% { transform: scale(1.1); }
            }

            @@keyframes shine {
                0% { transform: translateX(-100%) rotate(45deg); }
                100% { transform: translateX(100%) rotate(45deg); }
            }

            @@media (max-width: 768px) {
                .treasure-map { 
                    min-height: auto;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    gap: 3rem;
                    padding-bottom: 3rem;
                }
                .treasure-step { 
                    position: relative !important; 
                    left: auto !important; 
                    top: auto !important; 
                    transform: none !important; 
                    margin-bottom: 0; 
                }
                
                /* Reset individual positioning for mobile */
                .treasure-step:nth-child(2), 
                .treasure-step:nth-child(3), 
                .treasure-step:nth-child(4), 
                .treasure-step:nth-child(5) { 
                    top: auto !important; 
                }

                .treasure-path { display: none; }
                .step-marker { width: 80px; height: 80px; }
                .step-marker i { font-size: 1.5rem !important; }
            }
        </style>
    </section>

    <!-- Detailed Features -->
    <section id="detailed-features" class="py-20 bg-white">
