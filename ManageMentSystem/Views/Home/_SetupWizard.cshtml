@model dynamic

@{
    var showWizard = ViewBag.NeedsInitialSetup == true;
}

@if (showWizard)
{
    <div id="setupWizardModal" class="fixed inset-0 bg-gray-900 bg-opacity-75 flex items-center justify-center z-50 overflow-y-auto overflow-x-hidden p-4 md:p-0" style="display: flex;">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-lg mx-auto transform transition-all relative">
            
            <!-- Step Indicators -->
            <div class="absolute top-0 inset-x-0 h-1.5 bg-gray-100 rounded-t-2xl overflow-hidden flex" dir="ltr">
                <div id="progressStep1" class="h-full bg-indigo-600 w-1/2 transition-all duration-300"></div>
                <div id="progressStep2" class="h-full bg-gray-200 w-1/2 transition-all duration-300"></div>
            </div>

            <!-- Wizard Content -->
            <div class="p-8">
                
                <!-- STEP 1: INITIAL BALANCE -->
                <div id="wizardStep1" class="wizard-step">
                    <!-- Icon -->
                    <div class="text-center mb-6">
                        <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-indigo-800 to-indigo-900 rounded-full shadow-lg">
                            <i class="fas fa-hand-holding-usd text-white text-3xl"></i>
                        </div>
                    </div>
                    
                    <h2 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-2">مرحباً بك في كوتة!</h2>
                    <p class="text-center text-gray-500 mb-6">الخطوة 1 من 2: الرصيد الافتتاحي</p>

                    <div class="text-center text-gray-600 dark:text-gray-300 mb-6 space-y-3">
                        <p class="font-medium">لإضافة منتجاتك، أضف رصيد كبير للخزنة (يمكن تعديله لاحقاً)</p>
                        <div class="bg-indigo-50 rounded-lg p-3 border border-indigo-100">
                            <p class="text-sm font-bold text-indigo-800">💡 نقترح: 100,000 جنيه</p>
                        </div>
                    </div>
                    
                    <div class="mb-6">
                        <label class="block text-sm font-bold text-gray-700 mb-2 text-right">أدخل المبلغ:</label>
                        <div class="relative">
                            <input type="number" id="initialBalance" value="100000" min="0" step="1000"
                                   class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-right text-lg font-bold"
                                   placeholder="أدخل المبلغ">
                             <div class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-500">
                                <i class="fas fa-coins"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Error Message -->
                    <div id="step1Error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600 text-center font-bold"></div>

                    <button onclick="submitStep1()" id="btnStep1" class="w-full bg-indigo-800 hover:bg-indigo-900 text-white font-bold py-3 px-6 rounded-xl transition-all shadow-md hover:-translate-y-0.5">
                        <span id="btnTextStep1">متابعة للخطوة التالية</span>
                        <i class="fas fa-arrow-left mr-2"></i>
                    </button>
                </div>


                <!-- STEP 2: DESKTOP SHORTCUT -->
                <div id="wizardStep2" class="wizard-step hidden">
                     <!-- Icon -->
                    <div class="text-center mb-6">
                        <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-emerald-500 to-emerald-700 rounded-full shadow-lg">
                            <i class="fas fa-desktop text-white text-3xl"></i>
                        </div>
                    </div>
                    
                    <h2 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-2">سهولة الوصول</h2>
                    <p class="text-center text-gray-500 mb-6">الخطوة 2 من 2: أيقونة سطح المكتب</p>

                    <div class="text-center text-gray-600 dark:text-gray-300 mb-8">
                        <p class="font-medium mb-4">أضف النظام إلى سطح المكتب للوصول إليه بضغطة واحدة كأنه برنامج حقيقي.</p>
                        
                        <div class="bg-indigo-50 p-4 rounded-xl border border-indigo-100 mb-4 ">
                            <ol class="text-right text-sm space-y-2 list-decimal list-inside text-indigo-900 marker:font-bold">
                                <li>اضغط على زر <b>"تثبيت الآن"</b> بالأسفل.</li>
                                <li>وافق على طلب التثبيت من المتصفح.</li>
                                <li>ستظهر أيقونة النظام فوراً على <b>سطح المكتب</b>.</li>
                            </ol>
                        </div>
                    </div>

                    <div class="flex flex-col gap-3">
                         <button onclick="installPWA()" class="pwa-install-btn hidden w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 px-6 rounded-xl transition-all shadow-md hover:-translate-y-0.5 flex items-center justify-center gap-2">
                            <i class="fas fa-plus-circle"></i>
                            تثبيت الآن
                        </button>
                        
                        <button onclick="finishWizard()" class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-6 rounded-xl transition-all mt-2">
                            <i class="fas fa-check ml-2"></i>
                            تم الانتهاء
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        async function submitStep1() {
            const amount = parseFloat(document.getElementById('initialBalance').value);
            const btn = document.getElementById('btnStep1');
            const btnText = document.getElementById('btnTextStep1');
            const errorDiv = document.getElementById('step1Error');
            
            if (!amount || amount <= 0) {
                errorDiv.textContent = 'يرجى إدخال مبلغ صحيح أكبر من صفر';
                errorDiv.classList.remove('hidden');
                return;
            }
            
            errorDiv.classList.add('hidden');
            btn.disabled = true;
            const originalContent = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin ml-2"></i> جاري الحفظ...';
            
            try {
                const response = await fetch('@Url.Action("AddInitialBalance", "Home")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ amount: amount })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Success Step 1 -> Go to Step 2
                    document.getElementById('wizardStep1').classList.add('hidden');
                    document.getElementById('wizardStep2').classList.remove('hidden');
                    
                    // Update Progress Bar
                    document.getElementById('progressStep1').classList.remove('w-1/2');
                    document.getElementById('progressStep1').classList.add('w-full');
                    document.getElementById('progressStep2').classList.remove('bg-gray-200');
                    document.getElementById('progressStep2').classList.add('bg-emerald-500');
                    
                } else {
                    errorDiv.textContent = data.message || 'حدث خطأ أثناء الحفظ';
                    errorDiv.classList.remove('hidden');
                    btn.disabled = false;
                    btn.innerHTML = originalContent;
                }
            } catch (error) {
                console.error(error);
                errorDiv.textContent = 'خطأ في الاتصال بالسيرفر';
                errorDiv.classList.remove('hidden');
                btn.disabled = false;
                btn.innerHTML = originalContent;
            }
        }

        function finishWizard() {
            window.location.reload();
        }

        // Enter Key Support for Step 1
        document.getElementById('initialBalance')?.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') submitStep1();
        });
    </script>
}
