@model ManageMentSystem.ViewModels.PaginatedInstallmentsViewModel
@using ManageMentSystem.Helpers
@using ManageMentSystem.Models
@inject ManageMentSystem.Services.UserServices.IUserService UserService
@{
    ViewData["Title"] = "الأقساط";
    var summary = ViewBag.summary as ManageMentSystem.ViewModels.InstallmentSummaryViewModel;
    var currencySymbol = System.Globalization.CultureInfo.CurrentCulture.NumberFormat.CurrencySymbol;
}

@Html.AntiForgeryToken()

<div class="min-h-screen bg-[#f8f9fc] p-6 md:p-8 space-y-8" dir="rtl">
    
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div>
            <h1 class="text-2xl font-bold text-[#0f1419] tracking-tight">إدارة التقسيط</h1>
            <p class="text-sm text-gray-500 mt-1 font-medium">سجل جميع عمليات التقسيط الحالية والمنتهية</p>
        </div>
        <div class="flex gap-3">
             
                <button type="button" onclick="sendBulkOverdueAlerts()" id="bulkAlertBtn"
                        class="px-4 py-2.5 bg-red-50 text-accentRed text-sm font-bold rounded-xl hover:bg-red-100 transition-colors flex items-center gap-2 border border-red-100 hover:-translate-y-0.5 transition-all">
                    <i data-lucide="bell"></i>
                    تنبيه المتأخرين
                </button>
           
                <a href="@Url.Action("Create")" class="px-4 py-2.5 bg-[#0f1419] text-white text-sm font-bold rounded-xl hover:bg-primaryHover hover:text-white transition-all shadow-lg  flex items-center gap-2 decoration-none hover:-translate-y-0.5 transition-all">
                    <i data-lucide="plus" class="text-white "></i>
                    <span>تقسيط جديد</span>
                </a>
        </div>
    </div>

    @if (ViewBag.summary != null)
    {
        <div class="flex justify-between items-center cursor-pointer mb-2" onclick="toggleSummary()">
             <h3 class="text-lg font-bold text-[#0f1419]">نظرة عامة</h3>
             <div class="flex items-center gap-1 text-gray-500 text-xs font-bold hover:text-[#0f1419]">
                 <span id="summaryToggleText ">إخفاء</span>
                 <i id="summaryToggleIcon" data-lucide="chevron-up"></i>
             </div>
        </div>

        <div id="summaryContent" class="summary-animate">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 hover:shadow-md transition-all">
                    <div class="flex justify-between items-start">
                        <div><p class="text-gray-500 text-md font-bold mb-1">المبالغ الأساسية</p><h3 class="text-2xl font-bold text-[#0f1419]">@summary.TotalBaseAmount.ToString("N0")</h3></div>
                        <div class="p-3 rounded-xl bg-gray-50 text-[#0f1419]"><i data-lucide="wallet" class="text-xl"></i></div>
                    </div>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 hover:shadow-md transition-all">
                    <div class="flex justify-between items-start">
                        <div><p class="text-gray-500 text-md font-bold mb-1">المتوقع تحصيله</p><h3 class="text-2xl font-bold text-[#0f1419]">@((summary.TotalAmountWithInterest - summary.TotalDownPayments).ToString("N0"))</h3><span class="text-xs text-emerald-500 font-bold bg-emerald-50 px-2 py-0.5 rounded-full mt-2 inline-block">+@summary.TotalInterest.ToString("N0") فوائد</span></div>
                        <div class="p-3 rounded-xl bg-amber-50 text-amber-700"><i data-lucide="trending-up" class="text-xl"></i></div>
                    </div>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 hover:shadow-md transition-all">
                    <div class="flex justify-between items-start">
                        <div><p class="text-gray-500 text-md font-bold mb-1">تم تحصيله</p><h3 class="text-2xl font-bold text-[#0f1419]">@summary.TotalAmountPaid.ToString("N0")</h3><div class="w-24 bg-gray-100 rounded-full h-1.5 mt-2 overflow-hidden"><div class="bg-gray-500 h-1.5 rounded-full" style="width: @summary.PaymentPercentage%"></div></div></div>
                        <div class="p-3 rounded-xl bg-emerald-50 text-emerald-800"><i data-lucide="check-circle" class="text-xl"></i></div>
                    </div>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 hover:shadow-md transition-all">
                    <div class="flex justify-between items-start">
                        <div><p class="text-gray-500 text-md font-bold mb-1">المتبقي</p><h3 class="text-2xl font-bold text-[#0f1419]">@summary.TotalMonthlyPaymentsRemaining.ToString("N0")</h3></div>
                        <div class="p-3 rounded-xl bg-red-50 text-accentRed"><i data-lucide="clock" class="text-xl"></i></div>
                    </div>
                </div>
            </div>
            
            <div id="statusCountersArea" class="grid grid-cols-2 md:grid-cols-5 lg:grid-cols-5s gap-4 mb-8">
                <div class="p-4 bg-white rounded-xl border border-gray-200 shadow-sm flex flex-col items-center justify-center"><span class="text-gray-500 text-md font-bold mb-2">الإجمالي</span><span class="text-xxl font-bold text-[#0f1419]">@summary.TotalInstallments</span></div>
                <div class="p-4 bg-white rounded-xl border border-emerald-100 shadow-sm flex flex-col items-center justify-center bg-emerald-50/10"><span class="text-gray-500 text-md font-bold mb-2">نشط</span><span class="text-xxl font-bold text-accentGreen">@summary.ActiveInstallments</span></div>
                <div class="p-4 bg-white rounded-xl border border-gray-200 shadow-sm flex flex-col items-center justify-center bg-gray-50/10"><span class="text-gray-500 text-md font-bold mb-2">مكتمل</span><span class="text-xxl font-bold text-[#0f1419]">@summary.CompletedInstallments</span></div>
                <div class="p-4 bg-white rounded-xl border border-red-100 shadow-sm flex flex-col items-center justify-center bg-red-50/10"><span class="text-gray-500 text-md font-bold mb-2">متأخر</span><span class="text-xxl font-bold text-accentRed">@summary.OverdueInstallments</span></div>
                <div class="p-4 bg-white rounded-xl border border-gray-200 shadow-sm flex flex-col items-center justify-center"><span class="text-gray-500 text-md font-bold mb-2">العملاء</span><span class="text-xxl font-bold text-amber-700">@summary.TotalCustomers</span></div>
            </div>
        </div>
    }

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        
        <div class="p-6 border-b border-gray-200 flex flex-col md:flex-row justify-between items-center gap-4 bg-white">
            <div>
               <h3 class="text-lg font-bold text-[#0f1419]">قائمة الأقساط</h3>
               <p class="text-sm text-gray-500 mt-1">النتائج: <span class="font-bold text-[#0f1419]">@Model.TotalCount</span></p>
            </div>
            
            <form method="get" action="@Url.Action("Index")" class="flex gap-2 w-full md:w-auto">
                <div class="relative group flex-1 md:w-64">
                    <i data-lucide="search" class="absolute right-3 top-3 text-gray-500 group-focus-within:text-[#0f1419] transition-colors w-4 h-4"></i>
                    <input type="text" name="searchTerm" 
                           class="w-full bg-gray-50 border border-gray-200 text-gray-600 text-sm rounded-xl focus:ring-2 focus:ring-bgSubtle focus:border-[#0f1419] block py-2.5 pr-10 pl-2 font-medium placeholder:text-gray-500 outline-none transition-all" 
                           placeholder="بحث..." value="@ViewBag.SearchTerm">
                </div>
                <div class="relative w-40">
                    <select name="sortBy" onchange="this.form.submit()" class="w-full bg-gray-50 border border-gray-200 text-gray-600 text-sm rounded-xl focus:ring-2 focus:ring-bgSubtle focus:border-[#0f1419] block py-2.5 px-3 font-bold cursor-pointer outline-none appearance-none">
                        <option value="SequenceNumber" selected="@(ViewBag.SortBy == "SequenceNumber")">رقم التقسيط</option>
                        <option value="CustomerName" selected="@(ViewBag.SortBy == "CustomerName")">العميل</option>
                        <option value="TotalAmount" selected="@(ViewBag.SortBy == "TotalAmount")">المبلغ</option>
                        <option value="Status" selected="@(ViewBag.SortBy == "Status")">الحالة</option>
                    </select>
                </div>
                <div class="w-24">
                    <select name="sortOrder" onchange="this.form.submit()" class="w-full bg-gray-50 border border-gray-200 text-gray-600 text-sm rounded-xl focus:ring-2 focus:ring-bgSubtle focus:border-[#0f1419] block py-2.5 px-3 font-bold cursor-pointer outline-none appearance-none">
                        <option value="desc" selected="@(ViewBag.SortOrder == "desc")">تنازلي</option>
                        <option value="asc" selected="@(ViewBag.SortOrder == "asc")">تصاعدي</option>
                    </select>
                </div>
                <input type="hidden" name="page" value="1" />
                <button type="submit" class="px-4 py-2.5 bg-[#0f1419] text-white text-sm font-bold rounded-xl hover:bg-primaryHover transition-colors">
                    <i data-lucide="search"></i>
                </button>
            </form>
        </div>

        <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-right" id="installmentsTable">
                <thead class="bg-gray-50/80 border-b border-gray-200">
                    <tr>
                        <th class="px-3 py-4 text-sm font-bold text-black-900 uppercase tracking-wider">#</th>
                        <th class="px-3 py-4 text-sm font-bold text-black-900 uppercase tracking-wider">العميل</th>
                        <th class="px-3 py-4 text-sm font-bold text-black-900 uppercase tracking-wider">الإجمالي</th>
                        <th class="px-3 py-4 text-sm font-bold text-black-900 uppercase tracking-wider">المقدم</th>
                        <th class="px-3 py-4 text-sm font-bold text-black-900 uppercase tracking-wider">القسط</th>
                        <th class="px-3 py-4 text-center text-sm font-bold text-black-900 uppercase tracking-wider">المدة</th>
                        <th class="px-3 py-4 text-center text-sm font-bold text-black-900 uppercase tracking-wider">فائدة</th>
                        <th class="px-3 py-4 text-sm font-bold text-black-900 uppercase tracking-wider">مع الفائدة</th>
                        <th class="px-3 py-4 text-center text-sm font-bold text-black-900 uppercase tracking-wider">الحالة</th>
                        <th class="px-3 py-4 text-center text-sm font-bold text-black-900 uppercase tracking-wider">إجراءات</th>
                    </tr>
                </thead>
           <tbody class="divide-y divide-gray-100" id="installmentsTableBody">
            @if (Model.Installments.Any())
            {
                @foreach (var item in Model.Installments)
                {
                    // 1. تحديد لون خلفية الصف بالكامل
                    var rowBackground = item.Status switch {
                        "مكتمل" => "bg-blue-200",   // أخضر واضح (مدفوع)
                        "متأخر" => "bg-red-200",     // أحمر واضح (متأخر)
                        "نشط"   => "bg-white",       // أبيض (نشط)
                        _       => "bg-gray-50"
                    };
                    // 2. تحديد ألوان الملصق (Badge) الصغير داخل الحالة
                    var statusClasses = item.Status switch {
                        "نشط" => "bg-emerald-100 text-emerald-800 border border-emerald-200",
                        "متأخر" => "bg-red-100 text-red-800 border border-red-200",
                        "مكتمل" => "bg-gray-100 text-[#0f1419] border border-gray-200",
                        _ => "bg-gray-100 text-[#0f1419] border border-gray-200"
                    };

                    <tr class="@rowBackground transition-colors group">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="text-xs font-bold text-gray-500">@item.SequenceNumber</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <a href="@Url.Action("Statement", "Customers", new { id = item.CustomerId })" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
                                <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-[#0f1419] font-bold text-xs shadow-sm">
                                    @item.Customer?.FullName?.Substring(0, Math.Min(1, item.Customer?.FullName?.Length ?? 0))
                                </div>
                                <div>
                                    <p class="font-bold text-sm text-gray-600">@item.Customer?.FullName</p>
                                    <p class="text-[10px] text-gray-500">@item.StartDate.ToString("yyyy-MM-dd")</p>
                                </div>
                            </a>
                        </td>
                        <td class="px-3 py-4 whitespace-nowrap text-md font-bold ">@item.TotalAmount.ToString("N0") @currencySymbol</td>
                        <td class="px-3 py-4 whitespace-nowrap font-bold">
                            <span class="text-md font-medium text-emerald-600 bg-emerald-50/30 px-2 py-1 rounded-lg font-bold">@item.DownPayment.ToString("N0")</span>
                        </td>
                        <td class="px-3 py-4 whitespace-nowrap text-md font-bold ">@item.MonthlyPayment.ToString("N0")</td>
                        <td class="px-3 py-4 whitespace-nowrap text-center font-bold ">
                            <span class="bg-gray-100 px-2 py-1 rounded text-md font-bold">@item.NumberOfMonths</span>
                        </td>
                        <td class="px-3 py-4 whitespace-nowrap text-center font-bold text-md">@item.InterestRate%</td>
                        <td class="px-3 py-4 whitespace-nowrap">
                            <span class="text-md font-bold ">@item.TotalWithInterest.ToString("N0")</span>
                            <span class="text-[10px] text-accentRed bg-red-50 px-1 rounded ml-1">+@item.InterestAmount.ToString("N0")</span>
                        </td>
                        <td class="px-3 py-4 whitespace-nowrap text-center">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold @statusClasses">
                                @item.Status
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-center">
                            <div class="flex items-center justify-center gap-1 opacity-100 sm:opacity-60 group-hover:opacity-100 transition-opacity">
                                <a href="@Url.Action("Details", new { id = item.Id })" class="p-1.5 hover:bg-gray-50 text-gray-500 hover:text-gray-600 rounded-lg transition-colors" title="عرض"><i data-lucide="eye" class="w-4 h-4"></i></a>
                        
                                    <a href="@Url.Action("Create", "InstallmentPayments", new { installmentId = item.Id })" class="p-1.5 hover:bg-emerald-50 text-gray-500 hover:text-accentGreen rounded-lg transition-colors" title="إضافة دفعة"><i data-lucide="hand-coins" class="w-4 h-4"></i></a>

                                    <a href="@Url.Action("PrintInvoice", "Installments", new { id = item.Id })" target="_blank" class="p-1.5 hover:bg-gray-50 text-gray-500 hover:text-[#0f1419] rounded-lg transition-colors" title="طباعة"><i data-lucide="printer" class="w-4 h-4"></i></a>

                                    <a href="#" onclick="sendInvoiceWhatsapp(@item.Id, this); return false;" class="p-1.5 hover:bg-green-50 text-gray-500 hover:text-green-600 rounded-lg transition-colors relative" title="واتساب">
                                        <i data-lucide="message-circle" class="w-4 h-4"></i>
                                        <i data-lucide="loader-2" class="animate-spin w-4 h-4 text-green-600 hidden absolute top-1.5 right-1.5"></i>
                                    </a>
                        
                                    <button type="button" onclick="openEditModal(@item.Id)" class="p-1.5 hover:bg-gray-50 text-gray-500 hover:text-[#0f1419] rounded-lg transition-colors" title="تعديل عدد الشهور"><i data-lucide="edit" class="w-4 h-4"></i></button>

                                    <button type="button" onclick="deleteInstallment(@item.Id)" class="p-1.5 hover:bg-red-50 text-gray-500 hover:text-accentRed rounded-lg transition-colors" title="حذف"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" class="text-center py-16">
                        <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-500">
                            <i data-lucide="folder-open" class="text-4xl"></i>
                        </div>
                        <h5 class="text-lg font-bold text-gray-600">لا توجد بيانات</h5>
                    </td>
                </tr>
            }
        </tbody>
            </table>
        </div>
      
        <div class="p-4 border-t border-gray-200 flex items-center justify-between text-xs text-gray-500 bg-white" id="pagination">
             @if (Model.TotalPages > 1)
             {
                <span>صفحة @Model.CurrentPage من @Model.TotalPages</span>
                <div class="flex gap-1">
                    @if (Model.HasPreviousPage) {
                        <a href="@Url.Action("Index", new { page = Model.CurrentPage - 1, searchTerm = ViewBag.SearchTerm, sortBy = ViewBag.SortBy, sortOrder = ViewBag.SortOrder })" class="px-3 py-1 rounded bg-gray-50 hover:bg-gray-50 text-gray-500 font-bold border border-gray-200">السابق</a>
                    } else {
                        <span class="px-3 py-1 rounded bg-gray-50 opacity-50 text-gray-500 font-bold border border-gray-200 cursor-not-allowed">السابق</span>
                    }

                    @for (int i = Model.StartPage; i <= Model.EndPage; i++) {
                        <a href="@Url.Action("Index", new { page = i, searchTerm = ViewBag.SearchTerm, sortBy = ViewBag.SortBy, sortOrder = ViewBag.SortOrder })" class="px-3 py-1 rounded font-bold border @(i == Model.CurrentPage ? "bg-[#0f1419] text-white border-gray-200" : "bg-gray-50 hover:bg-gray-50 text-gray-500 border-gray-200")">@i</a>
                    }

                    @if (Model.HasNextPage) {
                        <a href="@Url.Action("Index", new { page = Model.CurrentPage + 1, searchTerm = ViewBag.SearchTerm, sortBy = ViewBag.SortBy, sortOrder = ViewBag.SortOrder })" class="px-3 py-1 rounded bg-gray-50 hover:bg-gray-50 text-gray-500 font-bold border border-gray-200">التالي</a>
                    } else {
                        <span class="px-3 py-1 rounded bg-gray-50 opacity-50 text-gray-500 font-bold border border-gray-200 cursor-not-allowed">التالي</span>
                    }
                </div>
             }
        </div>
    </div>
</div>

@* Edit modal removed - now using direct navigation to Edit page *@


@section Scripts {
    <script src="~/js/swal-config.js"></script>
    <script>
        function toggleSummary() {
            const content = document.getElementById('summaryContent');
            const icon = document.getElementById('summaryToggleIcon');
            const text = document.getElementById('summaryToggleText');
            if (content.style.display === 'none') {
                content.style.display = 'block';
                icon.classList.remove('rotate-180');
                text.innerText = 'إخفاء';
            } else {
                content.style.display = 'none';
                icon.classList.add('rotate-180');
                text.innerText = 'إظهار';
            }
        }

        // حذف قسط
        async function deleteInstallment(id) {
            const htmlContent = `<div class="text-start">
                    <p class="mb-3">سيتم حذف القسط نهائياً مع:</p>
                    <ul class="text-start mb-3">
                        <li>إرجاع المنتجات للمخزون</li>
                        <li>حذف جميع الدفعات المرتبطة</li>
                        <li>حذف جميع العمليات المالية المرتبطة</li>
                        <li>إلغاء العملية بالكامل</li>
                    </ul>
                    <p class="text-red-600 font-bold">⚠️ لا يمكن التراجع عن هذا الإجراء</p>
                </div>`;

            const result = await showDangerConfirm('هل أنت متأكد؟', htmlContent);

            if (result.isConfirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/Installments/Delete/' + id;
                
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if (token) {
                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = token;
                    form.appendChild(tokenInput);
                }
                
                document.body.appendChild(form);
                form.submit();
            }
        }

        // إرسال تنبيه جماعي للمتأخرين - نسخة محدثة مع شريط تقدم
        async function sendBulkOverdueAlerts() {
            // 1. طلب التأكيد الأول
            const confirmResult = await showConfirm(
                'إرسال تنبيهات جماعية؟', 
                'سيتم إرسال تنبيهات واتساب لجميع العملاء المتأخرين. سيستغرق هذا بعض الوقت.',
                'بدء الإرسال'
            );

            if (!confirmResult.isConfirmed) return;

            // 2. إظهار مودال التقدم
            const progressModal = document.getElementById('progressModal');
            const progressBar = document.getElementById('progressBar');
            const progressText = document.getElementById('progressText');
            const progressStatus = document.getElementById('progressStatus');
            const progressLog = document.getElementById('progressLog');
            const btnCloseProgress = document.getElementById('btnCloseProgress');

            // تصفير المودال
            progressBar.style.width = '0%';
            progressText.innerText = '0%';
            progressStatus.innerText = 'جاري التحضير...';
            progressLog.innerHTML = '';
            btnCloseProgress.classList.add('hidden');
            progressModal.classList.remove('hidden');

            try {
                // 3. جلب قائمة العملاء المتأخرين
                progressStatus.innerText = 'جاري جلب القائمة...';
                const response = await fetch('/Installments/GetOverdueInstallmentsList');
                const data = await response.json();

                if (!data.success || !data.list || data.list.length === 0) {
                     progressStatus.innerText = 'لا توجد بيانات';
                     progressLog.innerHTML += `<div class="text-red-600 mb-1 flex items-center"><i data-lucide="alert-circle" class="ml-1 w-4 h-4"></i> ${data.message || 'لا توجد أقساط متأخرة صالحة للإرسال'}</div>`;
                     lucide.createIcons();
                     btnCloseProgress.classList.remove('hidden');
                     return;
                }

                const list = data.list;
                const total = list.length;
                let successCount = 0;
                let failCount = 0;

                progressStatus.innerText = `جاري التحضير لإرسال ${total} رسالة...`;

                // 4. البدء في الإرسال (واحد تلو الآخر)
                for (let i = 0; i < total; i++) {
                    const item = list[i];
                    const currentNum = i + 1;
                    
                    // تحديث الحالة
                    progressStatus.innerText = `جاري إرسال ${currentNum} من ${total} (${item.customerName})`;
                    
                    // استدعاء API الإرسال الفردي
                    try {
                        const sendRes = await fetch('/Installments/SendOverdueAlert/' + item.id);
                        const sendData = await sendRes.json();

                        if (sendData.success) {
                            successCount++;
                            progressLog.innerHTML += `<div class="text-emerald-600 text-xs mb-1 flex items-center"><i data-lucide="check-circle" class="ml-1 w-3 h-3"></i> تم الإرسال للعميل: ${item.customerName}</div>`;
                            lucide.createIcons();
                        } else {
                            failCount++;
                            progressLog.innerHTML += `<div class="text-red-600 text-xs mb-1 flex items-center"><i data-lucide="alert-circle" class="ml-1 w-3 h-3"></i> فشل: ${item.customerName} - ${sendData.message}</div>`;
                            lucide.createIcons();
                        }
                    } catch (err) {
                        failCount++;
                        progressLog.innerHTML += `<div class="text-red-600 text-xs mb-1 flex items-center"><i data-lucide="wifi" class="ml-1 w-3 h-3"></i> خطأ اتصال: ${item.customerName}</div>`;
                        lucide.createIcons();
                    }

                    // تحديث شريط التقدم
                    const percent = Math.round((currentNum / total) * 100);
                    progressBar.style.width = `${percent}%`;
                    progressText.innerText = `${percent}%`;

                    // التمرير لأسفل السجل
                    progressLog.scrollTop = progressLog.scrollHeight;

                    // انتطار بسيط لتجنب الحظر (Delay)
                    await new Promise(r => setTimeout(r, 1000));
                }

                // 5. الانتهاء
                progressStatus.innerText = 'اكتملت العملية!';
                progressStatus.classList.add('text-emerald-600', 'font-bold');
                progressLog.innerHTML += `<div class="mt-4 pt-2 border-t border-gray-200 font-bold flex items-center gap-2"><i data-lucide="flag" class="text-[#0f1419] w-4 h-4"></i> النتيجة النهائية: نجاح (${successCount}) - فشل (${failCount})</div>`;
                lucide.createIcons();
                
                // إظهار زر الإغلاق
                btnCloseProgress.classList.remove('hidden');

                if (successCount > 0) {
                     await Swal.fire({
                        icon: 'success',
                        title: 'تم الانتهاء',
                        text: `تم إرسال ${successCount} رسالة بنجاح`,
                        timer: 3000
                    });
                }

            } catch (error) {
                progressStatus.innerText = 'حدث خطأ غير متوقع';
                progressLog.innerHTML += `<div class="text-red-600 font-bold mb-1 flex items-center"><i data-lucide="alert-triangle" class="ml-1 w-4 h-4"></i> ${error.message}</div>`;
                lucide.createIcons();
                btnCloseProgress.classList.remove('hidden');
            }
        }

        // إرسال فاتورة واتساب
        async function sendInvoiceWhatsapp(installmentId, btn) {
            btn.disabled = true;
            const spinner = btn.querySelector('.loading-spinner');
            if (spinner) spinner.classList.remove('hidden');
            
            try {
                const response = await fetch('/Installments/SendWhatsapp/' + installmentId);
                const result = await response.json();
                
                if (result.success) {
                    showSuccess('نجح!', result.message);
                } else {
                    showError('خطأ', result.message);
                    btn.disabled = false;
                }
            } catch (error) {
                showError('خطأ', 'حدث خطأ أثناء إرسال الفاتورة');
                btn.disabled = false;
            } finally {
                if (spinner) spinner.classList.add('hidden');
            }
        }

    </script>
    
    <!-- Progress Modal -->
    <div id="progressModal" class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[100] hidden flex items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-200">
            <!-- Header -->
            <div class="bg-black px-6 py-4 flex justify-between items-center">
                <h3 class="text-white font-bold text-lg flex items-center gap-2">
                    <i data-lucide="message-circle"></i>
                    إرسال التنبيهات
                </h3>
                <span id="progressText" class="text-[#0f1419] font-mono text-sm">0%</span>
            </div>

            <!-- Body -->
            <div class="p-6">
                <!-- Status Text -->
                <p id="progressStatus" class="text-gray-600 font-bold mb-4 text-center">جاري التحضير...</p>
                
                <!-- Progress Bar -->
                <div class="w-full bg-gray-100 rounded-full h-4 mb-6 overflow-hidden shadow-inner">
                    <div id="progressBar" class=" from-emerald-500 to-emerald-400 h-4 rounded-full transition-all duration-300" style="width: 0%"></div>
                </div>

                <!-- Log Area -->
                <div class="bg-gray-50 rounded-xl border border-gray-200 p-3 h-48 overflow-y-auto custom-scrollbar text-sm font-mono" id="progressLog">
                    <!-- Logs will appear here -->
                </div>

                <!-- Footer -->
                <div class="mt-6 flex justify-center">
                    <button id="btnCloseProgress" onclick="document.getElementById('progressModal').classList.add('hidden'); window.location.reload();" 
                            class="hidden px-6 py-2 bg-gray-100 text-white rounded-xl hover:bg-gray-50 transition-colors font-bold shadow-lg shadow-slate-200">
                        إغلاق وتحديث
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Months Modal -->
    <div id="editMonthsModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50 flex items-center justify-center">
        <div class="relative mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
            <div class="mt-3 text-center">
                <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-gray-100 mb-4">
                    <i data-lucide="calendar" class="text-[#0f1419] text-xl"></i>
                </div>
                <h3 class="text-lg leading-6 font-medium text-gray-900 mb-2">تعديل مدة التقسيط</h3>
                <p class="text-sm text-gray-500 mb-4">يمكنك تعديل عدد الشهور فقط، وسيتم إعادة جدولة القسط تلقائياً.</p>
                
                <form id="editMonthsForm" class="mt-2 text-right">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="edit_Id" name="id" />

                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="edit_NumberOfMonths">
                            عدد الشهور الجديد
                        </label>
                        <input type="number" id="edit_NumberOfMonths" name="numberOfMonths" min="1" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" required>
                    </div>

                    <div class="flex justify-center gap-2 mt-4">
                        <button type="submit" class="px-4 py-2 bg-[#0f1419] text-white text-base font-medium rounded-md w-full shadow-sm hover:bg-[#0f1419] focus:outline-none focus:ring-2 focus:ring-[#0f1419]">
                            حفظ التغييرات
                        </button>
                        <button type="button" onclick="document.getElementById('editMonthsModal').classList.add('hidden')" class="px-4 py-2 bg-gray-100 text-gray-700 text-base font-medium rounded-md w-full shadow-sm hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-300">
                            إلغاء
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        async function openEditModal(id) {
            try {
                // Fetch current installment data using the dedicated JSON endpoint
                const response = await fetch('/Installments/GetInstallmentData/' + id);
                
                if (!response.ok) throw new Error('Network response was not ok');
                
                const data = await response.json();

                if (data.success === false) {
                     showError('خطأ', data.message || 'فشل تحميل البيانات');
                     return;
                }
                
                // Populate simple form fields
                document.getElementById('edit_Id').value = data.id;
                document.getElementById('edit_NumberOfMonths').value = data.numberOfMonths;

                closeSwal();
                document.getElementById('editMonthsModal').classList.remove('hidden');

            } catch (error) {
                console.error('Error:', error);
                showError('خطأ', 'فشل تحميل بيانات القسط');
            }
        }

        document.getElementById('editMonthsForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            showLoading('جاري الحفظ...');

            try {
                const formData = new FormData(this);
               
                const response = await fetch('/Installments/UpdateMonths', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const result = await response.json();

                if (result.success) {
                    await showSuccess('تم بنجاح', result.message);
                    document.getElementById('editMonthsModal').classList.add('hidden');
                    window.location.reload(); 
                } else {
                    showError('خطأ', result.message || 'حدث خطأ أثناء الحفظ');
                }
            } catch (error) {
                console.error('Error:', error);
                showError('خطأ', 'حدث خطأ غير متوقع');
            }
        });
    </script>
}
