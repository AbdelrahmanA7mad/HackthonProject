@model ManageMentSystem.Models.PaymentMethodOption

@{
    ViewData["Title"] = "إضافة طريقة دفع";
}

<div class="container mx-auto px-4 py-6 max-w-2xl">
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <!-- Header -->
        <div class=" bg-primary  px-6 py-4">
            <h3 class="text-2xl font-bold text-white flex items-center gap-3">
                <i data-lucide="plus-circle" class="w-6 h-6"></i>
                إضافة طريقة دفع
            </h3>
        </div>

        <!-- Form -->
        <form asp-action="Create" method="post" class="p-6 space-y-6">
            <div>
                <label asp-for="Name" class="block text-sm font-semibold text-gray-700 mb-2">
                    <i data-lucide="tag" class="text-primary ml-1 w-4 h-4 inline-block"></i>
                    الاسم
                </label>
                <input asp-for="Name" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all" placeholder="مثال: نقدي، فيزا، إلخ" />
                <span asp-validation-for="Name" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <div>
                <label asp-for="SortOrder" class="block text-sm font-semibold text-gray-700 mb-2">
                    <i data-lucide="list-ordered" class="text-primary ml-1 w-4 h-4 inline-block"></i>
                    الترتيب
                </label>
                <input asp-for="SortOrder" type="number" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all" />
            </div>

            <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-lg">
                <input asp-for="IsActive" type="checkbox" class="w-5 h-5 text-primary border-gray-200 rounded focus:ring-primary" />
                <label asp-for="IsActive" class="text-sm font-medium text-gray-700 cursor-pointer">
                    <i data-lucide="toggle-right" class="text-green-600 ml-1 w-4 h-4 inline-block"></i>
                    نشط
                </label>
            </div>

            <div class="flex items-center gap-3 p-4 bg-amber-50 rounded-lg">
                <input asp-for="IsDefault" type="checkbox" class="w-5 h-5 text-amber-600 border-gray-200 rounded focus:ring-amber-500" />
                <label asp-for="IsDefault" class="text-sm font-medium text-gray-700 cursor-pointer">
                    <i data-lucide="star" class="text-amber-600 ml-1 w-4 h-4 inline-block"></i>
                    افتراضي
                </label>
            </div>

            <div class="flex gap-3 pt-4 border-t border-gray-200">
                <button type="submit" class="zen-btn zen-btn-primary flex-1">
                    <i data-lucide="save" class="w-5 h-5"></i>
                    حفظ
                </button>
                <a asp-action="Index" class="zen-btn zen-btn-neutral flex-1">
                    عودة
                    <i data-lucide="arrow-left" class="w-5 h-5"></i>
                </a>
            </div>
        </form>
    </div>
</div>
