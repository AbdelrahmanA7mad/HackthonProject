@model ManageMentSystem.Models.PaymentMethodOption

@{
    ViewData["Title"] = "تعديل طريقة دفع";
}

<div class="container mx-auto px-4 py-6 max-w-2xl">
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-indigo-800 to-indigo-900 px-6 py-4">
            <h3 class="text-2xl font-bold text-white flex items-center gap-3">
                <i class="fas fa-edit"></i>
                تعديل طريقة دفع
            </h3>
        </div>

        <!-- Form -->
        <form asp-action="Edit" method="post" class="p-6 space-y-6">
            <input type="hidden" asp-for="Id" />
            
            <div>
                <label asp-for="Name" class="block text-sm font-semibold text-gray-700 mb-2">
                    <i class="fas fa-tag text-indigo-800 ml-1"></i>
                    الاسم
                </label>
                <input asp-for="Name" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all" />
                <span asp-validation-for="Name" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <div>
                <label asp-for="SortOrder" class="block text-sm font-semibold text-gray-700 mb-2">
                    <i class="fas fa-sort-numeric-down text-indigo-800 ml-1"></i>
                    الترتيب
                </label>
                <input asp-for="SortOrder" type="number" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all" />
            </div>

            <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-lg">
                <input asp-for="IsActive" type="checkbox" class="w-5 h-5 text-indigo-800 border-gray-300 rounded focus:ring-indigo-500" />
                <label asp-for="IsActive" class="text-sm font-medium text-gray-700 cursor-pointer">
                    <i class="fas fa-toggle-on text-green-600 ml-1"></i>
                    نشط
                </label>
            </div>

            <div class="flex items-center gap-3 p-4 bg-amber-50 rounded-lg">
                <input asp-for="IsDefault" type="checkbox" class="w-5 h-5 text-amber-600 border-gray-300 rounded focus:ring-amber-500" />
                <label asp-for="IsDefault" class="text-sm font-medium text-gray-700 cursor-pointer">
                    <i class="fas fa-star text-amber-600 ml-1"></i>
                    افتراضي
                </label>
            </div>

            <div class="flex gap-3 pt-4 border-t border-gray-200">
                <button type="submit" class="flex-1 bg-indigo-800 hover:bg-indigo-900 text-white px-6 py-3 rounded-lg font-semibold transition-colors flex items-center justify-center gap-2">
                    <i class="fas fa-save"></i>
                    حفظ التعديلات
                </button>
                <a asp-action="Index" class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-3 rounded-lg font-semibold transition-colors flex items-center justify-center gap-2">
                    عودة
                    <i class="fas fa-arrow-left"></i>
                </a>
            </div>
        </form>
    </div>
</div>
