@model IEnumerable<ManageMentSystem.Models.PaymentMethodOption>
@using ManageMentSystem.Models
@inject ManageMentSystem.Services.UserServices.IUserService UserService
@{
    ViewData["Title"] = "إدارة طرق الدفع";
}

<div class="container mx-auto px-4 py-6">
    <!-- Header Section -->
    <div class="mb-6">
        <div class="flex justify-between items-center">
            <div class="flex items-center gap-4">
                <i class="fas fa-credit-card text-indigo-800 text-4xl"></i>
                <div>
                    <h2 class="text-3xl font-bold text-gray-900">طرق الدفع</h2>
                    <p class="text-gray-600 mt-1">إدارة وتنظيم طرق الدفع المختلفة</p>
                </div>
            </div>
          
                <a asp-action="Create" class="bg-indigo-800 hover:bg-indigo-900 text-white px-6 py-3 rounded-lg flex items-center gap-2 transition-colors">
                    <i class="fas fa-plus"></i>
                    <span>إضافة طريقة جديدة</span>
                </a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 border-r-4 border-green-500 text-green-800 p-4 rounded-lg mb-4 flex items-center gap-3">
            <i class="fas fa-check-circle text-green-500 text-xl"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border-r-4 border-red-500 text-red-800 p-4 rounded-lg mb-4 flex items-center gap-3">
            <i class="fas fa-exclamation-triangle text-red-500 text-xl"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <!-- Main Content Card -->
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <i class="fas fa-list text-gray-600"></i>
                    <h5 class="text-lg font-semibold text-gray-900">قائمة طرق الدفع</h5>
                </div>
                <span class="bg-indigo-100 text-indigo-800 px-3 py-1 rounded-full text-sm font-medium">@Model.Count() عنصر</span>
            </div>
        </div>
        
        <div class="p-0">
            @if (Model.Any())
            {
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50 border-b border-gray-200">
                            <tr>
                                <th class="px-6 py-3 text-center text-gray-600 font-semibold w-20">
                                    <i class="fas fa-hashtag text-gray-400 ml-1"></i> #
                                </th>
                                <th class="px-6 py-3 text-right text-gray-600 font-semibold">
                                    <i class="fas fa-tag text-gray-400 ml-2"></i>الاسم
                                </th>
                                <th class="px-6 py-3 text-center text-gray-600 font-semibold w-32">
                                    <i class="fas fa-star text-gray-400 ml-2"></i>افتراضي
                                </th>
                                <th class="px-6 py-3 text-center text-gray-600 font-semibold w-28">
                                    <i class="fas fa-toggle-on text-gray-400 ml-2"></i>الحالة
                                </th>
                                <th class="px-6 py-3 text-center text-gray-600 font-semibold w-28">
                                    <i class="fas fa-sort-numeric-down text-gray-400 ml-2"></i>الترتيب
                                </th>
                                <th class="px-6 py-3 text-center text-gray-600 font-semibold w-72">
                                    <i class="fas fa-cogs text-gray-400 ml-2"></i>الإجراءات
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var m in Model)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4 text-center font-bold text-gray-500">@m.Id</td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <i class="fas fa-wallet text-indigo-800"></i>
                                            <span class="font-medium text-gray-900">@m.Name</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-center">
                                        @if (m.IsDefault)
                                        {
                                            <span class="inline-flex items-center gap-1 bg-amber-100 text-amber-800 px-3 py-1 rounded-full text-sm font-medium">
                                                <i class="fas fa-star"></i>
                                                نعم
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-gray-400">لا</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 text-center">
                                        @if (m.IsActive)
                                        {
                                            <span class="inline-flex items-center gap-1 bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">
                                                <i class="fas fa-check"></i>
                                                نشط
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1 bg-gray-100 text-gray-600 px-3 py-1 rounded-full text-sm font-medium">
                                                <i class="fas fa-times"></i>
                                                معطل
                                            </span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 text-center">
                                        <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-lg text-sm font-medium border border-gray-300">@m.SortOrder</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex justify-center gap-2">
                                                <a asp-action="Edit" asp-route-id="@m.Id"
                                                   class="bg-amber-500 hover:bg-amber-600 text-white px-3 py-2 rounded-lg transition-colors"
                                                   title="تعديل">
                                                    <i class="fas fa-edit"></i>
                                                </a>

                                                <form asp-action="ToggleActive" asp-route-id="@m.Id" method="post" class="inline-block">
                                                    <button type="submit"
                                                            class="bg-gray-500 hover:bg-gray-600 text-white px-3 py-2 rounded-lg transition-colors"
                                                            title="@(m.IsActive ? "تعطيل" : "تفعيل")">
                                                        <i class="fas fa-@(m.IsActive ? "toggle-off" : "toggle-on")"></i>
                                                    </button>
                                                </form>

                                                @if (!m.IsDefault)
                                                {
                                                    <form asp-action="SetDefault" asp-route-id="@m.Id" method="post" class="inline-block">
                                                        <button type="submit"
                                                                class="bg-indigo-500 hover:bg-indigo-600 text-white px-3 py-2 rounded-lg transition-colors"
                                                                title="تعيين كافتراضي">
                                                            <i class="fas fa-star"></i>
                                                        </button>
                                                    </form>
                                                }
                                           
                                                <a asp-action="Delete" asp-route-id="@m.Id"
                                                   class="bg-red-500 hover:bg-red-600 text-white px-3 py-2 rounded-lg transition-colors"
                                                   title="حذف"
                                                   onclick="return confirm('هل أنت متأكد من حذف هذه الطريقة؟')">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-16">
                    <i class="fas fa-credit-card text-gray-300 text-6xl mb-4"></i>
                    <h4 class="text-xl font-semibold text-gray-600 mb-2">لا توجد طرق دفع</h4>
                    <p class="text-gray-500 mb-6">قم بإضافة طريقة دفع جديدة للبدء</p>
                  
                        <a asp-action="Create" class="inline-flex items-center gap-2 bg-indigo-800 hover:bg-indigo-900 text-white px-6 py-3 rounded-lg transition-colors">
                            <i class="fas fa-plus"></i>
                            <span>إضافة طريقة دفع</span>
                        </a>
                </div>
            }
        </div>
    </div>
</div>
