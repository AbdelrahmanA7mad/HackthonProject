@model IEnumerable<ManageMentSystem.Models.Product>
@using ManageMentSystem.Helpers
@{
    ViewData["Title"] = "إدارة المنتجات";
}

<div class="min-h-screen bg-[#f8f9fc] p-6 md:p-8 space-y-8" dir="rtl">
    <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 font-cairo flex items-center gap-3">
                <div class="p-2 bg-indigo-50 rounded-xl">
                    <i class="fas fa-box text-indigo-800"></i>
                </div>
                إدارة المنتجات
            </h1>
        </div>

        <div class="flex flex-col md:flex-row gap-3 items-stretch md:items-center">
            <form method="get" action="@Url.Action("Index", "Products")" class="relative flex-grow md:w-80">
                <div class="relative">
                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                        <i class="fas fa-search text-slate-400"></i>
                    </div>
                    <input type="text" 
                           class="block w-full p-2.5 pr-10 text-sm text-slate-900 border border-slate-200 rounded-xl bg-white focus:ring-indigo-500 focus:border-indigo-500 outline-none shadow-sm transition-all" 
                           name="q" 
                           placeholder="ابحث بالاسم، الباركود، الفئة..." 
                           value="@ViewBag.Query">
                    <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
                </div>
            </form>

           
                <div class="flex flex-wrap gap-2 pb-1 md:pb-0">
                    <button type="button" onclick="exportToExcel()" class="flex items-center justify-center px-6 py-2.5 text-sm font-bold text-white bg-emerald-800 hover:bg-emerald-900 rounded-xl shadow-sm hover:-translate-y-0.5 transition-all duration-200 gap-2 whitespace-nowrap" title="تصدير إلى Excel">
                        <i class="fas fa-file-excel"></i>
                        <span>تصدير</span>
                    </button>

                    <button type="button" onclick="printAllBarcodesFromCurrentPage()" class="flex items-center justify-center px-6 py-2.5 text-sm font-bold text-white bg-amber-600 hover:bg-amber-700 rounded-xl shadow-sm hover:-translate-y-0.5 transition-all duration-200 gap-2 whitespace-nowrap" title="طباعة باركود الصفحة">
                        <i class="fas fa-barcode"></i>
                        <span>الباركود</span>
                    </button>

                    <button type="button" data-bs-toggle="modal" data-bs-target="#addProductModal" class="flex items-center justify-center px-6 py-2.5 text-sm font-bold text-white bg-indigo-800 hover:bg-indigo-900 rounded-xl shadow-sm shadow-indigo-200 hover:-translate-y-0.5 transition-all duration-200 gap-2 whitespace-nowrap">
                        <i class="fas fa-plus"></i>
                        <span>منتج جديد</span>
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <h3 class="font-bold text-slate-700">قائمة المنتجات</h3>
            @if (Model.Any())
            {
                <div class="flex items-center gap-2">
                    <span class="text-sm w-full font-bold text-slate-500">عرض:</span>
                    <select id="pageSizeSelect" class="form-select bg-white bg-left pl-4 border-slate-200 text-slate-700 text-sm rounded-lg focus:ring-indigo-500 focus:border-indigo-500 block">
                        <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
                        <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
                        <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                        <option value="100" selected="@(ViewBag.PageSize == 100)">100</option>
                    </select>
                </div>
            }
        </div>

        <div class="overflow-x-auto">
            @if (Model.Any())
            {
                <table class="w-full text-right" id="productsTable">
                    <thead class="bg-slate-50 text-slate-600 text-sm uppercase font-bold">
                        <tr>
                            <th class="px-6 py-4 rounded-tr-lg">الاسم</th>
                            <th class="px-6 py-4">الفئة</th>
                            <th class="px-6 py-4">الكمية</th>
                                <th class="px-6 py-4">سعر الشراء</th>
                            <th class="px-6 py-4">سعر البيع</th>
                            <th class="px-6 py-4">الباركود</th>
                            <th class="px-6 py-4 rounded-tl-lg text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-sm">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50/80 transition-colors duration-150">
                                <td class="px-6 py-4 font-bold text-slate-700">@item.Name</td>
                                <td class="px-6 py-4">
                                    @if (item.Category != null)
                                    {
                                        <span class="bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full text-sm font-bold border border-slate-200">
                                            @item.Category.Name
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-slate-600">-</span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.Quantity <= ViewBag.LowStockThreshold)
                                    {
                                        <div class="flex items-center gap-1.5 text-red-700 bg-red-50 px-2.5 py-1 rounded-full w-fit border border-amber-100">
                                            
                                            <span class="font-bold">@item.Quantity</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="flex items-center gap-1.5 text-indigo-800 bg-indigo-50 px-2.5 py-1 rounded-full w-fit border border-indigo-100">
                                        
                                            <span class="font-bold">@item.Quantity</span>
                                        </div>
                                    }
                                </td>
                                <td class="px-6 py-4 text-slate-800 font-bold ">@item.PurchasePrice.ToString("C")</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2 max-w-[140px]">
                                        <span class="text-slate-800 font-bold ">@item.SalePrice.ToString("C")</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    @if (!string.IsNullOrEmpty(item.Barcode))
                                    {
                                        <span class="badge bg-info" style="display:none !important;">@item.Barcode</span>
                                        
                                        <div class="flex items-center gap-2">
                                            <span class="bg-indigo-50 text-indigo-800 px-2 py-1 rounded border border-indigo-100 font-mono text-xs select-all">
                                                @item.Barcode
                                            </span>
                                            <button type="button" class="text-indigo-800 hover:text-indigo-900 hover:bg-indigo-50 rounded-lg p-1.5 transition-colors"
                                                    onclick="printBarcodeXP360B('@item.Barcode', '@Html.Raw(Html.Encode(item.Name).Replace("'", "\\'"))', @item.SalePrice, 80)"
                                                    title="طباعة الباركود">
                                                <i class="fas fa-print"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-slate-400 text-xs italic">لا يوجد</span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-1">
                                        <button type="button" class="p-2 text-emerald-800 hover:bg-emerald-50 rounded-lg transition-colors"
                                                onclick="viewProduct(@item.Id)" title="عرض">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        
                                            <button type="button" class="p-2 text-indigo-800 hover:bg-indigo-50 rounded-lg transition-colors"
                                                    onclick="editProduct(@item.Id)" title="تعديل">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            
                                            <button type="button" class="p-2 text-amber-600 hover:bg-amber-50 rounded-lg transition-colors"
                                                    onclick="editProductQuantity(@item.Id)" title="تعديل الكمية">
                                                <i class="fas fa-hashtag"></i>
                                            </button>
                                        
                                            <button type="button" class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-colors"
                                                    onclick="deleteProduct(@item.Id)" title="حذف">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="p-4 border-t border-slate-100 bg-slate-50/50 flex flex-col md:flex-row justify-between items-center gap-4">
                    <p class="text-sm text-slate-500">
                        عرض <span class="font-bold text-slate-800">@((ViewBag.CurrentPage - 1) * ViewBag.PageSize + 1)</span> إلى <span class="font-bold text-slate-800">@Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems)</span> من أصل <span class="font-bold text-slate-800">@ViewBag.TotalItems</span> منتج
                    </p>

                    @if (ViewBag.TotalPages > 1)
                    {
                        <nav aria-label="Pagination">
                            <ul class="flex items-center gap-1">
                                <li>
                                    @if (ViewBag.HasPreviousPage)
                                    {
                                        <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize, q = ViewBag.Query })" 
                                           class="flex items-center justify-center w-8 h-8 rounded-lg border border-slate-200 bg-white text-slate-500 hover:bg-indigo-50 hover:text-indigo-800 hover:border-indigo-200 transition-all">
                                            <i class="fas fa-chevron-right text-xs"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="flex items-center justify-center w-8 h-8 rounded-lg border border-slate-100 bg-slate-50 text-slate-300 cursor-not-allowed">
                                            <i class="fas fa-chevron-right text-xs"></i>
                                        </span>
                                    }
                                </li>

                                @{
                                    int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                                    int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                                }

                                @if (startPage > 1)
                                {
                                    <li>
                                        <a href="@Url.Action("Index", new { page = 1, pageSize = ViewBag.PageSize, q = ViewBag.Query })" class="flex items-center justify-center w-8 h-8 rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-indigo-50 hover:text-indigo-800 text-sm font-medium">1</a>
                                    </li>
                                    @if (startPage > 2)
                                    {
                                        <li class="px-1 text-slate-400">...</li>
                                    }
                                }

                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    <li>
                                        <a href="@Url.Action("Index", new { page = i, pageSize = ViewBag.PageSize, q = ViewBag.Query })" 
                                           class="flex items-center justify-center w-8 h-8 rounded-lg border text-sm font-bold transition-all @(i == ViewBag.CurrentPage ? "bg-indigo-800 border-indigo-800 text-white shadow-sm shadow-indigo-200" : "border-slate-200 bg-white text-slate-600 hover:bg-indigo-50 hover:text-indigo-600")">
                                            @i
                                        </a>
                                    </li>
                                }

                                @if (endPage < ViewBag.TotalPages)
                                {
                                    @if (endPage < ViewBag.TotalPages - 1)
                                    {
                                        <li class="px-1 text-slate-400">...</li>
                                    }
                                    <li>
                                        <a href="@Url.Action("Index", new { page = ViewBag.TotalPages, pageSize = ViewBag.PageSize, q = ViewBag.Query })" class="flex items-center justify-center w-8 h-8 rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-indigo-50 hover:text-indigo-800 text-sm font-medium">@ViewBag.TotalPages</a>
                                    </li>
                                }

                                <li>
                                    @if (ViewBag.HasNextPage)
                                    {
                                        <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize, q = ViewBag.Query })" 
                                           class="flex items-center justify-center w-8 h-8 rounded-lg border border-slate-200 bg-white text-slate-500 hover:bg-indigo-50 hover:text-indigo-800 hover:border-indigo-200 transition-all">
                                            <i class="fas fa-chevron-left text-xs"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="flex items-center justify-center w-8 h-8 rounded-lg border border-slate-100 bg-slate-50 text-slate-300 cursor-not-allowed">
                                            <i class="fas fa-chevron-left text-xs"></i>
                                        </span>
                                    }
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-16 text-slate-400">
                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                        <i class="fas fa-box-open text-4xl text-slate-300"></i>
                    </div>
                    <h5 class="text-lg font-bold text-slate-600">لا توجد منتجات</h5>
                    <p class="text-sm">ابدأ بإضافة منتج جديد للمخزون</p>
                </div>
            }
        </div>
    </div>
</div>

<script src="~/lib/xlsx/xlsx.full.min.js"></script>

<div class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 rounded-2xl shadow-xl overflow-hidden">
            <div class="modal-header bg-slate-50 border-b border-slate-100 p-4">
                <h5 class="modal-title font-bold text-slate-800 flex items-center gap-2" id="addProductModalLabel">
                    <span class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-800 flex items-center justify-center text-sm">
                        <i class="fas fa-plus"></i>
                    </span>
                    إضافة منتج جديد
                </h5>
                <button type="button" class="btn-close text-slate-400 hover:text-red-500 transition-colors" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addProductForm" asp-action="Create" method="post">
                <div class="modal-body p-6 space-y-6 bg-white">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">اسم المنتج <span class="text-red-500">*</span></label>
                            <input type="text" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" name="Name" required placeholder="مثال: شاشة سامسونج 24 بوصة">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">الفئة <span class="text-red-500">*</span></label>
                            <select class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" name="CategoryId" required>
                                <option value="">اختر الفئة</option>
                                @if (ViewBag.Categories != null)
                                {
                                    @foreach (var category in ViewBag.Categories)
                                    {
                                        <option value="@category.Id">@category.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">الكمية <span class="text-red-500">*</span></label>
                            <input type="number" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" name="Quantity" required>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">سعر الشراء <span class="text-red-500">*</span></label>
                            <div class="flex relative">
                                <input type="number" class="block w-full p-2.5 pl-12 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" name="PurchasePrice" step="0.01" required>
                                @{ var currencySymbol = System.Globalization.CultureInfo.CurrentCulture.NumberFormat.CurrencySymbol; }
                                <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                    <span class="text-slate-500 font-bold text-xs bg-slate-200 px-2 py-1 rounded">@currencySymbol</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">سعر البيع <span class="text-red-500">*</span></label>
                            <div class="flex relative">
                                <input type="number" class="block w-full p-2.5 pl-12 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" name="SalePrice" step="0.01" required>
                                @{ currencySymbol = System.Globalization.CultureInfo.CurrentCulture.NumberFormat.CurrencySymbol; }
                                <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                    <span class="text-slate-500 font-bold text-xs bg-slate-200 px-2 py-1 rounded">@currencySymbol</span>
                                </div>
                            </div>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">الباركود</label>
                            <div class="flex gap-2">
                                <input type="text" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" name="Barcode" id="addProductBarcode" placeholder="أدخل الباركود أو اتركه للتوليد التلقائي">
                                <button type="button" class="px-3 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 border border-slate-200 rounded-xl transition-colors" id="generateBarcodeBtn" title="توليد باركود تلقائي">
                                    <i class="fas fa-barcode"></i>
                                </button>
                            </div>
                            <p class="mt-1 text-xs text-slate-400">يجب أن يكون الباركود فريدًا لكل منتج</p>
                            
                            <div id="addBarcodeAlert" class="mt-3 p-3 bg-amber-50 border border-amber-100 rounded-xl flex items-start gap-3" style="display: none;">
                                <i class="fas fa-exclamation-triangle text-amber-500 mt-0.5"></i>
                                <div class="flex-1">
                                    <span id="addBarcodeAlertText" class="text-sm text-amber-800 block mb-1"></span>
                                    <a href="#" id="addViewExistingProduct" class="text-xs font-bold text-amber-700 hover:underline">عرض المنتج الموجود</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block mb-2 text-sm font-bold text-slate-700">الوصف</label>
                        <textarea class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="addProductDescription" name="Description" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-slate-50 border-t border-slate-100 p-4 flex gap-2 justify-end">
                    <button type="button" class="px-5 py-2.5 text-sm font-bold text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 hover:text-slate-800 rounded-xl transition-colors" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="px-5 py-2.5 text-sm font-bold text-white bg-indigo-800 hover:bg-indigo-900 rounded-xl shadow-md shadow-indigo-200 transition-all">حفظ المنتج</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editProductModal" tabindex="-1" aria-labelledby="editProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 rounded-2xl shadow-xl overflow-hidden">
            <div class="modal-header bg-slate-50 border-b border-slate-100 p-4">
                <h5 class="modal-title font-bold text-slate-800 flex items-center gap-2" id="editProductModalLabel">
                    <span class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-800 flex items-center justify-center text-sm">
                        <i class="fas fa-edit"></i>
                    </span>
                    تعديل بيانات المنتج
                </h5>
                <button type="button" class="btn-close text-slate-400 hover:text-red-500 transition-colors" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editProductForm" method="post">
                <div class="modal-body p-6 space-y-6 bg-white">
                    <input type="hidden" id="editProductId" name="Id">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">اسم المنتج <span class="text-red-500">*</span></label>
                            <input type="text" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="editProductName" name="Name" required>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">الفئة <span class="text-red-500">*</span></label>
                            <select class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="editProductCategoryId" name="CategoryId" required>
                                <option value="">اختر الفئة</option>
                                @if (ViewBag.Categories != null)
                                {
                                    @foreach (var category in ViewBag.Categories)
                                    {
                                        <option value="@category.Id">@category.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">الكمية <span class="text-red-500">*</span></label>
                            <input type="number" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="editProductQuantity" name="Quantity" required>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">سعر الشراء <span class="text-red-500">*</span></label>
                            <input type="number" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="editProductPurchasePrice" name="PurchasePrice" step="1" required>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">سعر البيع <span class="text-red-500">*</span></label>
                            <input type="number" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="editProductSalePrice" name="SalePrice" step="1" required>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">الباركود</label>
                            <div class="flex gap-2">
                                <input type="text" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="editProductBarcode" name="Barcode" placeholder="أدخل الباركود أو اتركه للتوليد التلقائي">
                                <button type="button" class="px-3 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 border border-slate-200 rounded-xl transition-colors" id="editGenerateBarcodeBtn" title="توليد باركود تلقائي">
                                    <i class="fas fa-barcode"></i>
                                </button>
                            </div>
                            <p class="mt-1 text-xs text-slate-400">يجب أن يكون الباركود فريد لكل منتج</p>

                            <div id="editBarcodeAlert" class="mt-3 p-3 bg-amber-50 border border-amber-100 rounded-xl flex items-start gap-3" style="display: none;">
                                <i class="fas fa-exclamation-triangle text-amber-500 mt-0.5"></i>
                                <div class="flex-1">
                                    <span id="editBarcodeAlertText" class="text-sm text-amber-800 block mb-1"></span>
                                    <a href="#" id="editViewExistingProduct" class="text-xs font-bold text-amber-700 hover:underline">عرض المنتج الموجود</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div>
                        <label class="block mb-2 text-sm font-bold text-slate-700">الوصف</label>
                        <textarea class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="editProductDescription" name="Description" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-slate-50 border-t border-slate-100 p-4 flex gap-2 justify-end">
                    <button type="button" class="px-5 py-2.5 text-sm font-bold text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 hover:text-slate-800 rounded-xl transition-colors" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="px-5 py-2.5 text-sm font-bold text-white bg-indigo-800 hover:bg-indigo-900 rounded-xl shadow-md shadow-indigo-200 transition-all">حفظ التغييرات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editQuantityModal" tabindex="-1" aria-labelledby="editQuantityModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-2xl shadow-xl overflow-hidden">
            <div class="modal-header bg-slate-50 border-b border-slate-100 p-5">
                <h5 class="modal-title font-bold text-slate-800 flex items-center gap-2" id="editQuantityModalLabel">
                    <span class="w-8 h-8 rounded-lg bg-amber-100 text-amber-700 flex items-center justify-center text-sm">
                        <i class="fas fa-boxes"></i>
                    </span>
                    تعديل المخزون
                </h5>
                <button type="button" class="btn-close text-red-700 hover:text-red-800 transition-colors" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editQuantityForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-6 space-y-6 bg-white">
                    <input type="hidden" id="editQuantityProductId" name="Id">
                    <div>
                        <label class="block mb-2 text-sm font-bold text-slate-500">اسم المنتج</label>
                        <input type="text" class="block w-full p-2.5 text-sm text-slate-700 font-bold border border-slate-200 rounded-xl bg-slate-50" id="editQuantityProductName" readonly>
                    </div>
                    <div>
                        <label class="block mb-2 text-sm font-bold text-slate-500">الكمية الحالية</label>
                        <input type="number" class="block w-full p-2.5 text-sm text-slate-700 font-bold border border-slate-200 rounded-xl bg-slate-50" id="currentQuantity" readonly>
                    </div>
                    <div>
                        <label class="block mb-2 text-sm font-bold text-slate-700">الكمية الجديدة <span class="text-red-500">*</span></label>
                        <input type="number" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-amber-500 focus:border-amber-500 bg-white transition-all" id="editQuantityNew" name="Quantity" min="0" required placeholder="أدخل الكمية الجديدة">
                    </div>

                    <input type="hidden" id="editQuantityName" name="Name">
                    <input type="hidden" id="editQuantityCategoryId" name="CategoryId">
                    <input type="hidden" id="editQuantityPurchasePrice" name="PurchasePrice">
                    <input type="hidden" id="editQuantitySalePrice" name="SalePrice">
                    <input type="hidden" id="editQuantityDescription" name="Description">
                    <input type="hidden" id="editQuantityBarcode" name="Barcode">
                </div>
                <div class="modal-footer bg-slate-50 border-t border-slate-100 p-4 flex gap-2 justify-end">
                    <button type="button" class="px-5 py-2.5 text-sm font-bold text-slate-600 bg-white hover:bg-gray-100 border border-slate-200 hover:bg-slate-50 hover:text-slate-800 rounded-xl transition-colors hover:-translate-y-0.5 transition-all" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="px-5 py-2.5 text-sm font-bold text-white bg-amber-700 hover:bg-amber-800 rounded-xl shadow-xs shadow-amber-500 hover:-translate-y-0.5 transition-all">تحديث الكمية</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteProductModal" tabindex="-1" aria-labelledby="deleteProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-2xl shadow-xl overflow-hidden">
            <div class="modal-header bg-red-50 border-b border-red-100 p-5">
                <h5 class="modal-title font-bold text-red-800 flex items-center gap-2" id="deleteProductModalLabel">
                    <i class="fas fa-exclamation-circle"></i>
                    تأكيد الحذف
                </h5>
                <button type="button" class="btn-close text-red-400 hover:text-red-600 transition-colors" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-6 bg-white text-center space-y-4">
                <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto">
                    <i class="fas fa-trash-alt text-2xl text-red-500"></i>
                </div>
                <div>
                    <p class="font-bold text-slate-800 text-lg">هل أنت متأكد من حذف هذا المنتج؟</p>
                    <p class="text-slate-500 mt-2">سيتم حذف المنتج نهائياً من السجلات. لا يمكن التراجع عن هذا الإجراء.</p>
                </div>
            </div>
            <div class="modal-footer bg-slate-50 border-t border-slate-100 p-4 flex gap-2 justify-center">
                <button type="button" class="px-5 py-2.5 text-sm font-bold text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 hover:text-slate-800 rounded-xl transition-colors" data-bs-dismiss="modal">إلغاء</button>
                <form id="deleteProductForm" method="post" style="display: inline;">
                    <button type="submit" class="px-5 py-2.5 text-sm font-bold text-white bg-red-600 hover:bg-red-700 rounded-xl shadow-md shadow-red-200 transition-all">نعم، احذف المنتج</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/price-printing.js"></script>
    <script src="~/js/barcode.js"></script>
    <script src="~/js/sweetalert-products.js"></script>
    <script src="~/js/productjs/all-products.js"></script>
    
    <script>
        // Set global variables for pagination
        window.currentPage = @ViewBag.CurrentPage;
        window.pageSize = @ViewBag.PageSize;
        window.totalPages = @ViewBag.TotalPages;
    </script>
    
    <script>
        $(function () {
            var hasSuccess = $('#successAlert').length > 0;
            var hasError = $('#errorAlert').length > 0;
            if (hasSuccess) {
                try { $('#successAlert').show(); } catch (e) {} 
                var msg = `@((TempData.Peek("SuccessMessage")?.ToString() ?? "").Replace("`","\\`").Replace("\\", "\\\\").Replace("\r", "").Replace("\n", "\\n"))`;
                if (msg && msg.length) {
                   $('#successAlert').fadeIn();
                }
            }
            if (hasError) {
                try { $('#errorAlert').show(); } catch (e) {}
                var emsg = `@((TempData.Peek("ErrorMessage")?.ToString() ?? "").Replace("`","\\`").Replace("\\", "\\\\").Replace("\r", "").Replace("\n", "\\n"))`;
                if (emsg && emsg.length) {
                     $('#errorAlert').fadeIn();
                }
            }
        });
    </script>
}