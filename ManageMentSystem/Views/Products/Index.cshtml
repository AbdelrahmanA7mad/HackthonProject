                            <input type="number" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="editProductSalePrice" name="SalePrice" step="0.01" required>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-bold text-slate-700">الباركود</label>
                            <div class="flex gap-2">
                                <input type="text" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="editProductBarcode" name="Barcode" placeholder="أدخل الباركود أو اتركه للتوليد">
                                <button type="button" class="px-3 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 border border-slate-200 rounded-xl transition-colors" id="editGenerateBarcodeBtn" title="توليد باركود تلقائي">
