                    </div>

                    <input type="hidden" id="editQuantityName" name="Name">
                    <input type="hidden" id="editQuantityCategoryId" name="CategoryId">
                    <input type="hidden" id="editQuantityPurchasePrice" name="PurchasePrice">
                    <input type="hidden" id="editQuantitySalePrice" name="SalePrice">
                    <input type="hidden" id="editQuantityDescription" name="Description">
                    <input type="hidden" id="editQuantityBarcode" name="Barcode">
