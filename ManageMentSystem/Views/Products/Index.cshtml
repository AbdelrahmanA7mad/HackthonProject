                                <input type="number" class="block w-full p-2.5 text-sm text-slate-900 border border-slate-200 rounded-xl focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50 focus:bg-white transition-all" id="editProductPurchasePrice" name="PurchasePrice" step="0.01" required>
