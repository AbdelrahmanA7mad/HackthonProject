@section Scripts {
    <script src="~/js/price-printing.js"></script>
    <script src="~/js/barcode.js"></script>
    <script src="~/js/sweetalert-products.js"></script>
    <script src="~/js/productjs/index.js"></script>
    
    <script>
        // Set global variables for the page
        window.currentCategoryId = @Model.CategoryId;
        window.currentCategoryName = '@Model.CategoryName';
    </script>
    <script>
        $(function () {
            // استخدام SweetAlert أو التنبيهات المخصصة إذا كانت موجودة، مع fallback للتنبيهات العادية
            var hasSuccess = @((TempData["SuccessMessage"] != null).ToString().ToLower());
            var hasError = @((TempData["ErrorMessage"] != null).ToString().ToLower());
            
            if (hasSuccess) {
                var msg = `@((TempData["SuccessMessage"]?.ToString() ?? "").Replace("`","\\`").Replace("\\", "\\\\").Replace("\r", "").Replace("\n", "\\n"))`;
                if (msg && msg.length) {
                    if(typeof showSuccessMessage === 'function') {
                        showSuccessMessage('تم بنجاح', msg);
                    } else if (typeof Swal !== 'undefined') {
                         Swal.fire({ icon: 'success', title: 'تم بنجاح', text: msg });
                    }
                }
            }
            if (hasError) {
                var emsg = `@((TempData["ErrorMessage"]?.ToString() ?? "").Replace("`","\\`").Replace("\\", "\\\\").Replace("\r", "").Replace("\n", "\\n"))`;
                if (emsg && emsg.length) {
                    if(typeof showErrorMessage === 'function') {
                        showErrorMessage('خطأ', emsg);
                    } else if (typeof Swal !== 'undefined') {
                         Swal.fire({ icon: 'error', title: 'خطأ', text: emsg });
                    }
                }
            }
        });
    </script>
}