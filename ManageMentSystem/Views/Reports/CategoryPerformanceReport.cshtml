@model ManageMentSystem.ViewModels.CategoryPerformanceReportViewModel
@{
    ViewData["Title"] = "تقرير أداء الفئات";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="layers" class="text-primary"></i> تقرير أداء الفئات
            </h1>
            <p class="text-gray-500 mt-1 font-medium">تحليل المبيعات والربحية لكل فئة منتجات</p>
        </div>
        <div class="flex gap-2">
            <a href="@Url.Action("ExportCategoryPerformanceReportExcel", new { fromDate = Model.FromDate, toDate = Model.ToDate })" 
               class="zen-btn zen-btn-primary">
                <i data-lucide="file-spreadsheet"></i> تصدير Excel
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8 print:hidden">
        <form asp-action="CategoryPerformanceReport" method="get" class="grid grid-cols-1 gap-6 items-end">
            <div>
                <label class="block text-sm font-bold text-gray-600 mb-2">الفترة الزمنية</label>
                <partial name="_PremiumDateFilter" model="Model" />
            </div>
        </form>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium mb-1">إجمالي الفئات</p>
            <h3 class="text-2xl font-bold text-primary">@Model.TotalCategories</h3>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium mb-1">إجمالي المبيعات</p>
            <h3 class="text-2xl font-bold text-gray-800">@Model.TotalRevenue.ToString("N2") <span class="text-xs font-normal opacity-50">ج.م</span></h3>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium mb-1">صافي الأرباح</p>
            <h3 class="text-2xl font-bold text-green-600">@Model.TotalProfit.ToString("N2") <span class="text-xs font-normal opacity-50">ج.م</span></h3>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium mb-1">عدد عمليات البيع</p>
            <h3 class="text-2xl font-bold text-amber-600">@Model.TotalSales</h3>
        </div>
    </div>

    <!-- Performance List -->
    <div class="space-y-6">
        @foreach (var cat in Model.CategoryPerformance.OrderByDescending(x => x.Revenue))
        {
            <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow group">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-primary/5 text-primary rounded-xl flex items-center justify-center font-bold text-lg group-hover:bg-primary group-hover:text-white transition-colors">
                            @cat.CategoryName.Substring(0, 1)
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-gray-800">@cat.CategoryName</h3>
                            <p class="text-sm text-gray-500">@cat.SalesCount عملية بيع</p>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-8 w-full md:w-auto">
                        <div>
                            <p class="text-xs text-gray-400 font-bold mb-1 uppercase">الإيرادات</p>
                            <p class="font-bold text-gray-800">@cat.Revenue.ToString("N2")</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 font-bold mb-1 uppercase">الأرباح</p>
                            <p class="font-bold text-green-600">@cat.Profit.ToString("N2")</p>
                        </div>
                        <div class="col-span-2 md:col-span-1">
                            <p class="text-xs text-gray-400 font-bold mb-1 uppercase">هامش الربح</p>
                            <div class="flex items-center gap-2">
                                <div class="flex-1 h-2 bg-gray-100 rounded-full overflow-hidden w-24">
                                    <div class="h-full bg-green-500" style="width: @(Math.Min(100, (cat.Revenue > 0 ? (cat.Profit / cat.Revenue) * 100 : 0)))%"></div>
                                </div>
                                <span class="text-sm font-bold text-gray-600">@(cat.Revenue > 0 ? ((cat.Profit / cat.Revenue) * 100).ToString("F1") : "0")%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
