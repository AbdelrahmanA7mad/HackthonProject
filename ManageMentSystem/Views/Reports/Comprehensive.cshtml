@model ManageMentSystem.ViewModels.ComprehensiveReportViewModel
@{
    ViewData["Title"] = "تقرير الجرد الشامل";
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-chart-pie text-indigo-800"></i> تقرير الجرد الشامل
            </h1>
            <p class="text-slate-500 mt-1 font-medium">نظرة عامة على الأداء والمخزون والمبيعات</p>
        </div>
        <div>
            <a href="@Url.Action("ExportComprehensiveReportExcel", new { fromDate = Model.FromDate, toDate = Model.ToDate })" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl font-bold transition-all shadow-sm flex items-center gap-2 text-sm md:text-base">
                <i class="fas fa-file-excel"></i> تصدير Excel
            </a>
        </div>
    </div>
    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 mb-8 print:hidden">
        <form asp-action="Comprehensive" method="get" id="reportForm" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end">
                <div class="md:col-span-3">
                    <label for="fromDate" class="block text-sm font-bold text-slate-700 mb-2">من تاريخ</label>
                    <input type="date" id="fromDate" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none font-medium text-slate-800 transition-all" />
                </div>
                <div class="md:col-span-3">
                    <label for="toDate" class="block text-sm font-bold text-slate-700 mb-2">إلى تاريخ</label>
                    <input type="date" id="toDate" name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none font-medium text-slate-800 transition-all" />
                </div>
                <div class="md:col-span-6 flex flex-wrap gap-2">
                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:shadow-indigo-500/20">عرض التقرير</button>
                    <button type="button" class="quick-filter bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 px-4 py-2.5 rounded-xl font-bold transition-all" data-period="today">اليوم</button>
                    <button type="button" class="quick-filter bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 px-4 py-2.5 rounded-xl font-bold transition-all" data-period="month">هذا الشهر</button>
                    <button type="button" class="quick-filter bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 px-4 py-2.5 rounded-xl font-bold transition-all" data-period="year">هذه السنة</button>
                    <button type="button" class="quick-filter bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 px-4 py-2.5 rounded-xl font-bold transition-all" data-period="all">الكل</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Summary Section -->
    <div class="mb-8">
        <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
            <i class="fas fa-bolt text-amber-500"></i> التقارير السريعة
        </h2>
        <partial name="_ComprehensiveSummary" model="Model" />
    </div>

    <!-- Tabs Navigation -->
    <div class="mb-6 print:hidden">
        <div class="border-b border-slate-200">
            <nav class="-mb-px flex space-x-8 space-x-reverse" aria-label="Tabs">
                <button class="tab-btn active border-indigo-500 text-indigo-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-colors" data-target="#products">
                    <i class="fas fa-box ml-2"></i> المنتجات
                </button>
                <button class="tab-btn border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors" data-target="#sales">
                    <i class="fas fa-shopping-cart ml-2"></i> المبيعات
                </button>
                <button class="tab-btn border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors" data-target="#customers">
                    <i class="fas fa-users ml-2"></i> العملاء
                </button>
                <button class="tab-btn border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors" data-target="#charts">
                    <i class="fas fa-chart-bar ml-2"></i> الرسوم البيانية
                </button>
            </nav>
        </div>
    </div>

    <!-- Tab Content -->
    <div class="tab-content relative">
        <div id="products" class="tab-pane block">
            <partial name="_ComprehensiveProducts" model="Model" />
        </div>
        <div id="sales" class="tab-pane hidden">
            <partial name="_ComprehensiveSales" model="Model" />
        </div>
        <div id="customers" class="tab-pane hidden">
            <partial name="_ComprehensiveCustomers" model="Model" />
        </div>
        <div id="charts" class="tab-pane hidden">
            <partial name="_ComprehensiveCharts" model="Model" />
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Custom Tab Logic for Tailwind
            $('.tab-btn').click(function() {
                // Remove active classes from all tabs
                $('.tab-btn').removeClass('border-indigo-500 text-indigo-600 font-bold')
                             .addClass('border-transparent text-slate-500 font-medium hover:text-slate-700 hover:border-slate-300');
                
                // Add active classes to clicked tab
                $(this).removeClass('border-transparent text-slate-500 font-medium hover:text-slate-700 hover:border-slate-300')
                       .addClass('border-indigo-500 text-indigo-600 font-bold');
                
                // Hide all panes
                $('.tab-pane').addClass('hidden').removeClass('block');
                
                // Show target pane
                $($(this).data('target')).addClass('block').removeClass('hidden');
            });



            // Quick filter logic
            $('.quick-filter').on('click', function() {
                const period = $(this).data('period');
                const today = new Date();
                let fromDate = '';
                let toDate = today.toISOString().split('T')[0];

                if (period === 'today') {
                    fromDate = toDate;
                } else if (period === 'month') {
                    const firstDayOfMonth = new Date(today.getFullYear(), today.getMonth(), 1);
                    fromDate = firstDayOfMonth.toLocaleDateString('en-CA');
                } else if (period === 'year') {
                     const firstDayOfYear = new Date(today.getFullYear(), 0, 1);
                     fromDate = firstDayOfYear.toLocaleDateString('en-CA');
                } else if (period === 'all') {
                    fromDate = '';
                    toDate = '';
                }

                $('#fromDate').val(fromDate);
                $('#toDate').val(toDate);
                $('#reportForm').submit();
            });
        });
    </script>
}