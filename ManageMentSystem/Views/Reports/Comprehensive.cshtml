@model ManageMentSystem.ViewModels.ComprehensiveReportViewModel
@{
    ViewData["Title"] = "تقرير الجرد الشامل";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="pie-chart" class="text-primary"></i> تقرير الجرد الشامل
            </h1>
            <p class="text-gray-500 mt-1 font-medium">نظرة عامة على الأداء والمخزون والمبيعات</p>
        </div>
        <div>
            <a href="@Url.Action("ExportComprehensiveReportExcel", new { fromDate = Model.FromDate, toDate = Model.ToDate })" class="zen-btn zen-btn-primary md:text-base">
                <i data-lucide="file-spreadsheet"></i> تصدير Excel
            </a>
        </div>
    </div>
    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8 print:hidden">
        <form asp-action="Comprehensive" method="get" id="reportForm" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end">
                <div class="md:col-span-6">
                    <label class="block text-sm font-bold text-gray-600 mb-2">الفترة الزمنية</label>
                    <partial name="_PremiumDateFilter" model="Model" />
                </div>
                <div class="md:col-span-6 flex flex-wrap gap-2">
                    <button type="button" class="zen-btn zen-btn-neutral quick-filter" data-period="today">اليوم</button>
                    <button type="button" class="zen-btn zen-btn-neutral quick-filter" data-period="month">هذا الشهر</button>
                    <button type="button" class="zen-btn zen-btn-neutral quick-filter" data-period="year">هذه السنة</button>
                    <button type="button" class="zen-btn zen-btn-neutral quick-filter" data-period="all">الكل</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Summary Section -->
    <div class="mb-8">
        <h2 class="text-xl font-bold text-primary mb-4 flex items-center gap-2">
            <i data-lucide="zap" class="text-accentAmber"></i> التقارير السريعة
        </h2>
        <partial name="_ComprehensiveSummary" model="Model" />
    </div>

    <!-- Tabs Navigation -->
    <div class="mb-6 print:hidden">
        <div class="border-b border-gray-200">
            <nav class="-mb-px flex space-x-8 space-x-reverse" aria-label="Tabs">
                <button class="zen-btn zen-btn-neutral tab-btn active whitespace-nowrap" data-target="#products">
                    <i data-lucide="box" class="ml-2 inline-block w-4 h-4"></i> المنتجات
                </button>
                <button class="zen-btn zen-btn-neutral tab-btn whitespace-nowrap font-medium" data-target="#sales">
                    <i data-lucide="shopping-cart" class="ml-2 inline-block w-4 h-4"></i> المبيعات
                </button>
                <button class="zen-btn zen-btn-neutral tab-btn whitespace-nowrap font-medium" data-target="#customers">
                    <i data-lucide="users" class="ml-2 inline-block w-4 h-4"></i> العملاء
                </button>
                <button class="zen-btn zen-btn-neutral tab-btn whitespace-nowrap font-medium" data-target="#charts">
                    <i data-lucide="bar-chart-2" class="ml-2 inline-block w-4 h-4"></i> الرسوم البيانية
                </button>
            </nav>
        </div>
    </div>

    <!-- Tab Content -->
    <div class="tab-content relative">
        <div id="products" class="tab-pane block">
            <partial name="_ComprehensiveProducts" model="Model" />
        </div>
        <div id="sales" class="tab-pane hidden">
            <partial name="_ComprehensiveSales" model="Model" />
        </div>
        <div id="customers" class="tab-pane hidden">
            <partial name="_ComprehensiveCustomers" model="Model" />
        </div>
        <div id="charts" class="tab-pane hidden">
            <partial name="_ComprehensiveCharts" model="Model" />
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Custom Tab Logic for Tailwind
            $('.tab-btn').click(function() {
                // Remove active classes from all tabs
                $('.tab-btn').removeClass('border-gray-200 text-primary font-bold')
                             .addClass('border-transparent text-gray-500 font-medium hover:text-gray-600 hover:border-gray-200');
                
                // Add active classes to clicked tab
                $(this).removeClass('border-transparent text-gray-500 font-medium hover:text-gray-600 hover:border-gray-200')
                       .addClass('border-gray-200 text-primary font-bold');
                
                // Hide all panes
                $('.tab-pane').addClass('hidden').removeClass('block');
                
                // Show target pane
                $($(this).data('target')).addClass('block').removeClass('hidden');
            });



            // Quick filter logic
            $('.quick-filter').on('click', function() {
                const period = $(this).data('period');
                const today = new Date();
                let fromDate = '';
                let toDate = today.toISOString().split('T')[0];

                if (period === 'today') {
                    fromDate = toDate;
                } else if (period === 'month') {
                    const firstDayOfMonth = new Date(today.getFullYear(), today.getMonth(), 1);
                    fromDate = firstDayOfMonth.toLocaleDateString('en-CA');
                } else if (period === 'year') {
                     const firstDayOfYear = new Date(today.getFullYear(), 0, 1);
                     fromDate = firstDayOfYear.toLocaleDateString('en-CA');
                } else if (period === 'all') {
                    fromDate = '';
                    toDate = '';
                }

                $('#fromDate').val(fromDate);
                $('#toDate').val(toDate);
                $('#reportForm').submit();
            });
        });
    </script>
}
