@model ManageMentSystem.ViewModels.CustomerReportViewModel
@{
    ViewData["Title"] = "تقرير العملاء";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="users" class="text-primary"></i> تقرير العملاء الشامل
            </h1>
            <p class="text-gray-500 mt-1 font-medium">تحليل العملاء، الأكثر شراءً، وسجل المعاملات</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="@Url.Action("ExportCustomerReportExcel", new { fromDate = Model.FromDate, toDate = Model.ToDate })" 
               class="zen-btn zen-btn-primary">
                <i data-lucide="file-spreadsheet"></i> تصدير Excel
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 print:hidden">
        <form method="get" class="space-y-4">
            <div class="grid grid-cols-1 gap-4 items-end">
                <div>
                    <label class="block text-sm font-bold text-gray-600 mb-2">الفترة الزمنية</label>
                    <partial name="_PremiumDateFilter" model="Model" />
                </div>
            </div>
        </form>
    </div>

    <!-- Summary Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-bgSubtle flex items-center justify-center text-primary text-xl mb-3">
                <i data-lucide="users"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">إجمالي العملاء</div>
            <div class="text-2xl font-bold text-primary">@Model.TotalCustomers</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-bgSubtle flex items-center justify-center text-primary text-xl mb-3">
                <i data-lucide="user-check"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">العملاء النشطين</div>
            <div class="text-2xl font-bold text-primary">@Model.ActiveCustomers</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-amber-50 flex items-center justify-center text-amber-600 text-xl mb-3">
                <i data-lucide="user-plus"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">العملاء الجدد</div>
            <div class="text-2xl font-bold text-amber-600">@Model.NewCustomers</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-bgSubtle flex items-center justify-center text-primary text-xl mb-3">
                <i data-lucide="dollar-sign"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">إجمالي الإيرادات</div>
            <div class="text-2xl font-bold text-primary">@Model.TotalCustomerRevenue.ToString("C")</div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- Additional Details -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h5 class="font-bold text-primary mb-4 flex items-center gap-2 pb-3 border-b border-gray-200">
                <i data-lucide="info" class="text-primary"></i> تفاصيل إضافية
            </h5>
            <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">متوسط قيمة العميل</span>
                    <span class="font-bold text-primary">@Model.AverageCustomerValue.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">إجمالي ديون العملاء</span>
                    <span class="font-bold text-red-600">@Model.TotalCustomerDebts.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">نسبة العملاء النشطين</span>
                    <span class="font-bold text-primary">@(Model.TotalCustomers > 0 ? ((double)Model.ActiveCustomers / Model.TotalCustomers * 100).ToString("F1") : "0")%</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">نسبة العملاء الجدد</span>
                    <span class="font-bold text-amber-600">@(Model.TotalCustomers > 0 ? ((double)Model.NewCustomers / Model.TotalCustomers * 100).ToString("F1") : "0")%</span>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h5 class="font-bold text-primary mb-4 flex items-center gap-2 pb-3 border-b border-gray-200">
                <i data-lucide="bar-chart-2" class="text-primary"></i> أفضل 5 عملاء حسب المشتريات
            </h5>
            <div class="relative h-64 w-full flex justify-center">
                <canvas id="customerChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Top Customers Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-6">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-bgSubtle">
            <h5 class="font-bold text-primary flex items-center gap-2">
                <i data-lucide="trophy" class="text-amber-500"></i> أفضل 10 عملاء
            </h5>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-gray-50 text-gray-500 font-bold text-sm border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-4">المرتبة</th>
                        <th class="px-6 py-4">اسم العميل</th>
                        <th class="px-6 py-4">عدد المبيعات</th>
                        <th class="px-6 py-4">إجمالي المشتريات</th>
                        <th class="px-6 py-4">الديون المستحقة</th>
                        <th class="px-6 py-4">متوسط قيمة البيع</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @for (int i = 0; i < Model.TopCustomers.Count; i++)
                    {
                        var customer = Model.TopCustomers[i];
                        var averageSale = customer.SalesCount > 0 ? customer.TotalSpent / customer.SalesCount : 0;
                        <tr>
                            <td class="px-6 py-4">
                                @if (i == 0)
                                {
                                    <div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center text-amber-600 mx-auto border border-amber-200 shadow-sm"><i data-lucide="crown" class="w-4 h-4"></i></div>
                                }
                                else if (i == 1)
                                {
                                     <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-500 mx-auto border border-gray-200 shadow-sm"><span class="font-bold">2</span></div>
                                }
                                else if (i == 2)
                                {
                                     <div class="w-8 h-8 rounded-full bg-bgSubtle flex items-center justify-center text-primary mx-auto border border-gray-200 shadow-sm"><span class="font-bold">3</span></div>
                                }
                                else
                                {
                                    <span class="font-mono text-gray-500 font-bold block text-center">@(i + 1)</span>
                                }
                            </td>
                            <td class="px-6 py-4 font-bold text-gray-600">@customer.CustomerName</td>
                            <td class="px-6 py-4 text-gray-500 text-center">@customer.SalesCount</td>
                            <td class="px-6 py-4 font-bold text-primary">@customer.TotalSpent.ToString("C")</td>
                            <td class="px-6 py-4">
                                @if (customer.OutstandingDebt > 0)
                                {
                                    <span class="bg-red-100 text-accentRed px-3 py-1 rounded-full text-xs font-bold">@customer.OutstandingDebt.ToString("C")</span>
                                }
                                else
                                {
                                    <span class="text-primary font-bold text-xs"><i data-lucide="check" class="w-3 h-3 inline-block"></i> خالص</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-gray-500">@averageSale.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- All Customers Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-bgSubtle">
            <h5 class="font-bold text-primary flex items-center gap-2">
                <i data-lucide="table" class="text-primary"></i> تفاصيل جميع العملاء
            </h5>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-gray-50 text-gray-500 font-bold text-sm border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-4">اسم العميل</th>
                        <th class="px-6 py-4">رقم الهاتف</th>
                        <th class="px-6 py-4">العنوان</th>
                        <th class="px-6 py-4 text-center">عدد المبيعات</th>
                        <th class="px-6 py-4">إجمالي المشتريات</th>
                        <th class="px-6 py-4 text-center">الحالة</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var customer in Model.Customers)
                    {
                        var totalSpent = customer.Sales.Sum(s => s.TotalAmount);
                        var isActive = customer.Sales.Any();
                        
                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="px-6 py-4 font-bold text-gray-600">@customer.FullName</td>
                            <td class="px-6 py-4 font-mono text-gray-500">@customer.PhoneNumber</td>
                            <td class="px-6 py-4 text-gray-500">@customer.Address</td>
                            <td class="px-6 py-4 text-center text-gray-500">@customer.Sales.Count</td>
                            <td class="px-6 py-4 font-medium text-primary">@totalSpent.ToString("C")</td>
                            <td class="px-6 py-4 text-center">
                                @if (isActive)
                                {
                                    <span class="bg-gray-100 text-primary px-3 py-1 rounded-full text-xs font-bold">نشط</span>
                                }
                                else
                                {
                                    <span class="bg-gray-100 text-gray-500 px-3 py-1 rounded-full text-xs font-bold">غير نشط</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.js"></script>
    <script>
        const ctx = document.getElementById('customerChart').getContext('2d');
        const topCustomersData = @Html.Raw(Json.Serialize(Model.TopCustomers.Take(5)));
        const theme = window.THEME || window;
        const rgbaFromColor = (color, alpha) => {
            if (!color) return `rgba(15, 20, 25, ${alpha})`;
            const normalized = color.trim();
            if (normalized.startsWith('#')) {
                const hex = normalized.slice(1);
                const expanded = hex.length === 3 ? hex.split('').map(ch => ch + ch).join('') : hex;
                const parts = expanded.match(/.{1,2}/g) || ['0f', '14', '19'];
                const [r, g, b] = parts.map(part => parseInt(part, 16));
                return `rgba(${r}, ${g}, ${b}, ${alpha})`;
            }
            const rgbMatch = normalized.match(/rgba?\(([^)]+)\)/i);
            if (rgbMatch) {
                const values = rgbMatch[1].split(',').map(v => v.trim());
                return `rgba(${values[0]}, ${values[1]}, ${values[2]}, ${alpha})`;
            }
            return normalized;
        };

        const chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: topCustomersData.map(c => c.customerName),
                datasets: [{
                    label: 'إجمالي المشتريات',
                    data: topCustomersData.map(c => c.totalSpent),
                    backgroundColor: [
                        theme.primary,
                        theme.accentGreen,
                        theme.accentAmber,
                        theme.accentRed,
                        theme.accent
                    ],
                    borderRadius: 6,
                    borderWidth: 0,
                    barPercentage: 0.6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: rgbaFromColor(theme.primary, 0.92),
                        titleFont: { family: 'Cairo' },
                        bodyFont: { family: 'Cairo' },
                        padding: 10,
                        cornerRadius: 8
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { font: { family: 'Cairo' } }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: theme.borderSubtle || theme.bgSubtle || '#e5e7eb' },
                        ticks: { font: { family: 'Cairo' } }
                    }
                }
            }
        });
    </script>
}
