@model ManageMentSystem.ViewModels.FinancialReportViewModel
@{
    ViewData["Title"] = "التقرير المالي";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="pie-chart" class="text-primary"></i> التقرير المالي الشامل
            </h1>
            <p class="text-gray-500 mt-1 font-medium">تحليل الإيرادات والمصروفات والمركز المالي</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="@Url.Action("ExportFinancialReportExcel", new { fromDate = Model.FromDate, toDate = Model.ToDate })" 
               class="zen-btn zen-btn-primary">
                <i data-lucide="file-spreadsheet"></i> تصدير Excel
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 print:hidden">
        <form method="get" class="space-y-4">
            <div class="grid grid-cols-1 gap-4 items-end">
                <div>
                    <label class="block text-sm font-bold text-gray-600 mb-2">الفترة الزمنية</label>
                    <partial name="_PremiumDateFilter" model="Model" />
                </div>
            </div>
        </form>
    </div>



    <!-- Summary Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-bgSubtle flex items-center justify-center text-primary text-xl mb-3">
                <i data-lucide="arrow-up"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">إجمالي الإيرادات</div>
            <div class="text-2xl font-bold text-primary">@Model.TotalIncome.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-600 text-xl mb-3">
                <i data-lucide="arrow-down"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">إجمالي المصروفات</div>
            <div class="text-2xl font-bold text-red-600">@Model.TotalExpenses.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full @(Model.NetProfit >= 0 ? "bg-bgSubtle text-primary" : "bg-red-50 text-red-600") flex items-center justify-center text-xl mb-3">
                <i data-lucide="trending-up"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">صافي الربح</div>
            <div class="text-2xl font-bold @(Model.NetProfit >= 0 ? "text-primary" : "text-red-600")">@Model.NetProfit.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-bgSubtle flex items-center justify-center text-primary text-xl mb-3">
                <i data-lucide="wallet"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">الرصيد النقدي</div>
            <div class="text-2xl font-bold @(Model.CashBalance >= 0 ? "text-primary" : "text-red-600")">@Model.CashBalance.ToString("C")</div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- Additional Details -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h5 class="font-bold text-primary mb-4 flex items-center gap-2 pb-3 border-b border-gray-200">
                <i data-lucide="info" class="text-primary"></i> ملخص المركز المالي
            </h5>
            <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">إجمالي الأصول</span>
                    <span class="font-bold text-primary">@Model.TotalAssets.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">إجمالي الخصوم</span>
                    <span class="font-bold text-red-600">@Model.TotalLiabilities.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">رأس المال العامل</span>
                    <span class="font-bold @(Model.WorkingCapital >= 0 ? "text-primary" : "text-red-600")">@Model.WorkingCapital.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">عدد المعاملات</span>
                    <span class="font-bold text-primary">@Model.TotalTransactions</span>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h5 class="font-bold text-primary mb-4 flex items-center gap-2 pb-3 border-b border-gray-200">
                <i data-lucide="pie-chart" class="text-primary"></i> توزيع الإيرادات والمصروفات
            </h5>
            <div class="relative h-64 w-full flex justify-center">
                <canvas id="financialChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-bgSubtle">
            <h5 class="font-bold text-primary flex items-center gap-2">
                <i data-lucide="list" class="text-primary"></i> سجل المعاملات المالية
            </h5>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-gray-50 text-gray-500 font-bold text-sm border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-4">التاريخ</th>
                        <th class="px-6 py-4">الوصف</th>
                        <th class="px-6 py-4">نوع العملية</th>
                        <th class="px-6 py-4">المبلغ</th>
                        <th class="px-6 py-4">طريقة الدفع</th>
                        <th class="px-6 py-4">الرصيد</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var transaction in Model.Transactions)
                    {
                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="px-6 py-4 text-gray-500">@transaction.TransactionDate.ToString("dd/MM/yyyy")</td>
                            <td class="px-6 py-4 font-medium text-primary">@transaction.Description</td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 rounded-full text-xs font-bold @(transaction.TransactionType == ManageMentSystem.Models.TransactionType.Income ? "bg-emerald-100 text-accentGreen" : "bg-red-100 text-accentRed")">
                                    @(transaction.TransactionType == ManageMentSystem.Models.TransactionType.Income ? "إيراد" : "مصروف")
                                </span>
                            </td>
                            <td class="px-6 py-4 font-bold @(transaction.TransactionType == ManageMentSystem.Models.TransactionType.Income ? "text-primary" : "text-red-600")">
                                @transaction.Amount.ToString("C")
                            </td>
                            <td class="px-6 py-4 text-gray-500">@(transaction.PaymentMethod is string ? transaction.PaymentMethod : transaction.PaymentMethod?.ToString())</td>
                            <td class="px-6 py-4 font-mono text-gray-500">@transaction.Capital.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.js"></script>
    <script>
        const ctx = document.getElementById('financialChart').getContext('2d');
        const theme = window.THEME || window;
        const rgbaFromColor = (color, alpha) => {
            if (!color) return `rgba(15, 20, 25, ${alpha})`;
            const normalized = color.trim();
            if (normalized.startsWith('#')) {
                const hex = normalized.slice(1);
                const expanded = hex.length === 3 ? hex.split('').map(ch => ch + ch).join('') : hex;
                const parts = expanded.match(/.{1,2}/g) || ['0f', '14', '19'];
                const [r, g, b] = parts.map(part => parseInt(part, 16));
                return `rgba(${r}, ${g}, ${b}, ${alpha})`;
            }
            const rgbMatch = normalized.match(/rgba?\(([^)]+)\)/i);
            if (rgbMatch) {
                const values = rgbMatch[1].split(',').map(v => v.trim());
                return `rgba(${values[0]}, ${values[1]}, ${values[2]}, ${alpha})`;
            }
            return normalized;
        };
        const chart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['الإيرادات', 'المصروفات'],
                datasets: [{
                    data: [@Model.TotalIncome, @Model.TotalExpenses],
                    backgroundColor: [
                        theme.accentGreen,
                        theme.accentRed
                    ],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: { family: 'Cairo', size: 12 },
                            usePointStyle: true,
                            padding: 20
                        }
                    },
                     tooltip: {
                        backgroundColor: rgbaFromColor(theme.primary, 0.92),
                        titleFont: { family: 'Cairo' },
                        bodyFont: { family: 'Cairo' },
                        padding: 10,
                        cornerRadius: 8
                    }
                },
                cutout: '70%',
            }
        });
    </script>
}
