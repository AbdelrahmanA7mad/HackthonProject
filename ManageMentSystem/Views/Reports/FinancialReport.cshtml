@model ManageMentSystem.ViewModels.FinancialReportViewModel
@{
    ViewData["Title"] = "التقرير المالي";
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-[#0f1419] flex items-center gap-2">
                <i data-lucide="pie-chart" class="text-[#0f1419]"></i> التقرير المالي الشامل
            </h1>
            <p class="text-gray-500 mt-1 font-medium">تحليل الإيرادات والمصروفات والمركز المالي</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="@Url.Action("ExportFinancialReportExcel", new { fromDate = Model.FromDate, toDate = Model.ToDate })" 
               class="bg-[#0f1419] hover:bg-[#1a1f24] text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-md hover:shadow-gray-400/20 hover:-translate-y-0.5 flex items-center gap-2">
                <i data-lucide="file-spreadsheet"></i> تصدير Excel
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 print:hidden">
        <form method="get" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-end">
                <div>
                    <label class="block text-sm font-bold text-gray-600 mb-2">من تاريخ</label>
                    <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-bgSubtle focus:border-[#0f1419] outline-none font-medium text-[#0f1419] transition-all" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-600 mb-2">إلى تاريخ</label>
                    <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-bgSubtle focus:border-[#0f1419] outline-none font-medium text-[#0f1419] transition-all" />
                </div>
                <div class="flex gap-3">
                    <button type="submit" class="bg-[#0f1419] hover:bg-[#0f1419] text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:shadow-gray-400/20 flex items-center gap-2 flex-grow justify-center">
                        <i data-lucide="search"></i> تطبيق
                    </button>
                    <a href="@Url.Action("FinancialReport")" class="bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-[#0f1419] px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm flex items-center gap-2 flex-grow justify-center">
                        <i data-lucide="x"></i> إلغاء
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- Zenith AI Insights Widget -->
    <div class="mb-8 bg-[#0f1419] rounded-2xl p-6 shadow-xl border border-white/10 relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
            <i data-lucide="brain-circuit" class="w-32 h-32 text-white"></i>
        </div>
        
        <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-gray-500/20 rounded-xl flex items-center justify-center border border-white/10">
                    <i data-lucide="sparkles" class="text-[#0f1419] w-6 h-6"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">تحليلات Zenith AI المالية</h3>
                    <p class="text-gray-500 text-xs">رؤى ذكية حول المركز المالي والتدفقات النقدية</p>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-4 rounded-xl">
                    <div class="flex items-center gap-2 mb-2 text-emerald-400 font-bold text-sm">
                        <i data-lucide="wallet" class="w-4 h-4"></i>
                        تحسين السيولة
                    </div>
                    <p class="text-white text-xs leading-relaxed">
                        صافي الربح الحالي إيجابي. ننصح بتوجيه 10% من الأرباح المحتجزة لتوسيع فئات المنتجات الأكثر ربحية (ذات هامش ربح أعلى من 25%).
                    </p>
                </div>
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-4 rounded-xl">
                    <div class="flex items-center gap-2 mb-2 text-red-400 font-bold text-sm">
                        <i data-lucide="trending-down" class="w-4 h-4"></i>
                        مراقبة المصروفات
                    </div>
                    <p class="text-white text-xs leading-relaxed">
                        نلاحظ زيادة طفيفة في المصروفات التشغيلية. مراجعة بنود المصروفات المتغيرة قد تساعد في زيادة صافي الربح بنسبة 3% الشهر القادم.
                    </p>
                </div>
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-4 rounded-xl">
                    <div class="flex items-center gap-2 mb-2 text-blue-400 font-bold text-sm">
                        <i data-lucide="line-chart" class="w-4 h-4"></i>
                        التدفق النقدي المتوقع
                    </div>
                    <p class="text-white text-xs leading-relaxed">
                        من المتوقع زيادة التدفق النقدي بنسبة 12% نتيجة تحصيل الأقساط القادمة. هذا هو الوقت المناسب للتفاوض مع الموردين على خصومات الشراء النقدي.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-gray-50 flex items-center justify-center text-[#0f1419] text-xl mb-3">
                <i data-lucide="arrow-up"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">إجمالي الإيرادات</div>
            <div class="text-2xl font-bold text-[#0f1419]">@Model.TotalIncome.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-600 text-xl mb-3">
                <i data-lucide="arrow-down"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">إجمالي المصروفات</div>
            <div class="text-2xl font-bold text-red-600">@Model.TotalExpenses.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full @(Model.NetProfit >= 0 ? "bg-gray-50 text-[#0f1419]" : "bg-red-50 text-red-600") flex items-center justify-center text-xl mb-3">
                <i data-lucide="trending-up"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">صافي الربح</div>
            <div class="text-2xl font-bold @(Model.NetProfit >= 0 ? "text-[#0f1419]" : "text-red-600")">@Model.NetProfit.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-gray-50 flex items-center justify-center text-[#0f1419] text-xl mb-3">
                <i data-lucide="wallet"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">الرصيد النقدي</div>
            <div class="text-2xl font-bold @(Model.CashBalance >= 0 ? "text-[#0f1419]" : "text-red-600")">@Model.CashBalance.ToString("C")</div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- Additional Details -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h5 class="font-bold text-[#0f1419] mb-4 flex items-center gap-2 pb-3 border-b border-gray-200">
                <i data-lucide="info" class="text-white0"></i> ملخص المركز المالي
            </h5>
            <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">إجمالي الأصول</span>
                    <span class="font-bold text-[#0f1419]">@Model.TotalAssets.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">إجمالي الخصوم</span>
                    <span class="font-bold text-red-600">@Model.TotalLiabilities.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">رأس المال العامل</span>
                    <span class="font-bold @(Model.WorkingCapital >= 0 ? "text-[#0f1419]" : "text-red-600")">@Model.WorkingCapital.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">عدد المعاملات</span>
                    <span class="font-bold text-[#0f1419]">@Model.TotalTransactions</span>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h5 class="font-bold text-[#0f1419] mb-4 flex items-center gap-2 pb-3 border-b border-gray-200">
                <i data-lucide="pie-chart" class="text-white0"></i> توزيع الإيرادات والمصروفات
            </h5>
            <div class="relative h-64 w-full flex justify-center">
                <canvas id="financialChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-gray-50/50">
            <h5 class="font-bold text-[#0f1419] flex items-center gap-2">
                <i data-lucide="list" class="text-white0"></i> سجل المعاملات المالية
            </h5>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-gray-50 text-gray-500 font-bold text-sm border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-4">التاريخ</th>
                        <th class="px-6 py-4">الوصف</th>
                        <th class="px-6 py-4">نوع العملية</th>
                        <th class="px-6 py-4">المبلغ</th>
                        <th class="px-6 py-4">طريقة الدفع</th>
                        <th class="px-6 py-4">الرصيد</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var transaction in Model.Transactions)
                    {
                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="px-6 py-4 text-gray-500">@transaction.TransactionDate.ToString("dd/MM/yyyy")</td>
                            <td class="px-6 py-4 font-medium text-[#0f1419]">@transaction.Description</td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 rounded-full text-xs font-bold @(transaction.TransactionType == ManageMentSystem.Models.TransactionType.Income ? "bg-emerald-100 text-accentGreen" : "bg-red-100 text-accentRed")">
                                    @(transaction.TransactionType == ManageMentSystem.Models.TransactionType.Income ? "إيراد" : "مصروف")
                                </span>
                            </td>
                            <td class="px-6 py-4 font-bold @(transaction.TransactionType == ManageMentSystem.Models.TransactionType.Income ? "text-[#0f1419]" : "text-red-600")">
                                @transaction.Amount.ToString("C")
                            </td>
                            <td class="px-6 py-4 text-gray-500">@(transaction.PaymentMethod is string ? transaction.PaymentMethod : transaction.PaymentMethod?.ToString())</td>
                            <td class="px-6 py-4 font-mono text-gray-500">@transaction.Capital.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.js"></script>
    <script>
        const ctx = document.getElementById('financialChart').getContext('2d');
        const chart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['الإيرادات', 'المصروفات'],
                datasets: [{
                    data: [@Model.TotalIncome, @Model.TotalExpenses],
                    backgroundColor: [
                        '#059669', // emerald-500
                        '#e11d48'  // red-500
                    ],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: { family: 'Cairo', size: 12 },
                            usePointStyle: true,
                            padding: 20
                        }
                    },
                     tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        titleFont: { family: 'Cairo' },
                        bodyFont: { family: 'Cairo' },
                        padding: 10,
                        cornerRadius: 8
                    }
                },
                cutout: '70%',
            }
        });
    </script>
}
