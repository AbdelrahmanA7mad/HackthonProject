@model ManageMentSystem.ViewModels.GeneralDebtReportViewModel
@{
    ViewData["Title"] = "تقرير الديون العامة";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="file-text" class="text-primary"></i> تقرير الديون العامة الشامل
            </h1>
            <p class="text-gray-500 mt-1 font-medium">تحليل الديون المستحقة والالتزامات المالية والتحصيل</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="@Url.Action("ExportGeneralDebtReportExcel", new { fromDate = Model.FromDate, toDate = Model.ToDate })" 
               class="zen-btn zen-btn-primary">
                <i data-lucide="file-spreadsheet"></i> تصدير Excel
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 print:hidden">
        <form method="get" class="space-y-4">
            <div class="grid grid-cols-1 gap-4 items-end">
                <div>
                    <label class="block text-sm font-bold text-gray-600 mb-2">الفترة الزمنية</label>
                    <partial name="_PremiumDateFilter" model="Model" />
                </div>
            </div>
        </form>
    </div>



    <!-- Summary Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-bgSubtle flex items-center justify-center text-primary text-xl mb-3">
                <i data-lucide="dollar-sign"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">إجمالي مبلغ الديون</div>
            <div class="text-2xl font-bold text-primary">@Model.TotalDebtAmount.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center text-accentGreen text-xl mb-3">
                <i data-lucide="check-circle"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">إجمالي المحصل/المدفوع</div>
            <div class="text-2xl font-bold text-accentGreen">@Model.TotalPaidAmount.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-accentRed text-xl mb-3">
                <i data-lucide="clock"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">المبلغ المتبقي</div>
            <div class="text-2xl font-bold text-accentRed">@Model.OutstandingAmount.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 text-xl mb-3">
                <i data-lucide="activity"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">الديون النشطة</div>
            <div class="text-2xl font-bold text-blue-600">@Model.ActiveDebts</div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- Status Statistics -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h5 class="font-bold text-primary mb-4 flex items-center gap-2 pb-3 border-b border-gray-200">
                <i data-lucide="info" class="text-primary"></i> تحليل حالة الديون
            </h5>
            <div class="space-y-4">
                @foreach (var status in Model.DebtStatus)
                {
                    <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                        <div class="flex items-center gap-3">
                            <span class="w-3 h-3 rounded-full bg-primary"></span>
                            <span class="text-gray-600 font-bold">@status.Status</span>
                        </div>
                        <div class="text-left">
                            <div class="font-bold text-primary">@status.TotalAmount.ToString("C")</div>
                            <div class="text-xs text-gray-400 font-bold">@status.Count عملية</div>
                        </div>
                    </div>
                }
                @if (!Model.DebtStatus.Any())
                {
                    <div class="text-center py-8 text-gray-400 font-bold">لا توجد بيانات متاحة</div>
                }
            </div>
        </div>

        <!-- Charts Section -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h5 class="font-bold text-primary mb-4 flex items-center gap-2 pb-3 border-b border-gray-200">
                <i data-lucide="pie-chart" class="text-primary"></i> توزيع مبالغ الديون حسب الحالة
            </h5>
            <div class="relative h-64 w-full flex justify-center">
                <canvas id="debtStatusChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Debts Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-bgSubtle">
            <h5 class="font-bold text-primary flex items-center gap-2">
                <i data-lucide="list" class="text-primary"></i> تفاصيل الديون العامة
            </h5>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-gray-50 text-gray-500 font-bold text-sm border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-4">العنوان</th>
                        <th class="px-6 py-4">الطرف</th>
                        <th class="px-6 py-4">النوع</th>
                        <th class="px-6 py-4">المبلغ الإجمالي</th>
                        <th class="px-6 py-4">المدفوع/المحصل</th>
                        <th class="px-6 py-4">المتبقي</th>
                        <th class="px-6 py-4">تاريخ الاستحقاق</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var debt in Model.Debts)
                    {
                        var remaining = debt.Amount - debt.PaidAmount;
                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="px-6 py-4 font-bold text-primary">@debt.Title</td>
                            <td class="px-6 py-4 text-gray-600 font-medium">@(debt.PartyName ?? "غير محدد")</td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 rounded-full text-xs font-bold @(debt.DebtType == ManageMentSystem.Models.GeneralDebtType.OwedToMe ? "bg-emerald-100 text-accentGreen" : "bg-red-100 text-accentRed")">
                                    @(debt.DebtType == ManageMentSystem.Models.GeneralDebtType.OwedToMe ? "دين ليا" : "دين عليا")
                                </span>
                            </td>
                            <td class="px-6 py-4 font-bold text-gray-700">@debt.Amount.ToString("C")</td>
                            <td class="px-6 py-4 font-bold text-accentGreen">@debt.PaidAmount.ToString("C")</td>
                            <td class="px-6 py-4 font-bold @(remaining > 0 ? "text-accentRed" : "text-gray-400")">
                                @remaining.ToString("C")
                            </td>
                            <td class="px-6 py-4 text-gray-500 font-medium">
                                @(debt.DueDate?.ToString("dd/MM/yyyy") ?? "-")
                            </td>
                        </tr>
                    }
                    @if (!Model.Debts.Any())
                    {
                        <tr>
                            <td colspan="7" class="px-6 py-10 text-center text-gray-400 font-bold">لا توجد ديون مسجلة في هذه الفترة</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('debtStatusChart').getContext('2d');
            const theme = window.THEME || {
                primary: '#315f8f',
                accentGreen: '#10b981',
                accentRed: '#ef4444',
                accentAmber: '#f59e0b',
                accentBlue: '#3b82f6'
            };

            const labels = @Html.Raw(Json.Serialize(Model.DebtStatus.Select(s => s.Status)));
            const data = @Html.Raw(Json.Serialize(Model.DebtStatus.Select(s => s.TotalAmount)));
            
            const colors = [
                theme.primary,
                theme.accentGreen,
                theme.accentAmber,
                theme.accentRed,
                theme.accentBlue
            ];

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: colors.slice(0, labels.length),
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                font: { family: 'Cairo', size: 12, weight: 'bold' },
                                usePointStyle: true,
                                padding: 20
                            }
                        },
                        tooltip: {
                            titleFont: { family: 'Cairo' },
                            bodyFont: { family: 'Cairo' },
                            padding: 10,
                            cornerRadius: 8
                        }
                    },
                    cutout: '70%',
                }
            });
        });
    </script>
}
