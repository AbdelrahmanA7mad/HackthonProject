@using ManageMentSystem.Models
@inject ManageMentSystem.Services.UserServices.IUserService UserService
@{
    ViewData["Title"] = "التقارير";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
            <i data-lucide="trending-up" class="text-primary"></i> لوحة تحكم التقارير الشاملة
        </h1>
        <p class="text-gray-500 mt-1 font-medium">عرض وتحليلات شاملة لأداء النظام والمبيعات والمخزون</p>
    </div>

    <!-- Reports Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
       
            <!-- Sales Report -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md hover:border-gray-200 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-bgSubtle flex items-center justify-center text-primary text-2xl mb-4 group-hover:bg-primary group-hover:text-white transition-colors">
                    <i data-lucide="bar-chart-2"></i>
                </div>
                <h3 class="text-lg font-bold text-primary mb-2">تقرير المبيعات</h3>
                <p class="text-gray-500 text-sm mb-6 min-h-[40px]">تحليل مفصل للمبيعات والأرباح وفترات الذروة</p>
                <a asp-action="SalesReport" class="w-full bg-white border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-primary hover:border-gray-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-primary  group-hover:border-primary">
                    عرض التقرير <i data-lucide="arrow-left" class="w-4 h-4 mr-1 inline-block"></i>
                </a>
            </div>

            <!-- Inventory Report -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md hover:border-emerald-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-bgSubtle flex items-center justify-center text-primary text-2xl mb-4 group-hover:bg-primary group-hover:text-white transition-colors">
                    <i data-lucide="package"></i>
                </div>
                <h3 class="text-lg font-bold text-primary mb-2">تقرير المخزون</h3>
                <p class="text-gray-500 text-sm mb-6 min-h-[40px]">حالة المخزون، حركة المنتجات، والقيمة الإجمالية</p>
                <a asp-action="InventoryReport" class="w-full bg-white border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-primary hover:border-gray-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-primary  group-hover:border-primary">
                    عرض التقرير <i data-lucide="arrow-left" class="w-4 h-4 mr-1 inline-block"></i>
                </a>
            </div>

            <!-- Customer Report -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md hover:border-amber-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600 text-2xl mb-4 group-hover:bg-accentAmber group-hover:text-white transition-colors">
                    <i data-lucide="users"></i>
                </div>
                <h3 class="text-lg font-bold text-primary mb-2">تقرير العملاء</h3>
                <p class="text-gray-500 text-sm mb-6 min-h-[40px]">تحليل العملاء، الأكثر شراءً، وسجل المعاملات</p>
                <a asp-action="CustomerReport" class="w-full bg-white border border-gray-200 text-gray-600 hover:bg-amber-50 hover:text-amber-700 hover:border-amber-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-accentAmber  group-hover:border-accentAmber">
                    عرض التقرير <i data-lucide="arrow-left" class="w-4 h-4 mr-1 inline-block"></i>
                </a>
            </div>

            <!-- General Debt Report -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md hover:border-red-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-red-50 flex items-center justify-center text-red-600 text-2xl mb-4 group-hover:bg-accentRed group-hover:text-white transition-colors">
                    <i data-lucide="file-text"></i>
                </div>
                <h3 class="text-lg font-bold text-primary mb-2">تقرير الديون</h3>
                <p class="text-gray-500 text-sm mb-6 min-h-[40px]">إجمالي الديون العامة والمستحقات المالية</p>
                <a asp-action="GeneralDebtReport" class="w-full bg-white border border-gray-200 text-gray-600 hover:bg-red-50 hover:text-accentRed hover:border-red-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-accentRed  group-hover:border-accentRed">
                    عرض التقرير <i data-lucide="arrow-left" class="w-4 h-4 mr-1 inline-block"></i>
                </a>
            </div>

            <!-- Receivables (Customer Accounts) -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md hover:border-gray-200 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-bgSubtle flex items-center justify-center text-primary text-2xl mb-4 group-hover:bg-accent group-hover:text-white transition-colors">
                    <i data-lucide="user-check"></i>
                </div>
                <h3 class="text-lg font-bold text-primary mb-2">حسابات العملاء</h3>
                <p class="text-gray-500 text-sm mb-6 min-h-[40px]">كشف حساب تفصيلي للعملاء ومتابعة الأرصدة</p>
                <a asp-action="Receivables" class="w-full bg-white border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-primary hover:border-gray-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-accent  group-hover:border-accent">
                    عرض التقرير <i data-lucide="arrow-left" class="w-4 h-4 mr-1 inline-block"></i>
                </a>
            </div>

            <!-- Capital Summary -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md hover:border-gray-200 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-bgSubtle flex items-center justify-center text-primary text-2xl mb-4 group-hover:bg-accentGreen group-hover:text-white transition-colors">
                    <i data-lucide="scale"></i>
                </div>
                <h3 class="text-lg font-bold text-primary mb-2">ملخص رأس المال</h3>
                <p class="text-gray-500 text-sm mb-6 min-h-[40px]">المركز المالي، الأصول، والالتزامات الحالية</p>
                <a asp-action="CapitalSummary" class="w-full bg-white border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-primary hover:border-gray-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-accentGreen  group-hover:border-accentGreen">
                    عرض التقرير <i data-lucide="arrow-left" class="w-4 h-4 mr-1 inline-block"></i>
                </a>
            </div>

            <!-- Low Stock -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md hover:border-gray-200 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-bgSubtle flex items-center justify-center text-primary text-2xl mb-4 group-hover:bg-accentAmber group-hover:text-white transition-colors">
                    <i data-lucide="alert-triangle"></i>
                </div>
                <h3 class="text-lg font-bold text-primary mb-2">المنتجات شحيحة المخزون</h3>
                <p class="text-gray-500 text-sm mb-6 min-h-[40px]">تنبيهات بالمنتجات التي قاربت على النفاذ</p>
                <a asp-action="LowStock" class="w-full bg-white border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-primary hover:border-gray-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-accentAmber  group-hover:border-accentAmber">
                    عرض التقرير <i data-lucide="arrow-left" class="w-4 h-4 mr-1 inline-block"></i>
                </a>
            </div>

            <!-- Financial Report Report -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md hover:border-green-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-green-50 flex items-center justify-center text-green-600 text-2xl mb-4 group-hover:bg-accentGreen group-hover:text-white transition-colors">
                    <i data-lucide="pie-chart"></i>
                </div>
                <h3 class="text-lg font-bold text-primary mb-2">التقرير المالي</h3>
                <p class="text-gray-500 text-sm mb-6 min-h-[40px]">تحليل الإيرادات والمصروفات وصافي الربح</p>
                <a asp-action="FinancialReport" class="w-full bg-white border border-gray-200 text-gray-600 hover:bg-green-50 hover:text-green-700 hover:border-green-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-accentGreen  group-hover:border-accentGreen">
                    عرض التقرير <i data-lucide="arrow-left" class="w-4 h-4 mr-1 inline-block"></i>
                </a>
            </div>

            <!-- Profit & Loss Report -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md hover:border-gray-200 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-bgSubtle flex items-center justify-center text-primary text-2xl mb-4 group-hover:bg-accentRed group-hover:text-white transition-colors">
                    <i data-lucide="percent"></i>
                </div>
                <h3 class="text-lg font-bold text-primary mb-2">تقرير الأرباح والخسائر</h3>
                <p class="text-gray-500 text-sm mb-6 min-h-[40px]">تحليل الربحية، الهوامش، ومؤشرات الأداء المالي</p>
                <a asp-action="ProfitLossReport" class="w-full bg-white border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-primary hover:border-gray-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-accentRed  group-hover:border-accentRed">
                    عرض التقرير <i data-lucide="arrow-left" class="w-4 h-4 mr-1 inline-block"></i>
                </a>
            </div>

    </div>
</div>
