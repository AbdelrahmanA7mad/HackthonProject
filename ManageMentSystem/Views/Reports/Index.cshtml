@using ManageMentSystem.Models
@inject ManageMentSystem.Services.UserServices.IUserService UserService
@{
    ViewData["Title"] = "التقارير";
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
            <i class="fas fa-chart-line text-indigo-800"></i> لوحة تحكم التقارير الشاملة
        </h1>
        <p class="text-slate-500 mt-1 font-medium">عرض وتحليلات شاملة لأداء النظام والمبيعات والمخزون</p>
    </div>

    <!-- Reports Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
       
            <!-- Sales Report -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-indigo-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600 text-2xl mb-4 group-hover:bg-indigo-600 group-hover:text-white transition-colors">
                    <i class="fas fa-chart-bar"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-2">تقرير المبيعات</h3>
                <p class="text-slate-500 text-sm mb-6 min-h-[40px]">تحليل مفصل للمبيعات والأرباح وفترات الذروة</p>
                <a asp-action="SalesReport" class="w-full bg-white border border-slate-200 text-slate-700 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-indigo-600  group-hover:border-indigo-600">
                    عرض التقرير <i class="fas fa-arrow-left text-sm mr-1"></i>
                </a>
            </div>

            <!-- Inventory Report -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-emerald-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600 text-2xl mb-4 group-hover:bg-emerald-600 group-hover:text-white transition-colors">
                    <i class="fas fa-box-open"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-2">تقرير المخزون</h3>
                <p class="text-slate-500 text-sm mb-6 min-h-[40px]">حالة المخزون، حركة المنتجات، والقيمة الإجمالية</p>
                <a asp-action="InventoryReport" class="w-full bg-white border border-slate-200 text-slate-700 hover:bg-emerald-50 hover:text-emerald-700 hover:border-emerald-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-emerald-600  group-hover:border-emerald-600">
                    عرض التقرير <i class="fas fa-arrow-left text-sm mr-1"></i>
                </a>
            </div>

            <!-- Customer Report -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-amber-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600 text-2xl mb-4 group-hover:bg-amber-600 group-hover:text-white transition-colors">
                    <i class="fas fa-users"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-2">تقرير العملاء</h3>
                <p class="text-slate-500 text-sm mb-6 min-h-[40px]">تحليل العملاء، الأكثر شراءً، وسجل المعاملات</p>
                <a asp-action="CustomerReport" class="w-full bg-white border border-slate-200 text-slate-700 hover:bg-amber-50 hover:text-amber-700 hover:border-amber-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-amber-600  group-hover:border-amber-600">
                    عرض التقرير <i class="fas fa-arrow-left text-sm mr-1"></i>
                </a>
            </div>

            <!-- General Debt Report -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-red-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-red-50 flex items-center justify-center text-red-600 text-2xl mb-4 group-hover:bg-red-600 group-hover:text-white transition-colors">
                    <i class="fas fa-file-invoice-dollar"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-2">تقرير الديون</h3>
                <p class="text-slate-500 text-sm mb-6 min-h-[40px]">إجمالي الديون العامة والمستحقات المالية</p>
                <a asp-action="GeneralDebtReport" class="w-full bg-white border border-slate-200 text-slate-700 hover:bg-red-50 hover:text-red-700 hover:border-red-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-red-600  group-hover:border-red-600">
                    عرض التقرير <i class="fas fa-arrow-left text-sm mr-1"></i>
                </a>
            </div>

            <!-- Receivables (Customer Accounts) -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-violet-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-violet-50 flex items-center justify-center text-violet-600 text-2xl mb-4 group-hover:bg-violet-600 group-hover:text-white transition-colors">
                    <i class="fas fa-user-check"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-2">حسابات العملاء</h3>
                <p class="text-slate-500 text-sm mb-6 min-h-[40px]">كشف حساب تفصيلي للعملاء ومتابعة الأرصدة</p>
                <a asp-action="Receivables" class="w-full bg-white border border-slate-200 text-slate-700 hover:bg-violet-50 hover:text-violet-700 hover:border-violet-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-violet-600  group-hover:border-violet-600">
                    عرض التقرير <i class="fas fa-arrow-left text-sm mr-1"></i>
                </a>
            </div>

            <!-- Capital Summary -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-teal-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-teal-50 flex items-center justify-center text-teal-600 text-2xl mb-4 group-hover:bg-teal-600 group-hover:text-white transition-colors">
                    <i class="fas fa-balance-scale"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-2">ملخص رأس المال</h3>
                <p class="text-slate-500 text-sm mb-6 min-h-[40px]">المركز المالي، الأصول، والالتزامات الحالية</p>
                <a asp-action="CapitalSummary" class="w-full bg-white border border-slate-200 text-slate-700 hover:bg-teal-50 hover:text-teal-700 hover:border-teal-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-teal-600  group-hover:border-teal-600">
                    عرض التقرير <i class="fas fa-arrow-left text-sm mr-1"></i>
                </a>
            </div>

            <!-- Low Stock -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-orange-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-orange-50 flex items-center justify-center text-orange-600 text-2xl mb-4 group-hover:bg-orange-600 group-hover:text-white transition-colors">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-2">المنتجات شحيحة المخزون</h3>
                <p class="text-slate-500 text-sm mb-6 min-h-[40px]">تنبيهات بالمنتجات التي قاربت على النفاذ</p>
                <a asp-action="LowStock" class="w-full bg-white border border-slate-200 text-slate-700 hover:bg-orange-50 hover:text-orange-700 hover:border-orange-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-orange-600  group-hover:border-orange-600">
                    عرض التقرير <i class="fas fa-arrow-left text-sm mr-1"></i>
                </a>
            </div>

            <!-- Financial Report Report -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-green-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-green-50 flex items-center justify-center text-green-600 text-2xl mb-4 group-hover:bg-green-600 group-hover:text-white transition-colors">
                    <i class="fas fa-chart-pie"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-2">التقرير المالي</h3>
                <p class="text-slate-500 text-sm mb-6 min-h-[40px]">تحليل الإيرادات والمصروفات وصافي الربح</p>
                <a asp-action="FinancialReport" class="w-full bg-white border border-slate-200 text-slate-700 hover:bg-green-50 hover:text-green-700 hover:border-green-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-green-600  group-hover:border-green-600">
                    عرض التقرير <i class="fas fa-arrow-left text-sm mr-1"></i>
                </a>
            </div>

            <!-- Profit & Loss Report -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-rose-100 hover:-translate-y-1 transition-all group cursor-default">
                <div class="w-14 h-14 rounded-xl bg-rose-50 flex items-center justify-center text-rose-600 text-2xl mb-4 group-hover:bg-rose-600 group-hover:text-white transition-colors">
                    <i class="fas fa-percentage"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-2">تقرير الأرباح والخسائر</h3>
                <p class="text-slate-500 text-sm mb-6 min-h-[40px]">تحليل الربحية، الهوامش، ومؤشرات الأداء المالي</p>
                <a asp-action="ProfitLossReport" class="w-full bg-white border border-slate-200 text-slate-700 hover:bg-rose-50 hover:text-rose-700 hover:border-rose-200 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 group-hover:bg-rose-600  group-hover:border-rose-600">
                    عرض التقرير <i class="fas fa-arrow-left text-sm mr-1"></i>
                </a>
            </div>

    </div>
</div>