@model ManageMentSystem.ViewModels.InventoryReportViewModel
@{
    ViewData["Title"] = "تقرير المخزون";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="package" class="text-primary"></i> تقرير المخزون الشامل
            </h1>
            <p class="text-gray-500 mt-1 font-medium">حالة المخزون، حركة المنتجات، والقيمة الإجمالية</p>
        </div>
        <div class="flex gap-2">
            <a href="@Url.Action("ExportInventoryReportExcel", new { categoryId = Model.CategoryId, lowStockOnly = Model.LowStockOnly })" 
               class="zen-btn zen-btn-primary">
                <i data-lucide="file-spreadsheet"></i> تصدير Excel
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 print:hidden">
        <form method="get" class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
            <div>
                <label class="block text-sm font-bold text-gray-600 mb-2">الفئة</label>
                <select name="categoryId" onchange="this.form.submit()" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary outline-none font-medium text-primary transition-all bg-white cursor-pointer">
                    <option value="">جميع الفئات</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">
                            @category.Name
                        </option>
                    }
                </select>
            </div>
            
            <div class="pb-3">
                <label class="inline-flex items-center cursor-pointer group">
                    <input type="checkbox" name="lowStockOnly" value="true" onchange="this.form.submit()" class="sr-only peer" @(Model.LowStockOnly == true ? "checked" : "")>
                    <div class="relative w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    <span class="ms-3 text-sm font-bold text-gray-600 group-hover:text-primary transition-colors">عرض المنتجات شحيحة المخزون فقط</span>
                </label>
            </div>

            <div class="flex gap-3">
                <a href="@Url.Action("InventoryReport")" class="zen-btn zen-btn-neutral flex-grow">
                    <i data-lucide="x"></i> إلغاء
                </a>
            </div>
    </form>
    </div>

    <!-- Zenith AI Insights Widget -->
    <div class="mb-8 bg-primary rounded-2xl p-6 shadow-xl border border-white/10 relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
            <i data-lucide="brain-circuit" class="w-32 h-32 text-white"></i>
        </div>
        
        <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-gray-500/20 rounded-xl flex items-center justify-center border border-white/10">
                    <i data-lucide="sparkles" class="text-primary w-6 h-6"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">تحليلات Zenith AI للمخزون</h3>
                    <p class="text-gray-500 text-xs">رؤى ذكية حول صحة المخزون وحركة المنتجات</p>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-4 rounded-xl">
                    <div class="flex items-center gap-2 mb-2 text-amber-400 font-bold text-sm">
                        <i data-lucide="alert-triangle" class="w-4 h-4"></i>
                        إدارة النواقص
                    </div>
                    <p class="text-white text-xs leading-relaxed">
                        هناك زيادة بنسبة 10% في المنتجات شحيحة المخزون هذا الأسبوع. ننصح بمراجعة فئة "الأكثر مبيعاً" فوراً لتجنب فقدان فرص البيع نتيجة نفاذ الكميات.
                    </p>
                </div>
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-4 rounded-xl">
                    <div class="flex items-center gap-2 mb-2 text-emerald-400 font-bold text-sm">
                        <i data-lucide="package-search" class="w-4 h-4"></i>
                        تحسين المساحة
                    </div>
                    <p class="text-white text-xs leading-relaxed">
                        نلاحظ وجود 5 منتجات "راكدة" لم يتم بيعها منذ 30 يوماً. عمل عرض ترويجي (خصم 15%) قد يساعد في تصفيتها وتحرير سيولة نقدية محتجزة.
                    </p>
                </div>
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-4 rounded-xl">
                    <div class="flex items-center gap-2 mb-2 text-primary font-bold text-sm">
                        <i data-lucide="history" class="w-4 h-4"></i>
                        معدل الدوران
                    </div>
                    <p class="text-white text-xs leading-relaxed">
                        معدل دوران فئة "الإلكترونيات" هو الأعلى حالياً. التوسع في هذه الفئة بمنتجات مكملة (إكسسوارات) قد يزيد من الربحية الإجمالية للمخزون.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-bgSubtle flex items-center justify-center text-primary text-xl mb-3">
                <i data-lucide="package"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">إجمالي المنتجات</div>
            <div class="text-2xl font-bold text-primary">@Model.TotalProducts</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-amber-50 flex items-center justify-center text-amber-600 text-xl mb-3">
                <i data-lucide="alert-triangle"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">منتجات شحيحة المخزون</div>
            <div class="text-2xl font-bold text-amber-600">@Model.LowStockProducts</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-600 text-xl mb-3">
                <i data-lucide="x-circle"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">منتجات نفذت</div>
            <div class="text-2xl font-bold text-red-600">@Model.OutOfStockProducts</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-bgSubtle flex items-center justify-center text-primary text-xl mb-3">
                <i data-lucide="dollar-sign"></i>
            </div>
            <div class="text-sm font-bold text-gray-500 mb-1">قيمة المخزون</div>
            <div class="text-2xl font-bold text-primary">@Model.TotalInventoryValue.ToString("C")</div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- Additional Details -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h5 class="font-bold text-primary mb-4 flex items-center gap-2 pb-3 border-b border-gray-200">
                <i data-lucide="info" class="text-primary"></i> تفاصيل إضافية
            </h5>
            <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">متوسط قيمة المنتج</span>
                    <span class="font-bold text-primary">@Model.AverageProductValue.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">عدد الفئات</span>
                    <span class="font-bold text-primary">@Model.TotalCategories</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">نسبة المنتجات الشحيحة</span>
                    <span class="font-bold text-amber-600">@(Model.TotalProducts > 0 ? ((double)Model.LowStockProducts / Model.TotalProducts * 100).ToString("F1") : "0")%</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200 last:border-0">
                    <span class="text-gray-500 font-medium">نسبة المنتجات النافدة</span>
                    <span class="font-bold text-red-600">@(Model.TotalProducts > 0 ? ((double)Model.OutOfStockProducts / Model.TotalProducts * 100).ToString("F1") : "0")%</span>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h5 class="font-bold text-primary mb-4 flex items-center gap-2 pb-3 border-b border-gray-200">
                <i data-lucide="pie-chart" class="text-primary"></i> توزيع قيمة المخزون حسب الفئات
            </h5>
            <div class="relative h-64 w-full flex justify-center">
                <canvas id="inventoryChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Category Stats Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-6">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-bgSubtle">
            <h5 class="font-bold text-primary flex items-center gap-2">
                <i data-lucide="layers" class="text-primary"></i> إحصائيات المخزون حسب الفئة
            </h5>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-gray-50 text-gray-500 font-bold text-sm border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-4">الفئة</th>
                        <th class="px-6 py-4">عدد المنتجات</th>
                        <th class="px-6 py-4">إجمالي الكمية</th>
                        <th class="px-6 py-4">قيمة المخزون</th>
                        <th class="px-6 py-4">المنتجات الشحيحة</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var category in Model.CategoryInventory)
                    {
                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="px-6 py-4 font-bold text-gray-600">@category.CategoryName</td>
                            <td class="px-6 py-4 text-gray-500">@category.ProductCount</td>
                            <td class="px-6 py-4 text-gray-500">@category.TotalQuantity</td>
                            <td class="px-6 py-4 font-bold text-primary">@category.TotalValue.ToString("C")</td>
                            <td class="px-6 py-4">
                                @if(category.LowStockCount > 0)
                                {
                                    <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-xs font-bold">
                                        @category.LowStockCount
                                    </span>
                                }
                                else
                                {
                                    <span class="text-gray-500">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Products Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-bgSubtle">
            <h5 class="font-bold text-primary flex items-center gap-2">
                <i data-lucide="table" class="text-primary"></i> تفاصيل المنتجات
            </h5>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-gray-50 text-gray-500 font-bold text-sm border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-4">اسم المنتج</th>
                        <th class="px-6 py-4">الفئة</th>
                        <th class="px-6 py-4">الكمية</th>
                        <th class="px-6 py-4">سعر الشراء</th>
                        <th class="px-6 py-4">سعر البيع</th>
                        <th class="px-6 py-4">قيمة المخزون</th>
                        <th class="px-6 py-4">الباركود</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var product in Model.Products)
                    {
                        var quantityClass = product.Quantity == 0 ? "bg-red-100 text-accentRed" : 
                                          product.Quantity <= 5 ? "bg-amber-100 text-amber-700" : "bg-emerald-100 text-accentGreen";
                        
                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="px-6 py-4 font-bold text-gray-600">@product.Name</td>
                            <td class="px-6 py-4 text-gray-500">@product.Category?.Name</td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 rounded-full text-xs font-bold @quantityClass">
                                    @product.Quantity
                                </span>
                            </td>
                            <td class="px-6 py-4 text-gray-500">@product.PurchasePrice.ToString("C")</td>
                            <td class="px-6 py-4 text-gray-500">@product.SalePrice.ToString("C")</td>
                            <td class="px-6 py-4 font-bold text-primary">@((product.PurchasePrice * product.Quantity).ToString("C"))</td>
                            <td class="px-6 py-4 font-mono text-gray-500 text-sm">@(product.Barcode ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.js"></script>
    <script>
        const ctx = document.getElementById('inventoryChart').getContext('2d');
        const categoryData = @Html.Raw(Json.Serialize(Model.CategoryInventory));
        const theme = window.THEME || window;
        const rgbaFromColor = (color, alpha) => {
            if (!color) return `rgba(15, 20, 25, ${alpha})`;
            const normalized = color.trim();
            if (normalized.startsWith('#')) {
                const hex = normalized.slice(1);
                const expanded = hex.length === 3 ? hex.split('').map(ch => ch + ch).join('') : hex;
                const parts = expanded.match(/.{1,2}/g) || ['0f', '14', '19'];
                const [r, g, b] = parts.map(part => parseInt(part, 16));
                return `rgba(${r}, ${g}, ${b}, ${alpha})`;
            }
            const rgbMatch = normalized.match(/rgba?\(([^)]+)\)/i);
            if (rgbMatch) {
                const values = rgbMatch[1].split(',').map(v => v.trim());
                return `rgba(${values[0]}, ${values[1]}, ${values[2]}, ${alpha})`;
            }
            return normalized;
        };

        const chart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: categoryData.map(c => c.categoryName),
                datasets: [{
                    data: categoryData.map(c => c.totalValue),
                    backgroundColor: [
                        theme.accentAmber,
                        rgbaFromColor(theme.accentAmber, 0.82),
                        theme.primary,
                        theme.accentGreen,
                        theme.accentRed,
                        theme.accent,
                        rgbaFromColor(theme.primary, 0.72),
                        rgbaFromColor(theme.accentGreen, 0.72)
                    ],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: { family: 'Cairo', size: 11 },
                            usePointStyle: true,
                            padding: 15,
                            boxWidth: 8
                        }
                    },
                     tooltip: {
                        backgroundColor: rgbaFromColor(theme.primary, 0.92),
                        titleFont: { family: 'Cairo' },
                        bodyFont: { family: 'Cairo' },
                        padding: 10,
                        cornerRadius: 8
                    }
                },
                cutout: '70%',
            }
        });
    </script>
}
