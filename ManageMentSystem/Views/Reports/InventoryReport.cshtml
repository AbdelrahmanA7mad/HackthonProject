@model ManageMentSystem.ViewModels.InventoryReportViewModel
@{
    ViewData["Title"] = "تقرير المخزون";
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-box-open text-indigo-800"></i> تقرير المخزون الشامل
            </h1>
            <p class="text-slate-500 mt-1 font-medium">حالة المخزون، حركة المنتجات، والقيمة الإجمالية</p>
        </div>
        <div class="flex gap-2">
            <a href="@Url.Action("ExportInventoryReportExcel", new { categoryId = Model.CategoryId, lowStockOnly = Model.LowStockOnly })" 
               class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2.5 rounded-xl font-bold transition-all shadow-md hover:shadow-emerald-500/20 hover:-translate-y-0.5 flex items-center gap-2">
                <i class="fas fa-file-excel"></i> تصدير Excel
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 mb-6 print:hidden">
        <form method="get" class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">الفئة</label>
                <select name="categoryId" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none font-medium text-slate-800 transition-all bg-white cursor-pointer">
                    <option value="">جميع الفئات</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">
                            @category.Name
                        </option>
                    }
                </select>
            </div>
            
            <div class="pb-3">
                <label class="inline-flex items-center cursor-pointer group">
                    <input type="checkbox" name="lowStockOnly" value="true" class="sr-only peer" @(Model.LowStockOnly == true ? "checked" : "")>
                    <div class="relative w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-100 rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                    <span class="ms-3 text-sm font-bold text-slate-700 group-hover:text-indigo-600 transition-colors">عرض المنتجات شحيحة المخزون فقط</span>
                </label>
            </div>

            <div class="flex gap-3">
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:shadow-indigo-500/20 flex items-center gap-2 flex-grow justify-center">
                    <i class="fas fa-search"></i> تطبيق
                </button>
                <a href="@Url.Action("InventoryReport")" class="bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 hover:text-slate-800 px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm flex items-center gap-2 flex-grow justify-center">
                    <i class="fas fa-times"></i> إلغاء
                </a>
            </div>
        </form>
    </div>

    <!-- Summary Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-indigo-50 flex items-center justify-center text-indigo-600 text-xl mb-3">
                <i class="fas fa-boxes"></i>
            </div>
            <div class="text-sm font-bold text-slate-500 mb-1">إجمالي المنتجات</div>
            <div class="text-2xl font-bold text-slate-800">@Model.TotalProducts</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-amber-50 flex items-center justify-center text-amber-600 text-xl mb-3">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="text-sm font-bold text-slate-500 mb-1">منتجات شحيحة المخزون</div>
            <div class="text-2xl font-bold text-amber-600">@Model.LowStockProducts</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-600 text-xl mb-3">
                <i class="fas fa-times-circle"></i>
            </div>
            <div class="text-sm font-bold text-slate-500 mb-1">منتجات نفذت</div>
            <div class="text-2xl font-bold text-red-600">@Model.OutOfStockProducts</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600 text-xl mb-3">
                <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="text-sm font-bold text-slate-500 mb-1">قيمة المخزون</div>
            <div class="text-2xl font-bold text-emerald-600">@Model.TotalInventoryValue.ToString("C")</div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- Additional Details -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <h5 class="font-bold text-slate-800 mb-4 flex items-center gap-2 pb-3 border-b border-slate-50">
                <i class="fas fa-info-circle text-indigo-500"></i> تفاصيل إضافية
            </h5>
            <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-slate-50 last:border-0">
                    <span class="text-slate-600 font-medium">متوسط قيمة المنتج</span>
                    <span class="font-bold text-slate-800">@Model.AverageProductValue.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-50 last:border-0">
                    <span class="text-slate-600 font-medium">عدد الفئات</span>
                    <span class="font-bold text-slate-800">@Model.TotalCategories</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-50 last:border-0">
                    <span class="text-slate-600 font-medium">نسبة المنتجات الشحيحة</span>
                    <span class="font-bold text-amber-600">@(Model.TotalProducts > 0 ? ((double)Model.LowStockProducts / Model.TotalProducts * 100).ToString("F1") : "0")%</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-50 last:border-0">
                    <span class="text-slate-600 font-medium">نسبة المنتجات النافدة</span>
                    <span class="font-bold text-red-600">@(Model.TotalProducts > 0 ? ((double)Model.OutOfStockProducts / Model.TotalProducts * 100).ToString("F1") : "0")%</span>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <h5 class="font-bold text-slate-800 mb-4 flex items-center gap-2 pb-3 border-b border-slate-50">
                <i class="fas fa-chart-pie text-indigo-500"></i> توزيع قيمة المخزون حسب الفئات
            </h5>
            <div class="relative h-64 w-full flex justify-center">
                <canvas id="inventoryChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Category Stats Table -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden mb-6">
        <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <h5 class="font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-layer-group text-indigo-500"></i> إحصائيات المخزون حسب الفئة
            </h5>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-slate-50 text-slate-600 font-bold text-sm border-b border-slate-100">
                    <tr>
                        <th class="px-6 py-4">الفئة</th>
                        <th class="px-6 py-4">عدد المنتجات</th>
                        <th class="px-6 py-4">إجمالي الكمية</th>
                        <th class="px-6 py-4">قيمة المخزون</th>
                        <th class="px-6 py-4">المنتجات الشحيحة</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var category in Model.CategoryInventory)
                    {
                        <tr class="hover:bg-slate-50/80 transition-colors">
                            <td class="px-6 py-4 font-bold text-slate-700">@category.CategoryName</td>
                            <td class="px-6 py-4 text-slate-600">@category.ProductCount</td>
                            <td class="px-6 py-4 text-slate-600">@category.TotalQuantity</td>
                            <td class="px-6 py-4 font-bold text-emerald-600">@category.TotalValue.ToString("C")</td>
                            <td class="px-6 py-4">
                                @if(category.LowStockCount > 0)
                                {
                                    <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-xs font-bold">
                                        @category.LowStockCount
                                    </span>
                                }
                                else
                                {
                                    <span class="text-slate-400">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Products Table -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <h5 class="font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-table text-indigo-500"></i> تفاصيل المنتجات
            </h5>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-slate-50 text-slate-600 font-bold text-sm border-b border-slate-100">
                    <tr>
                        <th class="px-6 py-4">اسم المنتج</th>
                        <th class="px-6 py-4">الفئة</th>
                        <th class="px-6 py-4">الكمية</th>
                        <th class="px-6 py-4">سعر الشراء</th>
                        <th class="px-6 py-4">سعر البيع</th>
                        <th class="px-6 py-4">قيمة المخزون</th>
                        <th class="px-6 py-4">الباركود</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var product in Model.Products)
                    {
                        var quantityClass = product.Quantity == 0 ? "bg-red-100 text-red-700" : 
                                          product.Quantity <= 5 ? "bg-amber-100 text-amber-700" : "bg-emerald-100 text-emerald-700";
                        
                        <tr class="hover:bg-slate-50/80 transition-colors">
                            <td class="px-6 py-4 font-bold text-slate-700">@product.Name</td>
                            <td class="px-6 py-4 text-slate-600">@product.Category?.Name</td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 rounded-full text-xs font-bold @quantityClass">
                                    @product.Quantity
                                </span>
                            </td>
                            <td class="px-6 py-4 text-slate-600">@product.PurchasePrice.ToString("C")</td>
                            <td class="px-6 py-4 text-slate-600">@product.SalePrice.ToString("C")</td>
                            <td class="px-6 py-4 font-bold text-emerald-600">@((product.PurchasePrice * product.Quantity).ToString("C"))</td>
                            <td class="px-6 py-4 font-mono text-slate-500 text-sm">@(product.Barcode ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.js"></script>
    <script>
        const ctx = document.getElementById('inventoryChart').getContext('2d');
        const categoryData = @Html.Raw(Json.Serialize(Model.CategoryInventory));

        const chart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: categoryData.map(c => c.categoryName),
                datasets: [{
                    data: categoryData.map(c => c.totalValue),
                    backgroundColor: [
                        '#eab308', // amber-500
                        '#f59e0b', // amber-500 different shade
                        '#4f46e5', // indigo-600
                        '#059669', // emerald-600
                        '#ef4444', // red-500
                        '#8b5cf6', // violet-500
                        '#06b6d4', // cyan-500
                        '#ec4899'  // pink-500
                    ],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: { family: 'Cairo', size: 11 },
                            usePointStyle: true,
                            padding: 15,
                            boxWidth: 8
                        }
                    },
                     tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        titleFont: { family: 'Cairo' },
                        bodyFont: { family: 'Cairo' },
                        padding: 10,
                        cornerRadius: 8
                    }
                },
                cutout: '70%',
            }
        });
    </script>
}
