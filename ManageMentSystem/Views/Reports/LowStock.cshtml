@model IEnumerable<ManageMentSystem.Models.Product>
@{
    ViewData["Title"] = "تقرير المخزون الناقص";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="alert-triangle" class="text-accentAmber"></i> تقرير المخزون الناقص
            </h1>
            <p class="text-gray-500 mt-1 font-medium">المنتجات التي وصلت للحد الأدنى أو نفدت</p>
        </div>
        <div class="flex gap-2">
            <a href="@Url.Action("ExportLowStockReportExcel", new { categoryId = ViewBag.SelectedCategoryId })" class="zen-btn zen-btn-primary md:text-base">
                <i data-lucide="file-spreadsheet"></i> تصدير Excel
            </a>
        </div>
    </div>

    <!-- Print Header -->
    <div class="hidden print:block text-center mb-6">
        <h1 class="text-2xl font-bold text-primary mb-2">تقرير المخزون الناقص</h1>
        <p class="text-gray-500">تاريخ الطباعة: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 print:hidden">
        <form method="get" id="filterForm" class="space-y-4">
            <div class="flex flex-col md:flex-row gap-4 items-end">
                <div class="w-fit relative">
                    <label for="categoryId" class="block text-sm font-bold text-gray-600 mb-2 flex items-center gap-2">
                        <i data-lucide="tag" class="w-4 h-4 text-primary"></i>
                        تصفية حسب الفئة
                    </label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none text-gray-400 group-focus-within:text-primary transition-colors">
                            <i data-lucide="layers" class="w-5 h-5"></i>
                        </div>
                        <select name="categoryId" id="categoryId" 
                                class="w-fit min-w-[250px] pr-12 pl-10 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none font-bold text-gray-700 transition-all bg-white cursor-pointer appearance-none shadow-sm hover:border-primary/50" 
                                onchange="this.form.submit()">
                            <option value="">جميع الفئات</option>
                            @if (ViewBag.Categories != null)
                            {
                                @foreach (var category in ViewBag.Categories as List<ManageMentSystem.Models.Category>)
                                {
                                    <option value="@category.Id" selected="@(ViewBag.SelectedCategoryId?.ToString() == category.Id.ToString())">
                                        @category.Name
                                    </option>
                                }
                            }
                        </select>
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-400">
                            <i data-lucide="chevron-down" class="w-4 h-4"></i>
                        </div>
                    </div>
                </div>
            </div>

            @if (ViewBag.SelectedCategoryId != null)
            {
                <div class="bg-bgSubtle border border-gray-200 rounded-lg p-3 flex items-center gap-2 text-primary text-sm font-bold mt-2">
                    <i data-lucide="filter" class="w-4 h-4"></i>
                    <span>الفئة المحددة: </span>
                    @{
                        var msgCategories = ViewBag.Categories as List<ManageMentSystem.Models.Category>;
                        var catName = msgCategories?.FirstOrDefault(c => c.Id.ToString() == ViewBag.SelectedCategoryId.ToString())?.Name ?? "غير محدد";
                    }
                    <span class="text-gray-700">@catName</span>
                </div>
            }
        </form>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6 print:hidden">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center justify-between">
            <div>
                <div class="text-sm font-bold text-gray-500 mb-1">المنتجات النافدة</div>
                <div class="text-3xl font-bold text-red-600">@Model.Count(p => p.Quantity == 0)</div>
            </div>
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-600 text-xl">
                <i data-lucide="x-circle"></i>
            </div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center justify-between">
            <div>
                <div class="text-sm font-bold text-gray-500 mb-1">المنتجات منخفضة المخزون</div>
                <div class="text-3xl font-bold text-amber-600">@Model.Count(p => p.Quantity > 0)</div>
            </div>
            <div class="w-12 h-12 rounded-full bg-amber-50 flex items-center justify-center text-amber-600 text-xl">
                <i data-lucide="alert-triangle"></i>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden print:shadow-none print:border-0">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-bgSubtle print:hidden">
            <h5 class="font-bold text-primary flex items-center gap-2">
                <i data-lucide="table" class="text-primary"></i> قائمة المنتجات
            </h5>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right" id="lowStockTable">
                <thead class="bg-gray-50 text-gray-500 font-bold text-sm border-b border-gray-200 print:bg-gray-100 print:text-black">
                    <tr>
                        <th class="px-6 py-4 print:px-2 print:py-2">الاسم</th>
                        <th class="px-6 py-4 print:px-2 print:py-2">الفئة</th>
                        <th class="px-6 py-4 print:px-2 print:py-2">سعر الشراء</th>
                        <th class="px-6 py-4 print:px-2 print:py-2">سعر البيع</th>
                        <th class="px-6 py-4 text-center print:px-2 print:py-2">الكمية</th>
                        <th class="px-6 py-4 print:px-2 print:py-2">الوصف</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 print:border-t print:border-black">
                    @foreach (var p in Model)
                    {
                        var rowClass = p.Quantity == 0 ? "bg-red-50/50 hover:bg-red-50" : "bg-amber-50/50 hover:bg-amber-50";
                        var badgeClass = p.Quantity == 0 ? "bg-red-100 text-accentRed" : "bg-amber-100 text-amber-700";
                        
                        <tr class="transition-colors @rowClass print:bg-transparent">
                            <td class="px-6 py-4 font-bold text-gray-600 print:px-2 print:py-2 print:border-b print:border-gray-200">@p.Name</td>
                            <td class="px-6 py-4 print:px-2 print:py-2 print:border-b print:border-gray-200">
                                @if (p.Category != null)
                                {
                                    <span class="bg-gray-100 text-primary px-2 py-1 rounded text-xs font-bold print:bg-transparent print:text-black print:p-0">@p.Category.Name</span>
                                }
                                else
                                {
                                    <span class="text-gray-500">غير محدد</span>
                                }
                            </td>
                            <td class="px-6 py-4 font-mono text-gray-500 print:px-2 print:py-2 print:border-b print:border-gray-200">@p.PurchasePrice.ToString("C0")</td>
                            <td class="px-6 py-4 font-mono text-gray-500 print:px-2 print:py-2 print:border-b print:border-gray-200">@p.SalePrice.ToString("C0")</td>
                            <td class="px-6 py-4 text-center print:px-2 print:py-2 print:border-b print:border-gray-200">
                                <span class="px-3 py-1 rounded-full text-xs font-bold @badgeClass print:bg-transparent print:text-black print:border print:border-black">
                                    @p.Quantity
                                </span>
                            </td>
                            <td class="px-6 py-4 text-gray-500 text-sm max-w-xs truncate print:px-2 print:py-2 print:whitespace-normal print:border-b print:border-gray-200">@p.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // No extra scripts needed, form submits on change
    </script>
}
