@model ManageMentSystem.ViewModels.ProfitLossReportViewModel
@{
    ViewData["Title"] = "تقرير الأرباح والخسائر";
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-chart-line text-indigo-800"></i> تقرير الأرباح والخسائر
            </h1>
            <p class="text-slate-500 mt-1 font-medium">تحليل شامل للإيرادات والتكاليف وصافي الربح</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="@Url.Action("ExportProfitLossReportExcel", new { fromDate = Model.FromDate, toDate = Model.ToDate })" 
               class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl font-bold transition-all shadow-sm flex items-center gap-2 text-sm">
                <i class="fas fa-file-excel"></i> تصدير Excel
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 mb-6 print:hidden">
        <form method="get" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">من تاريخ</label>
                    <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none font-medium text-slate-800 transition-all" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">إلى تاريخ</label>
                    <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none font-medium text-slate-800 transition-all" />
                </div>
                <div class="flex gap-3">
                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:shadow-indigo-500/20 flex items-center gap-2 flex-grow justify-center">
                        <i class="fas fa-search"></i> تطبيق
                    </button>
                    <a href="@Url.Action("ProfitLossReport")" class="bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 hover:text-slate-800 px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm flex items-center gap-2 flex-grow justify-center">
                        <i class="fas fa-times"></i> إلغاء
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- Summary Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600 text-xl mb-3">
                <i class="fas fa-arrow-up"></i>
            </div>
            <div class="text-sm font-bold text-slate-500 mb-1">إجمالي الإيرادات</div>
            <div class="text-2xl font-bold text-emerald-600">@Model.TotalRevenue.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-600 text-xl mb-3">
                <i class="fas fa-arrow-down"></i>
            </div>
            <div class="text-sm font-bold text-slate-500 mb-1">إجمالي التكاليف</div>
            <div class="text-2xl font-bold text-red-600">@Model.TotalExpenses.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full @(Model.NetProfit >= 0 ? "bg-indigo-50 text-indigo-600" : "bg-red-50 text-red-600") flex items-center justify-center text-xl mb-3">
                <i class="fas fa-coins"></i>
            </div>
            <div class="text-sm font-bold text-slate-500 mb-1">صافي الربح</div>
            <div class="text-2xl font-bold @(Model.NetProfit >= 0 ? "text-indigo-600" : "text-red-600")">@Model.NetProfit.ToString("C")</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full @(Model.ProfitMargin >= 0 ? "bg-amber-50 text-amber-600" : "bg-red-50 text-red-600") flex items-center justify-center text-xl mb-3">
                <i class="fas fa-percentage"></i>
            </div>
            <div class="text-sm font-bold text-slate-500 mb-1">هامش الربح</div>
            <div class="text-2xl font-bold @(Model.ProfitMargin >= 0 ? "text-amber-600" : "text-red-600")">@Model.ProfitMargin.ToString("F1")%</div>
        </div>
    </div>

    <!-- Layout Container -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        
        <!-- Revenue Breakdown -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <h5 class="font-bold text-slate-800 mb-4 flex items-center gap-2 pb-3 border-b border-slate-50">
                <i class="fas fa-plus-circle text-emerald-500"></i> الإيرادات
            </h5>
            <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-slate-50 last:border-0">
                    <span class="text-slate-600 font-medium">إيرادات المبيعات</span>
                    <span class="font-bold text-emerald-600">@Model.SalesRevenue.ToString("C")</span>
                </div>
                <!-- Assuming OtherIncome exists, adding based on original file context, though not explicitly in VM snippets it was there before -->
                <div class="flex justify-between items-center py-2 border-b border-slate-50 last:border-0">
                    <span class="text-slate-600 font-medium">إيرادات أخرى</span>
                    <span class="font-bold text-emerald-600">@Model.OtherIncome.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-3 bg-emerald-50 px-4 rounded-lg mt-2">
                    <span class="text-emerald-800 font-bold">إجمالي الإيرادات</span>
                    <span class="text-emerald-800 font-bold text-lg">@Model.TotalRevenue.ToString("C")</span>
                </div>
            </div>
        </div>

        <!-- Expenses Breakdown -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <h5 class="font-bold text-slate-800 mb-4 flex items-center gap-2 pb-3 border-b border-slate-50">
                <i class="fas fa-minus-circle text-red-500"></i> التكاليف والمصروفات
            </h5>
            <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-slate-50 last:border-0">
                    <span class="text-slate-600 font-medium">تكلفة البضائع المباعة</span>
                    <span class="font-bold text-red-600">@Model.CostOfGoodsSold.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-slate-50 last:border-0">
                    <span class="text-slate-600 font-medium">المصروفات التشغيلية</span>
                    <span class="font-bold text-red-600">@Model.OperatingExpenses.ToString("C")</span>
                </div>
                <div class="flex justify-between items-center py-3 bg-red-50 px-4 rounded-lg mt-2">
                    <span class="text-red-800 font-bold">إجمالي التكاليف</span>
                    <span class="text-red-800 font-bold text-lg">@Model.TotalExpenses.ToString("C")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Profitability Analysis (Full Width) -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden mb-6">
        <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <h5 class="font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-calculator text-indigo-500"></i> تحليل الربحية التفصيلي
            </h5>
        </div>
        <div class="p-6">
            <div class="overflow-x-auto">
                <table class="w-full text-right">
                    <tbody class="divide-y divide-slate-100">
                        <tr class="bg-blue-50/50">
                            <td class="px-6 py-4 font-bold text-slate-800 w-1/2">إجمالي الإيرادات</td>
                            <td class="px-6 py-4 font-bold text-emerald-600 text-lg">@Model.TotalRevenue.ToString("C")</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 text-slate-600 w-1/2">(-) تكلفة البضائع المباعة</td>
                            <td class="px-6 py-4 text-red-500">@Model.CostOfGoodsSold.ToString("C")</td>
                        </tr>
                        <tr class="bg-amber-50/50 border-t border-b border-amber-100">
                            <td class="px-6 py-4 font-bold text-slate-800 w-1/2">(=) إجمالي الربح</td>
                            <td class="px-6 py-4 font-bold @(Model.GrossProfit >= 0 ? "text-emerald-600" : "text-red-600") text-lg">@Model.GrossProfit.ToString("C")</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 text-slate-600 w-1/2">(-) المصروفات التشغيلية</td>
                            <td class="px-6 py-4 text-red-500">@Model.OperatingExpenses.ToString("C")</td>
                        </tr>
                        <tr class="bg-indigo-50/50 border-t border-indigo-100">
                            <td class="px-6 py-4 font-bold text-indigo-900 w-1/2">(=) صافي الربح</td>
                            <td class="px-6 py-4 font-bold @(Model.NetProfit >= 0 ? "text-indigo-700" : "text-red-600") text-xl">@Model.NetProfit.ToString("C")</td>
                        </tr>
                        <tr class="bg-slate-50">
                            <td class="px-6 py-4 font-bold text-slate-600 w-1/2">هامش الربح</td>
                            <td class="px-6 py-4 font-bold @(Model.ProfitMargin >= 0 ? "text-emerald-600" : "text-red-600")">@Model.ProfitMargin.ToString("F1")%</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Chart Section -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
        <h5 class="font-bold text-slate-800 mb-4 flex items-center gap-2 pb-3 border-b border-slate-50">
            <i class="fas fa-chart-bar text-indigo-500"></i> الرسم البياني للتحليل المالي
        </h5>
        <div class="relative h-72 w-full flex justify-center">
            <canvas id="profitLossChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.js"></script>
    <script>
        const ctx = document.getElementById('profitLossChart').getContext('2d');
        const netProfit = @Model.NetProfit;
        const profitColor = netProfit >= 0 ? '#059669' : '#ef4444'; // emerald-600 or red-500

        const chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['الإيرادات', 'التكاليف', 'صافي الربح'],
                datasets: [{
                    label: 'التحليل المالي',
                    data: [@Model.TotalRevenue, @Model.TotalExpenses, netProfit],
                    backgroundColor: [
                        '#059669', // emerald-600
                        '#ef4444', // red-500
                        profitColor
                    ],
                    borderRadius: 8,
                    borderWidth: 0,
                    barPercentage: 0.5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        titleFont: { family: 'Cairo' },
                        bodyFont: { family: 'Cairo' },
                        padding: 10,
                        cornerRadius: 8,
                        callbacks: {
                            label: function(context) {
                                let label = context.dataset.label || '';
                                if (label) {
                                    label += ': ';
                                }
                                if (context.parsed.y !== null) {
                                    label += new Intl.NumberFormat('ar-EG', { style: 'currency', currency: 'EGP' }).format(context.parsed.y);
                                }
                                return label;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { font: { family: 'Cairo' } }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: '#f1f5f9' },
                        ticks: { font: { family: 'Cairo' } }
                    }
                }
            }
        });
    </script>
}
