@model ManageMentSystem.ViewModels.ReceivablesReportViewModel
@using System.Globalization
@{
    ViewData["Title"] = "حسابات العملاء - المستحقات";
    var egp = System.Globalization.CultureInfo.CurrentCulture;
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-hand-holding-usd text-blue-600"></i> حسابات العملاء
            </h1>
            <p class="text-slate-500 mt-1 font-medium">ملخص المستحقات المالية وأرصدة العملاء</p>
        </div>
        <div>
            <a href="@Url.Action("ExportReceivablesReportExcel")" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl font-bold transition-all shadow-sm flex items-center gap-2 text-sm md:text-base">
                <i class="fas fa-file-excel"></i> تصدير Excel
            </a>
        </div>
    </div>
    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex items-center justify-between">
            <div>
                <div class="text-sm font-bold text-slate-500 mb-1">إجمالي المستحق</div>
                <div class="text-3xl font-bold text-blue-600">@Model.TotalReceivables.ToString("C", egp)</div>
            </div>
            <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 text-xl">
                <i class="fas fa-donate"></i>
            </div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex items-center justify-between">
            <div>
                <div class="text-sm font-bold text-slate-500 mb-1">عدد العملاء ذوي الأرصدة</div>
                <div class="text-3xl font-bold text-slate-800">@Model.Entries.Count</div>
            </div>
            <div class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center text-slate-600 text-xl">
                <i class="fas fa-users"></i>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <h5 class="font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-list text-indigo-500"></i> تفاصيل الأرصدة
            </h5>
        </div>
        <div class="overflow-x-auto max-h-[600px] overflow-y-auto">
            <table class="w-full text-right relative">
                <thead class="bg-slate-50 text-slate-600 font-bold text-sm border-b border-slate-100 sticky top-0 z-10 shadow-sm">
                    <tr>
                        <th class="px-6 py-4 whitespace-nowrap">العميل</th>
                        <th class="px-6 py-4 whitespace-nowrap text-center">إجمالي الفواتير</th>
                        <th class="px-6 py-4 whitespace-nowrap text-center">إجمالي المدفوع</th>
                        <th class="px-6 py-4 whitespace-nowrap text-center">المتبقي</th>
                        <th class="px-6 py-4 whitespace-nowrap text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var e in Model.Entries)
                    {
                        <tr class="hover:bg-slate-50/80 transition-colors">
                            <td class="px-6 py-4 font-bold text-slate-700">@e.CustomerName</td>
                            <td class="px-6 py-4 text-center font-medium text-slate-600">@e.TotalSales.ToString("C", egp)</td>
                            <td class="px-6 py-4 text-center font-bold text-emerald-600">@e.TotalPaid.ToString("C", egp)</td>
                            <td class="px-6 py-4 text-center">
                                <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-xs font-bold">@e.Balance.ToString("C", egp)</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <a href="@Url.Action("Statement", "Customers", new { id = e.CustomerId })" class="text-indigo-600 hover:text-indigo-800 font-bold text-sm bg-indigo-50 hover:bg-indigo-100 px-3 py-1.5 rounded-lg transition-colors inline-block">
                                    <i class="fas fa-file-invoice ml-1"></i> كشف الحساب
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-slate-50 font-bold border-t border-slate-200 sticky bottom-0 z-10 shadow-inner">
                    <tr>
                        <td class="px-6 py-4 text-slate-800">الإجمالي</td>
                        <td class="px-6 py-4 text-center text-slate-800">@Model.Entries.Sum(x => x.TotalSales).ToString("C", egp)</td>
                        <td class="px-6 py-4 text-center text-emerald-600">@Model.Entries.Sum(x => x.TotalPaid).ToString("C", egp)</td>
                        <td class="px-6 py-4 text-center text-blue-600 text-lg">@Model.TotalReceivables.ToString("C", egp)</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
