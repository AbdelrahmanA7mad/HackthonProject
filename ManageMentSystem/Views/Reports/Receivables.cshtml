@model ManageMentSystem.ViewModels.ReceivablesReportViewModel
@using System.Globalization
@{
    ViewData["Title"] = "حسابات العملاء - المستحقات";
    var egp = System.Globalization.CultureInfo.CurrentCulture;
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="hand-coins" class="text-primary"></i> حسابات العملاء
            </h1>
            <p class="text-gray-500 mt-1 font-medium">ملخص المستحقات المالية وأرصدة العملاء</p>
        </div>
        <div>
            <a href="@Url.Action("ExportReceivablesReportExcel")" class="zen-btn zen-btn-primary md:text-base">
                <i data-lucide="file-spreadsheet"></i> تصدير Excel
            </a>
        </div>
    </div>
    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center justify-between">
            <div>
                <div class="text-sm font-bold text-gray-500 mb-1">إجمالي المستحق</div>
                <div class="text-3xl font-bold text-primary">@Model.TotalReceivables.ToString("C", egp)</div>
            </div>
            <div class="w-12 h-12 rounded-full bg-bgSubtle flex items-center justify-center text-primary text-xl">
                <i data-lucide="wallet"></i>
            </div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center justify-between">
            <div>
                <div class="text-sm font-bold text-gray-500 mb-1">عدد العملاء ذوي الأرصدة</div>
                <div class="text-3xl font-bold text-primary">@Model.Entries.Count</div>
            </div>
            <div class="w-12 h-12 rounded-full bg-gray-50 flex items-center justify-center text-gray-500 text-xl">
                <i data-lucide="users"></i>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-bgSubtle">
            <h5 class="font-bold text-primary flex items-center gap-2">
                <i data-lucide="list" class="text-primary"></i> تفاصيل الأرصدة
            </h5>
        </div>
        <div class="overflow-x-auto max-h-[600px] overflow-y-auto">
            <table class="w-full text-right relative">
                <thead class="bg-gray-50 text-gray-500 font-bold text-sm border-b border-gray-200 sticky top-0 z-10 shadow-sm">
                    <tr>
                        <th class="px-6 py-4 whitespace-nowrap">العميل</th>
                        <th class="px-6 py-4 whitespace-nowrap text-center">إجمالي الفواتير</th>
                        <th class="px-6 py-4 whitespace-nowrap text-center">إجمالي المدفوع</th>
                        <th class="px-6 py-4 whitespace-nowrap text-center">المتبقي</th>
                        <th class="px-6 py-4 whitespace-nowrap text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var e in Model.Entries)
                    {
                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="px-6 py-4 font-bold text-gray-600">@e.CustomerName</td>
                            <td class="px-6 py-4 text-center font-medium text-gray-500">@e.TotalSales.ToString("C", egp)</td>
                            <td class="px-6 py-4 text-center font-bold text-primary">@e.TotalPaid.ToString("C", egp)</td>
                            <td class="px-6 py-4 text-center">
                                <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-xs font-bold">@e.Balance.ToString("C", egp)</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <a href="@Url.Action("Statement", "Customers", new { id = e.CustomerId })" class="zen-btn zen-btn-neutral inline-block">
                                    <i data-lucide="receipt" class="ml-1 inline-block w-4 h-4"></i> كشف الحساب
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-gray-50 font-bold border-t border-gray-200 sticky bottom-0 z-10 shadow-inner">
                    <tr>
                        <td class="px-6 py-4 text-primary">الإجمالي</td>
                        <td class="px-6 py-4 text-center text-primary">@Model.Entries.Sum(x => x.TotalSales).ToString("C", egp)</td>
                        <td class="px-6 py-4 text-center text-primary">@Model.Entries.Sum(x => x.TotalPaid).ToString("C", egp)</td>
                        <td class="px-6 py-4 text-center text-primary text-lg">@Model.TotalReceivables.ToString("C", egp)</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
