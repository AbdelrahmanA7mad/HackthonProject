@model ManageMentSystem.ViewModels.StoreAccountReportViewModel
@{
    ViewData["Title"] = "تقرير حركة الخزنة";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="wallet" class="text-primary"></i> تقرير حركة الخزنة
            </h1>
            <p class="text-gray-500 mt-1 font-medium">متابعة التدفقات النقدية، المصروفات، والإيرادات</p>
        </div>
        <div class="flex gap-2">
            <button onclick="window.print()" class="zen-btn zen-btn-neutral">
                <i data-lucide="printer"></i> طباعة
            </button>
            <a href="@Url.Action("ExportFinancialReportExcel", new { fromDate = Model.FromDate, toDate = Model.ToDate })" class="zen-btn zen-btn-primary">
                <i data-lucide="file-spreadsheet"></i> تصدير Excel
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8 print:hidden">
        <form asp-action="StoreAccountReport" method="get" class="grid grid-cols-1 md:grid-cols-4 gap-6 items-end">
            <div>
                <label class="block text-sm font-bold text-gray-600 mb-2">من تاريخ</label>
                <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="w-full px-4 py-2 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary outline-none" />
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-600 mb-2">إلى تاريخ</label>
                <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="w-full px-4 py-2 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary outline-none" />
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-600 mb-2">نوع العملية</label>
                <select name="transactionType" class="w-full px-4 py-2 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary outline-none">
                    <option value="">الكل</option>
                    <option value="Income" selected="@(Model.TransactionType == "Income")">إيرادات</option>
                    <option value="Expense" selected="@(Model.TransactionType == "Expense")">مصروفات</option>
                </select>
            </div>
            <button type="submit" class="zen-btn zen-btn-primary w-full">
                <i data-lucide="filter"></i> تصفية
            </button>
        </form>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-green-50 text-green-600 rounded-xl flex items-center justify-center">
                    <i data-lucide="trending-up"></i>
                </div>
                <div>
                    <p class="text-sm text-gray-500 font-medium">إجمالي الإيرادات</p>
                    <h3 class="text-2xl font-bold text-gray-800">@Model.TotalIncome.ToString("N2") <span class="text-sm font-normal text-gray-400">ج.م</span></h3>
                </div>
            </div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-red-50 text-red-600 rounded-xl flex items-center justify-center">
                    <i data-lucide="trending-down"></i>
                </div>
                <div>
                    <p class="text-sm text-gray-500 font-medium">إجمالي المصروفات</p>
                    <h3 class="text-2xl font-bold text-gray-800">@Model.TotalExpenses.ToString("N2") <span class="text-sm font-normal text-gray-400">ج.م</span></h3>
                </div>
            </div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm @(Model.NetBalance >= 0 ? "border-green-100" : "border-red-100")">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 @(Model.NetBalance >= 0 ? "bg-green-600 text-white" : "bg-red-600 text-white") rounded-xl flex items-center justify-center shadow-lg">
                    <i data-lucide="scale"></i>
                </div>
                <div>
                    <p class="text-sm text-gray-500 font-medium">صافي الرصيد</p>
                    <h3 class="text-2xl font-bold @(Model.NetBalance >= 0 ? "text-green-600" : "text-red-600")">@Model.NetBalance.ToString("N2") <span class="text-sm font-normal opacity-70">ج.م</span></h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-6 border-b border-gray-100 flex justify-between items-center">
            <h3 class="font-bold text-primary flex items-center gap-2">
                <i data-lucide="list" class="w-5 h-5"></i> سجل العمليات
            </h3>
            <span class="bg-bgSubtle text-primary px-3 py-1 rounded-full text-xs font-bold">@Model.TotalTransactions عملية</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right border-collapse">
                <thead>
                    <tr class="bg-gray-50 text-gray-600 text-sm font-bold">
                        <th class="px-6 py-4">التاريخ</th>
                        <th class="px-6 py-4">البيان / الوصف</th>
                        <th class="px-6 py-4">النوع</th>
                        <th class="px-6 py-4">طريقة الدفع</th>
                        <th class="px-6 py-4">المبلغ</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model.Transactions)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 text-sm text-gray-600">@item.TransactionDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="px-6 py-4 font-bold text-gray-800">@item.Description</td>
                            <td class="px-6 py-4">
                                @if (item.TransactionType == ManageMentSystem.Models.TransactionType.Income)
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-green-50 text-green-700 text-xs font-bold border border-green-100">
                                        <i data-lucide="arrow-up-right" class="w-3 h-3"></i> إيراد
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-red-50 text-red-700 text-xs font-bold border border-red-100">
                                        <i data-lucide="arrow-down-left" class="w-3 h-3"></i> مصروف
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-500">
                                <span class="bg-gray-100 px-2 py-1 rounded text-xs">@item.PaymentMethodId</span>
                            </td>
                            <td class="px-6 py-4 font-bold @(item.TransactionType == ManageMentSystem.Models.TransactionType.Income ? "text-green-600" : "text-red-600")">
                                @item.Amount.ToString("N2")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
