@model ManageMentSystem.ViewModels.ComprehensiveReportViewModel

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
        <h4 class="font-bold text-primary mb-4 text-center">إجمالي الإيرادات الشهرية (للسنة الحالية)</h4>
        <div class="relative h-64 w-full flex justify-center">
            <canvas id="monthlyRevenueChart"></canvas>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
        <h4 class="font-bold text-primary mb-4 text-center">عدد المعاملات الشهرية (للسنة الحالية)</h4>
         <div class="relative h-64 w-full flex justify-center">
            <canvas id="monthlyTransactionsChart"></canvas>
        </div>
    </div>
</div>

<script src="~/lib/chartjs/chart.umd.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Keep fonts consistent
        Chart.defaults.font.family = 'Cairo';
        const theme = window.THEME || window;
        const rgbaFromColor = (color, alpha) => {
            if (!color) return `rgba(15, 20, 25, ${alpha})`;
            const normalized = color.trim();
            if (normalized.startsWith('#')) {
                const hex = normalized.slice(1);
                const expanded = hex.length === 3 ? hex.split('').map(ch => ch + ch).join('') : hex;
                const parts = expanded.match(/.{1,2}/g) || ['0f', '14', '19'];
                const [r, g, b] = parts.map(part => parseInt(part, 16));
                return `rgba(${r}, ${g}, ${b}, ${alpha})`;
            }
            const rgbMatch = normalized.match(/rgba?\(([^)]+)\)/i);
            if (rgbMatch) {
                const values = rgbMatch[1].split(',').map(v => v.trim());
                return `rgba(${values[0]}, ${values[1]}, ${values[2]}, ${alpha})`;
            }
            return normalized;
        };

        // Monthly Revenue Chart
        var revenueCtx = document.getElementById('monthlyRevenueChart').getContext('2d');
        var monthlyRevenueChart = new Chart(revenueCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.MonthlyRevenue.Select(m => m.Month))),
                datasets: [{
                    label: 'إيرادات المبيعات',
                    data: @Html.Raw(Json.Serialize(Model.MonthlyRevenue.Select(m => m.Revenue))),
                    backgroundColor: theme.primary,
                    borderRadius: 4,
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                         grid: { color: theme.borderSubtle || theme.bgSubtle || '#e5e7eb' },
                    },
                    x: {
                        grid: { display: false }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });

        // Monthly Transactions Chart
        var transactionsCtx = document.getElementById('monthlyTransactionsChart').getContext('2d');
        var monthlyTransactionsChart = new Chart(transactionsCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.MonthlySales.Select(m => m.Month))),
                datasets: [{
                    label: 'عدد المبيعات',
                    data: @Html.Raw(Json.Serialize(Model.MonthlySales.Select(m => m.SalesCount))),
                    backgroundColor: rgbaFromColor(theme.accentGreen, 0.1),
                    borderColor: theme.accentGreen,
                    borderWidth: 2,
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: theme.borderSubtle || theme.bgSubtle || '#e5e7eb' },
                    },
                    x: {
                         grid: { display: false }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });
    });
</script>
