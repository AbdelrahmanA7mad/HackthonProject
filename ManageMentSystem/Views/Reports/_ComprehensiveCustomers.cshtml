@model ManageMentSystem.ViewModels.ComprehensiveReportViewModel

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="bg-bgSubtle px-6 py-4 border-b border-gray-200 flex justify-between items-center">
        <h3 class="font-bold text-primary">قائمة العملاء</h3>
        <span class="bg-gray-100 text-primary text-xs px-2 py-1 rounded-full font-bold">@Model.TotalCustomers عميل</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-right">
            <thead class="bg-gray-50 text-gray-500 font-bold text-sm border-b border-gray-200">
                <tr>
                    <th class="px-6 py-4">اسم العميل</th>
                    <th class="px-6 py-4">رقم الهاتف</th>
                    <th class="px-6 py-4">العنوان</th>
                    <th class="px-6 py-4">إجمالي المبيعات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var customer in Model.Customers)
                {
                    <tr class="hover:bg-bgSubtle">
                        <td class="px-6 py-4 font-bold text-gray-600">@customer.FullName</td>
                        <td class="px-6 py-4 font-mono text-gray-500">@customer.PhoneNumber</td>
                        <td class="px-6 py-4 text-gray-500">@customer.Address</td>
                        <td class="px-6 py-4 font-bold text-primary">@customer.Sales.Sum(s => s.TotalAmount).ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
