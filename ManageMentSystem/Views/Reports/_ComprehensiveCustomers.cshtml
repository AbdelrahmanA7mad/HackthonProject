@model ManageMentSystem.ViewModels.ComprehensiveReportViewModel

<div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="bg-slate-50 px-6 py-4 border-b border-slate-100 flex justify-between items-center">
        <h3 class="font-bold text-slate-800">قائمة العملاء</h3>
        <span class="bg-indigo-100 text-indigo-700 text-xs px-2 py-1 rounded-full font-bold">@Model.TotalCustomers عميل</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-right">
            <thead class="bg-slate-50 text-slate-600 font-bold text-sm border-b border-slate-100">
                <tr>
                    <th class="px-6 py-4">اسم العميل</th>
                    <th class="px-6 py-4">رقم الهاتف</th>
                    <th class="px-6 py-4">العنوان</th>
                    <th class="px-6 py-4">إجمالي المبيعات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var customer in Model.Customers)
                {
                    <tr class="hover:bg-slate-50/50">
                        <td class="px-6 py-4 font-bold text-slate-700">@customer.FullName</td>
                        <td class="px-6 py-4 font-mono text-slate-600">@customer.PhoneNumber</td>
                        <td class="px-6 py-4 text-slate-600">@customer.Address</td>
                        <td class="px-6 py-4 font-bold text-emerald-600">@customer.Sales.Sum(s => s.TotalAmount).ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>