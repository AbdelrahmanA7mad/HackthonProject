@model ManageMentSystem.ViewModels.ComprehensiveReportViewModel

<div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="bg-slate-50 px-6 py-4 border-b border-slate-100 flex justify-between items-center">
        <h3 class="font-bold text-slate-800">تفاصيل المنتجات</h3>
        <span class="bg-indigo-100 text-indigo-700 text-xs px-2 py-1 rounded-full font-bold">@Model.TotalProducts منتج</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-right">
            <thead class="bg-slate-50 text-slate-600 font-bold text-sm border-b border-slate-100">
                <tr>
                    <th class="px-6 py-4">اسم المنتج</th>
                    <th class="px-6 py-4">كود المنتج</th>
                    <th class="px-6 py-4 text-center">الكمية</th>
                    <th class="px-6 py-4">سعر الشراء</th>
                    <th class="px-6 py-4">سعر البيع</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var item in Model.Products)
                {
                    <tr class="hover:bg-slate-50/50">
                        <td class="px-6 py-4 font-bold text-slate-700">@item.Name</td>
                        <td class="px-6 py-4 font-mono text-slate-500">@item.Barcode</td>
                        <td class="px-6 py-4 text-center">
                            <span class="@(item.Quantity <= 0 ? "text-red-600 font-bold" : "text-slate-700")">@item.Quantity</span>
                        </td>
                        <td class="px-6 py-4 text-slate-600">@item.PurchasePrice.ToString("C")</td>
                        <td class="px-6 py-4 font-medium text-slate-800">@item.SalePrice.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>