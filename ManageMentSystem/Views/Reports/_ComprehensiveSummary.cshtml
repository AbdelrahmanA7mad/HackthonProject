@model ManageMentSystem.ViewModels.ComprehensiveReportViewModel

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Inventory Summary -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-100 font-bold text-slate-800 flex items-center gap-2">
            <i class="fas fa-boxes text-indigo-500"></i> ملخص المخزون
        </div>
        <div class="p-6 space-y-3">
            <div class="flex justify-between border-b border-slate-50 pb-2">
                <span class="text-slate-600">إجمالي عدد المنتجات</span>
                <span class="font-bold text-slate-800">@Model.TotalProducts</span>
            </div>
            <div class="flex justify-between border-b border-slate-50 pb-2">
                <span class="text-slate-600">منتجات على وشك النفاذ</span>
                <span class="font-bold text-red-600">@Model.LowStockProducts</span>
            </div>
            <div class="flex justify-between pt-2">
                <span class="text-slate-600">قيمة المخزون (شراء)</span>
                <span class="font-bold text-emerald-600">@Model.InventoryValue.ToString("C")</span>
            </div>
        </div>
    </div>
    <!-- Revenue Summary -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-100 font-bold text-slate-800 flex items-center gap-2">
            <i class="fas fa-sack-dollar text-emerald-500"></i> ملخص الإيرادات
        </div>
        <div class="p-6 space-y-3">
            <div class="flex justify-between border-b border-slate-50 pb-2">
                <span class="text-slate-600">إجمالي إيرادات المبيعات</span>
                <span class="font-bold text-blue-600">@Model.TotalSalesRevenue.ToString("C")</span>
            </div>
            <div class="flex justify-between border-b border-slate-50 pb-2">
                <span class="text-slate-600">إجمالي الإيرادات</span>
                <span class="font-bold text-emerald-600">@Model.TotalRevenue.ToString("C")</span>
            </div>
            <div class="flex justify-between pt-2">
                <span class="text-slate-600">صافى الربح للمبيعات النقدية</span>
                <span class="font-bold text-indigo-600">@Model.NetSalesProfit.ToString("C")</span>
            </div>
        </div>
    </div>
</div>