@model ManageMentSystem.Models.Sale
@{
    ViewData["Title"] = "تفاصيل فاتورة البيع";
}

<div class="min-h-screen bg-bgSubtle p-6">

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-3">
                <div class="p-2 bg-gray-100 rounded-xl text-primary shadow-sm">
                    <i data-lucide="receipt" class="text-xl"></i>
                </div>
                فاتورة بيع #@Model.Id
            </h1>
        </div>

        <div class="flex gap-3">
            @if (Model.RemainingAmount > 0)
            {
                <a href="@Url.Action("Payment", "Sales", new { id = Model.Id })" class="zen-btn zen-btn-success zen-btn-sm">
                    <i data-lucide="banknote"></i> سداد دفعة
                </a>
            }
            <a asp-action="Index" class="zen-btn zen-btn-neutral zen-btn-sm">
                العودة للقائمة<i data-lucide="arrow-left"></i>
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <div class="lg:col-span-2 space-y-6">

            <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex items-center justify-between">
                    <h6 class="font-bold text-gray-800 flex items-center gap-2">
                        <i data-lucide="info" class="text-primary w-4 h-4"></i> البيانات الأساسية
                    </h6>
                    <span class="text-xs font-bold text-gray-500 font-mono">@Model.SaleDate.ToString("yyyy-MM-dd HH:mm")</span>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex items-start gap-4 p-3 bg-gray-50 rounded-xl border border-gray-200">
                            <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-primary text-lg">
                                <i data-lucide="user"></i>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 font-bold mb-1">العميل</p>
                                <a href="@Url.Action("Statement", "Customers", new { id = Model.CustomerId })" class="text-lg font-bold text-primary hover:underline">
                                    @(Model.Customer?.FullName ?? "عميل نقدي")
                                </a>
                                @if (!string.IsNullOrEmpty(Model.Customer?.PhoneNumber))
                                {
                                    <p class="text-xs text-gray-500 font-mono mt-1">@Model.Customer.PhoneNumber</p>
                                }
                            </div>
                        </div>

                        <div class="flex items-start gap-4 p-3 bg-gray-50 rounded-xl border border-gray-200">
                            <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-primary text-lg">
                                <i data-lucide="wallet"></i>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 font-bold mb-1">طريقة الدفع</p>
                                <p class="text-lg font-bold text-gray-800">@Model.PaymentType</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex justify-between items-center">
                    <h6 class="font-bold text-gray-800 flex items-center gap-2">
                        <i data-lucide="package" class="text-primary w-4 h-4"></i> تفاصيل المنتجات
                    </h6>
                    <span class="bg-white border border-gray-200 text-gray-600 px-3 py-1 rounded-lg text-xs font-bold shadow-sm">
                        @Model.SaleItems.Sum(x => x.Quantity) قطعة
                    </span>
                </div>

                @if (Model.SaleItems?.Any() == true)
                {
                    <div class="overflow-x-auto">
                        <table class="w-full text-right">
        <thead class="bg-bgSubtle text-gray-800 border-b border-gray-200 text-sm text-center">
                                <tr>
                                    <th class="px-6 py-3 font-bold">المنتج</th>
                                    <th class="px-6 py-3 font-bold text-center">الكمية</th>
                                    <th class="px-6 py-3 font-bold text-center">سعر الوحدة</th>
                                    <th class="px-6 py-3 font-bold text-center">الإجمالي</th>
                                    <th class="px-6 py-3 w-12">الاجراءات</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 text-center">
                                @foreach (var item in Model.SaleItems)
                                {
                                    <tr class="hover:bg-gray-50 transition-colors text-center">
                                        <td class="px-6 py-4 text-center">
                                            <a href="@Url.Action("Details", "Products", new { id = item.ProductId })" class="flex items-center gap-3 group">
                                                <span class="font-bold text-gray-700 group-hover:text-primary transition-colors text-center">@item.Product?.Name</span>
                                            </a>
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <span class="inline-block px-3 py-1 bg-gray-100 text-gray-700 rounded-lg text-sm font-bold border border-gray-200">
                                                @item.Quantity
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-center text-gray-600 font-medium">
                                            @item.UnitPrice.ToString("C")
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <span class="text-accentGreen font-bold">
                                                @((item.Quantity * item.UnitPrice).ToString("C"))
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <a href="@Url.Action("Details", "Products", new { id = item.ProductId })" class="text-primary hover:text-primary hover:bg-gray-50 p-2 rounded-xl transition-colors" title="عرض المنتج">
                                                <i data-lucide="external-link" class="w-4 h-4"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-8 text-center text-gray-500">
                        <i data-lucide="package-open" class="text-3xl mb-2 text-gray-300"></i>
                        <p>لا توجد منتجات مسجلة في هذه الفاتورة</p>
                    </div>
                }
            </div>
        </div>

        <div class="lg:col-span-1 space-y-6">

            <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden sticky top-6">
                <div class="bg-primary px-6 py-3 text-white flex justify-between items-center">
                    <h6 class="font-bold text-lg">ملخص الحساب</h6>
                    <i data-lucide="calculator" class="text-white w-4 h-4"></i>
                </div>

                <div class="p-6 space-y-4">
                    <div class="flex justify-between items-center pb-3 border-b border-dashed border-gray-200">
                        <span class="text-gray-600 font-bold">الإجمالي قبل الخصم</span>
                        <span class="text-gray-800 font-bold text-lg">@((Model.TotalAmount + Model.DiscountAmount).ToString("C"))</span>
                    </div>

                    @if (Model.DiscountAmount > 0)
                    {
                        <div class="flex justify-between items-center pb-3 border-b border-dashed border-gray-200 text-amber-600">
                            <span class="font-bold flex items-center gap-1">
                                <i data-lucide="tags" class="w-3 h-3"></i> خصم (@Model.DiscountPercentage%)
                            </span>
                            <span class="font-bold text-lg">- @Model.DiscountAmount.ToString("C")</span>
                        </div>
                    }

                    <div class="flex justify-between items-center py-2 bg-gray-50 rounded-lg px-3 border border-gray-200">
                                <span class="text-primary font-bold">صافي الفاتورة</span>
                        <span class="text-primary font-bold text-xl">@Model.TotalAmount.ToString("C")</span>
                    </div>

                    <div class="space-y-3 pt-2">
                        <div class="flex justify-between items-center">
                             <span class="text-gray-500 text-sm font-bold"><i data-lucide="check-circle" class="text-accentGreen w-3 h-3 inline-block"></i> المدفوع</span>
                            <span class="text-accentGreen font-bold">@Model.PaidAmount.ToString("C")</span>
                        </div>

                        @if (Model.ReturnedAmount > 0)
                        {
                            <div class="flex justify-between items-center">
                                 <span class="text-gray-500 text-sm font-bold"><i data-lucide="rotate-ccw" class="text-accentRed w-3 h-3 inline-block"></i> مرتجعات</span>
                                <span class="text-accentRed font-bold">@Model.ReturnedAmount.ToString("C")</span>
                            </div>
                        }

                        <div class="mt-4 pt-4 border-t-2 border-gray-200">
                            <div class="flex justify-between items-center">
                                <span class="text-gray-800 font-bold text-lg">المتبقي</span>
                                @if (Model.RemainingAmount > 0)
                                {
                                    <span class="text-red-600 font-bold text-2xl bg-red-50 px-3 py-1 rounded-lg border border-red-100">
                                        @Model.RemainingAmount.ToString("C")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-emerald-600 font-bold text-xl flex items-center gap-1">
                                         <i data-lucide="check-check" class="w-4 h-4"></i> خالص
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-gray-50 p-4 border-t border-gray-200 text-center">
                    <a href="@Url.Action("ReceiptInvoice", new { id = Model.Id })" target="_blank" class="zen-btn zen-btn-primary zen-btn-block w-full">
                        <i data-lucide="print" class="w-4 h-4 inline-block mr-1"></i> طباعة الإيصال
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
