@model ManageMentSystem.ViewModels.CreateSaleViewModel
@using ManageMentSystem.Models
@{
    ViewData["Title"] = "تعديل فاتورة بيع";
}

<div class="w-full p-4 md:p-6 bg-bgSubtle min-h-screen font-sans" dir="rtl">

    <div class="qs-container transition-all duration-300">
        <div class="flex justify-between items-center mb-6">
           
                <h1 class="text-2xl font-bold text-primary">تعديل فاتورة بيع #@ViewBag.SaleId</h1>

            <div class="flex items-center gap-3">
                <a href="@Url.Action("Index", "Sales")" class="zen-btn zen-btn-neutral">
                    العودة للمبيعات
                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                </a>
            </div>
        </div>


        <form id="editSaleFormPage" asp-action="Edit" method="post" class="h-full">
            <input type="hidden" name="id" value="@ViewBag.SaleId" />
            
            <div class="grid grid-cols-12 gap-6 h-full">

                <!-- القسم الأيمن: المنتجات -->
                <div class="col-span-12 lg:col-span-8 flex flex-col gap-4">

                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-3 items-center">

                            <div class="relative group">
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-gray-500">
                                    <i data-lucide="barcode" class="w-4 h-4"></i>
                                </div>
                                <input type="text" id="barcodeScanner" class="block w-full pr-10 pl-10 py-2 border-gray-500 rounded-lg focus:ring-primary focus:border-primary sm:text-sm border transition-shadow" placeholder="مسح باركود..." autocomplete="off">
                                <button type="button" onclick="clearBarcodeScanner()" class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 hover:text-accentRed cursor-pointer" title="مسح">
                                    <i data-lucide="x" class="w-4 h-4"></i>
                                </button>
                            </div>

                            <div class="relative">
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-gray-500">
                                    <i data-lucide="search" class="w-4 h-4"></i>
                                </div>
                                <input type="text" id="qsSearch" class="block w-full pr-10 py-2 border-gray-500 rounded-lg focus:ring-primary focus:border-primary sm:text-sm border" placeholder="بحث باسم المنتج...">
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4  flex flex-col">
                        <div id="qsProductsGrid" class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4 pr-1 pb-2 w-full h-fit">
                        </div>

                        <div id="qsNoResults" class="hidden flex flex-col items-center justify-center py-12 text-gray-500">
                            <i data-lucide="package-open" class="text-4xl mb-3 opacity-50"></i>
                            <p>لا توجد منتجات مطابقة</p>
                        </div>

                        <div id="qsPager" class="mt-2 pt-4 border-t border-gray-200 flex justify-between items-center hidden">
                            <button type="button" id="qsPrev" class="zen-btn zen-btn-primary font-medium disabled:opacity-50">السابق</button>
                            <span class="text-sm text-gray-600 font-bold" id="qsRange">عرض 0–0 من 0</span>
                            <button type="button" id="qsNext" class="zen-btn zen-btn-primary font-medium disabled:opacity-50">التالي</button>
                        </div>
                    </div>
                </div>

                <!-- القسم الأيسر: السلة والبيانات -->
                <div class="col-span-12 lg:col-span-4 flex flex-col gap-4">

                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-visible">
                        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 flex items-center">
                            <i data-lucide="user" class="ml-2 text-primary w-4 h-4"></i>
                            <h3 class="font-bold text-gray-700 text-sm">بيانات العميل والفاتورة</h3>
                        </div>
                        <div class="p-4 space-y-4">
                            <div class="relative">
                                <label class="block text-sm font-medium text-gray-700 mb-1">العميل</label>
                                <input type="text" id="customerSearch" class="block w-full border-gray-200 rounded-lg focus:ring-primary focus:border-primary sm:text-sm border py-2 px-3" placeholder="بحث عن عميل..." autocomplete="off">

                                <select name="CustomerId" id="modalCustomerSelect" class="hidden">
                                    <option value="">اختر العميل</option>
                                    <option value="0">➕ عميل جديد</option>
                                    @foreach (var customer in (IEnumerable<Customer>)(ViewBag.Customers ?? new List<Customer>()))
                                    {
                                        <option value="@customer.Id" selected="@(Model.CustomerId == customer.Id ? "selected" : null)" data-name="@customer.FullName.ToLower()" data-phone="@(customer.PhoneNumber?.ToLower() ?? "")">@customer.FullName</option>
                                    }
                                </select>
                                <div id="customerSearchResults" class="absolute z-50 w-full mt-1 bg-white shadow-lg max-h-48 rounded-md py-1 text-sm overflow-auto ring-1 ring-black ring-opacity-5 hidden"></div>
                            </div>
                            
                            <!-- باقي حقول العميل الجديد إذا لزم الأمر، يمكن نسخها من QuickSale -->

                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">تاريخ البيع</label>
                                    <input type="date" name="SaleDate" value="@Model.SaleDate.ToString("yyyy-MM-dd")" class="block w-full border-gray-200 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm py-1.5 px-2 border">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">نوع الدفع</label>
                                    <select disabled class="block w-full border-gray-200 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm py-1.5 px-2 border bg-gray-100 cursor-not-allowed">
                                        <!option value="1" @(Model.PaymentType == SalePaymentType.Cash ? "selected" : "")>كاش</!option>
                                        <!option value="2" @(Model.PaymentType == SalePaymentType.Partial ? "selected" : "")>جزئي</!option>
                                        <!option value="3" @(Model.PaymentType == SalePaymentType.Credit ? "selected" : "")>آجل</!option>
                                    </select>
                                    <input type="hidden" name="PaymentType" id="qsPaymentType" value="@((int)Model.PaymentType)" />
                                </div>
                            </div>

                            <div id="qsPaidWrapper" class="@(Model.PaymentType == SalePaymentType.Partial ? "" : "hidden")">
                                <label class="block text-sm font-medium text-gray-700 mb-1">المبلغ المدفوع</label>
                                <input type="number" step="0.01" min="0" name="PaidAmount" id="qsPaidAmount" value="@Model.PaidAmount" class="block w-full border-gray-200 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm py-1.5 px-2 border" readonly>
                            </div>

                            <div id="qsPaymentMethodWrapper" class="@(Model.PaymentType == SalePaymentType.Credit ? "hidden" : "")">
                                <label class="block text-sm font-medium text-gray-700 mb-1">طريقة الدفع</label>
                                    <select disabled class="block w-full border-gray-200 rounded-md shadow-sm focus:ring-primary focus:border-primary text-sm py-1.5 px-2 border bg-gray-100 cursor-not-allowed">
                                    <option value="">اختر الطريقة</option>
                                    @foreach (var pm in (IEnumerable<PaymentMethodOption>)(ViewBag.PaymentMethods ?? new List<PaymentMethodOption>()))
                                    {
                                        <option value="@pm.Id" selected="@(Model.PaymentMethodId == pm.Id ? "selected" : null)">@pm.Name</option>
                                    }
                                </select>
                                <input type="hidden" name="PaymentMethodId" id="qsPaymentMethod" value="@Model.PaymentMethodId" />
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 flex-grow flex flex-col">
                        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
                            <div class="flex items-center">
                                <i data-lucide="shopping-cart" class="ml-2 text-primary w-4 h-4"></i>
                                <h3 class="font-bold text-gray-700 text-sm">السلة</h3>
                            </div>
                            <button type="button" id="qsClearCart" class="text-sm text-accentRed hover:text-red-800 font-medium hover:underline transition-colors">
                                تفريغ
                            </button>
                        </div>

                        <div class="flex-grow overflow-auto custom-scrollbar" style="max-height: 250px;">
                            <table class="min-w-full divide-y divide-gray-200" id="qsCartTable">
                                <thead class="bg-gray-50 sticky top-0 z-10">
                                    <tr>
                                        <th scope="col" class="px-3 py-2 text-right text-sm font-medium text-gray-500 uppercase tracking-wider">المنتج</th>
                                        <th scope="col" class="px-3 py-2 text-center text-sm font-medium text-gray-500 uppercase tracking-wider w-16">الكمية</th>
                                        <th scope="col" class="px-3 py-2 text-center text-sm font-medium text-gray-500 uppercase tracking-wider">سعر</th>
                                        <th scope="col" class="px-3 py-2 text-center text-sm font-medium text-gray-500 uppercase tracking-wider">مجموع</th>
                                        <th scope="col" class="px-3 py-2 w-8"></th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200 text-sm">
                                </tbody>
                            </table>
                        </div>

                        <div class="p-4 bg-gray-50 border-t border-gray-200 space-y-3">
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-sm text-gray-500 mb-1">خصم %</label>
                                    <input type="number" id="qsDiscountPercentage" step=".5" min="0" max="100" value="@Model.DiscountPercentage" class="block w-full border-gray-200 rounded shadow-sm focus:ring-primary focus:border-primary text-sm py-1 px-2 border text-center">
                                </div>
                                <div>
                                    <label class="block text-sm text-gray-500 mb-1">مبلغ الخصم</label>
                                    <input type="number" id="qsDiscountAmount" step=".5" min="0" value="@Model.DiscountAmount" class="block w-full border-gray-200 rounded shadow-sm focus:ring-primary focus:border-primary text-sm py-1 px-2 border text-center">
                                </div>
                            </div>

                            <div class="flex justify-between items-center p-2  rounded-lg">
                                <span class="font-bold text-md">الإجمالي</span>
                                <span class="font-mono text-md font-bold tracking-wide" id="qsTotal">@Model.TotalAmount.ToString("F2")</span>
                            </div>
                            <input type="hidden" name="TotalAmount" id="qsTotalInput" value="@Model.TotalAmount" />

                            <div class="grid grid-cols-1 gap-3 mt-3">
                                <button type="submit" id="qsSaveEditBtn" class="zen-btn zen-btn-primary w-full">
                                    <i data-lucide="save" class="ml-2 w-4 h-4"></i> حفظ التعديلات
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/js/sweetalert-sales.js"></script>

    <!-- Initialize page data -->
    <script>
        window.isAdmin = @(ViewBag.IsAdmin == true ? "true" : "false");
        
        // Prepare initial cart data from server-side model
        var initialCartData = [];
        @if (Model.SaleItems != null)
        {
            foreach (var item in Model.SaleItems)
            {
                <text>
                initialCartData.push({
                    productId: @item.ProductId,
                    productName: '@Html.Raw(item.ProductName?.Replace("'", "\\'"))',
                    price: @item.UnitPrice,  // Using UnitPrice as base price mostly
                    customSalePrice: @item.CustomSalePrice,
                    purchasePrice: @item.PurchasePrice,
                    quantity: @item.Quantity,
                    availableStock: 9999, // In edit mode, we might need a way to know real stock, for now assume available or handled by backend logic
                    barcode: '' // We might not have barcode here easily unless we join, but user can scan to add new
                });
                </text>
            }
        }
    </script>
    
    <!-- Reusing QuickSale scripts but we might need a specific one for Edit initialization -->
    <script src="~/js/salejs/utilities.js"></script>
    <!-- We will use a modified version or a new script for Edit page logic -->
    <script src="~/js/salejs/editsalepage.js"></script> 
}
