@model IEnumerable<ManageMentSystem.Models.Sale>
@using ManageMentSystem.Helpers
@using ManageMentSystem.Models
@{
    ViewData["Title"] = "المبيعات";
}

<div class="min-h-screen bg-gray-50/50 p-6">

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
                <i class="fas fa-shopping-cart text-indigo-800"></i> إدارة المبيعات
            </h1>
            <div class="flex items-center gap-2 mt-4">
                <span class="text-sm font-bold text-gray-600">المستخدم الحالي:</span>
                <span class="bg-indigo-50 text-indigo-800 px-3 py-1 rounded-lg text-sm font-bold border border-indigo-100 flex items-center gap-1">
                    <i class="fas fa-user-circle"></i> @ViewBag.CurrentUser?.FullName
                </span>
            </div>
        </div>

        <div class="flex gap-3">
            <a asp-action="UnpaidSales" class="bg-amber-700 hover:bg-amber-800 text-white px-6 py-3 rounded-xl font-bold transition-all shadow-sm hover:shadow-amber-500 hover:-translate-y-0.5 flex items-center gap-2">
                <i class="fas fa-clock fa-md text-white me-1"></i> مبيعات غير مدفوعة
            </a>
                <a asp-action="QuickSale" class="bg-indigo-800 hover:bg-indigo-900 text-white px-6 py-3 rounded-xl font-bold transition-all shadow-sm hover:shadow-indigo-500 hover:-translate-y-0.5 flex items-center gap-2">
                    <i class="fas fa-cash-register fa-md text-white me-1"></i> شاشة البيع
                </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl flex items-center gap-3 shadow-sm relative" role="alert">
            <i class="fas fa-exclamation-triangle text-xl"></i>
            <span class="font-bold">@TempData["ErrorMessage"]</span>
            <button type="button" class="absolute left-4 top-3 text-red-400 hover:text-red-600" data-bs-dismiss="alert"><i class="fas fa-times"></i></button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl flex items-center gap-3 shadow-sm relative" role="alert">
            <i class="fas fa-check-circle text-xl"></i>
            <span class="font-bold">@TempData["SuccessMessage"]</span>
            <button type="button" class="absolute left-4 top-3 text-emerald-400 hover:text-emerald-600" data-bs-dismiss="alert"><i class="fas fa-times"></i></button>
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
        <form method="get" action="@Url.Action("Index", "Sales")" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">البحث العام</label>
                <div class="relative">
                    <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                           class="w-full pl-4 pr-10 py-2.5 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none text-sm font-bold transition-all"
                           placeholder="اسم العميل أو رقم الفاتورة...">
                    <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
                </div>
            </div>

            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">نوع الفاتورة</label>
                <select name="paymentType" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none text-sm font-bold transition-all bg-white">
                    <option value="">الكل</option>
                    <option value="1" selected="@(ViewBag.PaymentType == ManageMentSystem.Models.SalePaymentType.Cash)">كاش</option>
                    <option value="2" selected="@(ViewBag.PaymentType == ManageMentSystem.Models.SalePaymentType.Partial)">جزئي</option>
                    <option value="3" selected="@(ViewBag.PaymentType == ManageMentSystem.Models.SalePaymentType.Credit)">آجل</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">تاريخ الفاتورة</label>
                <input type="date" name="date" value="@ViewBag.date" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-1 focus:ring-indigo-800 focus:border-indigo-800 outline-none text-sm font-bold transition-all text-gray-600">
            </div>

            <div class="flex gap-2">
                <button type="submit" class="flex-1 bg-indigo-800 hover:bg-indigo-900 text-white py-2.5 rounded-lg font-bold transition-colors shadow-sm">
                    <i class="fas fa-filter text-sm"></i> تصفية
                </button>
                <a href="@Url.Action("Index", "Sales")" class="px-4 py-2.5 bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 hover:text-red-600 rounded-lg font-bold transition-colors">
                    <i class="fas fa-times"></i>
                </a>
            </div>
        </form>
    </div>

    <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex justify-between items-center">
            <h6 class="font-bold text-gray-800">سجل المبيعات</h6>
            <span class="text-xs font-bold text-gray-700 bg-white px-2 py-1 rounded border border-gray-200">العدد: @Model.Count()</span>
        </div>

        @if (Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-right" id="salesTable">
                    <thead>
                        <tr class="bg-indigo-50/50 text-indigo-900 border-b border-indigo-100 text-sm text-center">
                            <th class="px-6 py-4 font-bold"># الفاتورة</th>
                            <th class="px-6 py-4 font-bold">العميل</th>
                            <th class="px-6 py-4 font-bold">التاريخ</th>
                            <th class="px-6 py-4 font-bold">المبلغ</th>
                            <th class="px-6 py-4 font-bold">النوع</th>
                            <th class="px-6 py-4 font-bold">الحالة</th>
                            <th class="px-6 py-4 font-bold">بواسطة</th>
                            <th class="px-6 py-4 font-bold text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 text-center font-bold text-sm">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition-colors group">
                                <td class="px-6 py-4  font-mono ">
                                    <div class="flex items-center gap-1.5 text-indigo-700 bg-indigo-50 px-2.5 py-1 font-bold rounded-full w-fit border border-indigo-100">

                                        <span class="font-bold"># @item.Id</span>
                                    </div>
                                </td>


                                <td class="px-6 py-4">
                                    <a href="@Url.Action("Statement", "Customers", new { id = item.CustomerId })" class="flex items-center gap-2 text-gray-700 hover:text-indigo-700 transition-colors">
                                        <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-600 ">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        @item.Customer?.FullName
                                    </a>
                                </td>
                                <td class="px-6 py-4 text-gray-600 text-sm">@item.SaleDate.ToString("dd/MM/yyyy")</td>
                                <td class="px-6 py-4">
                                    <span class="text-emerald-700 font-bold bg-emerald-50 px-2 py-1 rounded-full border border-emerald-100">
                                        @item.TotalAmount.ToString("C")
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class=" font-bold px-2 py-1 rounded-full border bg-gray-50 text-gray-700 border-gray-200">
                                        @item.PaymentType
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    @{
                                        var isFullyPaid = item.RemainingAmount <= 0;
                                        var isPartial = item.PaidAmount > 0 && item.RemainingAmount > 0;
                                    }
                                    @if (isFullyPaid)
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full  bg-emerald-50 text-emerald-700 border border-emerald-200">
                                            <i class="fas fa-check text-[10px]"></i> خالص
                                        </span>
                                    }
                                    else if (isPartial)
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-amber-50 text-amber-700 border border-amber-200">
                                            <i class="fas fa-clock text-[10px]"></i> جزئي
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-red-50 text-red-700 border border-red-200">
                                            <i class="fas fa-times text-[10px]"></i> غير مسدد
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-2 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
                                        <button type="button" onclick="viewSale(@item.Id)" class="w-8 h-8 flex items-center justify-center rounded-lg  text-emerald-700 hover:bg-emerald-100 transition-colors" title="عرض">
                                            <i class="fas fa-eye text-xs"></i>
                                        </button>

                                            <a href="@Url.Action("ReceiptInvoice", new { id = item.Id })" target="_blank" class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-700 hover:text-gray-700 hover:bg-gray-100 transition-colors" title="طباعة">
                                                <i class="fas fa-print text-xs"></i>
                                            </a>

                                            <a href="#" onclick="sendInvoiceWhatsapp(@item.Id, this); return false;" class="w-8 h-8 flex items-center justify-center rounded-lg text-emerald-600 hover:text-emerald-600 hover:bg-emerald-100 transition-colors" title="واتساب">
                                                <i class="fab fa-whatsapp text-xs"></i>
                                                <span class="spinner-border spinner-border-sm hidden" role="status"></span>
                                            </a>

                                            <a href="@Url.Action("ReturnFromSale", "Sales", new { id = item.Id })" class="w-8 h-8 flex items-center justify-center rounded-lg text-amber-700 hover:text-amber-700 hover:bg-amber-100 transition-colors" title="استرجاع">
                                                <i class="fas fa-undo text-xs"></i>
                                            </a>

                                            <a asp-action="Edit" asp-route-id="@item.Id" class="w-8 h-8 flex items-center justify-center rounded-lg text-indigo-800 hover:bg-indigo-100 transition-colors" title="تعديل">
                                                <i class="fas fa-edit text-xs"></i>
                                            </a>
                                            <button type="button" onclick="deleteSale(@item.Id)" class="w-8 h-8 flex items-center justify-center rounded-lg text-red-700 hover:bg-red-100 transition-colors" title="حذف">
                                                <i class="fas fa-trash text-xs"></i>
                                            </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div class="bg-gray-50 px-6 py-4 border-t border-gray-100 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <div class="text-sm font-bold text-gray-500">
                        عرض @(((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1) إلى @Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalCount) من @ViewBag.TotalCount مبيعات
                    </div>

                    <div class="flex gap-1">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a href="@Url.Action("Index", "Sales", new { page = ViewBag.CurrentPage - 1, searchTerm = ViewBag.SearchTerm, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-600 hover:bg-indigo-50 hover:text-indigo-800 transition-all">
                                <i class="fas fa-chevron-right text-xs"></i>
                            </a>
                        }

                        @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                        {
                            <a href="@Url.Action("Index", "Sales", new { page = i, searchTerm = ViewBag.SearchTerm, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg border text-sm font-bold transition-all @(i == ViewBag.CurrentPage ? "bg-indigo-800 text-white border-indigo-800 shadow-sm" : "bg-white border-gray-300 text-gray-600 hover:bg-indigo-50 hover:text-indigo-800")">
                                @i
                            </a>
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a href="@Url.Action("Index", "Sales", new { page = ViewBag.CurrentPage + 1, searchTerm = ViewBag.SearchTerm, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-600 hover:bg-indigo-50 hover:text-indigo-800 transition-all">
                                <i class="fas fa-chevron-left text-xs"></i>
                            </a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12">
                <div class="bg-gray-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-shopping-cart text-3xl text-gray-300"></i>
                </div>
                <h5 class="text-lg font-bold text-gray-800">لا توجد مبيعات</h5>
                <p class="text-gray-500 mt-1">ابدأ بإضافة عملية بيع جديدة</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/js/sweetalert-sales.js"></script>
    <script src="~/js/salejs/utilities.js"></script>
}