@model ManageMentSystem.ViewModels.CreateSaleViewModel
@using ManageMentSystem.Models
@{
    ViewData["Title"] = "بيع سريع";
}

<div class="w-full p-4 md:p-6 bg-gray-50 min-h-screen font-sans" dir="rtl">

    <div class="qs-container transition-all duration-300">
        <div class="flex justify-between items-center mb-6">
           
                <h1 class="text-2xl font-bold text-gray-800">بيع سريع</h1>

            <div class="flex items-center gap-3">
                <button type="button" id="qsFullscreenToggle" class="flex items-center justify-center w-12 h-12 rounded-full border border-indigo-600 text-indigo-800 hover:bg-indigo-50 transition-colors" title="ملء الشاشة">
                    <i class="fas fa-expand text-md"></i>
                </button>
                <a href="@Url.Action("Index", "Sales")" class="px-6 py-2.5 bg-white border border-slate-200 text-slate-600 rounded-xl font-bold hover:bg-indigo-100 hover:-translate-y-0.5 transition-all shadow-sm flex items-center gap-2">
                    العودة للمبيعات
                    <i class="mx-2 fas fa-arrow-left ml-2"></i>
                </a>
            </div>
        </div>


        <form id="quickSaleForm" asp-action="Create" method="post" class="h-full">
            <div class="grid grid-cols-12 gap-6 h-full">

                <div class="col-span-12 lg:col-span-8 flex flex-col gap-4">

                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
                        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-3 items-center">

                            <div class="relative group">
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-gray-400">
                                    <i class="fas fa-barcode"></i>
                                </div>
                                <input type="text" id="barcodeScanner" class="block w-full pr-10 pl-10 py-2 border-gray-500 rounded-lg focus:ring-indigo-800 focus:border-indigo-800 sm:text-sm border transition-shadow" placeholder="مسح باركود..." autocomplete="off">
                                <button type="button" onclick="clearBarcodeScanner()" class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 hover:text-red-700 cursor-pointer" title="مسح">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>

                            <div class="relative">
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-gray-400">
                                    <i class="fas fa-search"></i>
                                </div>
                                <input type="text" id="qsSearch" class="block w-full pr-10 py-2 border-gray-500 rounded-lg focus:ring-indigo-500 focus:border-indigo-800 sm:text-sm border" placeholder="بحث باسم المنتج...">
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4  flex flex-col">
                        <div id="qsProductsGrid" class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4 pr-1 pb-2 w-full h-fit">
                        </div>

                        <div id="qsNoResults" class="hidden flex flex-col items-center justify-center py-12 text-gray-400">
                            <i class="fas fa-box-open text-4xl mb-3 opacity-50"></i>
                            <p>لا توجد منتجات مطابقة</p>
                        </div>

                        <div id="qsPager" class="mt-2 pt-4 border-t border-gray-100 flex justify-between items-center hidden">
                            <button type="button" id="qsPrev" class="px-3 py-1.5 border border-gray-300 rounded-md text-sm font-medium text-white bg-indigo-800 hover:bg-indigo-900 disabled:opacity-50 hover:-translate-y-0.5 transition-all">السابق</button>
                            <span class="text-sm text-gray-600 font-bold" id="qsRange">عرض 0–0 من 0</span>
                            <button type="button" id="qsNext" class="px-3 py-1.5 border border-gray-300 rounded-md text-sm font-medium text-white bg-indigo-800 hover:bg-indigo-900 disabled:opacity-50 hover:-translate-y-0.5 transition-all">التالي</button>
                        </div>
                    </div>
                </div>

                <div class="col-span-12 lg:col-span-4 flex flex-col gap-4">

                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-visible">
                        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 flex items-center">
                            <i class="fas fa-user ml-2 text-indigo-800"></i>
                            <h3 class="font-bold text-gray-700 text-sm">بيانات العميل</h3>
                        </div>
                        <div class="p-4 space-y-4">
                            <div class="relative">
                                <label class="block text-sm font-medium text-gray-700 mb-1">العميل *</label>
                                <input type="text" id="customerSearch" class="block w-full border-gray-300 rounded-lg focus:ring-indigo-800 focus:border-indigo-800 sm:text-sm border py-2 px-3" placeholder="بحث عن عميل..." autocomplete="off">

                                <select name="CustomerId" id="modalCustomerSelect" class="hidden">
                                    <option value="">اختر العميل</option>
                                    <option value="0">➕ عميل جديد</option>
                                    @foreach (var customer in (IEnumerable<Customer>)(ViewBag.Customers ?? new List<Customer>()))
                                    {
                                        <option value="@customer.Id" data-name="@customer.FullName.ToLower()" data-phone="@(customer.PhoneNumber?.ToLower() ?? "")">@customer.FullName</option>
                                    }
                                </select>
                                <div id="customerSearchResults" class="absolute z-50 w-full mt-1 bg-white shadow-lg max-h-48 rounded-md py-1 text-sm overflow-auto ring-1 ring-black ring-opacity-5 hidden"></div>
                            </div>

                            <div id="modalNewCustomerFields" class="hidden space-y-3 p-3 bg-indigo-50 rounded-lg border border-indigo-100">
                                <div class="text-sm text-indigo-700 font-bold mb-1 flex items-center">
                                    <i class="fas fa-plus-circle ml-1"></i> عميل جديد
                                </div>
                                <input type="text" id="modalNewCustomerName" name="NewCustomerName" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-800 focus:border-indigo-800 text-sm py-1.5 px-2 border" placeholder="اسم العميل *">
                                <input type="text" id="modalNewCustomerPhone" name="NewCustomerPhone" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-800 focus:border-indigo-800 text-sm py-1.5 px-2 border" placeholder="رقم الهاتف *">
                                <input type="text" id="modalNewCustomerAddress" name="NewCustomerAddress" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-800 focus:border-indigo-800 text-sm py-1.5 px-2 border" placeholder="العنوان">
                            </div>

                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">تاريخ البيع</label>
                                    <input type="date" name="SaleDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-800 focus:border-indigo-800 text-sm py-1.5 px-2 border">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">نوع الدفع</label>
                                    <select name="PaymentType" id="qsPaymentType" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-800 focus:border-indigo-800 text-sm py-1.5 px-2 border bg-white">
                                        <option value="1">كاش</option>
                                        <option value="2">جزئي</option>
                                        <option value="3">آجل</option>
                                    </select>
                                </div>
                            </div>

                            <div id="qsPaidWrapper" class="hidden">
                                <label class="block text-sm font-medium text-gray-700 mb-1">المبلغ المدفوع</label>
                                <input type="number" step="0.01" min="0" name="PaidAmount" id="qsPaidAmount" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-800 focus:border-indigo-800 text-sm py-1.5 px-2 border">
                            </div>

                            <div id="qsPaymentMethodWrapper">
                                <label class="block text-sm font-medium text-gray-700 mb-1">طريقة الدفع</label>
                                <select name="PaymentMethodId" id="qsPaymentMethod" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-800 focus:border-indigo-800 text-sm py-1.5 px-2 border bg-white">
                                    <option value="">اختر الطريقة</option>
                                    @foreach (var pm in (IEnumerable<PaymentMethodOption>)(ViewBag.PaymentMethods ?? new List<PaymentMethodOption>()))
                                    {
                                        <option value="@pm.Id">@pm.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 flex-grow flex flex-col">
                        <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
                            <div class="flex items-center">
                                <i class="fas fa-shopping-cart ml-2 text-indigo-800"></i>
                                <h3 class="font-bold text-gray-700 text-sm">السلة</h3>
                            </div>
                            <button type="button" id="qsClearCart" class="text-sm text-red-700 hover:text-red-800 font-medium hover:underline transition-colors">
                                تفريغ
                            </button>
                        </div>

                        <div class="flex-grow overflow-auto custom-scrollbar" style="max-height: 250px;">
                            <table class="min-w-full divide-y divide-gray-200" id="qsCartTable">
                                <thead class="bg-gray-50 sticky top-0 z-10">
                                    <tr>
                                        <th scope="col" class="px-3 py-2 text-right text-sm font-medium text-gray-500 uppercase tracking-wider">المنتج</th>
                                        <th scope="col" class="px-3 py-2 text-center text-sm font-medium text-gray-500 uppercase tracking-wider w-16">الكمية</th>
                                        <th scope="col" class="px-3 py-2 text-center text-sm font-medium text-gray-500 uppercase tracking-wider">سعر</th>
                                        <th scope="col" class="px-3 py-2 text-center text-sm font-medium text-gray-500 uppercase tracking-wider">مجموع</th>
                                        <th scope="col" class="px-3 py-2 w-8"></th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200 text-sm">
                                </tbody>
                            </table>
                        </div>

                        <div class="p-4 bg-gray-50 border-t border-gray-200 space-y-3">
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-sm text-gray-500 mb-1">خصم %</label>
                                    <input type="number" id="qsDiscountPercentage" step=".5" min="0" max="100" value="0" class="block w-full border-gray-300 rounded shadow-sm focus:ring-indigo-800 focus:border-indigo-800 text-sm py-1 px-2 border text-center">
                                </div>
                                <div>
                                    <label class="block text-sm text-gray-500 mb-1">مبلغ الخصم</label>
                                    <input type="number" id="qsDiscountAmount" step=".5" min="0" value="0" class="block w-full border-gray-300 rounded shadow-sm focus:ring-indigo-800 focus:border-indigo-800 text-sm py-1 px-2 border text-center">
                                </div>
                            </div>

                            <div class="flex justify-between items-center p-2  rounded-lg">
                                <span class="font-bold text-md">الإجمالي</span>
                                <span class="font-mono text-md font-bold tracking-wide" id="qsTotal">0.00</span>
                            </div>
                            <input type="hidden" name="TotalAmount" id="qsTotalInput" value="0" />

                            <div class="grid grid-cols-2 gap-3 mt-3">
                                <button type="submit" id="qsSaveBtn" class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-gray-700 hover:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-900 hover:-translate-y-0.5 transition-all">
                                    <i class="fas fa-save ml-2"></i> حفظ البيع
                                </button>

                                <button type="button" id="saveAndPrintBtn" class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-indigo-800 hover:bg-indigo-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-800 hover:-translate-y-0.5 transition-all">
                                    <i class="fas fa-print ml-2"></i> حفظ وطباعة
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/js/sweetalert-sales.js"></script>

    <script>
        window.isAdmin = @(ViewBag.IsAdmin == true ? "true" : "false");
    </script>
    <script src="~/js/salejs/utilities.js"></script>
    <script src="~/js/salejs/forms.js"></script>
    <script src="~/js/salejs/customermanagement.js"></script>
    <script src="~/js/salejs/index.js"></script>
    <script src="~/js/salejs/productmanagement.js"></script>
    <script src="~/js/salejs/productsearch.js"></script>
    <script src="~/js/salejs/calculations.js"></script>
    <script src="~/js/salejs/salepage.js"></script>
    <script src="~/js/salejs/barcode.js"></script>
}