@model ManageMentSystem.ViewModels.CreateReturnFromSaleViewModel
@{
    ViewData["Title"] = "إرجاع من فاتورة البيع";
}

<div class="min-h-screen bg-gray-50/50 p-6">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-3">
                <span class="p-2 bg-red-100 rounded-xl text-accentRed">
                    <i data-lucide="rotate-ccw"></i>
                </span>
                إرجاع من فاتورة البيع  
                    #@Model.SaleId
            </h1>
        </div>

        <a href="@Url.Action("Details", "Sales", new { id = Model.SaleId })" class="px-6 py-2.5 bg-white border border-gray-200 text-gray-500 rounded-xl font-bold hover:bg-gray-50 hover:-translate-y-0.5 transition-all shadow-sm flex items-center gap-2">
            العودة للفاتورة<i data-lucide="arrow-left"></i>
        </a>
    </div>

    <form id="createReturnForm" asp-action="CreateReturnFromSale" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SaleId" />
        <input type="hidden" asp-for="CustomerId" />

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex items-center gap-2">
                    <i data-lucide="file-edit" class="text-[#0f1419] w-4 h-4"></i>
                    <h6 class="font-bold text-gray-800">بيانات المرتجع</h6>
                </div>

                <div class="p-6 space-y-6">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">العميل</label>
                        <div class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-gray-600 font-bold flex items-center gap-2">
                            <i data-lucide="user" class="text-gray-500 w-4 h-4"></i> @Model.CustomerName
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">تاريخ المرتجع <span class="text-accentRed">*</span></label>
                        <input type="date" asp-for="ReturnDate" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-1 focus:ring-[#0f1419] focus:border-[#0f1419] outline-none transition-all font-bold text-gray-700" required>
                    </div>

                    <div id="customerBalanceInfo" class="hidden animate-fade-in">
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">طريقة خصم المبلغ</label>
                        <div class="relative">
                            <select asp-for="DeductionType" id="deductionType" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-1 focus:ring-[#0f1419] focus:border-[#0f1419] outline-none font-bold text-gray-700 appearance-none bg-white">
                                <option value="0" selected="@(Model.DeductionType == ManageMentSystem.ViewModels.ReturnDeductionType.Auto)">🤖 تلقائي (الأفضل)</option>
                                <option value="1" selected="@(Model.DeductionType == ManageMentSystem.ViewModels.ReturnDeductionType.FromCustomer)">👤 خصم من رصيد العميل</option>
                                <option value="2" selected="@(Model.DeductionType == ManageMentSystem.ViewModels.ReturnDeductionType.FromStore)">🏪 خصم من حساب المحل (كاش)</option>
                            </select>
                            <i data-lucide="chevron-down" class="absolute left-4 top-3.5 text-gray-500 pointer-events-none w-4 h-4"></i>
                        </div>
                        <div id="deductionHelpText" class="mt-2 text-xs text-gray-500 font-medium space-y-1">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">ملاحظات</label>
                        <textarea asp-for="Notes" rows="3" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-1 focus:ring-[#0f1419] focus:border-[#0f1419] outline-none transition-all resize-none" placeholder="أي ملاحظات إضافية..."></textarea>
                    </div>
                    <small class="form-text text-muted">
                        <strong>تلقائي:</strong> إذا كان للعميل رصيد يُخصم منه، وإلا يُخصم من المحل<br>
                        <strong>من العميل:</strong> يُخصم من رصيد العميل مباشرة (يقلل من المبلغ المستحق عليه)<br>
                        <strong>من المحل:</strong> يُخصم من حساب المحل مباشرة (يظهر كمصروف في الخزنة)
                    </small>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden flex flex-col h-full">
                <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex justify-between items-center">
                    <h6 class="font-bold text-gray-800 flex items-center gap-2">
                        <i data-lucide="package" class="text-[#0f1419] w-4 h-4"></i> المنتجات
                    </h6>
                    <span class="text-xs font-bold bg-gray-100 text-[#0f1419] px-2 py-1 rounded">@Model.SaleItems.Count صنف</span>
                </div>

                <div class="p-0 flex-grow">
                    <div class="overflow-x-auto">
                        <table class="w-full text-right" id="selectedProductsTable">
                            <thead class="bg-gray-50/50 text-[#0f1419] text-sm border-b border-gray-200">
                                <tr>
                                    <th class="px-4 py-3 text-center">#</th>
                                    <th class="px-4 py-3 font-bold">المنتج</th>
                                    <th class="px-4 py-3 font-bold">الباركود</th>
                                    <th class="px-4 py-3 font-bold text-center">مباع</th>
                                    <th class="px-4 py-3 font-bold text-center">إرجاع</th>
                                    <th class="px-4 py-3 font-bold">السعر</th>
                                    <th class="px-4 py-3 font-bold">الإجمالي</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 text-sm text-center">
                                @for (int i = 0; i < Model.SaleItems.Count; i++)
                                {
                                    var item = Model.SaleItems[i];
                                    <tr class="hover:bg-gray-50 transition-colors group">
                                        <td class="p-1 text-center align-middle">
                                            <input type="checkbox" asp-for="@Model.SaleItems[i].IsSelected"
                                                   class="form-check-input item-checkbox w-5 h-5 text-[#0f1419] border-gray-200 rounded focus:ring-[#0f1419] cursor-pointer"
                                                   data-index="@i">
                                        </td>
                                        <td class="p-1 font-bold text-gray-800 align-middle">
                                            @item.ProductName
                                            <input type="hidden" asp-for="@Model.SaleItems[i].SaleItemId" />
                                            <input type="hidden" asp-for="@Model.SaleItems[i].ProductId" />
                                            <input type="hidden" asp-for="@Model.SaleItems[i].ProductName" />
                                        </td>
                                        <td class="px-1 text-gray-500 font-mono text-xs align-middle">@(item.Barcode ?? "-")</td>
                                        <td class="px-1 text-center align-middle">
                                            <span class="inline-block px-2 py-1 bg-gray-100 text-gray-600 rounded text-sm font-bold border border-gray-200">
                                                @item.OriginalQuantity
                                            </span>
                                            <input type="hidden" asp-for="@Model.SaleItems[i].OriginalQuantity" />
                                        </td>
                                        <td class="p-1 align-middle">
                                            <input type="number" asp-for="@Model.SaleItems[i].ReturnQuantity"
                                                   min="0" max="@item.OriginalQuantity" step="1"
                                                   class="return-quantity w-full px-1 py-1 text-center border border-gray-500 rounded-lg focus:ring-2 focus:ring-[#0f1419] outline-none h-8 font-bold text-gray-700 disabled:bg-gray-100 disabled:text-gray-500 transition-all"
                                                   data-index="@i" disabled>
                                        </td>
                                        <td class="p-1 align-middle font-medium text-gray-600">
                                            @item.UnitPrice.ToString("C")
                                            <input type="hidden" asp-for="@Model.SaleItems[i].UnitPrice" />
                                        </td>
                                        <td class="p-1 align-middle">
                                            <span class="item-total text-accentGreen font-bold" data-index="@i">0.00</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="bg-gray-50 border-t border-gray-200">
                                <tr>
                                    <td colspan="6" class="px-4 py-3 text-left font-bold text-gray-600">إجمالي قيمة المرتجع:</td>
                                    <td class="px-4 py-3 font-bold text-lg text-[#0f1419] font-mono">
                                        <span id="totalAmount">0.00</span>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white p-4 rounded-xl shadow-lg border border-gray-200 flex flex-col sm:flex-row justify-between items-center gap-4 sticky bottom-4 z-10">
            <div class="text-md font-bold text-gray-600">
                <i data-lucide="info" class="text-[#0f1419] w-4 h-4"></i> يرجى التأكد من الكميات قبل الحفظ
            </div>
            <div class="flex gap-3 w-full sm:w-auto">
                <a href="@Url.Action("Details", "Sales", new { id = Model.SaleId })" class="px-6 py-2.5  border border-gray-200 text-gray-700 hover:text-accentRed font-bold rounded-xl hover:bg-red-50 transition-colors text-center flex-1 sm:flex-none hover:-translate-y-0.5 transition-all">
                    إلغاء
                </a>
                <button type="submit" class="px-8 py-2.5  from-indigo-700  hover:bg-[#0f1419] hover: text-white font-bold rounded-xl shadow-sm  hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2 flex-1 sm:flex-none">
                    <i data-lucide="save"></i> حفظ المرتجع
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script>
        // تحميل رصيد العميل عند تحميل الصفحة
        document.addEventListener('DOMContentLoaded', async () => {
            await loadStoreBalance();
            updateCustomerBalanceInfo(@Model.CustomerId);
            updateDeductionDescription();
            updateTotal();
        });

        // دالة لجلب رصيد المحل
        let storeBalance = 0;
        async function loadStoreBalance() {
            try {
                const response = await fetch('@Url.Action("GetStoreBalance", "Customers")');
                if (response.ok) {
                    const data = await response.json();
                    storeBalance = data.balance;
                }
            } catch (error) {
                console.error('خطأ في جلب رصيد المحل:', error);
            }
        }

        // تحديث وصف نوع الخصم (محدث ليستخدم كلاسات Tailwind)
        function updateDeductionDescription() {
            const deductionType = document.getElementById('deductionType');
            const helpText = document.getElementById('deductionHelpText');

            if (deductionType && helpText) {
                const selectedType = deductionType.value;
                let description = '';
                let icon = 'info';
                let colorClass = 'text-gray-500';

                switch (selectedType) {
                    case '0': // تلقائي
                        description = '• سيتم تحديد المصدر تلقائياً (رصيد العميل أولاً).';
                        break;
                    case '1': // من العميل
                        description = '• سيتم إنقاص المبلغ من رصيد العميل (الدين).';
                        colorClass = 'text-[#0f1419]';
                        icon = 'user';
                        break;
                    case '2': // من المحل
                        description = `• سيتم صرف المبلغ نقداً من الخزينة. (متاح: ${storeBalance.toFixed(2)})`;
                        colorClass = 'text-emerald-600';
                        icon = 'banknote';
                        break;
                }

                helpText.innerHTML = `<span class="${colorClass}"><i data-lucide="${icon}" class="ml-1 w-4 h-4 inline-block"></i> ${description}</span>`;
                lucide.createIcons();
            }
        }

        document.getElementById('deductionType').addEventListener('change', updateDeductionDescription);

        // دالة لتحديث معلومات رصيد العميل (HTML محدث لـ Tailwind)
        async function updateCustomerBalanceInfo(customerId) {
            try {
                const response = await fetch(`@Url.Action("GetCustomerBalance", "Customers")?customerId=${customerId}`);
                if (response.ok) {
                    const data = await response.json();
                    const balanceInfo = document.getElementById('customerBalanceInfo');

                    if (balanceInfo) {
                        balanceInfo.classList.remove('hidden');

                        let bgClass = 'bg-gray-50 border-gray-200 text-[#0f1419]';
                        let icon = 'wallet';
                        let iconColor = 'text-[#0f1419]';
                        let message = `رصيد العميل الحالي: <span class="font-bold text-lg">${data.balance.toFixed(2)}</span> ج.م`;

                        if (data.balance <= 0) {
                            bgClass = 'bg--50 border-amber-200 text-amber-800';
                            icon = 'alert-circle';
                            iconColor = 'text-amber-500';
                            message = `العميل ليس لديه رصيد كافٍ (${data.balance.toFixed(2)} ج.م)`;
                        }

                        // Tailwind HTML structure
                        balanceInfo.innerHTML = `
                            <div class="${bgClass} border rounded-xl p-4 flex items-start gap-3 shadow-sm">
                                <div class="p-2 bg-white rounded-lg ${iconColor}">
                                    <i data-lucide="${icon}" class="text-xl"></i>
                                </div>
                                <div>
                                    <p class="text-sm font-medium opacity-80 mb-1">حالة الحساب</p>
                                    <div class="text-base">${message}</div>
                                </div>
                            </div>
                        `;
                        lucide.createIcons();
                    }
                }
            } catch (error) {
                console.error('خطأ في جلب رصيد العميل:', error);
            }
        }

        // إدارة اختيار المنتجات والكميات
        const checkboxes = document.querySelectorAll('.item-checkbox');
        const quantityInputs = document.querySelectorAll('.return-quantity');

        checkboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const index = this.getAttribute('data-index');
                const quantityInput = document.querySelector(`.return-quantity[data-index="${index}"]`);

                if (this.checked) {
                    quantityInput.disabled = false;
                    quantityInput.value = quantityInput.max; // افتراضي: كل الكمية
                    quantityInput.classList.remove('bg-gray-100');
                    quantityInput.classList.add('bg-white');
                    quantityInput.focus();
                } else {
                    quantityInput.disabled = true;
                    quantityInput.value = 0;
                    quantityInput.classList.add('bg-gray-100');
                    quantityInput.classList.remove('bg-white');
                }
                updateTotal();
            });
        });

        quantityInputs.forEach(input => {
            input.addEventListener('input', function() {
                const index = this.getAttribute('data-index');
                const max = parseInt(this.max);
                const value = parseInt(this.value) || 0;

                if (value > max) {
                    this.value = max;
                    showWarning('تنبيه الكمية', `الحد الأقصى للإرجاع هو (${max})`);
                }
                updateTotal();
            });
        });

        function updateTotal() {
            let total = 0;
            checkboxes.forEach(checkbox => {
                if (checkbox.checked) {
                    const index = checkbox.getAttribute('data-index');
                    const quantityInput = document.querySelector(`.return-quantity[data-index="${index}"]`);
                    const unitPrice = parseFloat(document.querySelector(`input[name="SaleItems[${index}].UnitPrice"]`).value) || 0;
                    const quantity = parseFloat(quantityInput.value) || 0;
                    const itemTotal = quantity * unitPrice;

                    total += itemTotal;

                    // تحديث الإجمالي للعنصر
                    const itemTotalSpan = document.querySelector(`.item-total[data-index="${index}"]`);
                    if (itemTotalSpan) {
                        itemTotalSpan.textContent = itemTotal.toFixed(2);
                    }
                } else {
                    const index = checkbox.getAttribute('data-index');
                    const itemTotalSpan = document.querySelector(`.item-total[data-index="${index}"]`);
                    if (itemTotalSpan) {
                        itemTotalSpan.textContent = '0.00';
                    }
                }
            });

            document.getElementById('totalAmount').textContent = total.toFixed(2);
        }

        // التحقق قبل الإرسال
        document.getElementById('createReturnForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const selectedItems = Array.from(checkboxes).filter(cb => cb.checked);
            if (selectedItems.length === 0) {
                showWarning('تنبيه', 'يجب اختيار منتج واحد على الأقل');
                return;
            }

            let hasInvalidQuantity = false;
            selectedItems.forEach(checkbox => {
                const index = checkbox.getAttribute('data-index');
                const quantityInput = document.querySelector(`.return-quantity[data-index="${index}"]`);
                const quantity = parseInt(quantityInput.value) || 0;

                if (quantity <= 0) {
                    hasInvalidQuantity = true;
                }
            });

            if (hasInvalidQuantity) {
                showWarning('تنبيه', 'يرجى تحديد كمية صحيحة (أكبر من 0) لكل منتج مختار');
                return;
            }

            // إرسال النموذج
            try {
                const formData = new FormData(this);
                const response = await fetch('@Url.Action("CreateReturnFromSale", "Sales")', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const result = await response.json();

                if (result.success) {
                    showSuccess('تم بنجاح!', result.message).then(() => {
                        window.location.href = '@Url.Action("Details", "Returns")' + '/' + result.returnId;
                    });
                } else {
                    if (result.isValidationError) {
                        showWarning('بيانات غير مكتملة', result.message);
                    } else {
                        showError('خطأ', result.message);
                    }
                }
            } catch (error) {
                showError('خطأ', 'حدث خطأ في الاتصال، يرجى المحاولة مرة أخرى');
            }
        });
    </script>
}
