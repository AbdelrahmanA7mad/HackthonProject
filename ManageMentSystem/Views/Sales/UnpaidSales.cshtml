@model ManageMentSystem.ViewModels.UnpaidSalesViewModel
@{
    ViewData["Title"] = "مبيعات لم تسدد بالكامل";
}

<div class="min-h-screen bg-gray-50 p-6">

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-6">
        <div>
            <h1 class="text-2xl font-bold text-indigo-800 flex items-center gap-3">
                <i class="fas fa-file-invoice-dollar"></i>
                مبيعات لم تسدد بالكامل
            </h1>
        </div>
        <div>
            <a href="@Url.Action("Index", "Sales")" class="bg-white border border-indigo-800 text-indigo-800 px-6 py-3 rounded-xl font-bold hover:bg-indigo-50 transition-colors flex items-center gap-2 shadow-sm">
                رجوع
                <i class="fas fa-arrow-left"></i>
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 mb-8">
        <!-- Total Invoices -->
        <div class="bg-indigo-800 text-white rounded-xl shadow-md p-6 flex flex-col items-center transform hover:-translate-y-1 transition-transform">
            <i class="fas fa-file-invoice fa-2x opacity-60 mb-3"></i>
            <h6 class="text-indigo-100 mb-1 font-medium">إجمالي الفواتير</h6>
            <h4 class="font-bold text-white text-3xl">@Model.TotalCount</h4>
        </div>

        <!-- Total Remaining -->
        <div class="bg-emerald-700 text-white rounded-xl shadow-md p-6 flex flex-col items-center transform hover:-translate-y-1 transition-transform">
            <i class="fas fa-money-bill-wave fa-2x opacity-60 mb-3"></i>
            <h6 class="text-emerald-100 mb-1 font-medium">إجمالي المتبقي</h6>
            <h4 class="font-bold text-white text-3xl">@Model.TotalUnpaidAmount.ToString("C")</h4>
        </div>

        <!-- Credit Invoices -->
        <div class="bg-red-700 text-white rounded-xl shadow-md p-6 flex flex-col items-center transform hover:-translate-y-1 transition-transform">
            <i class="fas fa-clock fa-2x opacity-60 mb-3"></i>
            <h6 class="text-red-100 mb-1 font-medium">فواتير آجلة</h6>
            <h4 class="font-bold text-white text-3xl">@Model.Sales.Count(s => s.PaymentType == ManageMentSystem.Models.SalePaymentType.Credit)</h4>
        </div>

        <!-- Partial Invoices -->
        <div class="bg-amber-700 text-white rounded-xl shadow-md p-6 flex flex-col items-center transform hover:-translate-y-1 transition-transform">
            <i class="fas fa-percent fa-2x opacity-60 mb-3"></i>
            <h6 class="text-amber-100 mb-1 font-medium">فواتير جزئية</h6>
            <h4 class="font-bold text-white text-3xl">@Model.Sales.Count(s => s.PaymentType == ManageMentSystem.Models.SalePaymentType.Partial)</h4>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
        <form method="get" action="@Url.Action("UnpaidSales", "Sales")" class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">من تاريخ</label>
                <div class="relative">
                    <input type="date" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd") ?? "")"
                           class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-800 focus:border-indigo-800 outline-none text-sm font-bold" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">إلى تاريخ</label>
                <div class="relative">
                    <input type="date" name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd") ?? "")"
                           class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-800 focus:border-indigo-800 outline-none text-sm font-bold" />
                </div>
            </div>
            <div class="flex gap-3">
                <button type="submit" class="flex-1 bg-indigo-800 hover:bg-indigo-900 text-white py-3 rounded-xl font-bold transition-all shadow-sm hover:shadow-md">
                    <i class="fas fa-search me-1"></i> بحث
                </button>
                <a href="@Url.Action("UnpaidSales", "Sales")" class="px-5 py-3 bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 hover:text-red-600 rounded-xl font-bold transition-colors shadow-sm text-center">
                    <i class="fas fa-redo"></i>
                </a>
            </div>
        </form>
    </div>

    <!-- Sales Table -->
    <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden">
        <div class="bg-gray-50/50 px-8 py-5 border-b border-gray-200 flex justify-between items-center">
            <h6 class="font-bold text-gray-800 flex items-center gap-2">
                <i class="fas fa-table text-indigo-400"></i>
                الفواتير غير المسددة
            </h6>
            <span class="text-xs font-bold text-gray-700 bg-white px-3 py-1.5 rounded-lg border border-gray-200 shadow-sm">العدد: @Model.Sales.Count()</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-indigo-50 text-indigo-900 text-sm font-bold border-b border-indigo-100">
                    <tr>
                        <th class="px-6 py-4 text-center"># الفاتورة</th>
                        <th class="px-6 py-4">العميل</th>
                        <th class="px-6 py-4 text-center">التاريخ</th>
                        <th class="px-6 py-4 text-center">الإجمالي</th>
                        <th class="px-6 py-4 text-center">المدفوع</th>
                        <th class="px-6 py-4 text-center">المتبقي</th>
                        <th class="px-6 py-4 text-center">النوع</th>
                        <th class="px-6 py-4 text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-sm">
                    @if (Model.Sales.Any())
                    {
                        @foreach (var s in Model.Sales)
                        {
                            var remaining = s.RemainingAmount;
                            <tr class="hover:bg-gray-50/80 transition-colors group">
                                <td class="px-6 py-4 font-mono font-bold text-indigo-700 text-center">
                                    <span class="bg-indigo-50 px-2.5 py-1 rounded-lg border border-indigo-100">#@s.Id</span>
                                </td>
                                <td class="px-6 py-4 font-bold text-gray-800 flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-500">
                                        <i class="fas fa-user"></i>
                                    </div>
                                    @s.Customer?.FullName ?? "غير محدد"
                                </td>
                                <td class="px-6 py-4 text-gray-600 text-center">@s.SaleDate.ToString("yyyy-MM-dd")</td>
                                <td class="px-6 py-4 text-center font-bold">@s.TotalAmount.ToString("C")</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="text-emerald-700 font-bold">@s.PaidAmount.ToString("C")</span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="px-3 py-1 rounded-full font-bold text-xs @(remaining > 0 ? "bg-amber-50 text-amber-700 border border-amber-200" : "bg-gray-100 text-gray-600")">
                                        @remaining.ToString("C")
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="px-3 py-1 rounded-full text-xs font-bold border @(s.PaymentType == ManageMentSystem.Models.SalePaymentType.Credit ? "bg-red-50 text-red-700 border-red-200" : "bg-indigo-50 text-indigo-800 border-indigo-100")">
                                        @((s.PaymentType == ManageMentSystem.Models.SalePaymentType.Credit) ? "آجل" : "جزئي")
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-2 opacity-100">
                                        <button type="button" 
                                                class="w-9 h-9 flex items-center justify-center rounded-lg text-emerald-700 hover:bg-emerald-100 hover:text-emerald-800 transition-all" 
                                                onclick="openPaymentModal(@s.CustomerId, '@(s.Customer?.FullName ?? "غير محدد")', @remaining)"
                                                title="دفع">
                                            <i class="fas fa-money-bill-wave"></i>
                                        </button>
                                        <a href="@Url.Action("Details", "Sales", new { id = s.Id })" 
                                           class="w-9 h-9 flex items-center justify-center rounded-lg text-indigo-700 hover:bg-indigo-100 hover:text-indigo-800 transition-all"
                                           title="عرض التفاصيل">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-gray-400 py-12">
                                <i class="fas fa-inbox fa-3x mb-3"></i>
                                لا توجد فواتير غير مسددة
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="px-4 py-4 bg-gray-50 border-t border-gray-200 flex flex-wrap justify-between items-center gap-2">
                <div class="text-gray-500 text-sm">
                    عرض @(((Model.CurrentPage - 1) * Model.PageSize) + 1) إلى @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount) من @Model.TotalCount فاتورة
                </div>
                <div class="flex gap-1">
                    @if (Model.CurrentPage > 1)
                    {
                        <a href="@Url.Action("UnpaidSales", "Sales", new { page = Model.CurrentPage - 1, pageSize = Model.PageSize, fromDate = Model.FromDate?.ToString("yyyy-MM-dd"), toDate = Model.ToDate?.ToString("yyyy-MM-dd") })"
                           class="px-3 py-1 rounded-full border border-gray-300 hover:bg-indigo-50 hover:text-indigo-800"><i class="fas fa-chevron-right"></i></a>
                    }
                    @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                    {
                        <a href="@Url.Action("UnpaidSales", "Sales", new { page = i, pageSize = Model.PageSize, fromDate = Model.FromDate?.ToString("yyyy-MM-dd"), toDate = Model.ToDate?.ToString("yyyy-MM-dd") })"
                           class="px-3 py-1 rounded-full border text-sm font-bold @(i == Model.CurrentPage ? "bg-indigo-800 text-white border-indigo-800" : "bg-white border-gray-300 hover:bg-indigo-50 hover:text-indigo-800")">@i</a>
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a href="@Url.Action("UnpaidSales", "Sales", new { page = Model.CurrentPage + 1, pageSize = Model.PageSize, fromDate = Model.FromDate?.ToString("yyyy-MM-dd"), toDate = Model.ToDate?.ToString("yyyy-MM-dd") })"
                           class="px-3 py-1 rounded-full border border-gray-300 hover:bg-indigo-50 hover:text-indigo-800"><i class="fas fa-chevron-left"></i></a>
                    }
                </div>
            </div>
        }
    </div>

</div>

<!-- Payment Modal -->
<div id="paymentModal" class="fixed inset-0 hidden z-50 items-center justify-center bg-black/50 backdrop-blur-sm transition-all duration-300 p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg transform scale-100 transition-all flex flex-col max-h-[90vh]">
        
        <!-- Header -->
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-100 flex justify-between items-center rounded-t-2xl flex-shrink-0">
            <h5 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                <i class="fas fa-credit-card text-indigo-800"></i> سداد دفعة للعميل
            </h5>
            <button onclick="closePaymentModal()" class="text-gray-400 hover:text-red-500 transition-colors w-8 h-8 flex items-center justify-center rounded-full hover:bg-red-50">
                <i class="fas fa-times text-lg"></i>
            </button>
        </div>

        <!-- Body (Scrollable) -->
        <div class="overflow-y-auto p-6 custom-scrollbar">
            <form id="customerPaymentForm" class="space-y-4">
                <input type="hidden" name="CustomerId" id="paymentCustomerId" />
                
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1.5">
                        <i class="fas fa-user text-indigo-800 me-1"></i> العميل
                    </label>
                    <input type="text" class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl font-bold text-gray-600 focus:outline-none" id="paymentCustomerName" readonly />
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1.5">
                        <i class="fas fa-dollar-sign text-emerald-600 me-1"></i> المبلغ
                    </label>
                    <div class="relative">
                        <input type="number" step="0.1" min="0.1" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all font-bold text-lg" name="Amount" id="paymentAmount" required placeholder="0.00" />

                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1.5">
                        <i class="fas fa-percentage text-red-600 me-1"></i> خصم مباشر (اختياري)
                    </label>
                    <input type="number" step="0.01" min="0" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all" name="DiscountAmount" placeholder="0.00" />
                    <p class="text-xs text-gray-500 mt-1 flex items-center gap-1">
                        <i class="fas fa-info-circle text-indigo-600"></i>
                         خصم من أقدم فاتورة مفتوحة.
                    </p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1.5">
                            <i class="fas fa-credit-card text-indigo-800 me-1"></i> طريقة الدفع
                        </label>
                        <div class="relative">
                            <select class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all appearance-none bg-white" name="PaymentMethodId">
                                @foreach (var pm in (IEnumerable<ManageMentSystem.Models.PaymentMethodOption>)(ViewBag.PaymentMethods ?? new List<ManageMentSystem.Models.PaymentMethodOption>()))
                                {
                                    <option value="@pm.Id">@pm.Name</option>
                                }
                            </select>
                            <i class="fas fa-chevron-down absolute left-4 top-3.5 text-gray-400 pointer-events-none text-xs"></i>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1.5">
                            <i class="fas fa-calendar text-indigo-800 me-1"></i> التاريخ
                        </label>
                        <input type="date" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all text-gray-600 font-bold" name="PaymentDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1.5">
                        <i class="fas fa-comment text-gray-500 me-1"></i> ملاحظات
                    </label>
                    <textarea class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-800 focus:border-indigo-800 outline-none transition-all resize-none" name="Notes" placeholder="أي ملاحظات إضافية..." rows="2"></textarea>
                </div>
            </form>
        </div>

        <!-- Footer Buttons -->
        <div class="px-6 py-4 border-t border-gray-100 flex gap-3 flex-shrink-0">
            <button type="button" class="flex-1 py-2.5 border border-gray-300 text-gray-700 hover:text-red-700 rounded-xl font-bold hover:bg-gray-50 hover:-translate-y-0.5 transition-all" onclick="closePaymentModal()">
                إلغاء
            </button>
            <button type="submit" form="customerPaymentForm" class="flex-1 py-2.5 bg-indigo-800 text-white rounded-xl font-bold hover:bg-indigo-900 shadow-lg shadow-indigo-200 hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2">
                <i class="fas fa-check"></i> تأكيد السداد
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sweetalert-customers.js"></script>
    <script>
        function openPaymentModal(customerId, customerName, remainingAmount) {
            document.getElementById('paymentCustomerId').value = customerId;
            document.getElementById('paymentCustomerName').value = customerName;
            const amtInput = document.getElementById('paymentAmount');
            amtInput.value = remainingAmount.toFixed(2);
            amtInput.max = remainingAmount;
            document.getElementById('paymentModal').classList.remove('hidden');
            document.getElementById('paymentModal').classList.add('flex');
        }
        function closePaymentModal() {
            document.getElementById('paymentModal').classList.add('hidden');
            document.getElementById('paymentModal').classList.remove('flex');
        }

        $('#customerPaymentForm').on('submit', function(e){
            e.preventDefault();
            const form = $(this);
            const btn = form.find('button[type="submit"]');
            const amountVal = parseFloat(form.find('input[name="Amount"]').val()||'0');
            if(!amountVal || amountVal<=0){
                showWarningMessage('تنبيه','يرجى إدخال مبلغ صحيح'); return;
            }
            showCustomAlert('تأكيد السداد', `هل تريد تأكيد سداد مبلغ ${amountVal.toFixed(2)} د.ك؟`, 'question', 'تأكيد', 'إلغاء', true)
            .then((result)=>{
                if(!result.isConfirmed) return;
                btn.prop('disabled',true).html('<i class="fas fa-spinner fa-spin me-2"></i>جارٍ السداد...');
                $.ajax({
                    url:'@Url.Action("AddPaymentForSale", "Sales")',
                    type:'POST',
                    data:form.serialize(),
                    headers:{'X-Requested-With':'XMLHttpRequest'},
                    success:function(res){
                        if(res.success){
                            closePaymentModal();
                            showSuccessAutoClose('تم بنجاح','تم تسجيل الدفعة بنجاح');
                            setTimeout(()=>location.reload(),1500);
                        } else{
                            showErrorMessage('خطأ',res.message||'فشل في تسجيل الدفعة');
                            btn.prop('disabled',false).html('<i class="fas fa-check me-2"></i>تأكيد السداد');
                        }
                    },
                    error:function(){
                        showErrorMessage('خطأ','حدث خطأ أثناء تسجيل الدفعة');
                        btn.prop('disabled',false).html('<i class="fas fa-check me-2"></i>تأكيد السداد');
                    }
                });
            });
        });
    </script>
}
