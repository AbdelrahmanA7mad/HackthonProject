@{
    ViewData["Title"] = "غير مصرح";
}

<div class="min-h-[80vh] flex items-center justify-center p-6">
    <div class="max-w-md w-full bg-white rounded-3xl shadow-sm border border-gray-200 p-8 text-center">
        <div class="w-20 h-20 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-6">
            <i data-lucide="lock" class="w-10 h-10 text-red-600"></i>
        </div>
        
        <h2 class="text-2xl font-bold text-primary mb-4">غير مصرح</h2>
        
        <p class="text-gray-500 mb-8 leading-relaxed">
            عذراً، ليس لديك صلاحية للوصول إلى هذه الصفحة.
            <br>
            يرجى التواصل مع مدير النظام إذا كنت تعتقد أن هذا خطأ.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="javascript:history.back()" class="zen-btn zen-btn-neutral w-full sm:w-auto">
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
                رجوع
            </a>
            <a asp-controller="Home" asp-action="Index" class="zen-btn zen-btn-primary w-full sm:w-auto">
                <i data-lucide="home" class="w-4 h-4"></i>
                الرئيسية
            </a>
        </div>
    </div>
</div> 

