<!-- AI Chat Floating Button -->
<button onclick="toggleAiChat()" class="fixed bottom-6 left-6 z-[900] bg-[#0f1419] text-white rounded-full w-14 h-14 flex items-center justify-center shadow-lg shadow-[#0f1419]/20 hover:scale-110 hover:rotate-12 transition-all duration-300 group print:hidden">
    <i data-lucide="bot" class="w-7 h-7 group-hover:animate-bounce"></i>
    <span class="absolute top-0 right-0 w-3.5 h-3.5 bg-[#059669] border-2 border-white rounded-full"></span>
    
    <!-- Tooltip -->
    <span class="absolute left-16 bg-white text-[#0f1419] px-3 py-1.5 rounded-lg text-sm font-bold shadow-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-gray-200">
        مساعد كوتة الذكي
        <span class="absolute top-1/2 -left-1.5 w-3 h-3 bg-white border-l border-b border-gray-200 transform -translate-y-1/2 rotate-45"></span>
    </span>
    
    <!-- Pulse Effect -->
    <span class="absolute inset-0 rounded-full border-2 border-gray-200 animate-ping opacity-30"></span>
</button>

<!-- AI Chat Overlay -->
<div id="aiChatOverlay" onclick="toggleAiChat()" class="fixed inset-0 bg-gray-900/50 z-[1000] hidden opacity-0 transition-opacity duration-300 backdrop-blur-sm print:hidden"></div>

<!-- AI Chat Offcanvas -->
<div id="aiChatPanel" class="fixed top-0 left-0 h-screen w-full sm:w-[420px] bg-white z-[1001] shadow-2xl transform -translate-x-full transition-transform duration-300 flex flex-col border-r border-[#e5e7eb] print:hidden">
    
    <!-- Header -->
    <div class="bg-[#0f1419] px-4 py-4 flex items-center justify-between text-white shadow-md z-10">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center border border-white/20 shadow-inner">
                <i data-lucide="bot" class="w-6 h-6 text-white"></i>
            </div>
            <div>
                <h2 class="font-bold text-base leading-tight">مساعد كوتة الذكي</h2>
                <div class="flex items-center gap-1.5 text-[11px] text-white/70 mt-0.5">
                    <span class="w-2 h-2 rounded-full bg-[#059669] animate-pulse"></span>
                    جاهز للمساعدة
                </div>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <a href="/Ai/Index" class="w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors flex items-center justify-center" title="تكبير للصفحة الكاملة">
                <i data-lucide="maximize-2" class="w-4 h-4"></i>
            </a>
            <button onclick="clearAiHistory()" class="w-8 h-8 rounded-full bg-white/10 hover:bg-red-500/80 text-white transition-colors flex items-center justify-center" title="مسح المحادثة">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
            </button>
            <button onclick="toggleAiChat()" class="w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors flex items-center justify-center" title="إغلاق">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
    </div>

    <!-- Quick Suggestions (Horizontal Scroll) -->
    <div class="bg-gray-100/50 border-b border-gray-200 px-3 py-2.5">
        <div class="flex overflow-x-auto gap-2 pb-1 hide-scrollbar" style="scrollbar-width: none;">
            <button onclick="sendAiSuggestion('كام إجمالي المبيعات النهارده؟')" class="whitespace-nowrap px-3 py-1.5 bg-white border border-[#e5e7eb] hover:border-[#e5e7eb] text-[#0f1419] text-xs rounded-full shadow-sm hover:shadow transition-all flex items-center gap-1.5">
                <i data-lucide="banknote" class="w-3.5 h-3.5 text-[#0f1419]"></i> مبيعات اليوم
            </button>
            <button onclick="sendAiSuggestion('أكتر 5 منتجات مبيعاً الشهر ده؟')" class="whitespace-nowrap px-3 py-1.5 bg-white border border-[#e5e7eb] hover:border-[#e5e7eb] text-[#0f1419] text-xs rounded-full shadow-sm hover:shadow transition-all flex items-center gap-1.5">
                <i data-lucide="trophy" class="w-3.5 h-3.5 text-[#0f1419]"></i> أفضل المنتجات
            </button>
            <button onclick="sendAiSuggestion('أيه المنتجات اللي خلصت تقريباً؟')" class="whitespace-nowrap px-3 py-1.5 bg-white border border-[#e5e7eb] hover:border-[#e5e7eb] text-[#0f1419] text-xs rounded-full shadow-sm hover:shadow transition-all flex items-center gap-1.5">
                <i data-lucide="package" class="w-3.5 h-3.5 text-[#0f1419]"></i> نواقص المخزون
            </button>
            <button onclick="sendAiSuggestion('إيه رصيد الخزينة؟')" class="whitespace-nowrap px-3 py-1.5 bg-white border border-[#e5e7eb] hover:border-[#e5e7eb] text-[#0f1419] text-xs rounded-full shadow-sm hover:shadow transition-all flex items-center gap-1.5">
                <i data-lucide="wallet" class="w-3.5 h-3.5 text-[#0f1419]"></i> رصيد الخزينة
            </button>
        </div>
    </div>

    <!-- Messages Area -->
    <div id="ai-messages" class="flex-1 overflow-y-auto p-4 space-y-5 bg-gray-50/50 relative">
        <!-- Welcome Message -->
        <div id="ai-welcome-msg" class="absolute inset-0 flex flex-col items-center justify-center text-center p-6 opacity-70">
            <div class="w-16 h-16 bg-[#f8f9fa] text-[#0f1419] rounded-full flex items-center justify-center mb-3 shadow-sm border border-[#e5e7eb]">
                <i data-lucide="sparkles" class="w-8 h-8"></i>
            </div>
            <h3 class="text-lg font-bold text-gray-800 mb-1">مرحباً بك!</h3>
            <p class="text-xs text-gray-500 max-w-[250px] leading-relaxed">
                أنا المساعد الذكي، اسألني عن أرباحك، مبيعاتك، ومخزونك في أي وقت.
            </p>
        </div>
    </div>

    <!-- Input Area -->
    <div class="p-3 bg-white border-t border-gray-200 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]">
        <div class="relative flex items-end gap-2">
            <div class="flex-1 relative">
                <textarea 
                    id="ai-user-input" 
                    rows="1" 
                    class="w-full bg-gray-50 border border-gray-200 rounded-xl pr-3 pl-10 py-3 focus:outline-none focus:ring-2 focus:ring-[#0f1419] focus:border-gray-200 transition-all resize-none max-h-24 text-gray-700 shadow-inner text-sm"
                    placeholder="اكتب رسالتك..."
                    onkeydown="handleAiKey(event)"
                    oninput="autoResizeAi(this)"
                ></textarea>
            </div>
            
            <button id="ai-send-btn" onclick="sendAiMessage()" class="w-11 h-11 rounded-xl bg-[#f8f9fa] hover:bg-[#e5e7eb] text-[#0f1419] flex items-center justify-center transition-all shadow-md active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed flex-shrink-0">
                <i data-lucide="send" class="w-5 h-5 transform -translate-x-0.5"></i>
            </button>
        </div>
    </div>

</div>

<style>
    .ai-bubble-bot strong { color: #0f1419; font-weight: 700; }
    .ai-bubble-bot ul { list-style-type: disc; margin-right: 1.2rem; margin-top: 0.5rem; margin-bottom: 0.5rem; }
    .ai-bubble-bot li { margin-bottom: 0.25rem; }
    
    #ai-messages::-webkit-scrollbar { width: 5px; }
    #ai-messages::-webkit-scrollbar-track { background: transparent; }
    #ai-messages::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    #ai-messages::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

    /* Hide scrollbar for suggestions */
    .hide-scrollbar::-webkit-scrollbar { display: none; }
</style>

<script>
    const aiMessagesEl = document.getElementById('ai-messages');
    const aiInputEl    = document.getElementById('ai-user-input');
    const aiSendBtn    = document.getElementById('ai-send-btn');
    const aiWelcomeEl  = document.getElementById('ai-welcome-msg');
    const aiPanel      = document.getElementById('aiChatPanel');
    const aiOverlay    = document.getElementById('aiChatOverlay');
    let isAiStreaming  = false;

    // Load History on Page Load
    document.addEventListener('DOMContentLoaded', loadAiHistory);

    async function loadAiHistory() {
        try {
            const response = await fetch('/Ai/GetHistory');
            if (!response.ok) return;
            const history = await response.json();
            
            if (history.length > 0) {
                if (aiWelcomeEl && aiWelcomeEl.parentNode === aiMessagesEl) {
                    aiMessagesEl.removeChild(aiWelcomeEl);
                    aiMessagesEl.classList.remove('relative');
                }
                
                history.forEach(msg => {
                    const { wrapper } = createAiBubble(msg.role === 'user' ? 'user' : 'bot', formatAiText(msg.text));
                    aiMessagesEl.appendChild(wrapper);
                });
                
                lucide.createIcons();
                scrollAiToBottom();
            }
        } catch (err) {
            console.error('Error loading AI history:', err);
        }
    }

    function toggleAiChat() {
        if (aiPanel.classList.contains('-translate-x-full')) {
            // Open
            aiPanel.classList.remove('-translate-x-full');
            aiOverlay.classList.remove('hidden');
            setTimeout(() => { aiOverlay.classList.remove('opacity-0'); }, 10);
            setTimeout(() => { aiInputEl.focus(); }, 300);
        } else {
            // Close
            aiPanel.classList.add('-translate-x-full');
            aiOverlay.classList.add('opacity-0');
            setTimeout(() => { aiOverlay.classList.add('hidden'); }, 300);
        }
    }

    function handleAiKey(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendAiMessage();
        }
    }

    function autoResizeAi(el) {
        el.style.height = 'auto';
        el.style.height = Math.min(el.scrollHeight, 96) + 'px';
    }

    function sendAiSuggestion(text) {
        aiInputEl.value = text;
        sendAiMessage();
    }

    function formatAiText(text) {
        return text
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\\n/g, '\n')
            .replace(/\n/g, '<br>');
    }

    function createAiBubble(role, htmlContent, id = null) {
        const msgWrapper = document.createElement('div');
        msgWrapper.className = `flex gap-2 items-end animate-[fadeIn_0.3s_ease-out] w-full ${role === 'user' ? 'flex-row-reverse' : ''}`;
        if (id) msgWrapper.id = id;

        const avatar = document.createElement('div');
        avatar.className = `w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 text-xs shadow-sm ${
            role === 'user' 
            ? 'bg-[#f8f9fa] text-[#0f1419] border border-[#e5e7eb]' 
            : 'bg-[#0f1419] text-white'
        }`;
        avatar.innerHTML = role === 'user' ? '<i data-lucide="user" class="w-4 h-4"></i>' : '<i data-lucide="bot" class="w-4 h-4"></i>';

        const bubble = document.createElement('div');
        if (role === 'user') {
            bubble.className = 'max-w-[85%] bg-[#0f1419] text-white px-3 py-2 rounded-2xl rounded-bl-sm shadow-sm text-sm leading-relaxed';
            bubble.innerHTML = htmlContent;
        } else {
            bubble.className = 'ai-bubble-bot max-w-[85%] bg-white border border-[#e5e7eb] text-gray-800 px-4 py-3 rounded-2xl rounded-br-sm shadow-sm text-sm leading-relaxed';
            bubble.innerHTML = htmlContent;
        }

        msgWrapper.appendChild(avatar);
        msgWrapper.appendChild(bubble);
        return { wrapper: msgWrapper, bubble };
    }

    function addAiThinking() {
        if (aiWelcomeEl && aiWelcomeEl.parentNode === aiMessagesEl) {
            aiMessagesEl.removeChild(aiWelcomeEl);
            aiMessagesEl.classList.remove('relative');
        }

        const thinkingHtml = `
            <div class="flex items-center gap-1 h-4 px-1">
                <div class="w-1.5 h-1.5 bg-gray-100 rounded-full animate-bounce" style="animation-delay: 0s"></div>
                <div class="w-1.5 h-1.5 bg-gray-100 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                <div class="w-1.5 h-1.5 bg-gray-100 rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
            </div>
        `;
        
        const { wrapper, bubble } = createAiBubble('bot', thinkingHtml, 'ai-thinking-msg');
        aiMessagesEl.appendChild(wrapper);
        lucide.createIcons({ attrs: { 'data-lucide': true } });
        scrollAiToBottom();
        return bubble;
    }

    function scrollAiToBottom() {
        aiMessagesEl.scrollTop = aiMessagesEl.scrollHeight;
    }

    async function sendAiMessage() {
        const text = aiInputEl.value.trim();
        if (!text || isAiStreaming) return;

        isAiStreaming = true;
        aiSendBtn.disabled = true;
        aiInputEl.disabled = true;

        if (aiWelcomeEl && aiWelcomeEl.parentNode === aiMessagesEl) {
            aiMessagesEl.removeChild(aiWelcomeEl);
            aiMessagesEl.classList.remove('relative');
        }

        const { wrapper: userMsg } = createAiBubble('user', formatAiText(text));
        aiMessagesEl.appendChild(userMsg);
        lucide.createIcons();
        
        aiInputEl.value = '';
        aiInputEl.style.height = 'auto';

        const bubble = addAiThinking();

        try {
            const response = await fetch('/Ai/Stream', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text })
            });

            if (!response.ok) throw new Error('فشل الاتصال بالخادم.');

            const reader  = response.body.getReader();
            const decoder = new TextDecoder();
            let fullText  = '';
            let firstChunk = true;

            while (true) {
                const { done, value } = await reader.read();
                if (done) break;

                const rawChunk = decoder.decode(value);
                const lines = rawChunk.split('\n');

                for (const line of lines) {
                    if (!line.startsWith('data: ')) continue;
                    const data = line.slice(6);

                    if (data === '[DONE]') break;
                    
                    if (data.startsWith('[ERROR]')) {
                        bubble.innerHTML = `<div class="flex items-center gap-1.5 text-red-600 text-xs"><i data-lucide="alert-circle" class="w-3.5 h-3.5"></i> <span>${data.slice(7)}</span></div>`;
                        lucide.createIcons();
                        break;
                    }

                    if (firstChunk && data.includes('⚙️')) {
                        bubble.innerHTML = `<div class="flex items-center gap-1.5 text-[#0f1419] font-medium animate-pulse text-xs"><i data-lucide="database" class="w-3.5 h-3.5"></i> <span>جاري استخراج البيانات...</span></div>`;
                        lucide.createIcons();
                        firstChunk = false;
                        continue;
                    }

                    firstChunk = false;
                    const chunk = data.replace(/\\n/g, '\n');
                    fullText += chunk;
                    bubble.innerHTML = formatAiText(fullText);
                    scrollAiToBottom();
                }
            }

        } catch (err) {
            bubble.innerHTML = `<div class="flex items-center gap-1.5 text-red-600 text-xs"><i data-lucide="alert-triangle" class="w-3.5 h-3.5"></i> <span>حدث خطأ: ${err.message}</span></div>`;
            lucide.createIcons();
        } finally {
            isAiStreaming = false;
            aiSendBtn.disabled = false;
            aiInputEl.disabled = false;
            aiInputEl.focus();
        }
    }

    async function clearAiHistory() {
        await fetch('/Ai/Clear', { method: 'POST' });
        aiMessagesEl.innerHTML = '';
        aiMessagesEl.classList.add('relative');
        aiMessagesEl.appendChild(aiWelcomeEl);
        aiInputEl.value = '';
    }
</script>
