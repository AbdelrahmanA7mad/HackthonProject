            @@keyframes pulse-ring {
              0% { transform: scale(0.8); box-shadow: 0 0 0 0 rgb(var(--zen-theme-primary-rgb) / 0.7); }
              70% { transform: scale(1); box-shadow: 0 0 0 10px rgb(var(--zen-theme-primary-rgb) / 0); }
              100% { transform: scale(0.8); box-shadow: 0 0 0 0 rgb(var(--zen-theme-primary-rgb) / 0); }
            }
            body { background-color: var(--zen-theme-bg-base); color: var(--zen-theme-primary); font-family: 'Cairo', sans-serif; }
            .sidebar-link-active { background-color: var(--zen-theme-bg-subtle); color: var(--zen-theme-primary); border-right: 4px solid var(--zen-theme-primary); }
        </style>
        <link href="~/lib/datatables-bs5/css/dataTables.bootstrap5.min.css" rel="stylesheet">
        <link href="~/lib/datatables-buttons-bs5/css/buttons.bootstrap5.min.css" rel="stylesheet">

    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="var(--zen-theme-primary)" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <div id="pageLoader" class="page-loading-bar" aria-hidden="true"></div>

    @await Component.InvokeAsync("SubscriptionStatus")

    @if (User?.Identity?.IsAuthenticated == true)
    {
