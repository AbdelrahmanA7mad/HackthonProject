@using Microsoft.AspNetCore.Identity
@using ManageMentSystem.Models
@using ManageMentSystem.Services.SystemSettings
@inject ISystemSettingsService SystemSettingsService
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام إدارة المبيعات</title>

    <script src="~/lib/tailwindcss/tailwind.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Cairo', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Local Cairo Font -->
    <link rel="stylesheet" href="~/css/cairo-font.css" />

        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
        <link href="~/lib/fontawesome/css/all.min.css" rel="stylesheet">
        <link rel="stylesheet" href="~/lib/sweetalert2/sweetalert2.min.css" />
        <link rel="stylesheet" href="~/lib/animate.css/animate.min.css" />
        <link href="~/lib/datatables-bs5/css/dataTables.bootstrap5.min.css" rel="stylesheet">
        <link href="~/lib/datatables-buttons-bs5/css/buttons.bootstrap5.min.css" rel="stylesheet">

    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="#1e1b4b" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <div id="pageLoader" class="page-loading-bar" aria-hidden="true"></div>

    @await Component.InvokeAsync("SubscriptionStatus")

    @if (User?.Identity?.IsAuthenticated == true)
    {
        var tabSettings = await SystemSettingsService.GetTabVisibilitySettingsAsync();
        
        <!-- Mobile Header (Fixed) -->
        <header class="fixed top-0 inset-x-0 h-16 bg-gradient-to-br from-indigo-800 to-indigo-900 border-b border-indigo-700 flex items-center justify-between px-4 z-[1000] md:hidden shadow-md transition-all duration-300 print:hidden">
            <!-- Menu Toggle -->
            <button id="mobileMenuBtn" class="flex items-center justify-center w-10 h-10 rounded-xl bg-indigo-50 text-indigo-800 hover:bg-indigo-100 transition-colors border border-indigo-600">
                <i class="fas fa-bars text-lg"></i>
            </button>

            <!-- Logo (Centered) -->
            <img src="~/images/translogo.webp" alt="Qota" onclick="toggleAboutModal()" class="h-8 object-contain cursor-pointer active:scale-95 transition-transform drop-shadow-sm" />

            <!-- Spacer/Placeholder -->
            <div class="w-10"></div>
        </header>

        <div class="fixed top-0 left-0 w-full h-full bg-black/50 z-40 hidden opacity-0 transition-opacity duration-300 ease-in-out md:hidden print:hidden" id="sidebarOverlay"></div>

        <div class="flex">
            <nav id="sidebar" class="fixed top-0 right-0 h-screen w-72  border-r border-indigo-50 shadow-xl z-50 overflow-y-auto transition-all duration-300 ease-in-out translate-x-full md:translate-x-0 bg-gradient-to-br from-indigo-800 to-indigo-900 print:hidden">
                <div class="sidebar-header text-center border-b border-indigo-50 p-2 md:p-6 bg-gradient-to-br from-indigo-800 to-indigo-900 sticky top-0 z-10">
                    <img src="~/images/translogo.webp" alt="Qota Logo" onclick="toggleAboutModal()" class="h-12 w-28 mx-auto object-contain drop-shadow-md transition-transform hover:scale-105 duration-300 cursor-pointer" />
                </div>

                <div class="sidebar-content p-0 flex flex-col">
                    <ul class="flex flex-col flex-grow">
                        @{
                            // تم تغيير جميع ألوان Sky إلى Indigo هنا (active state)
                            string activeLinkClasses = "bg-indigo-50  text-indigo-800  font-semibold shadow-sm shadow-indigo-100/50 border-r-4 border-indigo-800  transform translate-x-0.5";

                            // تم تغيير ألوان الـ Hover هنا إلى Indigo
                            string baseLinkClasses = "flex items-center font-medium p-3 rounded-xl transition-all duration-300 text-indigo-50  hover:bg-indigo-50 hover:text-indigo-800 hover:translate-x-[-4px]";
                        }

                        <li class="mt-2 mb-0.5 mx-2">
                            <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? activeLinkClasses : "")" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home ml-2"></i>
                                الرئيسية
                            </a>
                        </li>

                        @if (tabSettings.ShowProducts )
                        {
                        <li class="my-0.5 mx-2">
                            <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? activeLinkClasses : "")" asp-controller="Products" asp-action="Index">
                                <i class="fas fa-box ml-2"></i>
                                المنتجات
                            </a>
                        </li>
                        }

                        @if (tabSettings.ShowCategories )
                        {
                        <li class="my-0.5 mx-2">
                            <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" ? activeLinkClasses : "")" asp-controller="Categories" asp-action="Index">
                                <i class="fas fa-tags ml-2"></i>
                                الفئات
                            </a>
                        </li>
                        }

                        @if (tabSettings.ShowCustomers)
                        {
                        <li class="my-0.5 mx-2">
                            <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Customers" ? activeLinkClasses : "")" asp-controller="Customers" asp-action="Index">
                                <i class="fas fa-users ml-2"></i>
                                العملاء
                            </a>
                        </li>
                        }

                        @if (tabSettings.ShowSales )
                        {
                        <li class="my-0.5 mx-2">
                            <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Sales"  &&
                               ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? activeLinkClasses : "")" asp-controller="Sales" asp-action="Index">
                                <i class="fas fa-shopping-cart ml-2"></i>
                                المبيعات
                            </a>
                        </li>
                        }

                        @if (tabSettings.ShowInstallments )
                        {
                        <li class="my-0.5 mx-2">
                            <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Installments" ? activeLinkClasses : "")" asp-controller="Installments" asp-action="Index">
                                <i class="fas fa-credit-card ml-2"></i>
                                الأقساط
                            </a>
                        </li>
                        }

                        @if (tabSettings.ShowGeneralDebts )
                        {
                        <li class="my-0.5 mx-2">
                            <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Controller"]?.ToString() == "GeneralDebts" ? activeLinkClasses : "")" asp-controller="GeneralDebts" asp-action="Index">
                                <i class="fas fa-scale-balanced ml-2"></i>
                                الديون
                            </a>
                        </li>
                        }

                        @if (tabSettings.ShowStoreAccount )
                        {
                        <li class="my-0.5 mx-2">
                            <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Controller"]?.ToString() == "StoreAccount" ? activeLinkClasses : "")" asp-controller="StoreAccount" asp-action="Index">
                                <i class="fas fa-calculator ml-2"></i>
                                الحسابات
                            </a>
                        </li>
                        }

                        <li class="nav-item my-0.5 mx-2">
                             <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Controller"]?.ToString() == "SystemSettings" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? activeLinkClasses : "")" asp-controller="SystemSettings" asp-action="Index">
                               <i class="fas fa-users-cog ml-2"></i>
                                الإعدادات
                             </a>
                        </li>
                        
                        <li class="nav-item my-0.5 mx-2">
                             <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Action"]?.ToString() == "Subscription" ? activeLinkClasses : "")" asp-controller="SystemSettings" asp-action="Subscription">
                               <i class="fas fa-crown ml-2"></i>
                                الاشتراك
                             </a>
                        </li>

                        @if (tabSettings.ShowReports)
                        {
                        <li class="my-0.5 mx-2">
                            <a class="@(baseLinkClasses) @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reports" ? activeLinkClasses : "")" asp-controller="Reports" asp-action="Index">
                                <i class="fas fa-chart-bar ml-2"></i>
                                التقارير
                            </a>
                        </li>
                        }

                        <li class="mt-4 mb-4 mx-2">
                            <form asp-controller="Home" asp-action="Logout" method="post">
                                <button type="submit" class="bg-red-700 hover:bg-red-800 text-white font-medium py-2 w-full rounded-xl transition-all duration-300 shadow-md hover:shadow-lg" style="border-radius:1rem;">
                                    <i class="fas fa-sign-out-alt ml-1"></i> تسجيل الخروج
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </nav>

            <div class="main-content flex-grow mr-0 md:mr-72 transition-all duration-300 ease-in-out pt-16 md:pt-0 w-full max-w-full overflow-x-auto">

                <main class="p-4 w-full max-w-full overflow-x-auto">
                    @RenderBody()
                </main>
            </div>
        </div>
        }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/datatables/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables-buttons/js/dataTables.buttons.min.js"></script>
    <script src="~/lib/jszip/jszip.min.js"></script>
    <script src="~/lib/pdfmake/pdfmake.min.js"></script>
    <script src="~/lib/pdfmake/vfs_fonts.js"></script>
    <script src="~/lib/datatables-buttons/js/buttons.html5.min.js"></script>
    <script src="~/lib/datatables-buttons/js/buttons.print.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/js/swal-config.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="~/js/barcode.js" asp-append-version="true"></script>
    <script src="~/js/page-loader.js" asp-append-version="true"></script>
    <script src="~/js/sidebar.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>


    <script>

        $(document).ready(function() {

            // ===================================================
            // 1. Mobile Sidebar Toggle (Hamburger Button Fix)
            // ===================================================
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            const mobileBtn = document.getElementById('mobileMenuBtn');

            function toggleSidebar() {
                // تبديل كلاسات Tailwind لإظهار/إخفاء الشريط الجانبي
                sidebar.classList.toggle('translate-x-full');
                sidebar.classList.toggle('translate-x-0');

                // تبديل كلاسات Overlay (الخلفية المعتمة)
                overlay.classList.toggle('hidden');
                overlay.classList.toggle('opacity-0');
                overlay.classList.toggle('opacity-100');
            }

            if (mobileBtn && sidebar && overlay) {
                mobileBtn.addEventListener('click', toggleSidebar);
                overlay.addEventListener('click', toggleSidebar);
            }


            // ===================================================
            // 2. Settings Dropdown Toggle (Click/Accordion Fix)
            // ===================================================
            $('#settingsDropdownToggle').on('click', function(e) {
                e.preventDefault();

                const subMenu = $('#settingsSubMenu');
                const icon = $('#settingsIcon');

                // التحقق مما إذا كانت القائمة مفتوحة
                if (subMenu.hasClass('is-open')) {
                    // إغلاق القائمة
                    subMenu.removeClass('is-open');
                    subMenu.css('max-height', '0');
                    icon.removeClass('rotate-90');
                } else {
                    // فتح القائمة
                    subMenu.addClass('is-open');
                    // حساب ارتفاع المحتوى لتمكين انتقال سلس
                    const contentHeight = subMenu.prop('scrollHeight');
                    subMenu.css('max-height', contentHeight + 'px');
                    icon.addClass('rotate-90');
                }
            });
            // للحفاظ على القائمة مفتوحة إذا كان أحد عناصرها نشطاً عند تحميل الصفحة
            if ($('#settingsSubMenu a.font-semibold').length > 0) {
                 const subMenu = $('#settingsSubMenu');
                 subMenu.addClass('is-open').css('max-height', subMenu.prop('scrollHeight') + 'px');
                 $('#settingsIcon').addClass('rotate-90');
            }
        });

        window.APP_CURRENCY_SYMBOL = '@System.Globalization.CultureInfo.CurrentCulture.NumberFormat.CurrencySymbol';
        // تحديث الـ navbar عند حذف فئة
        @if (TempData["RefreshNavbar"] != null)
        {
                            <text>
                            $(document).ready(function() {
                                setTimeout(function() {
                                    location.reload();
                                }, 1000);
                            });
                            </text>
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- About Us Modal -->
    <div id="aboutModal" class="fixed inset-0 z-[9999] hidden" aria-labelledby="about-title" role="dialog" aria-modal="true">
        <!-- Backdrop -->
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity backdrop-blur-sm" onclick="toggleAboutModal()"></div>

        <div class="fixed inset-0 z-10 overflow-y-auto">
            <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                
                <div class="relative transform overflow-hidden rounded-2xl bg-white text-right shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-md border border-indigo-100">
                    
                    <!-- Decorative Header -->
                    <div class="bg-gradient-to-r from-indigo-800 to-indigo-900 h-24 relative overflow-hidden flex items-center justify-center">
                         <div class="absolute inset-0 opacity-20" style="background-image: repeating-linear-gradient(45deg, #fff 0px, #fff 1px, transparent 1px, transparent 10px);"></div>
                         <img src="~/images/translogo.webp" alt="Qota" class="h-16 relative z-10 drop-shadow-xs filter" />
                    </div>

                    <div class="px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                        <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-center">
                            <h3 class="text-xl font-bold leading-6 text-indigo-900 mb-2" id="about-title">نظام كوتة لإدارة المبيعات</h3>
                            <div class="mt-2">
                                <p class="text-sm font-bold text-gray-700 mb-4 bg-indigo-50 py-1 px-3 rounded-full inline-block font-mono">الإصدار 1.0.0</p>
                                <p class="text-sm text-gray-600 leading-relaxed">
                                    نظام متكامل صُمم خصيصاً لتسهيل إدارة مبيعاتك، مخزونك، وعملائك. نهدف لتمكين أصحاب الأعمال من النمو والتحكم الكامل بمشاريعهم.
                                </p>
                            </div>

                            <!-- Social Links -->
                            <div class="mt-8 flex justify-center gap-6">
                                <a href="https://www.facebook.com/profile.php?id=61586835293416" target="_blank" class="group flex flex-col items-center gap-1 text-gray-500 hover:text-indigo-800 transition-colors">
                                    <div class="w-10 h-10 rounded-full bg-indigo-50 flex items-center justify-center group-hover:bg-indigo-100 transition-colors">
                                        <i class="fab fa-facebook-f text-lg"></i>
                                    </div>
                                </a>
                                <a href="https://www.youtube.com/@@qotaSystem" target="_blank" class="group flex flex-col items-center gap-1 text-gray-500 hover:text-red-600 transition-colors">
                                    <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center group-hover:bg-red-100 transition-colors">
                                        <i class="fab fa-youtube text-lg"></i>
                                    </div>
                                </a>
                                <a href="#" class="group flex flex-col items-center gap-1 text-gray-500 hover:text-pink-600 transition-colors">
                                    <div class="w-10 h-10 rounded-full bg-pink-50 flex items-center justify-center group-hover:bg-pink-100 transition-colors">
                                        <i class="fab fa-instagram text-lg"></i>
                                    </div>
                                </a>
                                <a href="#" class="group flex flex-col items-center gap-1 text-gray-500 hover:text-black transition-colors">
                                    <div class="w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center group-hover:bg-gray-200 transition-colors">
                                        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-gray-100 px-4 py-3 flex flex-col sm:flex-row-reverse gap-2 sm:px-6 justify-center">
                        <button type="button" class="inline-flex w-full justify-center rounded-lg bg-gray-50 hover:bg-red-100 border border-gray-400 px-8 py-2 text-sm font-semibold text-gray-900 shadow-sm transition-colors sm:w-auto" onclick="toggleAboutModal()">إغلاق</button>
                        <button type="button" class="pwa-install-btn hidden inline-flex w-full justify-center rounded-lg bg-indigo-800 hover:bg-indigo-900 border border-transparent px-6 py-2 text-sm font-semibold text-white shadow-sm transition-colors sm:w-auto items-center gap-2" onclick="installPWA()">
                            <i class="fas fa-plus-circle"></i>
                            تثبيت على سطح المكتب
                        </button>
                    </div>
                    
                    <div class="text-center pb-4 text-xs text-gray-500">
                        &copy; @DateTime.Now.Year Qota System. All rights reserved.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleAboutModal() {
            const modal = document.getElementById('aboutModal');
            if (modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
            } else {
                modal.classList.add('hidden');
            }
        }

        // تسجيل Service Worker للـ PWA
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('Service Worker registered'))
                    .catch(err => console.log('Service Worker registration failed', err));
            });
        }
    </script>

    @functions {
    private bool HasPermission(System.Security.Claims.ClaimsPrincipal user, string permissionName)
    {
        // All authenticated users have full access - no permission checks needed
        return user != null && user.Identity != null && user.Identity.IsAuthenticated;
    }
}
</body>
</html>