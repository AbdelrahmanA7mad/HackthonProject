@model ManageMentSystem.Models.Tenant

<div class="fixed inset-0 bg-primary/95 z-[9999] flex items-center justify-center backdrop-blur-sm" style="direction: rtl;">
    <div class="bg-white p-10 rounded-3xl text-center w-[90%] max-w-lg shadow-2xl border border-gray-200 relative overflow-hidden">
        
        <!-- Decorative Background Elements -->
        <div class="absolute top-0 left-0 w-full h-2 bg-primary"></div>
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-gray-50 rounded-full blur-3xl opacity-50 pointer-events-none"></div>
        <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-gray-50 rounded-full blur-3xl opacity-50 pointer-events-none"></div>

        <!-- Icon -->
        <div class="mb-8 relative z-10">
            <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4 border border-gray-200">
                <i data-lucide="alert-triangle" class="w-12 h-12 text-primary"></i>
            </div>
        </div>

        <!-- Title -->
        <h2 class="text-3xl font-black text-primary mb-4 tracking-tight relative z-10">
            انتهى اشتراكك
        </h2>

        <!-- Message -->
        <p class="text-lg text-gray-500 mb-8 leading-relaxed font-medium relative z-10">
            عذراً، لقد انتهت فترة الاشتراك الخاصة بك.
            <br />
            للاستمرار في استخدام النظام، يرجى تجديد الاشتراك.
        </p>

        <!-- Actions -->
        <div class="space-y-4 relative z-10">
            <!-- WhatsApp Action -->
            <a href="https://wa.me/201129452725?text=أريد%20تجديد%20الاشتراك"
               class="zen-btn zen-btn-success w-full group no-underline"
               target="_blank" rel="noopener">
                <i data-lucide="message-circle" class="w-6 h-6 group-hover:scale-110 transition-transform duration-300"></i>
                <span>تواصل عبر واتساب للتجديد</span>
            </a>

            <!-- Support Text -->
            <p class="text-gray-500 text-sm font-medium pt-2">
                للاستفسارات والدعم الفني، يمكنك التواصل معنا مباشرة
            </p>

            <!-- Divider -->
            <div class="h-px bg-gray-100 my-6"></div>

            <!-- Logout Form -->
            <form asp-controller="Home" asp-action="Logout" method="post" class="block">
                @Html.AntiForgeryToken()
                <button type="submit" class="zen-btn zen-btn-neutral w-full group">
                    <i data-lucide="log-out" class="w-5 h-5 group-hover:-translate-x-1 transition-transform duration-300"></i>
                    تسجيل الخروج
                </button>
            </form>
        </div>
    </div>
</div>

