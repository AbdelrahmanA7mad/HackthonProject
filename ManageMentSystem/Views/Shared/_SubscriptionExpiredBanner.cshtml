@model ManageMentSystem.Models.Tenant

<div class="fixed inset-0 bg-slate-900/95 z-[9999] flex items-center justify-center backdrop-blur-sm" style="direction: rtl;">
    <div class="bg-white p-10 rounded-3xl text-center w-[90%] max-w-lg shadow-2xl border border-indigo-50 relative overflow-hidden">
        
        <!-- Decorative Background Elements -->
        <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-red-800 via-amber-600 to-red-800"></div>
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-indigo-50 rounded-full blur-3xl opacity-50 pointer-events-none"></div>
        <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-amber-50 rounded-full blur-3xl opacity-50 pointer-events-none"></div>

        <!-- Icon -->
        <div class="mb-8 relative z-10">
            <div class="w-24 h-24 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4 animate-pulse">
                <i class="fas fa-exclamation-triangle text-5xl text-red-700"></i>
            </div>
        </div>

        <!-- Title -->
        <h2 class="text-3xl font-black text-red-700 mb-4 tracking-tight relative z-10">
            انتهى اشتراكك
        </h2>

        <!-- Message -->
        <p class="text-lg text-slate-600 mb-8 leading-relaxed font-medium relative z-10">
            عذراً، لقد انتهت فترة الاشتراك الخاصة بك.
            <br />
            للاستمرار في استخدام النظام، يرجى تجديد الاشتراك.
        </p>

        <!-- Actions -->
        <div class="space-y-4 relative z-10">
            <!-- WhatsApp Action -->
            <a href="https://wa.me/201129452725?text=أريد%20تجديد%20الاشتراك"
               class="inline-flex items-center justify-center gap-2 w-full bg-emerald-700 hover:bg-emerald-800 text-white text-lg font-bold py-4 px-8 rounded-2xl transition-all duration-300 hover:-translate-y-1 shadow-lg shadow-emerald-200 group no-underline"
               target="_blank" rel="noopener">
                <i class="fab fa-whatsapp text-2xl group-hover:scale-110 transition-transform duration-300"></i>
                <span>تواصل عبر واتساب للتجديد</span>
            </a>

            <!-- Support Text -->
            <p class="text-slate-400 text-sm font-medium pt-2">
                للاستفسارات والدعم الفني، يمكنك التواصل معنا مباشرة
            </p>

            <!-- Divider -->
            <div class="h-px bg-slate-100 my-6"></div>

            <!-- Logout Form -->
            <form asp-controller="Home" asp-action="Logout" method="post" class="block">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full border border-red-200 bg-red-50 hover:bg-red-100 text-red-700 font-bold py-3.5 px-6 rounded-xl transition-all duration-300 flex items-center justify-center gap-2 group">
                    <i class="fas fa-sign-out-alt group-hover:-translate-x-1 transition-transform duration-300"></i>
                    تسجيل الخروج
                </button>
            </form>
        </div>
    </div>
</div>
