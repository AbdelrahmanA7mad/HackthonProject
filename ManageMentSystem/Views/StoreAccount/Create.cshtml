@model ManageMentSystem.ViewModels.StoreAccountViewModel

@{
    ViewData["Title"] = "إضافة عملية مالية جديدة";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
            <i data-lucide="plus-circle" class="text-primary"></i> إضافة عملية مالية جديدة
        </h1>
        <p class="text-gray-500 mt-1 font-medium">تسجيل عملية إيداع أو سحب جديدة</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-4xl mx-auto">
        <form asp-action="Create" method="post" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl flex items-center gap-2" role="alert">
                <i data-lucide="alert-circle" class="text-xl"></i>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Transaction Name -->
                <div>
                    <label asp-for="TransactionName" class="block text-sm font-bold text-gray-600 mb-1.5"></label>
                    <div class="relative">
                        <input asp-for="TransactionName" class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/10 focus:border-primary outline-none font-bold text-primary transition-all placeholder:text-gray-500" placeholder="اسم العملية" />
                        <i data-lucide="type" class="absolute left-4 top-4 text-gray-500 w-4 h-4"></i>
                    </div>
                    <span asp-validation-for="TransactionName" class="text-sm font-bold text-accentRed mt-1 block"></span>
                </div>

                <!-- Transaction Type -->
                <div>
                    <label asp-for="TransactionType" class="block text-sm font-bold text-gray-600 mb-1.5"></label>
                    <div class="relative">
                        <select asp-for="TransactionType" asp-items="ViewBag.TransactionTypes" class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/10 focus:border-primary outline-none font-bold text-primary transition-all bg-white appearance-none">
                            <option value="">اختر نوع العملية</option>
                        </select>
                        <i data-lucide="arrow-left-right" class="absolute left-4 top-4 text-gray-500 w-4 h-4"></i>
                        <i data-lucide="chevron-down" class="absolute right-4 top-4 text-gray-500 w-4 h-4 pointer-events-none"></i>
                    </div>
                    <span asp-validation-for="TransactionType" class="text-sm font-bold text-accentRed mt-1 block"></span>
                </div>

                <!-- Amount -->
                <div>
                    <label asp-for="Amount" class="block text-sm font-bold text-gray-600 mb-1.5"></label>
                    <div class="relative">
                        <input asp-for="Amount" class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/10 focus:border-primary outline-none font-bold text-primary transition-all placeholder:text-gray-500" type="number" step="0.01" min="0.01" />
                        <i data-lucide="coins" class="absolute left-4 top-4 text-gray-500 w-4 h-4"></i>
                    </div>
                    <span asp-validation-for="Amount" class="text-sm font-bold text-accentRed mt-1 block"></span>
                </div>

                <!-- Date -->
                <div>
                    <label asp-for="TransactionDate" class="block text-sm font-bold text-gray-600 mb-1.5"></label>
                    <div class="relative">
                        <input asp-for="TransactionDate" class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/10 focus:border-primary outline-none font-bold text-primary transition-all text-right" type="date" />
                        <i data-lucide="calendar" class="absolute left-4 top-4 text-gray-500 w-4 h-4"></i>
                    </div>
                    <span asp-validation-for="TransactionDate" class="text-sm font-bold text-accentRed mt-1 block"></span>
                </div>

                <!-- Category -->
                <div>
                    <label asp-for="Category" class="block text-sm font-bold text-gray-600 mb-1.5"></label>
                    <div class="relative">
                        <input asp-for="Category" class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/10 focus:border-primary outline-none font-bold text-primary transition-all placeholder:text-gray-500" placeholder="مثال: المبيعات، الصيانة، الإيجار" />
                        <i data-lucide="tags" class="absolute left-4 top-4 text-gray-500 w-4 h-4"></i>
                    </div>
                    <span asp-validation-for="Category" class="text-sm font-bold text-accentRed mt-1 block"></span>
                </div>

                <!-- Payment Method -->
                <div>
                    <label asp-for="PaymentMethodId" class="block text-sm font-bold text-gray-600 mb-1.5"></label>
                    <div class="relative">
                        <select asp-for="PaymentMethodId" asp-items="ViewBag.PaymentMethods" class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/10 focus:border-primary outline-none font-bold text-primary transition-all bg-white appearance-none">
                            <option value="">اختر طريقة الدفع</option>
                        </select>
                        <i data-lucide="credit-card" class="absolute left-4 top-4 text-gray-500 w-4 h-4"></i>
                        <i data-lucide="chevron-down" class="absolute right-4 top-4 text-gray-500 w-4 h-4 pointer-events-none"></i>
                    </div>
                    <span asp-validation-for="PaymentMethodId" class="text-sm font-bold text-accentRed mt-1 block"></span>
                </div>

                <!-- Description -->
                <div class="md:col-span-2">
                    <label asp-for="Description" class="block text-sm font-bold text-gray-600 mb-1.5"></label>
                    <textarea asp-for="Description" rows="3" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/10 focus:border-primary outline-none font-medium text-primary transition-all placeholder:text-gray-500 resize-none" placeholder="وصف العملية"></textarea>
                    <span asp-validation-for="Description" class="text-sm font-bold text-accentRed mt-1 block"></span>
                </div>
            </div>

            <div class="pt-6 border-t border-gray-200 flex items-center gap-4 mt-4">
                <button type="submit" class="zen-btn zen-btn-primary">
                    <i data-lucide="save"></i> حفظ العملية
                </button>
                <a asp-action="Index" class="zen-btn zen-btn-neutral">
                    <i data-lucide="arrow-right"></i> العودة للقائمة
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Set default date to today if empty
            const dateInput = document.querySelector('input[type="date"]');
            if (dateInput && !dateInput.value) {
                dateInput.value = new Date().toISOString().split('T')[0];
            }
        });
    </script>
}

