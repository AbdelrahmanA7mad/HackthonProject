@model ManageMentSystem.Models.StoreAccount
@using ManageMentSystem.Helpers

@{
    ViewData["Title"] = "تفاصيل العملية المالية";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="mb-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="file-digit" class="text-primary"></i> تفاصيل العملية المالية
            </h1>
            <p class="text-gray-500 mt-1 font-medium">عرض كافة تفاصيل العملية المسجلة</p>
        </div>
        <div class="flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="zen-btn zen-btn-primary">
                <i data-lucide="edit"></i> تعديل
            </a>
            <a asp-action="Index" class="zen-btn zen-btn-neutral">
                العودة<i data-lucide="arrow-left"></i>
            </a>
        </div>
    </div>

    <!-- Details Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Name -->
            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                <label class="block text-xs font-bold text-gray-500 mb-1">اسم العملية</label>
                <p class="font-bold text-primary text-lg">@Model.TransactionName</p>
            </div>

            <!-- Type -->
            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                <label class="block text-xs font-bold text-gray-500 mb-1">نوع العملية</label>
                <div class="mt-1">
                    <span class="px-3 py-1 rounded-full font-bold text-sm @(Model.TransactionType == TransactionType.Income ? "bg-emerald-100 text-emerald-800 border border-emerald-200" : "bg-red-100 text-red-800 border border-red-200")">
                        @Model.TransactionType.GetDisplayName()
                    </span>
                </div>
            </div>

            <!-- Amount -->
            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                <label class="block text-xs font-bold text-gray-500 mb-1">المبلغ</label>
                <p class="font-bold text-xl @(Model.TransactionType == TransactionType.Income ? "text-accentGreen" : "text-accentRed")">@Model.Amount.ToString("C")</p>
            </div>

            <!-- Date -->
            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                <label class="block text-xs font-bold text-gray-500 mb-1">التاريخ</label>
                <p class="font-bold text-primary text-lg">
                    <i data-lucide="calendar" class="text-gray-500 ml-2"></i>
                    @Model.TransactionDate.ToString("yyyy-MM-dd")
                </p>
            </div>
            
            <!-- Time -->
            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                <label class="block text-xs font-bold text-gray-500 mb-1">الوقت</label>
                <p class="font-bold text-primary text-lg">
                    <i data-lucide="clock" class="text-gray-500 ml-2"></i>
                    @Model.TransactionDate.ToString("HH:mm:ss")
                </p>
            </div>

            <!-- Category -->
            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                <label class="block text-xs font-bold text-gray-500 mb-1">الفئة</label>
                <p class="font-bold text-primary">
                    <i data-lucide="tag" class="text-gray-500 ml-2"></i>
                    @(Model.Category ?? "غير محدد")
                </p>
            </div>

            <!-- Payment Method -->
            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                <label class="block text-xs font-bold text-gray-500 mb-1">طريقة الدفع</label>
                <p class="font-bold text-primary">
                    <i data-lucide="credit-card" class="ml-2 text-primary"></i>
                    @Model.PaymentMethod?.Name
                </p>
            </div>

            <!-- Description -->
            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200 md:col-span-2">
                <label class="block text-xs font-bold text-gray-500 mb-1">الوصف</label>
                <p class="font-bold text-primary leading-relaxed">@(Model.Description ?? "-")</p>
            </div>
        </div>
    </div>
</div>

