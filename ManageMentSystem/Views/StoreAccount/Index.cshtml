@model IEnumerable<ManageMentSystem.Models.StoreAccount>
@using ManageMentSystem.ViewModels
@using ManageMentSystem.Helpers

@{
    ViewData["Title"] = "الحسابات";
}

<div class="min-h-screen bg-gray-50/50 p-6">
    <!-- Hidden Delete Form -->
    <form id="deleteForm" method="post" action="">
        @Html.AntiForgeryToken()
    </form>

    <!-- Page Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-calculator text-indigo-800"></i> الحسابات
            </h1>
        </div>
        <div class="flex flex-wrap gap-2 items-center justify-end">
                    <button type="button" onclick="openDepositModal()" class="bg-emerald-700 hover:bg-emerald-800 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:shadow-emerald-500/30 hover:-translate-y-0.5 flex items-center gap-2">
                        <i class="fas fa-plus-circle"></i> إيداع رصيد
                    </button>
                    <button type="button" onclick="openWithdrawModal()" class="bg-red-700 hover:bg-red-800 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:shadow-red-500/30 hover:-translate-y-0.5 flex items-center gap-2">
                        <i class="fas fa-minus-circle"></i> سحب رصيد
                    </button>
                <a asp-controller="StoreAccount" asp-action="PaymentMethodBalances" class="bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 hover:text-indigo-800 px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:-translate-y-0.5 flex items-center gap-2">
                    <i class="fas fa-wallet"></i> أرصدة طرق الدفع
                </a>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Income -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-700 text-xl shadow-sm">
                <i class="fas fa-arrow-up"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-500 mb-1">إجمالي الإيرادات</p>
                <h3 class="text-2xl font-bold text-emerald-700">@ViewBag.TotalIncome?.ToString("C")</h3>
            </div>
        </div>

        <!-- Expenses -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-700 text-xl shadow-sm">
                <i class="fas fa-arrow-down"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-500 mb-1">إجمالي المصروفات</p>
                <h3 class="text-2xl font-bold text-red-700">@ViewBag.TotalExpenses?.ToString("C")</h3>
            </div>
        </div>

        <!-- Balance -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-indigo-50 flex items-center justify-center text-indigo-800 text-xl shadow-sm">
                <i class="fas fa-chart-line"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-500 mb-1">مجموع الارصدة</p>
                <h3 class="text-2xl font-bold text-indigo-800">@(ViewBag.CashBalance.ToString("C"))</h3>
            </div>
        </div>

        <!-- Capital -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-amber-50 flex items-center justify-center text-amber-700 text-xl shadow-sm">
                <i class="fas fa-coins"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-500 mb-1">رأس المال</p>
                <h3 class="text-2xl font-bold text-amber-700">@ViewBag.TotalCapital?.ToString("C")</h3>
            </div>
        </div>

        <!-- Debts Alert Card -->
        @if ((decimal)(ViewBag.GDPayables ?? 0m) > 0)
        {
            <div class="bg-white rounded-xl shadow-sm border-r-4 border-red-500 p-6 flex items-center gap-4 hover:shadow-md transition-shadow lg:col-span-4">
                <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-700 text-xl shadow-sm animate-pulse">
                    <i class="fas fa-triangle-exclamation"></i>
                </div>
                <div>
                    <h6 class="font-bold text-red-700 mb-1">دين علينا الآن</h6>
                    <div class="text-3xl font-bold text-red-700 mb-1">@((ViewBag.GDPayables as decimal?)?.ToString("C"))</div>
                    <div class="text-xs font-bold text-slate-500">تم خصم المتاح من الكاش، والباقي دين</div>
                </div>
            </div>
        }
    </div>

    <!-- Sales & Installments Summary -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 border-r-4 border-r-emerald-500 relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-24 h-24 bg-emerald-50 rounded-full -translate-x-8 -translate-y-8 opacity-50 group-hover:scale-110 transition-transform"></div>
            <div class="flex items-center gap-4 mb-4 relative z-10">
                <i class="fas fa-shopping-cart text-4xl text-emerald-500"></i>
                <div>
                    <h4 class="text-xl font-bold text-emerald-800">المبيعات</h4>
                    <p class="text-sm font-bold text-slate-500">الربح من المبيعات</p>
                </div>
            </div>
            <a asp-action="RealizedProfit" class="inline-flex items-center gap-2 text-emerald-700 font-bold hover:text-emerald-800 hover:translate-x-1 transition-all">
                عرض ربح المبيعات <i class="fas fa-arrow-left"></i>
            </a>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-24 h-24 bg-indigo-50 rounded-full -translate-x-8 -translate-y-8 opacity-50 group-hover:scale-110 transition-transform"></div>
            <div class="flex items-center gap-4 mb-4 relative z-10">
                <i class="fas fa-credit-card text-4xl text-indigo-800"></i>
                <div>
                    <h3 class="text-xl font-bold text-indigo-900">الأقساط</h3>
                    <p class="text-sm font-bold text-slate-500">تفاصيل الأقساط والدفعات</p>
                </div>
            </div>
            <a asp-action="InstallmentDetails" class="inline-flex items-center gap-2 text-indigo-800 font-bold hover:text-indigo-900 hover:translate-x-1 transition-all">
                عرض ربح الاقساط <i class="fas fa-arrow-left"></i>
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 mb-8">
        <div class="flex items-center gap-2 mb-4 border-b border-slate-100 pb-3">
            <i class="fas fa-filter text-indigo-800"></i>
            <h6 class="font-bold text-slate-700">فلترة العمليات</h6>
        </div>

        <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
            <div>
                <label class="block text-sm font-bold text-slate-600 mb-2">نوع العملية</label>
                <select name="TransactionType" class="w-full px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none text-sm font-bold transition-all bg-white text-slate-700">
                    <option value="">الكل</option>
                    @foreach (var item in ViewBag.TransactionTypes)
                    {
                        <option value="@item.Value" selected="@(ViewBag.Filter?.TransactionType?.ToString() == item.Value)">@item.Text</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-bold text-slate-600 mb-2">طريقة الدفع</label>
                <select name="PaymentMethodId" class="w-full px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none text-sm font-bold transition-all bg-white text-slate-700">
                    <option value="">الكل</option>
                    @foreach (var item in ViewBag.PaymentMethods)
                    {
                        <option value="@item.Value" selected="@(ViewBag.Filter?.PaymentMethodId?.ToString() == item.Value)">@item.Text</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-bold text-slate-600 mb-2">من تاريخ</label>
                <input type="date" name="FromDate" value="@ViewBag.Filter?.FromDate?.ToString("yyyy-MM-dd")" class="w-full px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none text-sm font-bold transition-all text-slate-700" />
            </div>
            <div>
                <label class="block text-sm font-bold text-slate-600 mb-2">إلى تاريخ</label>
                <div class="flex gap-2">
                    <input type="date" name="ToDate" value="@ViewBag.Filter?.ToDate?.ToString("yyyy-MM-dd")" class="w-full px-4 py-2.5 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none text-sm font-bold transition-all text-slate-700" />
                    <button type="submit" class="bg-indigo-800 hover:bg-indigo-900 text-white p-2.5 rounded-lg transition-colors shadow-sm">
                        <i class="fas fa-search"></i>
                    </button>
                    <a asp-action="Index" class="bg-white border border-slate-200 text-slate-500 hover:bg-red-50 hover:text-red-600 hover:border-red-200 p-2.5 rounded-lg transition-all shadow-sm">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </div>
            <input type="hidden" name="page" value="1" />
        </form>
    </div>

    <!-- Transactions Table -->
    <div class="bg-white rounded-xl shadow-md border border-slate-100 overflow-hidden">
        <div class="bg-slate-50/50 px-6 py-4 border-b border-slate-200 flex justify-between items-center">
            <h6 class="font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-list text-indigo-800"></i> العمليات المالية
            </h6>
                <a asp-action="Export" class="text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-200 hover:bg-emerald-100 px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1">
                    <i class="fas fa-download"></i> تصدير
                </a>
        </div>

        @if (Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-right">
                    <thead class="bg-slate-50 border-b border-slate-200 text-slate-700 text-sm uppercase font-bold text-center">
                        <tr>
                            <th class="px-6 py-4">التاريخ</th>
                            <th class="px-6 py-4">اسم العملية</th>
                            <th class="px-6 py-4">النوع</th>
                            <th class="px-6 py-4">المبلغ</th>
                            <th class="px-6 py-4">الفئة</th>
                            <th class="px-6 py-4">طريقة الدفع</th>
                            <th class="px-6 py-4 text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-slate-700 text-sm text-center">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50/80 transition-colors group">
                                <td class="px-6 py-4 font-bold">@item.TransactionDate.ToString("yyyy-MM-dd")</td>
                                <td class="px-6 py-4 font-bold text-slate-800">@item.TransactionName</td>
                                <td class="px-6 py-4">
                                    <span class="px-2.5 py-1 rounded-full font-bold text-xs @(item.TransactionType == TransactionType.Income ? "bg-emerald-100 text-emerald-800 border border-emerald-200" : "bg-red-100 text-red-800 border border-red-200")">
                                        @item.TransactionType.GetDisplayName()
                                    </span>
                                </td>
                                <td class="px-6 py-4 font-bold @(item.TransactionType == TransactionType.Income ? "text-emerald-700" : "text-red-700")">
                                    @item.Amount.ToString("C")
                                </td>
                                <td class="px-6 py-4">
                                    <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs font-bold border border-gray-200">@item.Category</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="bg-indigo-50 text-indigo-800 px-2 py-1 rounded text-xs font-bold border border-indigo-100">@item.PaymentMethod?.Name</span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-2 opacity-100 sm:opacity-60 sm:group-hover:opacity-100 transition-all">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="w-8 h-8 flex items-center justify-center rounded-lg text-indigo-800 hover:bg-indigo-100 transition-colors" title="تفاصيل">
                                            <i class="fas fa-eye text-xs"></i>
                                        </a>
                                       
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="w-8 h-8 flex items-center justify-center rounded-lg text-amber-700 hover:bg-amber-100 transition-colors" title="تعديل">
                                                <i class="fas fa-edit text-xs"></i>
                                            </a>
                                       
                                            <button type="button" onclick="confirmDeleteTransaction(@item.Id)" class="w-8 h-8 flex items-center justify-center rounded-lg text-red-700 hover:bg-red-100 transition-colors" title="حذف">
                                                <i class="fas fa-trash text-xs"></i>
                                            </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (ViewBag.TotalPages > 1)
            {
                <div class="bg-slate-50 border-t border-slate-200 px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <div class="text-sm font-bold text-slate-500">
                        عرض @(((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1) إلى @Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems) من @ViewBag.TotalItems نتيجة
                    </div>

                    <div class="flex gap-1.5" dir="ltr">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize, TransactionType = ViewBag.Filter?.TransactionType, PaymentMethodId = ViewBag.Filter?.PaymentMethodId, FromDate = ViewBag.Filter?.FromDate?.ToString("yyyy-MM-dd"), ToDate = ViewBag.Filter?.ToDate?.ToString("yyyy-MM-dd") })"
                               class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-500 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 transition-all">
                                <i class="fas fa-chevron-left text-xs"></i>
                            </a>
                        }

                        @{
                            var startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                            var endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                        }

                        @if (startPage > 1)
                        {
                            <a href="@Url.Action("Index", new { page = 1, pageSize = ViewBag.PageSize })" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-500 hover:bg-indigo-50 hover:text-indigo-700 transition-all text-xs font-bold">1</a>
                            @if (startPage > 2)
                            {
                                <span class="w-8 h-8 flex items-center justify-center text-slate-400">...</span>
                            }
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-indigo-800 text-white border border-indigo-800 text-xs font-bold shadow-sm shadow-indigo-200">@i</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Index", new { page = i, pageSize = ViewBag.PageSize, TransactionType = ViewBag.Filter?.TransactionType, PaymentMethodId = ViewBag.Filter?.PaymentMethodId, FromDate = ViewBag.Filter?.FromDate?.ToString("yyyy-MM-dd"), ToDate = ViewBag.Filter?.ToDate?.ToString("yyyy-MM-dd") })"
                                   class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-500 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 transition-all text-xs font-bold">@i</a>
                            }
                        }

                        @if (endPage < ViewBag.TotalPages)
                        {
                            @if (endPage < ViewBag.TotalPages - 1)
                            {
                                <span class="w-8 h-8 flex items-center justify-center text-slate-400">...</span>
                            }
                            <a href="@Url.Action("Index", new { page = ViewBag.TotalPages, pageSize = ViewBag.PageSize })" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-500 hover:bg-indigo-50 hover:text-indigo-700 transition-all text-xs font-bold">@ViewBag.TotalPages</a>
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize, TransactionType = ViewBag.Filter?.TransactionType, PaymentMethodId = ViewBag.Filter?.PaymentMethodId, FromDate = ViewBag.Filter?.FromDate?.ToString("yyyy-MM-dd"), ToDate = ViewBag.Filter?.ToDate?.ToString("yyyy-MM-dd") })"
                               class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-500 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 transition-all">
                                <i class="fas fa-chevron-right text-xs"></i>
                            </a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12">
                <div class="bg-slate-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 border border-slate-100">
                    <i class="fas fa-inbox text-3xl text-slate-300"></i>
                </div>
                <h5 class="text-lg font-bold text-slate-800">لا توجد عمليات مالية</h5>
                <p class="text-slate-500 mt-1">ابدأ بإضافة عملية جديدة</p>
            </div>
        }
    </div>
</div>

<!-- Deposit Modal (Tailwind) -->
<div id="depositModal" class="fixed inset-0 z-[1050] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity opacity-0" id="depositModalBackdrop" onclick="closeDepositModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0">
        <div class="relative transform overflow-hidden rounded-2xl bg-white text-right shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" id="depositModalPanel">
            <div class="bg-emerald-700 px-6 py-4 flex justify-between items-center">
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                    <i class="fas fa-plus-circle"></i> إيداع رصيد جديد
                </h3>
                <button type="button" onclick="closeDepositModal()" class="text-emerald-200 hover:text-white transition-colors">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <form asp-action="Create" method="post" class="p-6">
                <input type="hidden" name="TransactionType" value="Income" />
                <input type="hidden" name="TransactionDate" class="current-date-input" />
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1.5">اسم العملية</label>
                        <input type="text" name="TransactionName" class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none font-bold text-slate-800" required />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1.5">المبلغ</label>
                        <input type="number" name="Amount" class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none font-bold text-slate-800" required min="0.01" step="0.01" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1.5">طريقة الدفع</label>
                        <select name="PaymentMethodId" class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none font-bold text-slate-700 bg-white" required>
                            @foreach (var item in ViewBag.PaymentMethods)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1.5">ملاحظات</label>
                        <textarea name="Notes" rows="2" class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none font-medium text-slate-700"></textarea>
                    </div>
                </div>

                <div class="mt-8 flex gap-3">
                    <button type="submit" class="flex-1 bg-emerald-700 hover:bg-emerald-800 text-white px-4 py-2.5 rounded-xl font-bold hover:-translate-y-0.5 transition-all shadow-sm flex items-center justify-center gap-2">
                        <i class="fas fa-check"></i> إيداع
                    </button>
                    <button type="button" onclick="closeDepositModal()" class="px-6 py-2.5 rounded-xl font-bold text-slate-600 hover:bg-red-50 hover:text-red-700 transition-colors border border-transparent hover:border-red-200">
                        إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="withdrawModal" class="fixed inset-0 z-[1050] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity opacity-0" id="withdrawModalBackdrop" onclick="closeWithdrawModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0">
        <div class="relative transform overflow-hidden rounded-2xl bg-white text-right shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" id="withdrawModalPanel">
            <div class="bg-red-700 px-6 py-4 flex justify-between items-center">
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                    <i class="fas fa-minus-circle"></i> سحب رصيد
                </h3>
                <button type="button" onclick="closeWithdrawModal()" class="text-red-200 hover:text-white transition-colors">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <form asp-action="Create" method="post" class="p-6" onsubmit="return handleWithdrawSubmit(event, this)">
                <input type="hidden" name="TransactionType" value="Expense" />
                <input type="hidden" name="TransactionDate" class="current-date-input" />
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1.5">اسم العملية</label>
                        <input type="text" name="TransactionName" class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none font-bold text-slate-800" required />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1.5">المبلغ</label>
                        <input type="number" name="Amount" class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none font-bold text-slate-800" required min="0.01" step="0.01" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1.5">طريقة الدفع</label>
                        <select name="PaymentMethodId" class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none font-bold text-slate-700 bg-white" required>
                            @foreach (var item in ViewBag.PaymentMethods)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1.5">ملاحظات</label>
                        <textarea name="Notes" rows="2" class="w-full px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none font-medium text-slate-700"></textarea>
                    </div>
                </div>

                <div class="mt-8 flex gap-3">
                    <button type="submit" id="withdrawSubmitBtn" class="flex-1 bg-red-700 hover:bg-red-800 text-white px-4 py-2.5 rounded-xl font-bold hover:-translate-y-0.5 transition-all shadow-sm flex items-center justify-center gap-2">
                        <i class="fas fa-check"></i> سحب
                    </button>
                    <button type="button" onclick="closeWithdrawModal()" class="px-6 py-2.5 rounded-xl font-bold text-slate-600 hover:bg-slate-100 transition-colors border border-transparent hover:border-slate-200">
                        إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sweetalert-accounts.js"></script>
    <script>
        // --- Alerts on Load ---
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                showSuccess('تم بنجاح', '@Html.Raw(TempData["SuccessMessage"])');
            </text>
        }
        @if (TempData["GlobalSuccess"] != null)
        {
             <text>
                showSuccess('تم بنجاح', '@Html.Raw(TempData["GlobalSuccess"])');
            </text>
        }
        @if (TempData["Success"] != null)
        {
             <text>
                showSuccess('تم بنجاح', '@Html.Raw(TempData["Success"])');
            </text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <text>
                showError('خطأ', '@Html.Raw(TempData["ErrorMessage"])');
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
                showError('خطأ', '@Html.Raw(TempData["Error"])');
            </text>
        }

        // --- Delete Logic ---
        function confirmDeleteTransaction(id) {
            showDeleteTransactionConfirmation(id).then((result) => {
                if (result.isConfirmed) {
                    const form = document.getElementById('deleteForm');
                    form.action = '/StoreAccount/Delete/' + id;
                    form.submit();
                }
            });
        }

        // --- Modal Logic ---
        function openModal(modalId, backdropId, panelId) {
            const modal = document.getElementById(modalId);
            const backdrop = document.getElementById(backdropId);
            const panel = document.getElementById(panelId);
            
            // Set current date
            const dateInputs = modal.querySelectorAll('.current-date-input');
            dateInputs.forEach(input => input.value = new Date().toISOString().split('T')[0]);

            modal.classList.remove('hidden');
            setTimeout(() => {
                backdrop.classList.remove('opacity-0');
                panel.classList.remove('opacity-0', 'translate-y-4', 'sm:translate-y-0', 'sm:scale-95');
            }, 10);
        }

        function closeModal(modalId, backdropId, panelId) {
            const modal = document.getElementById(modalId);
            const backdrop = document.getElementById(backdropId);
            const panel = document.getElementById(panelId);

            backdrop.classList.add('opacity-0');
            panel.classList.add('opacity-0', 'translate-y-4', 'sm:translate-y-0', 'sm:scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }

        function openDepositModal() { openModal('depositModal', 'depositModalBackdrop', 'depositModalPanel'); }
        function closeDepositModal() { closeModal('depositModal', 'depositModalBackdrop', 'depositModalPanel'); }

        function openWithdrawModal() { openModal('withdrawModal', 'withdrawModalBackdrop', 'withdrawModalPanel'); }
        function closeWithdrawModal() { closeModal('withdrawModal', 'withdrawModalBackdrop', 'withdrawModalPanel'); }

        // --- Withdraw Validation ---
        async function handleWithdrawSubmit(e, form) {
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التحقق...';

            const amount = parseFloat(form.querySelector('input[name="Amount"]').value);
            const paymentMethodId = form.querySelector('select[name="PaymentMethodId"]').value;

            try {
                const response = await fetch(`/StoreAccount/GetBalanceByMethod?paymentMethodId=${paymentMethodId}`);
                const data = await response.json();

                if (data.success && data.balance >= amount) {
                    form.submit();
                } else {
                    showInsufficientFundsError(data.balance, amount);
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            } catch (error) {
                console.error(error);
                showError('خطأ', 'حدث خطأ أثناء التحقق من الرصيد');
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }
        
        // --- Reset Page on Filter ---
        document.querySelector('form').addEventListener('submit', function() {
            const pageInput = this.querySelector('input[name="page"]');
            if (pageInput) pageInput.value = '1';
        });
    </script>
}