@model IEnumerable<ManageMentSystem.Models.StoreAccount>
@using ManageMentSystem.ViewModels
@using ManageMentSystem.Helpers

@{
    ViewData["Title"] = "الحسابات";
}

<div class="min-h-screen bg-bgSubtle p-6">
    <!-- Hidden Delete Form -->
    <form id="deleteForm" method="post" action="">
        @Html.AntiForgeryToken()
    </form>

    <!-- Page Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="calculator" class="text-primary"></i> الحسابات
            </h1>
        </div>
        <div class="flex flex-wrap gap-2 items-center justify-end">
                    <button type="button" onclick="openDepositModal()" class="zen-btn zen-btn-success zen-btn-sm">
                        <i data-lucide="plus-circle"></i> إيداع رصيد
                    </button>
                    <button type="button" onclick="openWithdrawModal()" class="zen-btn zen-btn-danger zen-btn-sm">
                        <i data-lucide="minus-circle"></i> سحب رصيد
                    </button>
                <a asp-controller="StoreAccount" asp-action="PaymentMethodBalances" class="zen-btn zen-btn-neutral zen-btn-sm">
                    <i data-lucide="wallet"></i> أرصدة طرق الدفع
                </a>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Income -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center text-accentGreen text-xl shadow-sm">
                <i data-lucide="arrow-up"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-gray-500 mb-1">إجمالي الإيرادات</p>
                <h3 class="text-2xl font-bold text-accentGreen">@ViewBag.TotalIncome?.ToString("C")</h3>
            </div>
        </div>

        <!-- Expenses -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-accentRed text-xl shadow-sm">
                <i data-lucide="arrow-down"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-gray-500 mb-1">إجمالي المصروفات</p>
                <h3 class="text-2xl font-bold text-accentRed">@ViewBag.TotalExpenses?.ToString("C")</h3>
            </div>
        </div>

        <!-- Balance -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-gray-50 flex items-center justify-center text-primary text-xl shadow-sm">
                <i data-lucide="trending-up"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-gray-500 mb-1">مجموع الارصدة</p>
                <h3 class="text-2xl font-bold text-primary">@(ViewBag.CashBalance.ToString("C"))</h3>
            </div>
        </div>

        <!-- Capital -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-amber-50 flex items-center justify-center text-accentAmber text-xl shadow-sm">
                <i data-lucide="coins"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-gray-500 mb-1">رأس المال</p>
                <h3 class="text-2xl font-bold text-accentAmber">@ViewBag.TotalCapital?.ToString("C")</h3>
            </div>
        </div>

        <!-- Debts Alert Card -->
        @if ((decimal)(ViewBag.GDPayables ?? 0m) > 0)
        {
            <div class="bg-white rounded-xl shadow-sm border-r-4 border-red-500 p-6 flex items-center gap-4 hover:shadow-md transition-shadow lg:col-span-4">
                <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-accentRed text-xl shadow-sm animate-pulse">
                    <i data-lucide="alert-triangle"></i>
                </div>
                <div>
                    <h6 class="font-bold text-accentRed mb-1">دين علينا الآن</h6>
                    <div class="text-3xl font-bold text-accentRed mb-1">@((ViewBag.GDPayables as decimal?)?.ToString("C"))</div>
                    <div class="text-xs font-bold text-gray-500">تم خصم المتاح من الكاش، والباقي دين</div>
                </div>
            </div>
        }
    </div>

    <!-- Sales & Installments Summary -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 border-r-4 border-r-emerald-500 relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-24 h-24 bg-emerald-50 rounded-full -translate-x-8 -translate-y-8 opacity-50 group-hover:scale-110 transition-transform"></div>
            <div class="flex items-center gap-4 mb-4 relative z-10">
                <i data-lucide="shopping-cart" class="text-4xl text-accentGreen w-10 h-10"></i>
                <div>
                    <h4 class="text-xl font-bold text-accentGreen">المبيعات</h4>
                    <p class="text-sm font-bold text-gray-500">الربح من المبيعات</p>
                </div>
            </div>
            <a asp-action="RealizedProfit" class="inline-flex items-center gap-2 text-accentGreen font-bold hover:text-accentGreen hover:translate-x-1 transition-all">
                عرض ربح المبيعات <i data-lucide="arrow-left" class="w-4 h-4 inline-block"></i>
            </a>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-24 h-24 bg-gray-50 rounded-full -translate-x-8 -translate-y-8 opacity-50 group-hover:scale-110 transition-transform"></div>
            <div class="flex items-center gap-4 mb-4 relative z-10">
                <i data-lucide="credit-card" class="text-4xl text-primary w-10 h-10"></i>
                <div>
                    <h3 class="text-xl font-bold text-primary">الأقساط</h3>
                    <p class="text-sm font-bold text-gray-500">تفاصيل الأقساط والدفعات</p>
                </div>
            </div>
            <a asp-action="InstallmentDetails" class="inline-flex items-center gap-2 text-primary font-bold hover:text-primary hover:translate-x-1 transition-all">
                عرض ربح الاقساط <i data-lucide="arrow-left" class="w-4 h-4 inline-block"></i>
            </a>
        </div>
    </div>

    <div class="mb-8 print:hidden">
        <form method="get" class="space-y-4">
            <div class="flex flex-col lg:flex-row items-end gap-4">
                <div class="flex-grow">
                    <partial name="_PremiumDateFilter" model="ViewBag.Filter" />
                </div>
                <div class="w-full lg:w-48">
                    <label class="block text-sm font-bold text-gray-500 mb-2">نوع العملية</label>
                    <select name="TransactionType" onchange="this.form.submit()" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary outline-none text-sm font-bold transition-all bg-white text-gray-600 h-[42px]">
                        <option value="">الكل</option>
                        @foreach (var item in ViewBag.TransactionTypes)
                        {
                            <option value="@item.Value" selected="@(ViewBag.Filter?.TransactionType?.ToString() == item.Value)">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="w-full lg:w-48">
                    <label class="block text-sm font-bold text-gray-500 mb-2">طريقة الدفع</label>
                    <select name="PaymentMethodId" onchange="this.form.submit()" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary outline-none text-sm font-bold transition-all bg-white text-gray-600 h-[42px]">
                        <option value="">الكل</option>
                        @foreach (var item in ViewBag.PaymentMethods)
                        {
                            <option value="@item.Value" selected="@(ViewBag.Filter?.PaymentMethodId?.ToString() == item.Value)">@item.Text</option>
                        }
                    </select>
                </div>
                <div>
                    <a asp-action="Index" class="zen-btn zen-btn-neutral h-[42px] flex items-center justify-center" title="إعادة تعيين">
                        <i data-lucide="rotate-ccw"></i>
                    </a>
                </div>
            </div>
            <input type="hidden" name="page" value="1" />
        </form>
    </div>

    <!-- Transactions Table -->
    <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
        <div class="bg-bgSubtle px-6 py-4 border-b border-gray-200 flex justify-between items-center">
            <h6 class="font-bold text-primary flex items-center gap-2">
                <i data-lucide="list" class="text-primary"></i> العمليات المالية
            </h6>
                <a asp-action="Export" class="zen-btn zen-btn-success zen-btn-sm">
                    <i data-lucide="download"></i> تصدير
                </a>
        </div>

        @if (Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-right">
                    <thead class="bg-gray-50 border-b border-gray-200 text-gray-600 text-sm uppercase font-bold text-center">
                        <tr>
                            <th class="px-6 py-4">التاريخ</th>
                            <th class="px-6 py-4">اسم العملية</th>
                            <th class="px-6 py-4">النوع</th>
                            <th class="px-6 py-4">المبلغ</th>
                            <th class="px-6 py-4">الفئة</th>
                            <th class="px-6 py-4">طريقة الدفع</th>
                            <th class="px-6 py-4 text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 text-gray-600 text-sm text-center">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50/80 transition-colors group">
                                <td class="px-6 py-4 font-bold">@item.TransactionDate.ToString("yyyy-MM-dd")</td>
                                <td class="px-6 py-4 font-bold text-primary">@item.TransactionName</td>
                                <td class="px-6 py-4">
                                    <span class="px-2.5 py-1 rounded-full font-bold text-xs @(item.TransactionType == TransactionType.Income ? "bg-emerald-100 text-emerald-800 border border-emerald-200" : "bg-red-100 text-red-800 border border-red-200")">
                                        @item.TransactionType.GetDisplayName()
                                    </span>
                                </td>
                                <td class="px-6 py-4 font-bold @(item.TransactionType == TransactionType.Income ? "text-accentGreen" : "text-accentRed")">
                                    @item.Amount.ToString("C")
                                </td>
                                <td class="px-6 py-4">
                                    <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs font-bold border border-gray-200">@item.Category</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="bg-gray-50 text-primary px-2 py-1 rounded text-xs font-bold border border-gray-200">@item.PaymentMethod?.Name</span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-2 opacity-100 sm:opacity-60 sm:group-hover:opacity-100 transition-all">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="zen-action-btn zen-action-btn-neutral" title="تفاصيل">
                                            <i data-lucide="eye" class="w-4 h-4"></i>
                                        </a>
                                       
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="zen-action-btn zen-action-btn-neutral" title="تعديل">
                                                <i data-lucide="edit" class="w-4 h-4"></i>
                                            </a>
                                       
                                            <button type="button" onclick="confirmDeleteTransaction(@item.Id)" class="zen-action-btn zen-action-btn-danger" title="حذف">
                                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                                            </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (ViewBag.TotalPages > 1)
            {
                <div class="bg-gray-50 border-t border-gray-200 px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <div class="text-sm font-bold text-gray-500">
                        عرض @(((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1) إلى @Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems) من @ViewBag.TotalItems نتيجة
                    </div>

                    <div class="flex gap-1.5" dir="ltr">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize, TransactionType = ViewBag.Filter?.TransactionType, PaymentMethodId = ViewBag.Filter?.PaymentMethodId, FromDate = ViewBag.Filter?.FromDate?.ToString("yyyy-MM-dd"), ToDate = ViewBag.Filter?.ToDate?.ToString("yyyy-MM-dd") })"
                               class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-primary hover:border-gray-200 transition-all">
                                <i data-lucide="chevron-left" class="w-4 h-4"></i>
                            </a>
                        }

                        @{
                            var startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                            var endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
                        }

                        @if (startPage > 1)
                        {
                            <a href="@Url.Action("Index", new { page = 1, pageSize = ViewBag.PageSize })" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-primary transition-all text-xs font-bold">1</a>
                            @if (startPage > 2)
                            {
                                <span class="w-8 h-8 flex items-center justify-center text-gray-500">...</span>
                            }
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-primary text-white border border-gray-200 text-xs font-bold shadow-sm ">@i</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Index", new { page = i, pageSize = ViewBag.PageSize, TransactionType = ViewBag.Filter?.TransactionType, PaymentMethodId = ViewBag.Filter?.PaymentMethodId, FromDate = ViewBag.Filter?.FromDate?.ToString("yyyy-MM-dd"), ToDate = ViewBag.Filter?.ToDate?.ToString("yyyy-MM-dd") })"
                                   class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-primary hover:border-gray-200 transition-all text-xs font-bold">@i</a>
                            }
                        }

                        @if (endPage < ViewBag.TotalPages)
                        {
                            @if (endPage < ViewBag.TotalPages - 1)
                            {
                                <span class="w-8 h-8 flex items-center justify-center text-gray-500">...</span>
                            }
                            <a href="@Url.Action("Index", new { page = ViewBag.TotalPages, pageSize = ViewBag.PageSize })" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-primary transition-all text-xs font-bold">@ViewBag.TotalPages</a>
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize, TransactionType = ViewBag.Filter?.TransactionType, PaymentMethodId = ViewBag.Filter?.PaymentMethodId, FromDate = ViewBag.Filter?.FromDate?.ToString("yyyy-MM-dd"), ToDate = ViewBag.Filter?.ToDate?.ToString("yyyy-MM-dd") })"
                               class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-primary hover:border-gray-200 transition-all">
                                <i data-lucide="chevron-right" class="w-4 h-4"></i>
                            </a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12">
                <div class="bg-gray-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 border border-gray-200">
                    <i data-lucide="inbox" class="text-3xl text-gray-500 w-10 h-10"></i>
                </div>
                <h5 class="text-lg font-bold text-primary">لا توجد عمليات مالية</h5>
                <p class="text-gray-500 mt-1">ابدأ بإضافة عملية جديدة</p>
            </div>
        }
    </div>
</div>

<!-- Deposit Modal (Black & White) -->
<div id="depositModal" class="fixed inset-0 z-[1050] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity duration-300 opacity-0" id="depositModalBackdrop" onclick="closeDepositModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0 relative z-10 pointer-events-none">
        <div class="relative transform overflow-hidden rounded-2xl bg-white text-right shadow-2xl transition-all duration-300 opacity-0 translate-y-8 scale-95 sm:w-full sm:max-w-md pointer-events-auto" id="depositModalPanel">
            <div class="bg-white px-6 py-5 border-b border-gray-100 flex justify-between items-center">
                <h3 class="text-lg font-black text-gray-900 flex items-center gap-2">
                    <i data-lucide="arrow-down-to-line" class="text-gray-900"></i> إيداع رصيد
                </h3>
                <button type="button" onclick="closeDepositModal()" class="text-gray-400 hover:text-red-500 transition-colors">
                    <i data-lucide="x" class="text-xl w-5 h-5"></i>
                </button>
            </div>
            <form asp-action="Create" method="post" class="p-6">
                <input type="hidden" name="TransactionType" value="Income" />
                <input type="hidden" name="TransactionDate" class="current-date-input" />
                
                <div class="space-y-5">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">اسم العملية</label>
                        <input type="text" name="TransactionName" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900/10 focus:border-gray-900 outline-none font-bold text-gray-900 transition-all bg-gray-50/50 focus:bg-white" required placeholder="مثال: إيداع نقدي" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">المبلغ</label>
                        <input type="number" name="Amount" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900/10 focus:border-gray-900 outline-none font-black text-gray-900 transition-all bg-gray-50/50 focus:bg-white" required min="0.01" step="0.01" placeholder="0.00" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">طريقة الدفع</label>
                        <select name="PaymentMethodId" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900/10 focus:border-gray-900 outline-none font-bold text-gray-900 transition-all bg-gray-50/50 focus:bg-white cursor-pointer" required>
                            @foreach (var item in ViewBag.PaymentMethods)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">ملاحظات (اختياري)</label>
                        <textarea name="Notes" rows="2" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900/10 focus:border-gray-900 outline-none font-medium text-gray-900 transition-all bg-gray-50/50 focus:bg-white" placeholder="أضف أي تفاصيل أخرى..."></textarea>
                    </div>
                </div>

                <div class="mt-8 flex gap-3">
                    <button type="submit" class="flex-1 bg-gray-900 hover:bg-black text-white font-bold py-3 px-4 rounded-xl transition-all shadow-md shadow-gray-900/20 flex items-center justify-center gap-2">
                        <i data-lucide="check" class="w-5 h-5"></i> تأكيد الإيداع
                    </button>
                    <button type="button" onclick="closeDepositModal()" class="px-6 py-3 bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 font-bold rounded-xl transition-colors">
                        إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Withdraw Modal (Black & White) -->
<div id="withdrawModal" class="fixed inset-0 z-[1050] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity duration-300 opacity-0" id="withdrawModalBackdrop" onclick="closeWithdrawModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0 relative z-10 pointer-events-none">
        <div class="relative transform overflow-hidden rounded-2xl bg-white text-right shadow-2xl transition-all duration-300 opacity-0 translate-y-8 scale-95 sm:w-full sm:max-w-md pointer-events-auto" id="withdrawModalPanel">
            <div class="bg-white px-6 py-5 border-b border-gray-100 flex justify-between items-center">
                <h3 class="text-lg font-black text-gray-900 flex items-center gap-2">
                    <i data-lucide="arrow-up-from-line" class="text-gray-900"></i> سحب رصيد
                </h3>
                <button type="button" onclick="closeWithdrawModal()" class="text-gray-400 hover:text-red-500 transition-colors">
                    <i data-lucide="x" class="text-xl w-5 h-5"></i>
                </button>
            </div>
            <form asp-action="Create" method="post" class="p-6" onsubmit="return handleWithdrawSubmit(event, this)">
                <input type="hidden" name="TransactionType" value="Expense" />
                <input type="hidden" name="TransactionDate" class="current-date-input" />
                
                <div class="space-y-5">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">اسم العملية</label>
                        <input type="text" name="TransactionName" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900/10 focus:border-gray-900 outline-none font-bold text-gray-900 transition-all bg-gray-50/50 focus:bg-white" required placeholder="مثال: سحب أرباح" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">المبلغ</label>
                        <input type="number" name="Amount" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900/10 focus:border-gray-900 outline-none font-black text-gray-900 transition-all bg-gray-50/50 focus:bg-white" required min="0.01" step="0.01" placeholder="0.00" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">طريقة الدفع</label>
                        <select name="PaymentMethodId" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900/10 focus:border-gray-900 outline-none font-bold text-gray-900 transition-all bg-gray-50/50 focus:bg-white cursor-pointer" required>
                            @foreach (var item in ViewBag.PaymentMethods)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">ملاحظات (اختياري)</label>
                        <textarea name="Notes" rows="2" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900/10 focus:border-gray-900 outline-none font-medium text-gray-900 transition-all bg-gray-50/50 focus:bg-white" placeholder="أضف أي تفاصيل أخرى..."></textarea>
                    </div>
                </div>

                <div class="mt-8 flex gap-3">
                    <button type="submit" id="withdrawSubmitBtn" class="flex-1 bg-white hover:bg-gray-50 text-gray-900 font-bold border-2 border-gray-900 py-3 px-4 rounded-xl transition-all shadow-sm flex items-center justify-center gap-2">
                        <i data-lucide="check" class="w-5 h-5"></i> تأكيد السحب
                    </button>
                    <button type="button" onclick="closeWithdrawModal()" class="px-6 py-3 bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 font-bold rounded-xl transition-colors">
                        إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sweetalert-accounts.js"></script>
    <script>
        // --- Alerts on Load ---
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                showSuccess('تم بنجاح', '@Html.Raw(TempData["SuccessMessage"])');
            </text>
        }
        @if (TempData["GlobalSuccess"] != null)
        {
             <text>
                showSuccess('تم بنجاح', '@Html.Raw(TempData["GlobalSuccess"])');
            </text>
        }
        @if (TempData["Success"] != null)
        {
             <text>
                showSuccess('تم بنجاح', '@Html.Raw(TempData["Success"])');
            </text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <text>
                showError('خطأ', '@Html.Raw(TempData["ErrorMessage"])');
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
                showError('خطأ', '@Html.Raw(TempData["Error"])');
            </text>
        }

        // --- Delete Logic ---
        function confirmDeleteTransaction(id) {
            showDeleteTransactionConfirmation(id).then((result) => {
                if (result.isConfirmed) {
                    const form = document.getElementById('deleteForm');
                    form.action = '/StoreAccount/Delete/' + id;
                    form.submit();
                }
            });
        }

        function openModal(modalId, backdropId, panelId) {
            const modal = document.getElementById(modalId);
            const backdrop = document.getElementById(backdropId);
            const panel = document.getElementById(panelId);
            
            // Set current date
            const dateInputs = modal.querySelectorAll('.current-date-input');
            dateInputs.forEach(input => input.value = new Date().toISOString().split('T')[0]);

            modal.classList.remove('hidden');
            
            // Force reflow for animation
            void modal.offsetWidth;

            backdrop.classList.remove('opacity-0');
            panel.classList.remove('opacity-0', 'translate-y-8', 'scale-95');
        }

        function closeModal(modalId, backdropId, panelId) {
            const modal = document.getElementById(modalId);
            const backdrop = document.getElementById(backdropId);
            const panel = document.getElementById(panelId);

            backdrop.classList.add('opacity-0');
            panel.classList.add('opacity-0', 'translate-y-8', 'scale-95');
            
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }

        function openDepositModal() { openModal('depositModal', 'depositModalBackdrop', 'depositModalPanel'); }
        function closeDepositModal() { closeModal('depositModal', 'depositModalBackdrop', 'depositModalPanel'); }

        function openWithdrawModal() { openModal('withdrawModal', 'withdrawModalBackdrop', 'withdrawModalPanel'); }
        function closeWithdrawModal() { closeModal('withdrawModal', 'withdrawModalBackdrop', 'withdrawModalPanel'); }

        // --- Withdraw Validation ---
        async function handleWithdrawSubmit(e, form) {
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<i data-lucide="loader-2" class="animate-spin inline-block"></i> جاري التحقق...';
            lucide.createIcons();

            const amount = parseFloat(form.querySelector('input[name="Amount"]').value);
            const paymentMethodId = form.querySelector('select[name="PaymentMethodId"]').value;

            try {
                const response = await fetch(`/StoreAccount/GetBalanceByMethod?paymentMethodId=${paymentMethodId}`);
                const data = await response.json();

                if (data.success && data.balance >= amount) {
                    form.submit();
                } else {
                    showInsufficientFundsError(data.balance, amount);
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            } catch (error) {
                console.error(error);
                showError('خطأ', 'حدث خطأ أثناء التحقق من الرصيد');
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }
        
        // --- Reset Page on Filter ---
        document.querySelector('form').addEventListener('submit', function() {
            const pageInput = this.querySelector('input[name="page"]');
            if (pageInput) pageInput.value = '1';
        });
    </script>
}



