@model IEnumerable<ManageMentSystem.ViewModels.PaymentMethodBalanceViewModel>

@{
    ViewData["Title"] = "أرصدة طرق الدفع";
    var totalIncome = Model.Sum(x => x.TotalIncome);
    var totalExpenses = Model.Sum(x => x.TotalExpenses);
    var totalNet = totalIncome - totalExpenses;
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-[#0f1419] flex items-center gap-2">
                <i data-lucide="wallet" class="text-[#0f1419]"></i> أرصدة طرق الدفع
            </h1>
            <p class="text-gray-500 mt-1 font-medium">عرض الأرصدة الحالية لكل طريقة دفع</p>
        </div>
        <form method="get" class="flex gap-2">
            <input type="date" name="fromDate" value="@ViewBag.FromDate" class="px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-bgSubtle focus:border-[#0f1419] outline-none font-bold text-gray-600" />
            <input type="date" name="toDate" value="@ViewBag.ToDate" class="px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-bgSubtle focus:border-[#0f1419] outline-none font-bold text-gray-600" />
            <button type="submit" class="bg-[#0f1419] hover:bg-primaryHover text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:shadow-gray-400/20 hover:-translate-y-0.5 flex items-center gap-2">
                <i data-lucide="filter"></i> تطبيق
            </button>
        </form>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <!-- Income -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center text-accentGreen text-xl shadow-sm">
                <i data-lucide="arrow-up"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-gray-500 mb-1">إجمالي الإيرادات</p>
                <h3 class="text-2xl font-bold text-accentGreen">@totalIncome.ToString("C")</h3>
            </div>
        </div>

        <!-- Expenses -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-accentRed text-xl shadow-sm">
                <i data-lucide="arrow-down"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-gray-500 mb-1">إجمالي المصروفات</p>
                <h3 class="text-2xl font-bold text-accentRed">@totalExpenses.ToString("C")</h3>
            </div>
        </div>

        <!-- Net Balance -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-gray-50 flex items-center justify-center text-[#0f1419] text-xl shadow-sm">
                <i data-lucide="scale"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-gray-500 mb-1">الرصيد الصافي</p>
                <h3 class="text-2xl font-bold @(totalNet >= 0 ? "text-[#0f1419]" : "text-accentRed")">@totalNet.ToString("C")</h3>
            </div>
        </div>
    </div>

    <!-- Payment Methods Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var pm in Model.OrderBy(m => m.Name))
        {
            var netPositive = pm.Net >= 0;
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-all group hover:-translate-y-1">
                <div class="flex justify-between items-center mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center text-gray-500 group-hover:bg-gray-50 group-hover:text-[#0f1419] transition-colors">
                            <i data-lucide="credit-card"></i>
                        </div>
                        <h3 class="font-bold text-[#0f1419] text-lg">@pm.Name</h3>
                    </div>
                    <a asp-action="PaymentMethodDetails" asp-route-id="@pm.PaymentMethodId" asp-route-fromDate="@ViewBag.FromDate" asp-route-toDate="@ViewBag.ToDate" 
                       class="w-8 h-8 flex items-center justify-center rounded-lg text-[#0f1419] hover:bg-gray-50 transition-colors" title="عرض التفاصيل">
                        <i data-lucide="eye" class="text-sm"></i>
                    </a>
                </div>
                
                <div class="space-y-3">
                    <div class="flex justify-between items-center text-sm border-b border-gray-200 pb-2">
                        <span class="text-accentGreen font-medium">
                            <i data-lucide="arrow-up" class="text-sm ml-1"></i> إيرادات
                        </span>
                        <span class="font-bold text-accentGreen">@pm.TotalIncome.ToString("C")</span>
                    </div>
                    <div class="flex justify-between items-center text-sm border-b border-gray-200 pb-2">
                        <span class="text-accentRed font-medium">
                            <i data-lucide="arrow-down" class="text-sm ml-1"></i> مصروفات
                        </span>
                        <span class="font-bold text-accentRed">@pm.TotalExpenses.ToString("C")</span>
                    </div>
                    <div class="flex justify-between items-center pt-1">
                        <span class="text-gray-500 font-bold">الرصيد الحالي</span>
                        <span class="font-bold text-xl @(netPositive ? "text-[#0f1419]" : "text-accentRed")">@pm.Net.ToString("C")</span>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-12">
            <div class="bg-gray-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 border border-gray-200">
                <i data-lucide="wallet" class="text-3xl text-gray-500"></i>
            </div>
            <h5 class="text-lg font-bold text-[#0f1419]">لا توجد بيانات</h5>
            <p class="text-gray-500 mt-1">لا توجد حركات مالية في الفترة المحددة</p>
        </div>
    }
</div>
