@model IEnumerable<ManageMentSystem.ViewModels.PaymentMethodBalanceViewModel>

@{
    ViewData["Title"] = "أرصدة طرق الدفع";
    var totalIncome = Model.Sum(x => x.TotalIncome);
    var totalExpenses = Model.Sum(x => x.TotalExpenses);
    var totalNet = totalIncome - totalExpenses;
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-wallet text-indigo-800"></i> أرصدة طرق الدفع
            </h1>
            <p class="text-slate-500 mt-1 font-medium">عرض الأرصدة الحالية لكل طريقة دفع</p>
        </div>
        <form method="get" class="flex gap-2">
            <input type="date" name="fromDate" value="@ViewBag.FromDate" class="px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none font-bold text-slate-700" />
            <input type="date" name="toDate" value="@ViewBag.ToDate" class="px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none font-bold text-slate-700" />
            <button type="submit" class="bg-indigo-800 hover:bg-indigo-900 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:shadow-indigo-500/30 hover:-translate-y-0.5 flex items-center gap-2">
                <i class="fas fa-filter"></i> تطبيق
            </button>
        </form>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <!-- Income -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-700 text-xl shadow-sm">
                <i class="fas fa-arrow-up"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-500 mb-1">إجمالي الإيرادات</p>
                <h3 class="text-2xl font-bold text-emerald-700">@totalIncome.ToString("C")</h3>
            </div>
        </div>

        <!-- Expenses -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-700 text-xl shadow-sm">
                <i class="fas fa-arrow-down"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-500 mb-1">إجمالي المصروفات</p>
                <h3 class="text-2xl font-bold text-red-700">@totalExpenses.ToString("C")</h3>
            </div>
        </div>

        <!-- Net Balance -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-indigo-50 flex items-center justify-center text-indigo-600 text-xl shadow-sm">
                <i class="fas fa-scale-balanced"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-500 mb-1">الرصيد الصافي</p>
                <h3 class="text-2xl font-bold @(totalNet >= 0 ? "text-indigo-800" : "text-red-700")">@totalNet.ToString("C")</h3>
            </div>
        </div>
    </div>

    <!-- Payment Methods Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var pm in Model.OrderBy(m => m.Name))
        {
            var netPositive = pm.Net >= 0;
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md transition-all group hover:-translate-y-1">
                <div class="flex justify-between items-center mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-indigo-50 group-hover:text-indigo-600 transition-colors">
                            <i class="fas fa-credit-card"></i>
                        </div>
                        <h3 class="font-bold text-slate-800 text-lg">@pm.Name</h3>
                    </div>
                    <a asp-action="PaymentMethodDetails" asp-route-id="@pm.PaymentMethodId" asp-route-fromDate="@ViewBag.FromDate" asp-route-toDate="@ViewBag.ToDate" 
                       class="w-8 h-8 flex items-center justify-center rounded-lg text-indigo-800 hover:bg-indigo-100 transition-colors" title="عرض التفاصيل">
                        <i class="fas fa-eye text-sm"></i>
                    </a>
                </div>
                
                <div class="space-y-3">
                    <div class="flex justify-between items-center text-sm border-b border-slate-50 pb-2">
                        <span class="text-emerald-700 font-medium">
                            <i class="fas fa-arrow-up text-sm ml-1"></i> إيرادات
                        </span>
                        <span class="font-bold text-emerald-700">@pm.TotalIncome.ToString("C")</span>
                    </div>
                    <div class="flex justify-between items-center text-sm border-b border-slate-50 pb-2">
                        <span class="text-red-700 font-medium">
                            <i class="fas fa-arrow-down text-sm ml-1"></i> مصروفات
                        </span>
                        <span class="font-bold text-red-700">@pm.TotalExpenses.ToString("C")</span>
                    </div>
                    <div class="flex justify-between items-center pt-1">
                        <span class="text-slate-500 font-bold">الرصيد الحالي</span>
                        <span class="font-bold text-xl @(netPositive ? "text-indigo-800" : "text-red-700")">@pm.Net.ToString("C")</span>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-12">
            <div class="bg-slate-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 border border-slate-100">
                <i class="fas fa-wallet text-3xl text-slate-300"></i>
            </div>
            <h5 class="text-lg font-bold text-slate-800">لا توجد بيانات</h5>
            <p class="text-slate-500 mt-1">لا توجد حركات مالية في الفترة المحددة</p>
        </div>
    }
</div>
