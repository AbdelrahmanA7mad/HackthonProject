@model IEnumerable<ManageMentSystem.Models.StoreAccount>
@using ManageMentSystem.Helpers

@{
    ViewData["Title"] = "تفاصيل وسيلة الدفع";
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-credit-card text-indigo-800"></i> @ViewBag.PaymentMethodName
            </h1>
            <p class="text-slate-500 mt-1 font-medium">عرض تفاصيل الحركات لوسيلة الدفع المحددة</p>
        </div>
        <form method="get" class="flex gap-2">
            <input type="hidden" name="id" value="@ViewBag.PaymentMethodId" />
            <input type="date" name="fromDate" value="@ViewBag.FromDate" class="px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none font-bold text-slate-700" />
            <input type="date" name="toDate" value="@ViewBag.ToDate" class="px-4 py-2.5 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-100 focus:border-indigo-600 outline-none font-bold text-slate-700" />
            <button type="submit" class="bg-indigo-800 hover:bg-indigo-900 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-sm hover:shadow-indigo-500/30 hover:-translate-y-0.5 flex items-center gap-2">
                <i class="fas fa-filter"></i> تطبيق
            </button>
            <a asp-action="PaymentMethodBalances" class="bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 hover:text-slate-800 px-4 py-2.5 rounded-xl font-bold transition-all hover:-translate-y-0.5 shadow-sm" title="العودة للأرصدة">
                <i class="fas fa-arrow-left"></i>
            </a>
        </form>
    </div>

    <!-- Transactions Table -->
    <div class="bg-white rounded-xl shadow-md border border-slate-100 overflow-hidden">
        <div class="bg-slate-50/50 px-6 py-4 border-b border-slate-200">
            <h6 class="font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-list text-indigo-800"></i> سجل العمليات
            </h6>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-right">
                <thead class="bg-slate-50 border-b border-slate-200 text-slate-700 text-sm uppercase font-bold text-center">
                    <tr>
                        <th class="px-6 py-4">التاريخ</th>
                        <th class="px-6 py-4">اسم العملية</th>
                        <th class="px-6 py-4">النوع</th>
                        <th class="px-6 py-4">المبلغ</th>
                        <th class="px-6 py-4">الفئة</th>
                        <th class="px-6 py-4">مرجع</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-slate-700 text-sm text-center">
                    @foreach (var t in Model)
                    {
                        <tr class="hover:bg-slate-50/80 transition-colors">
                            <td class="px-6 py-4 font-bold">@t.TransactionDate.ToString("yyyy-MM-dd")</td>
                            <td class="px-6 py-4 font-bold text-slate-800">@t.TransactionName</td>
                            <td class="px-6 py-4">
                                <span class="px-2.5 py-1 rounded-full font-bold text-xs @(t.TransactionType == ManageMentSystem.Models.TransactionType.Income ? "bg-emerald-100 text-emerald-800 border border-emerald-200" : "bg-red-100 text-red-800 border border-red-200")">
                                    @t.TransactionType.GetDisplayName()
                                </span>
                            </td>
                            <td class="px-6 py-4 font-bold @(t.TransactionType == ManageMentSystem.Models.TransactionType.Income ? "text-emerald-700" : "text-red-700")">
                                @t.Amount.ToString("C")
                            </td>
                            <td class="px-6 py-4">
                                <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs font-bold border border-gray-200">@(t.Category ?? "-")</span>
                            </td>
                            <td class="px-6 py-4 font-mono text-slate-500 text-xs">@(t.ReferenceNumber ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="bg-slate-50 border-t border-slate-200 px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="text-sm font-bold text-slate-500">
                    عرض @(((ViewBag.CurrentPage - 1) * ViewBag.PageSize) + 1) إلى @Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems) من @ViewBag.TotalItems نتيجة
                </div>
                <div class="flex gap-1.5" dir="ltr">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <a href="@Url.Action("PaymentMethodDetails", new { id = ViewBag.PaymentMethodId, page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize, fromDate = ViewBag.FromDate, toDate = ViewBag.ToDate })" 
                           class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-500 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 transition-all">
                            <i class="fas fa-chevron-left text-xs"></i>
                        </a>
                    }

                    @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                    {
                        if (i == ViewBag.CurrentPage)
                        {
                            <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-indigo-800 text-white border border-indigo-800 text-xs font-bold shadow-sm shadow-indigo-200">@i</span>
                        }
                        else
                        {
                            <a href="@Url.Action("PaymentMethodDetails", new { id = ViewBag.PaymentMethodId, page = i, pageSize = ViewBag.PageSize, fromDate = ViewBag.FromDate, toDate = ViewBag.ToDate })" 
                               class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-500 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 transition-all text-xs font-bold">@i</a>
                        }
                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <a href="@Url.Action("PaymentMethodDetails", new { id = ViewBag.PaymentMethodId, page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize, fromDate = ViewBag.FromDate, toDate = ViewBag.ToDate })" 
                           class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-500 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 transition-all">
                            <i class="fas fa-chevron-right text-xs"></i>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>
