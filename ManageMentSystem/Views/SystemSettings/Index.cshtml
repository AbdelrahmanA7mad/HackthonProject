@using ManageMentSystem.Services.UserServices
@inject IUserService UserService
@{
    ViewBag.Title = "إعدادات النظام";
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
            <i class="fas fa-cogs text-indigo-800"></i> إعدادات النظام
        </h1>
        <p class="text-slate-500 mt-1 font-medium">التحكم في إعدادات وخصائص النظام</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Invoice Design -->
            <a asp-controller="UserInvoice" asp-action="Index" class="group block">
                <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 h-full hover:shadow-md transition-all hover:-translate-y-1 group-hover:border-indigo-200">
                    <div class="w-14 h-14 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-800 text-2xl mb-4 group-hover:bg-indigo-800 group-hover:text-white transition-colors">
                        <i class="fas fa-file-invoice"></i>
                    </div>
                    <h5 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-indigo-800 transition-colors">تصميم الفاتورة</h5>
                    <p class="text-sm text-slate-500 font-medium leading-relaxed">تخصيص شكل الفاتورة، التسلسل، والرسائل الترحيبية.</p>
                </div>
            </a>

            <!-- WhatsApp Settings -->
            <a asp-controller="WhatsApp" asp-action="Index" class="group block">
                <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 h-full hover:shadow-md transition-all hover:-translate-y-1 group-hover:border-emerald-200">
                    <div class="w-14 h-14 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600 text-2xl mb-4 group-hover:bg-emerald-600 group-hover:text-white transition-colors">
                        <i class="fab fa-whatsapp"></i>
                    </div>
                    <h5 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-emerald-700 transition-colors">اعدادات الواتساب</h5>
                    <p class="text-sm text-slate-500 font-medium leading-relaxed">إعدادات إرسال الفواتير والإشعارات عبر الواتساب.</p>
                </div>
            </a>

            <!-- Payment Methods -->
            <a asp-controller="PaymentMethods" asp-action="Index" class="group block">
                <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 h-full hover:shadow-md transition-all hover:-translate-y-1 group-hover:border-amber-200">
                    <div class="w-14 h-14 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600 text-2xl mb-4 group-hover:bg-amber-600 group-hover:text-white transition-colors">
                        <i class="fas fa-wallet"></i>
                    </div>
                    <h5 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-amber-700 transition-colors">طرق الدفع</h5>
                    <p class="text-sm text-slate-500 font-medium leading-relaxed">إعدادات طرق الدفع (فودافون كاش، إنستاباي، نقدي).</p>
                </div>
            </a>

            <!-- Tenant Settings -->
            <a asp-controller="SystemSettings" asp-action="TenantSettings" class="group block">
                <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 h-full hover:shadow-md transition-all hover:-translate-y-1 group-hover:border-blue-200">
                    <div class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center text-blue-800 text-2xl mb-4 group-hover:bg-blue-800 group-hover:text-white transition-colors">
                        <i class="fas fa-building"></i>
                    </div>
                    <h5 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-blue-800 transition-colors">إعدادات المؤسسة</h5>
                    <p class="text-sm text-slate-500 font-medium leading-relaxed">تخصيص بيانات المؤسسة، العملة، وغيرها.</p>
                </div>
            </a>

            <!-- Inventory Settings -->
            <a asp-controller="SystemSettings" asp-action="Inventory" class="group block">
                <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 h-full hover:shadow-md transition-all hover:-translate-y-1 group-hover:border-indigo-200">
                    <div class="w-14 h-14 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-800 text-2xl mb-4 group-hover:bg-indigo-800 group-hover:text-white transition-colors">
                        <i class="fas fa-boxes"></i>
                    </div>
                    <h5 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-indigo-800 transition-colors">إعدادات المخزون</h5>
                    <p class="text-sm text-slate-500 font-medium leading-relaxed">إدارة تنبيهات نقص المخزون والحد الأدنى للكميات.</p>
                </div>
            </a>

            <!-- Tab Visibility -->
            <a asp-controller="SystemSettings" asp-action="TabVisibility" class="group block">
                <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 h-full hover:shadow-md transition-all hover:-translate-y-1 group-hover:border-indigo-200">
                    <div class="w-14 h-14 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-800 text-2xl mb-4 group-hover:bg-indigo-800 group-hover:text-white transition-colors">
                        <i class="fas fa-columns"></i>
                    </div>
                    <h5 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-indigo-800 transition-colors">ظهور القوائم</h5>
                    <p class="text-sm text-slate-500 font-medium leading-relaxed">التحكم في القوائم المرئية في الشريط الجانبي للنظام.</p>
                </div>
            </a>

        </div>
    </div>
</div>