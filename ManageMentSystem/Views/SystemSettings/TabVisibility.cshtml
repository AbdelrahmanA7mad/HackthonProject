@model ManageMentSystem.Models.TabVisibilitySettings
@{
    ViewData["Title"] = "إعدادات ظهور القوائم";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="columns" class="text-primary"></i> إعدادات ظهور القوائم
            </h1>
            <p class="text-gray-500 mt-1 font-medium">التحكم في القوائم المرئية في الشريط الجانبي</p>
        </div>
        <a asp-controller="SystemSettings" asp-action="Index" class="zen-btn zen-btn-neutral">
            العودة للإعدادات<i data-lucide="arrow-left"></i>
        </a>
    </div>

    <!-- Main Content -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-5xl mx-auto">
        <div class="mb-8 bg-gray-50 border border-gray-200 text-primary px-6 py-4 rounded-xl flex items-start gap-4">
            <i data-lucide="info" class="text-xl mt-0.5"></i>
            <div>
                <h6 class="font-bold mb-1">تعليمات</h6>
                <p class="text-sm opacity-90 leading-relaxed font-medium">
                    قم بتفعيل أو تعطيل القوائم التي تريد إظهارها في الشريط الجانبي. القوائم المعطلة لن تظهر لأي مستخدم في النظام حتى يتم تفعيلها مرة أخرى.
                </p>
            </div>
        </div>

        <form asp-action="TabVisibility" method="post" class="space-y-8">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TenantId" />

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Products -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-gray-200">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-gray-50 flex items-center justify-center text-primary text-xl group-hover:bg-primary group-hover:text-white transition-colors">
                            <i data-lucide="box"></i>
                        </div>
                        <label asp-for="ShowProducts" class="font-bold text-gray-600 cursor-pointer select-none">المنتجات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowProducts" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    </label>
                </div>

                <!-- Categories -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-emerald-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-emerald-50 flex items-center justify-center text-accentGreen text-xl group-hover:bg-accentGreen group-hover:text-white transition-colors">
                            <i data-lucide="tags"></i>
                        </div>
                        <label asp-for="ShowCategories" class="font-bold text-gray-600 cursor-pointer select-none">الفئات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowCategories" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accentGreen/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accentGreen"></div>
                    </label>
                </div>

                <!-- Customers -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-sky-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-bgSubtle flex items-center justify-center text-accent text-xl group-hover:bg-accent group-hover:text-white transition-colors">
                            <i data-lucide="users"></i>
                        </div>
                        <label asp-for="ShowCustomers" class="font-bold text-gray-600 cursor-pointer select-none">العملاء</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowCustomers" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accent/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accent"></div>
                    </label>
                </div>

                <!-- Sales -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-amber-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-amber-50 flex items-center justify-center text-accentAmber text-xl group-hover:bg-accentAmber group-hover:text-white transition-colors">
                            <i data-lucide="shopping-cart"></i>
                        </div>
                        <label asp-for="ShowSales" class="font-bold text-gray-600 cursor-pointer select-none">المبيعات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowSales" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accentAmber/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accentAmber"></div>
                    </label>
                </div>

                <!-- Returns -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-red-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-red-50 flex items-center justify-center text-accentRed text-xl group-hover:bg-accentRed group-hover:text-white transition-colors">
                            <i data-lucide="rotate-ccw"></i>
                        </div>
                        <label asp-for="ShowReturns" class="font-bold text-gray-600 cursor-pointer select-none">المرتجعات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowReturns" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accentRed/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accentRed"></div>
                    </label>
                </div>

                <!-- Installments -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-gray-200">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center text-primary text-xl group-hover:bg-primary group-hover:text-white transition-colors">
                            <i data-lucide="credit-card"></i>
                        </div>
                        <label asp-for="ShowInstallments" class="font-bold text-gray-600 cursor-pointer select-none">الأقساط</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowInstallments" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    </label>
                </div>

                <!-- General Debts -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-gray-200">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center text-primary text-xl group-hover:bg-primary group-hover:text-white transition-colors">
                            <i data-lucide="scale"></i>
                        </div>
                        <label asp-for="ShowGeneralDebts" class="font-bold text-gray-600 cursor-pointer select-none">الديون</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowGeneralDebts" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    </label>
                </div>

                <!-- Suppliers -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-gray-200">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-gray-50 flex items-center justify-center text-primary text-xl group-hover:bg-primary group-hover:text-white transition-colors">
                            <i data-lucide="truck"></i>
                        </div>
                        <label asp-for="ShowSuppliers" class="font-bold text-gray-600 cursor-pointer select-none">الموردين</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowSuppliers" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    </label>
                </div>

                <!-- Purchase Invoices -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-emerald-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-emerald-50 flex items-center justify-center text-accentGreen text-xl group-hover:bg-accentGreen group-hover:text-white transition-colors">
                            <i data-lucide="file-text"></i>
                        </div>
                        <label asp-for="ShowPurchaseInvoices" class="font-bold text-gray-600 cursor-pointer select-none">فواتير المشتريات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowPurchaseInvoices" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accentGreen/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accentGreen"></div>
                    </label>
                </div>

                <!-- Store Account -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-gray-200">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-gray-50 flex items-center justify-center text-primary text-xl group-hover:bg-primary group-hover:text-white transition-colors">
                            <i data-lucide="calculator"></i>
                        </div>
                        <label asp-for="ShowStoreAccount" class="font-bold text-gray-600 cursor-pointer select-none">الحسابات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowStoreAccount" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    </label>
                </div>


                <!-- Reports -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-red-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-red-50 flex items-center justify-center text-accentRed text-xl group-hover:bg-accentRed group-hover:text-white transition-colors">
                            <i data-lucide="bar-chart-2"></i>
                        </div>
                        <label asp-for="ShowReports" class="font-bold text-gray-600 cursor-pointer select-none">التقارير</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowReports" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accentRed/15 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accentRed"></div>
                    </label>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="pt-6 border-t flex flex-wrap border-gray-200 flex items-center gap-4">
                <button type="submit" class="zen-btn zen-btn-primary">
                    <i data-lucide="save"></i> حفظ التغييرات
                </button>
                <a asp-action="Index" class="zen-btn zen-btn-neutral">
                    <i data-lucide="arrow-right"></i> العودة للإعدادات
                </a>
            </div>
        </form>
    </div>
</div>

