@model ManageMentSystem.Models.TabVisibilitySettings
@{
    ViewData["Title"] = "إعدادات ظهور القوائم";
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-[#0f1419] flex items-center gap-2">
                <i data-lucide="columns" class="text-[#0f1419]"></i> إعدادات ظهور القوائم
            </h1>
            <p class="text-gray-500 mt-1 font-medium">التحكم في القوائم المرئية في الشريط الجانبي</p>
        </div>
        <a asp-controller="SystemSettings" asp-action="Index" class="bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-[#0f1419] px-6 py-2.5 rounded-xl font-bold transition-all hover:-translate-y-0.5 flex items-center gap-2 shadow-sm">
            العودة للإعدادات<i data-lucide="arrow-left"></i>
        </a>
    </div>

    <!-- Main Content -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-5xl mx-auto">
        <div class="mb-8 bg-gray-50 border border-gray-200 text-[#0f1419] px-6 py-4 rounded-xl flex items-start gap-4">
            <i data-lucide="info" class="text-xl mt-0.5"></i>
            <div>
                <h6 class="font-bold mb-1">تعليمات</h6>
                <p class="text-sm opacity-90 leading-relaxed font-medium">
                    قم بتفعيل أو تعطيل القوائم التي تريد إظهارها في الشريط الجانبي. القوائم المعطلة لن تظهر لأي مستخدم في النظام حتى يتم تفعيلها مرة أخرى.
                </p>
            </div>
        </div>

        <form asp-action="TabVisibility" method="post" class="space-y-8">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TenantId" />

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Products -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-gray-200">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-gray-50 flex items-center justify-center text-[#0f1419] text-xl group-hover:bg-[#0f1419] group-hover:text-white transition-colors">
                            <i data-lucide="box"></i>
                        </div>
                        <label asp-for="ShowProducts" class="font-bold text-gray-600 cursor-pointer select-none">المنتجات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowProducts" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-bgSubtle rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#0f1419]"></div>
                    </label>
                </div>

                <!-- Categories -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-emerald-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-emerald-50 flex items-center justify-center text-accentGreen text-xl group-hover:bg-emerald-600 group-hover:text-white transition-colors">
                            <i data-lucide="tags"></i>
                        </div>
                        <label asp-for="ShowCategories" class="font-bold text-gray-600 cursor-pointer select-none">الفئات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowCategories" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-emerald-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-600"></div>
                    </label>
                </div>

                <!-- Customers -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-sky-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-sky-50 flex items-center justify-center text-sky-700 text-xl group-hover:bg-sky-600 group-hover:text-white transition-colors">
                            <i data-lucide="users"></i>
                        </div>
                        <label asp-for="ShowCustomers" class="font-bold text-gray-600 cursor-pointer select-none">العملاء</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowCustomers" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-sky-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-sky-600"></div>
                    </label>
                </div>

                <!-- Sales -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-amber-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-amber-50 flex items-center justify-center text-amber-600 text-xl group-hover:bg-amber-500 group-hover:text-white transition-colors">
                            <i data-lucide="shopping-cart"></i>
                        </div>
                        <label asp-for="ShowSales" class="font-bold text-gray-600 cursor-pointer select-none">المبيعات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowSales" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-amber-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-amber-500"></div>
                    </label>
                </div>

                <!-- Returns -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-red-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-red-50 flex items-center justify-center text-red-600 text-xl group-hover:bg-red-600 group-hover:text-white transition-colors">
                            <i data-lucide="rotate-ccw"></i>
                        </div>
                        <label asp-for="ShowReturns" class="font-bold text-gray-600 cursor-pointer select-none">المرتجعات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowReturns" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-red-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-red-600"></div>
                    </label>
                </div>

                <!-- Installments -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-gray-200">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center text-gray-500 text-xl group-hover:bg-gray-50 group-hover:text-white transition-colors">
                            <i data-lucide="credit-card"></i>
                        </div>
                        <label asp-for="ShowInstallments" class="font-bold text-gray-600 cursor-pointer select-none">الأقساط</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowInstallments" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-slate-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-gray-100"></div>
                    </label>
                </div>

                <!-- General Debts -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-gray-200">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center text-gray-700 text-xl group-hover:bg-gray-700 group-hover:text-white transition-colors">
                            <i data-lucide="scale"></i>
                        </div>
                        <label asp-for="ShowGeneralDebts" class="font-bold text-gray-600 cursor-pointer select-none">الديون</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowGeneralDebts" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-gray-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-gray-700"></div>
                    </label>
                </div>

                <!-- Suppliers -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-gray-200">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-gray-50 flex items-center justify-center text-[#0f1419] text-xl group-hover:bg-[#0f1419] group-hover:text-white transition-colors">
                            <i data-lucide="truck"></i>
                        </div>
                        <label asp-for="ShowSuppliers" class="font-bold text-gray-600 cursor-pointer select-none">الموردين</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowSuppliers" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-bgSubtle rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#0f1419]"></div>
                    </label>
                </div>

                <!-- Purchase Invoices -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-emerald-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-emerald-50 flex items-center justify-center text-accentGreen text-xl group-hover:bg-emerald-600 group-hover:text-white transition-colors">
                            <i data-lucide="file-text"></i>
                        </div>
                        <label asp-for="ShowPurchaseInvoices" class="font-bold text-gray-600 cursor-pointer select-none">فواتير المشتريات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowPurchaseInvoices" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-emerald-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-600"></div>
                    </label>
                </div>

                <!-- Store Account -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-gray-200">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-gray-50 flex items-center justify-center text-[#0f1419] text-xl group-hover:bg-[#0f1419] group-hover:text-white transition-colors">
                            <i data-lucide="calculator"></i>
                        </div>
                        <label asp-for="ShowStoreAccount" class="font-bold text-gray-600 cursor-pointer select-none">الحسابات</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowStoreAccount" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-bgSubtle rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#0f1419]"></div>
                    </label>
                </div>


                <!-- Reports -->
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center justify-between hover:shadow-md transition-all group hover:bg-white hover:border-red-100">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-red-50 flex items-center justify-center text-red-600 text-xl group-hover:bg-red-600 group-hover:text-white transition-colors">
                            <i data-lucide="bar-chart-2"></i>
                        </div>
                        <label asp-for="ShowReports" class="font-bold text-gray-600 cursor-pointer select-none">التقارير</label>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="ShowReports" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-100 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-red-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-200 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-red-600"></div>
                    </label>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="pt-6 border-t flex flex-wrap border-gray-200 flex items-center gap-4">
                <button type="submit" class="bg-[#0f1419] hover:bg-primaryHover text-white px-8 py-3 rounded-xl font-bold transition-all shadow-md hover:shadow-gray-400/20 hover:-translate-y-0.5 flex items-center gap-2">
                    <i data-lucide="save"></i> حفظ التغييرات
                </button>
                <a asp-action="Index" class="bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-[#0f1419] px-6 py-3 rounded-xl font-bold transition-all hover:-translate-y-0.5 flex items-center gap-2 shadow-sm">
                    <i data-lucide="arrow-right"></i> العودة للإعدادات
                </a>
            </div>
        </form>
    </div>
</div>
