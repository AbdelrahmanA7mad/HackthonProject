@model ManageMentSystem.ViewModels.TenantSettingsViewModel

@{
    ViewData["Title"] = "إعدادات المؤسسة";
}

<div class="min-h-screen bg-gray-50/50 p-6" dir="rtl">
    <!-- Header -->
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                <i class="fas fa-building text-blue-800"></i> إعدادات المؤسسة
            </h1>
            <p class="text-slate-500 mt-1 font-medium">تخصيص بيانات المؤسسة والعملة</p>
        </div>
        <a asp-action="Index" class="bg-white text-slate-700 hover:bg-slate-50 border border-slate-200 font-medium py-2.5 px-5 rounded-xl transition-all duration-300 shadow-sm hover:shadow-md flex items-center gap-2">
            عودة للإعدادات
            <i class="fas fa-arrow-left"></i>
        </a>
    </div>

    <!-- Main Content -->
    <div class="max-w-4xl mx-auto">
        <form asp-action="TenantSettings" method="post">
            <div asp-validation-summary="ModelOnly" class="bg-red-50 text-red-600 p-4 rounded-xl mb-6 border border-red-100"></div>

            <!-- Basic Info Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-6">
                <div class="p-6 border-b border-slate-50 bg-gradient-to-r from-blue-50 to-indigo-50">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                        <i class="fas fa-info-circle text-blue-600"></i>
                        البيانات الأساسية
                    </h2>
                </div>

                <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Name -->
                    <div class="md:col-span-2">
                        <label asp-for="Name" class="block text-sm font-bold text-slate-700 mb-2">
                            <i class="fas fa-building ml-1 text-blue-500"></i> اسم المؤسسة
                        </label>
                        <input asp-for="Name" class="w-full bg-slate-50 border border-slate-200 text-slate-800 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block p-4 transition-all duration-300 focus:bg-white" placeholder="أدخل اسم المؤسسة">
                        <span asp-validation-for="Name" class="text-red-500 text-sm mt-1 block"></span>
                    </div>

                    <!-- Phone -->
                    <div>
                        <label asp-for="Phone" class="block text-sm font-bold text-slate-700 mb-2">
                            <i class="fas fa-phone ml-1 text-green-500"></i> رقم الهاتف
                        </label>
                        <input asp-for="Phone" type="tel" class="w-full bg-slate-50 border border-slate-200 text-slate-800 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block p-4 transition-all duration-300 focus:bg-white" placeholder="01xxxxxxxxx" dir="ltr">
                        <span asp-validation-for="Phone" class="text-red-500 text-sm mt-1 block"></span>
                    </div>

                    <!-- Currency -->
                    <div>
                        <label asp-for="CurrencyCode" class="block text-sm font-bold text-slate-700 mb-2">
                            <i class="fas fa-coins ml-1 text-amber-500"></i> العملة
                        </label>
                        <select asp-for="CurrencyCode" class="w-full bg-slate-50 border border-slate-200 text-slate-800 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block p-4 transition-all duration-300 focus:bg-white">
                            <option value="EGP">EGP - جنيه مصري</option>
                            <option value="SAR">SAR - ريال سعودي</option>
                            <option value="USD">USD - دولار أمريكي</option>
                            <option value="AED">AED - درهم إماراتي</option>
                            <option value="KWD">KWD - دينار كويتي</option>
                        </select>
                        <span asp-validation-for="CurrencyCode" class="text-red-500 text-sm mt-1 block"></span>
                    </div>

                    <!-- Address -->
                    <div class="md:col-span-2">
                        <label asp-for="Address" class="block text-sm font-bold text-slate-700 mb-2">
                            <i class="fas fa-map-marker-alt ml-1 text-red-500"></i> العنوان
                        </label>
                        <textarea asp-for="Address" rows="2" class="w-full bg-slate-50 border border-slate-200 text-slate-800 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block p-4 transition-all duration-300 focus:bg-white resize-none" placeholder="أدخل عنوان المؤسسة"></textarea>
                        <span asp-validation-for="Address" class="text-red-500 text-sm mt-1 block"></span>
                    </div>

                    <!-- Logo URL -->
                    <div class="md:col-span-2">
                        <label asp-for="LogoUrl" class="block text-sm font-bold text-slate-700 mb-2">
                            <i class="fas fa-image ml-1 text-purple-500"></i> رابط الشعار (اختياري)
                        </label>
                        <input asp-for="LogoUrl" type="url" class="w-full bg-slate-50 border border-slate-200 text-slate-800 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block p-4 transition-all duration-300 focus:bg-white" placeholder="https://example.com/logo.png" dir="ltr">
                        <span asp-validation-for="LogoUrl" class="text-red-500 text-sm mt-1 block"></span>
                        <p class="text-slate-400 text-xs mt-2">
                            <i class="fas fa-info-circle ml-1"></i>
                            أدخل رابط صورة الشعار (يُفضل بتنسيق PNG أو SVG)
                        </p>
                    </div>
                </div>
            </div>

            <!-- Account Info Card (Read-only) -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-6">
                <div class="p-6 border-b border-slate-50 bg-gradient-to-r from-slate-50 to-gray-50">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                        <i class="fas fa-shield-alt text-slate-600"></i>
                        معلومات الحساب
                        <span class="text-xs font-normal text-slate-400 bg-slate-100 px-2 py-1 rounded-full">للعرض فقط</span>
                    </h2>
                </div>

                <div class="p-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Created At -->
                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                        <p class="text-xs text-slate-500 mb-1">
                            <i class="fas fa-calendar-plus ml-1"></i> تاريخ الإنشاء
                        </p>
                        <p class="font-bold text-slate-800" dir="ltr">@Model.CreatedAt.ToString("yyyy/MM/dd")</p>
                    </div>

                    <!-- Subscription Status -->
                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                        <p class="text-xs text-slate-500 mb-1">
                            <i class="fas fa-star ml-1"></i> حالة الاشتراك
                        </p>
                        @{
                            var statusClass = Model.SubscriptionStatus switch
                            {
                                "Active" => "text-green-600 bg-green-100",
                                "Trial" => "text-blue-600 bg-blue-100",
                                _ => "text-red-600 bg-red-100"
                            };
                            var statusText = Model.SubscriptionStatus switch
                            {
                                "Active" => "نشط",
                                "Trial" => "فترة تجريبية",
                                _ => "منتهي"
                            };
                        }
                        <span class="px-3 py-1 rounded-full text-sm font-bold @statusClass">@statusText</span>
                    </div>

                    <!-- Trial End Date -->
                    @if (Model.TrialEndDate.HasValue && Model.SubscriptionStatus == "Trial")
                    {
                        <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                            <p class="text-xs text-slate-500 mb-1">
                                <i class="fas fa-hourglass-half ml-1"></i> انتهاء التجربة
                            </p>
                            <p class="font-bold text-slate-800" dir="ltr">@Model.TrialEndDate.Value.ToString("yyyy/MM/dd")</p>
                        </div>
                    }

                    <!-- Subscription End Date -->
                    @if (Model.SubscriptionEndDate.HasValue && Model.SubscriptionStatus == "Active")
                    {
                        <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                            <p class="text-xs text-slate-500 mb-1">
                                <i class="fas fa-calendar-times ml-1"></i> انتهاء الاشتراك
                            </p>
                            <p class="font-bold text-slate-800" dir="ltr">@Model.SubscriptionEndDate.Value.ToString("yyyy/MM/dd")</p>
                        </div>
                    }

                    <!-- Active Status -->
                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                        <p class="text-xs text-slate-500 mb-1">
                            <i class="fas fa-toggle-on ml-1"></i> الحالة
                        </p>
                        @if (Model.IsActive)
                        {
                            <span class="px-3 py-1 rounded-full text-sm font-bold text-green-600 bg-green-100">فعال</span>
                        }
                        else
                        {
                            <span class="px-3 py-1 rounded-full text-sm font-bold text-red-600 bg-red-100">معطل</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="flex items-center justify-end gap-3">
                <a asp-action="Index" class="bg-white text-slate-600 hover:bg-slate-50 border border-slate-200 font-bold py-3 px-8 rounded-xl transition-all duration-300">
                    إلغاء
                </a>
                <button type="submit" class="bg-gradient-to-r from-blue-700 to-blue-600 hover:from-blue-800 hover:to-blue-700 text-white font-bold py-3 px-10 rounded-xl transition-all duration-300 shadow-lg shadow-blue-200 transform hover:-translate-y-0.5 flex items-center gap-2">
                    <i class="fas fa-save"></i>
                    حفظ التغييرات
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
