@* Views/WhatsApp/Index.cshtml - محسّن ومعدل لـ Tailwind *@
@using ManageMentSystem.Models
@inject ManageMentSystem.Services.UserServices.IUserService UserService
@{
    ViewData["Title"] = "توصيل واتساب";
}

<div class="min-h-screen bg-bgSubtle p-6" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
                <i data-lucide="message-circle" class="text-emerald-600"></i> إعدادات واتساب
            </h1>
            <p class="text-gray-500 mt-1 font-medium">إدارة اتصال واتساب لإرسال الفواتير والإشعارات</p>
        </div>
        <a asp-controller="SystemSettings" asp-action="Index" class="zen-btn zen-btn-neutral">
            العودة للإعدادات<i data-lucide="arrow-left" class="w-4 h-4 inline-block mr-1"></i>
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
        <!-- Main Connection Card -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="bg-emerald-600 px-6 py-4 flex items-center justify-between">
                    <h4 class="text-white font-bold text-lg flex items-center gap-2">
                        <i data-lucide="message-circle"></i> حالة الاتصال
                    </h4>
                    @if (ViewBag.IsConnected)
                    {
                        <span class="bg-white/20 text-white px-3 py-1 rounded-full text-sm font-bold backdrop-blur-sm">
                            <i data-lucide="wifi" class="text-xs w-4 h-4 inline-block"></i> متصل
                        </span>
                    }
                    else
                    {
                        <span class="bg-white/20 text-white px-3 py-1 rounded-full text-sm font-bold backdrop-blur-sm">
                            <i data-lucide="wifi-off" class="text-xs w-4 h-4 inline-block"></i> غير متصل
                        </span>
                    }
                </div>

                <div class="p-8">
                    @if (ViewBag.ServerError == true)
                    {
                        <div class="bg-red-50 border border-red-200 rounded-xl p-6 mb-6">
                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-600 shrink-0">
                                    <i data-lucide="server"></i>
                                </div>
                                <div>
                                    <h5 class="text-red-800 font-bold text-lg mb-1">خطأ في الاتصال بالسيرفر!</h5>
                                    <p class="text-red-600 text-sm mb-3">تأكد من أن سيرفر Node.js يعمل على المنفذ 3000</p>
                                    <code class="bg-red-100 text-red-800 px-3 py-1.5 rounded-lg text-sm font-mono dir-ltr block w-fit">node server.js</code>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Connected State -->
                    <div id="connected-state" style="display: @(ViewBag.IsConnected ? "block" : "none")">
                        <div class="text-center py-8">
                            <div class="w-24 h-24 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-500 text-5xl mx-auto mb-6 animate-pulse">
                                <i data-lucide="check-circle"></i>
                            </div>
                            <h3 class="text-2xl font-bold text-primary mb-2">تم الاتصال بنجاح!</h3>
                            <p class="text-gray-500 max-w-md mx-auto mb-8">حسابك متصل الآن بسيرفر واتساب. يمكنك إرسال الفواتير والرسائل مباشرة للعملاء.</p>
                       
                                <button onclick="WhatsAppManager.disconnect()" class="zen-btn zen-btn-danger">
                                    <i data-lucide="log-out" class="w-4 h-4 inline-block mr-1"></i> قطع الاتصال
                                </button>
                        </div>
                    </div>

                    <!-- Not Connected State -->
                    <div id="not-connected-state" style="display: @(ViewBag.IsConnected ? "none" : "block")">
                        @if (ViewBag.SessionExists)
                        {
                            <!-- QR Code Section -->
                            <div id="qr-section">
                                <div class="bg-amber-50 border border-amber-100 rounded-xl p-4 mb-8 flex items-center gap-3 text-amber-800 font-medium">
                                    <i data-lucide="qr-code" class="text-xl"></i>
                                    يرجى مسح رمز QR أدناه لتوصيل حسابك
                                </div>

                                <div class="flex flex-col md:flex-row items-center justify-center gap-12">
                                    <!-- Instructions -->
                                    <div class="flex-1 max-w-sm">
                                        <h5 class="font-bold text-primary mb-4 border-b border-gray-200 pb-2">خطوات التوصيل:</h5>
                                        <ol class="space-y-4">
                                            <li class="flex items-start gap-3">
                                                <span class="w-6 h-6 rounded-full bg-slate-100 text-gray-500 flex items-center justify-center text-sm font-bold shrink-0">1</span>
                                                <span class="text-gray-500">افتح تطبيق واتساب على هاتفك</span>
                                            </li>
                                            <li class="flex items-start gap-3">
                                                <span class="w-6 h-6 rounded-full bg-slate-100 text-gray-500 flex items-center justify-center text-sm font-bold shrink-0">2</span>
                                                <span class="text-gray-500">اضغط على القائمة <strong class="mx-1">(⋮)</strong> أو الإعدادات</span>
                                            </li>
                                            <li class="flex items-start gap-3">
                                                <span class="w-6 h-6 rounded-full bg-slate-100 text-gray-500 flex items-center justify-center text-sm font-bold shrink-0">3</span>
                                                <span class="text-gray-500">اختر <strong>"الأجهزة المرتبطة"</strong></span>
                                            </li>
                                            <li class="flex items-start gap-3">
                                                <span class="w-6 h-6 rounded-full bg-slate-100 text-gray-500 flex items-center justify-center text-sm font-bold shrink-0">4</span>
                                                <span class="text-gray-500">اضغط على <strong>"ربط جهاز"</strong> وامسح الكود</span>
                                            </li>
                                        </ol>
                                    </div>

                                    <!-- QR Display -->
                                    <div class="flex-1 flex flex-col items-center">
                                        <div id="qr-loading" class="text-center py-8">
                                            <div class="w-12 h-12 border-4 border-emerald-200 border-t-emerald-600 rounded-full animate-spin mx-auto mb-4"></div>
                                            <p class="text-gray-500 font-medium">جاري إنشاء رمز QR...</p>
                                        </div>

                                        <div id="qr-container" style="display: none;" class="bg-white p-4 border border-gray-200 rounded-2xl shadow-sm">
                                            <img id="qr-code" src="" alt="QR Code" class="max-w-[280px] w-full mx-auto" />
                                            <p class="text-gray-500 text-sm text-center mt-3 font-medium animate-pulse">
                                                <i data-lucide="refresh-cw" class="mr-1 w-4 h-4 animate-spin inline-block"></i> في انتظار المسح...
                                            </p>
                                        </div>

                                        <div id="qr-error" style="display: none;" class="bg-red-50 border border-red-200 rounded-xl p-6 text-center max-w-xs">
                                            <div class="text-red-500 text-3xl mb-2"><i data-lucide="alert-circle"></i></div>
                                            <p id="qr-error-message" class="text-red-700 font-medium mb-4">حدث خطأ</p>
                                            <button onclick="WhatsAppManager.retryQR()" class="zen-btn zen-btn-neutral">
                                                <i data-lucide="rotate-ccw" class="w-4 h-4 inline-block mr-1"></i> إعادة المحاولة
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Initial Setup -->
                            <div id="setup-section" class="text-center py-12">
                                <div class="w-20 h-20 rounded-full bg-slate-100 flex items-center justify-center text-gray-500 text-4xl mx-auto mb-6">
                                    <i data-lucide="plug"></i>
                                </div>
                                <h3 class="text-xl font-bold text-primary mb-2">لم يتم إنشاء جلسة واتساب بعد</h3>
                                <p class="text-gray-500 max-w-sm mx-auto mb-8">قم بإنشاء جلسة جديدة للبدء في ربط حسابك واستخدام خدمة الرسائل.</p>

                          
                                    <button onclick="WhatsAppManager.createSession()" class="zen-btn zen-btn-success mx-auto">
                                        <i data-lucide="message-circle" class="text-xl"></i> إنشاء جلسة واتساب
                                    </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Info Sidebar -->
        <div class="lg:col-span-1">
            <div class="bg-bgSubtle rounded-xl border border-gray-200 p-6">
                <h5 class="font-bold text-primary mb-4 flex items-center gap-2">
                    <i data-lucide="lightbulb" class="text-primary"></i> معلومات مهمة
                </h5>
                <ul class="space-y-4">
                    <li class="flex items-start gap-3 text-gray-500 text-sm leading-relaxed">
                        <i data-lucide="check" class="text-primary mt-1 w-4 h-4"></i>
                        يمكنك إرسال الفواتير بصيغة PDF مباشرة لعملائك بمجرد إصدار الفاتورة.
                    </li>
                    <li class="flex items-start gap-3 text-gray-500 text-sm leading-relaxed">
                        <i data-lucide="check" class="text-primary mt-1 w-4 h-4"></i>
                        ستبقى الجلسة متصلة حتى تقوم بقطع الاتصال يدوياً أو تسجيل الخروج من تطبيق واتساب.
                    </li>
                    <li class="flex items-start gap-3 text-gray-500 text-sm leading-relaxed">
                        <i data-lucide="check" class="text-primary mt-1 w-4 h-4"></i>
                        يمكن ربط رقم واحد فقط لكل حساب في النظام.
                    </li>
                    <li class="flex items-start gap-3 text-gray-500 text-sm leading-relaxed">
                        <i data-lucide="check" class="text-primary mt-1 w-4 h-4"></i>
                        في حالة عدم استجابة السيرفر، حاول تحديث الصفحة أو إعادة تشغيل سيرفر الرسائل.
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
const accentGreen = window.accentGreen || window.THEME?.accentGreen || window.getComputedStyle(document.documentElement).getPropertyValue('--zen-theme-accent-green').trim();
const accentRed = window.accentRed || window.THEME?.accentRed || window.getComputedStyle(document.documentElement).getPropertyValue('--zen-theme-accent-red').trim();
        const textMuted = window.textMuted || '#64748b';

        const WhatsAppManager = {
            checkInterval: null,
            qrRetryCount: 0,
            maxRetries: 10, // زيادة عدد المحاولات لجلب الـ QR
            statusCheckDelay: 3000,
            qrLoadDelay: 2000,

            init() {
                // تشغيل الفحص التلقائي إذا كانت الجلسة موجودة ولكن غير متصلة عند فتح الصفحة
                @if (ViewBag.SessionExists && !ViewBag.IsConnected)
                {
                        <text>
                        this.loadQRCode();
                        this.startStatusCheck();
                        </text>
                }
            },

            showLoading(title = 'جاري المعالجة...') {
                Swal.fire({
                    title: title,
                    html: '<p class="text-sm text-gray-500">يرجى الانتظار، قد تستغرق العملية ثوانٍ...</p>',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });
            },

            showSuccess(title, text, reload = true) {
                Swal.fire({
                    icon: 'success',
                    title: title,
                    text: text,
                    confirmButtonText: 'ممتاز',
                    confirmButtonColor: accentGreen
                }).then(() => {
                    if (reload) location.reload();
                });
            },

            showError(text) {
                Swal.fire({
                    icon: 'error',
                    title: 'عذراً!',
                    text: text,
                    confirmButtonText: 'حاول مجدداً'
                });
            },

            async createSession() {
                this.showLoading('جاري إنشاء جلسة جديدة...');
                try {
                    const response = await $.ajax({
                        url: '@Url.Action("CreateSession", "WhatsApp")',
                        type: 'POST',
                        timeout: 40000 // وقت كافٍ لبدء تشغيل سيرفر الـ Node
                    });

                    if (response.success) {
                        Swal.close();

                        // تحويل الواجهة برمجياً بدلاً من الريفريش
                        $('#setup-section').fadeOut(300, () => {
                            // إظهار قسم الـ QR حتى لو كان مخفياً بـ Razor
                            if ($('#qr-section').length > 0) {
                                $('#qr-section').fadeIn().removeClass('hidden');
                            } else {
                                // إذا كان الـ Razor قد حذف الكود تماماً، نضطر للريفريش مرة واحدة
                                location.reload();
                            }
                        });

                        // البدء فوراً في محاولة جلب الـ QR
                        this.qrRetryCount = 0;
                        this.loadQRCode();
                        this.startStatusCheck();
                    } else {
                        this.showError(response.message || 'فشل إنشاء الجلسة');
                    }
                } catch (error) {
                    this.showError('حدث خطأ في الاتصال بالسيرفر، تأكد من تشغيل خدمة الواتساب.');
                    console.error('Create session error:', error);
                }
            },

            async loadQRCode() {
                if (this.qrRetryCount >= this.maxRetries) {
                    this.handleQRError('استغرق السيرفر وقتاً طويلاً لتوليد الرمز. يرجى إعادة المحاولة.');
                    return;
                }

                try {
                    const data = await $.ajax({
                        url: '@Url.Action("GetQRCode", "WhatsApp")',
                        type: 'GET',
                        cache: false,
                        timeout: 15000
                    });

                    if (data.isReady) {
                        // إذا اكتشف السيرفر أن الجهاز اتصل بالفعل
                        this.stopStatusCheck();
                        this.showSuccess('تم الاتصال!', 'تم ربط الحساب بنجاح');
                    }
                    else if (data.qrCode) {
                        // عرض الرمز فوراً
                        this.displayQRCode(data.qrCode);
                        this.qrRetryCount = 0; // تصفير العداد عند النجاح
                    }
                    else {
                        // إذا لم يجهز الـ QR بعد، ننتظر ونحاول مرة أخرى
                        this.qrRetryCount++;
                        setTimeout(() => this.loadQRCode(), this.qrLoadDelay);
                    }
                } catch (error) {
                    this.qrRetryCount++;
                    console.warn('محاولة جلب QR فاشلة، جارِ التكرار...');
                    setTimeout(() => this.loadQRCode(), this.qrLoadDelay);
                }
            },

            displayQRCode(qrCodeBase64) {
                $('#qr-loading').hide();
                $('#qr-error').hide();
                $('#qr-container').fadeIn();
                // تحديث الصورة بالبيانات المستلمة (Base64)
                $('#qr-code').attr('src', qrCodeBase64);
            },

            handleQRError(message) {
                $('#qr-loading').hide();
                $('#qr-container').hide();
                $('#qr-error').fadeIn().removeClass('hidden');
                $('#qr-error-message').text(message);
            },

            retryQR() {
                this.qrRetryCount = 0;
                $('#qr-error').hide();
                $('#qr-loading').show();
                this.loadQRCode();
            },

            startStatusCheck() {
                this.stopStatusCheck();
                this.checkInterval = setInterval(async () => {
                    try {
                        const data = await $.ajax({
                            url: '@Url.Action("CheckStatus", "WhatsApp")',
                            type: 'GET',
                            cache: false
                        });

                        if (data.isReady) {
                            this.stopStatusCheck();
                            this.showSuccess('✅ متصل الآن!', 'تم ربط هاتفك بنجاح بالنظام');
                        }
                    } catch (error) {
                        console.error('فشل فحص الحالة الدوري');
                    }
                }, this.statusCheckDelay);
            },

            stopStatusCheck() {
                if (this.checkInterval) {
                    clearInterval(this.checkInterval);
                    this.checkInterval = null;
                }
            },

            async disconnect() {
                const result = await Swal.fire({
                    title: 'قطع الاتصال؟',
                    text: "لن تتمكن من إرسال رسائل تلقائية حتى تعيد الربط.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: accentRed,
                    cancelButtonColor: textMuted,
                    confirmButtonText: 'نعم، افصل الآن',
                    cancelButtonText: 'تراجع'
                });

                if (!result.isConfirmed) return;

                this.showLoading('جاري تسجيل الخروج...');
                try {
                    const response = await $.ajax({
                        url: '@Url.Action("DisconnectWhatsApp", "WhatsApp")',
                        type: 'POST'
                    });

                    if (response.success) {
                        this.showSuccess('تم الفصل', 'تم تسجيل الخروج بنجاح');
                    } else {
                        this.showError(response.message);
                    }
                } catch (error) {
                    this.showError('حدث خطأ أثناء محاولة قطع الاتصال.');
                }
            }
        };

        $(document).ready(() => WhatsAppManager.init());

        // تنظيف الذاكرة عند مغادرة الصفحة
        $(window).on('beforeunload', () => WhatsAppManager.stopStatusCheck());
    </script>
}

