                        }
                    </select>
                </div>

                <div class="flex gap-2">
                    <button type="submit" class="zen-btn zen-btn-primary h-[42px] px-6">ШӘШөЩҒЩҠШ©</button>
                    <a href="@Url.Action("SalesReport")" class="zen-btn zen-btn-neutral h-[42px] w-[42px] flex items-center justify-center" title="ШҘШ№Ш§ШҜШ© ШӘШ№ЩҠЩҠЩҶ">
                        <i data-lucide="rotate-ccw" class="w-4 h-4"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
