                    <select name="categoryId" onchange="this.form.submit()" class="w-full px-4 py-2.5 bg-gray-50/50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/10 focus:border-primary outline-none text-sm font-bold text-primary transition-all bg-white cursor-pointer h-[42px]">
                        <option value="">Ш¬Щ…ЩҠШ№ Ш§Щ„ЩҒШҰШ§ШӘ</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">
                                @category.Name
